h_indices, vertex_indices),\n   157\t        ),\n   158\t        shape=(patch_count, surface_vertex_count),\n   159\t    )\n   160\t    prolongation.sort_indices()\n   161\t    restriction.sort_indices()\n   162\t    return restriction, prolongation\n   163\t\n   164\t\n   165\tdef _collect_patch_vertices(\n   166\t    adj: sp.csr_matrix,\n   167\t    *,\n   168\t    seed: int,\n   169\t    unassigned: np.ndarray,\n   170\t    patch_hops: int,\n   171\t    cap: int,\n   172\t) -> np.ndarray:\n   173\t    queue: deque[tuple[int, int]] = deque([(int(seed), 0)])\n   174\t    visited = {int(seed)}\n   175\t    patch_vertices: list[int] = []\n   176\t\n   177\t    while queue and len(patch_vertices) < cap:\n   178\t        vertex, distance = queue.popleft()\n   179\t        if not bool(unassigned[vertex]):\n   180\t            continue\n   181\t\n   182\t        patch_vertices.append(vertex)\n   183\t        if distance >= patch_hops:\n   184\t            continue\n   185\t\n   186\t        start = int(adj.indptr[vertex])\n   187\t        end = int(adj.indptr[vertex + 1])\n   188\t        for neighbor in adj.indices[start:end]:\n   189\t            neighbor_idx = int(neighbor)\n   190\t            if neighbor_idx in visited or not bool(unassigned[neighbor_idx]):\n   191\t                continue\n   192\t            visited.add(neighbor_idx)\n   193\t            queue.append((neighbor_idx, distance + 1))\n   194\t\n   195\t    return np.asarray(patch_vertices, dtype=np.int32)\n   196\t\n   197\t\n   198\tdef _build_patch_membership_arrays(patches: list[np.ndarray]) -> tuple[np.ndarray, np.ndarray]:\n   199\t    member_vertex_indptr = np.zeros(len(patches) + 1, dtype=np.int32)\n   200\t    if not patches:\n   201\t        return np.empty(0, dtype=np.int32), member_vertex_indptr\n   202\t\n   203\t    counts = np.asarray([int(patch.size) for patch in patches], dtype=np.int32)\n   204\t    member_vertex_indptr[1:] = np.cumsum(counts, dtype=np.int32)\n   205\t    member_vertex_indices = np.concatenate(patches).astype(np.int32, copy=False)\n   206\t    return member_vertex_indices, member_vertex_indptr\n   207\t\n   208\t\n   209\tdef _build_patch_adjacency(\n   210\t    adj: sp.csr_matrix,\n   211\t    surface_to_patch: np.ndarray,\n   212\t    *,\n   213\t    patch_count: int,\n   214\t) -> sp.csr_matrix:\n   215\t    if patch_count <= 0:\n   216\t        return sp.csr_matrix((0, 0), dtype=np.float32)\n   217\t\n   218\t    upper_edges = sp.triu(adj, k=1).tocoo()\n   219\t    edge_weights: dict[tuple[int, int], float] = {}\n   220\t    for row, col, weight in zip(upper_edges.row, upper_edges.col, upper_edges.data):\n   221\t        patch_u = int(surface_to_patch[int(row)])\n   222\t        patch_v = int(surface_to_patch[int(col)])\n   223\t        if patch_u == patch_v:\n   224\t            continue\n   225\t        if patch_u > patch_v:\n   226\t            patch_u, patch_v = patch_v, patch_u\n   227\t        edge_weights[(patch_u, patch_v)] = edge_weights.get((patch_u, patch_v), 0.0) + float(weight)\n   228\t\n   229\t    if not edge_weights:\n   230\t        return sp.csr_matrix((patch_count, patch_count), dtype=np.float32)\n   231\t\n   232\t    rows: list[int] = []\n   233\t    cols: list[int] = []\n   234\t    data: list[float] = []\n   235\t    for (patch_u, patch_v), weight in sorted(edge_weights.items()):\n   236\t        rows.extend([patch_u, patch_v])\n   237\t        cols.extend([patch_v, patch_u])\n   238\t        data.extend([weight, weight])\n   239\t\n   240\t    patch_adj = sp.csr_matrix(\n   241\t        (np.asarray(data, dtype=np.float32), (rows, cols)),\n   242\t        shape=(patch_count, patch_count),\n   243\t    )\n   244\t    patch_adj.eliminate_zeros()\n   245\t    patch_adj.sort_indices()\n   246\t    return patch_adj\n   247\t\n   248\t\n   249\tdef _partition_surface_into_patches(\n   250\t    adj: sp.csr_matrix,\n   251\t    vertices: np.ndarray,\n   252\t    *,\n   253\t    patch_hops: int,\n   254\t    patch_vertex_cap: int,\n   255\t) -> PatchDecomposition:\n   256\t    n_vertices = int(adj.shape[0])\n   257\t    if patch_hops < 0:\n   258\t        raise ValueError(\"patch_hops must be non-negative.\")\n   259\t    if patch_vertex_cap <= 0:\n   260\t        raise ValueError(\"patch_vertex_cap must be positive.\")\n","exit_code":0,"status":"completed"}}
