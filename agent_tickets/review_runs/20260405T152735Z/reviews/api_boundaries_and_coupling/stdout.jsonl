       raw_dir,\n   224\t            \"neurotransmitter_predictions_csv\",\n   225\t            OPTIONAL_SOURCE_CANDIDATES[\"nt_predictions\"],\n   226\t        ),\n   227\t        connections=_resolve_optional_path(paths_cfg, raw_dir, \"connections_csv\", OPTIONAL_SOURCE_CANDIDATES[\"connections\"]),\n   228\t        synapses=_resolve_synapse_source_path(cfg),\n   229\t        visual_annotations=_resolve_optional_path(\n   230\t            paths_cfg,\n   231\t            raw_dir,\n   232\t            \"visual_annotations_csv\",\n   233\t            OPTIONAL_SOURCE_CANDIDATES[\"visual_annotations\"],\n   234\t        ),\n   235\t        visual_columns=_resolve_optional_path(paths_cfg, raw_dir, \"visual_columns_csv\", OPTIONAL_SOURCE_CANDIDATES[\"visual_columns\"]),\n   236\t    )\n   237\t\n   238\t\n   239\tdef resolve_synapse_source_path(cfg: dict[str, Any]) -> Path | None:\n   240\t    return _resolve_synapse_source_path(cfg)\n   241\t\n   242\t\n   243\tdef load_neuron_registry(path: str | Path) -> pd.DataFrame:\n   244\t    df = pd.read_csv(path)\n   245\t    _require_columns(df, [\"root_id\", \"project_role\", \"snapshot_version\", \"materialization_version\"], Path(path))\n   246\t    df[\"root_id\"] = _normalize_int_series(df[\"root_id\"], \"root_id\")\n   247\t    return df\n   248\t\n   249\t\n   250\tdef load_connectivity_registry(path: str | Path) -> pd.DataFrame:\n   251\t    df = pd.read_csv(path)\n   252\t    _require_columns(df, [\"pre_root_id\", \"post_root_id\", \"syn_count\"], Path(path))\n   253\t    df[\"pre_root_id\"] = _normalize_int_series(df[\"pre_root_id\"], \"pre_root_id\")\n   254\t    df[\"post_root_id\"] = _normalize_int_series(df[\"post_root_id\"], \"post_root_id\")\n   255\t    df[\"syn_count\"] = _normalize_int_series(df[\"syn_count\"], \"syn_count\")\n   256\t    return df\n   257\t\n   258\t\n   259\tdef load_synapse_registry(path: str | Path) -> pd.DataFrame:\n   260\t    csv_path = Path(path)\n   261\t    df = pd.read_csv(csv_path)\n   262\t    _require_columns(\n   263\t        df,\n   264\t        [\n   265\t            \"synapse_row_id\",\n   266\t            \"source_row_number\",\n   267\t            \"pre_root_id\",\n   268\t            \"post_root_id\",\n   269\t            \"source_file\",\n   270\t        ],\n   271\t        csv_path,\n   272\t    )\n   273\t    for column in SYNAPSE_REGISTRY_COLUMNS:\n   274\t        if column not in df.columns:\n   275\t            df[column] = pd.NA\n   276\t    df[\"synapse_row_id\"] = _clean_text_series(df[\"synapse_row_id\"])\n   277\t    df[\"synapse_id\"] = _clean_text_series(df[\"synapse_id\"])\n   278\t    df[\"pre_root_id\"] = _normalize_int_series(df[\"pre_root_id\"], \"pre_root_id\")\n   279\t    df[\"post_root_id\"] = _normalize_int_series(df[\"post_root_id\"], \"post_root_id\")\n   280\t    df[\"source_row_number\"] = _normalize_int_series(df[\"source_row_number\"], \"source_row_number\")\n   281\t    for axis in [\"x\", \"y\", \"z\", \"pre_x\", \"pre_y\", \"pre_z\", \"post_x\", \"post_y\", \"post_z\", \"confidence\", \"weight\"]:\n   282\t        df[axis] = _normalize_optional_float_series(df[axis], axis)\n   283\t    for column in [\"neuropil\", \"source_file\"]:\n   284\t        df[column] = _clean_text_series(df[column])\n   285\t    df[\"nt_type\"] = _clean_text_series(df[\"nt_type\"]).str.upper()\n   286\t    df[\"sign\"] = _clean_text_series(df[\"sign\"]).str.lower()\n   287\t    _validate_synapse_localization_rows(df, csv_path)\n   288\t    return df.loc[:, SYNAPSE_REGISTRY_COLUMNS]\n   289\t\n   290\t\n   291\tdef validate_selected_root_ids(\n   292\t    root_ids: Sequence[int],\n   293\t    registry: pd.DataFrame,\n   294\t    registry_path: str | Path,\n   295\t    *,\n   296\t    sample_size: int = 10,\n   297\t) -> None:\n   298\t    known_root_ids = {int(root_id) for root_id in registry[\"root_id\"].tolist()}\n   299\t    missing_root_ids = sorted({int(root_id) for root_id in root_ids} - known_root_ids)\n   300\t    if missing_root_ids:\n   301\t        raise RuntimeError(\n   302\t            f\"{len(missing_root_ids)} selected root IDs were not found in the registry {registry_path}. \"\n   303\t            f\"Sample missing IDs: {missing_root_ids[:sample_size]}\"\n   304\t        )\n   305\t\n   306\t\n   307\tdef materialize_synapse_registry(\n   308\t    cfg: dict[str, Any],\n   309\t    *,\n   310\t    root_ids: Sequence[int] | None = None,\n   311\t    root_ids_path: str | Path | None = None,\n   312\t    scope_label: str | None = None,\n   313\t) -> dict[str, Any]:\n   314\t    if root_ids is not None and root_ids_path is not None:\n   315\t        raise ValueError(\"Provide either root_ids or root_ids_path when materializing a synapse registry, not both.\")\n   316\t\n   317\t    synapse_source_path = resolve_synapse_source_path(cfg)\n   318\t    snapshot_version, materialization_version = _resolve_snapshot_and_materialization_versions(cfg)\n   319\t    synapse_registry = _load_synapse_table(synapse_source_path)\n   320\t\n   321\t    root_id_list: list[int] | None = None\n   322\t    root_id_path_value: Path | None = None\n   323\t    if root_ids_path is not None:\n   324\t        root_id_path_value = Path(root_ids_path)\n   325\t        if not root_id_path_value.exists():\n   326\t            raise FileNotFoundError(f\"Could not find root-id file for synapse materialization at {root_id_path_value}.\")\n   327\t        root_id_list = read_root_ids(root_id_path_value)\n   328\t    elif root_ids is not None:\n   329\t        root_id_list = [int(root_id) for root_id in root_ids]\n   330\t\n   331\t    synapse_registry = _filter_synapses_to_root_ids(synapse_registry, root_id_list)\n   332\t    synapse_registry[\"snapshot_version\"] = pd.Series(snapshot_version, index=synapse_registry.index, dtype=\"string\")\n   333\t    synapse_registry[\"materialization_version\"] = pd.Series(materialization_version, index=synapse_registry.index, dtype=\"string\")\n   334\t    output_paths = _resolve_synapse_registry_artifact_paths(cfg)\n   335\t\n   336\t    ensure_dir(output_paths[\"registry_path\"].parent)\n   337\t    ensure_dir(output_paths[\"provenance_path\"].parent)\n   338\t    synapse_registry.to_csv(output_paths[\"registry_path\"], index=False)\n   339\t\n   340\t    provenance = _build_synapse_registry_provenance(\n   341\t        synapse_source_path=synapse_source_path,\n   342\t        synapse_registry_path=output_paths[\"registry_path\"],\n   343\t        snapshot_version=snapshot_version,\n   344\t        materialization_version=materialization_version,\n   345\t        row_count=len(synapse_registry),\n   346\t        root_ids=root_id_list,\n   347\t        root_ids_path=root_id_path_value,\n   348\t        scope_label=scope_label,\n   349\t    )\n   350\t    write_json(provenance, output_paths[\"provenance_path\"])\n   351\t\n   352\t    return {\n   353\t        \"synapse_registry_path\": str(output_paths[\"registry_path\"]),\n   354\t        \"synapse_registry_provenance_path\": str(output_paths[\"provenance_path\"]),\n   355\t        \"synapse_count\": int(len(synapse_registry)),\n   356\t        \"scope\": provenance[\"scope\"][\"mode\"],\n   357\t    }\n   358\t\n   359\t\n   360\tdef build_registry(cfg: dict[str, Any]) -> dict[str, Any]:\n   361\t    source_paths = resolve_registry_source_paths(cfg)\n   362\t    paths_cfg = cfg.get(\"paths\", {})\n   363\t    registry_cfg = cfg.get(\"registry\", {})\n   364\t\n   365\t    neuron_registry_path = Path(paths_cfg.get(\"neuron_registry_csv\", \"data/interim/registry/neuron_registry.csv\"))\n   366\t    connectivity_registry_path = Path(\n   367\t        paths_cfg.get(\"connectivity_registry_csv\", \"data/interim/registry/connectivity_registry.csv\")\n   368\t    )\n   369\t    provenance_path = Path(paths_cfg.get(\"registry_provenance_json\", \"data/interim/registry/registry_provenance.json\"))\n   370\t    synapse_output_paths = _resolve_synapse_registry_artifact_paths(cfg)\n   371\t\n   372\t    snapshot_version, materialization_version = _resolve_snapshot_and_materialization_versions(cfg)\n   373\t    project_role_rules = _resolve_project_role_rules(registry_cfg.get(\"project_roles\", {}))\n   374\t\n   375\t    classification_df = _load_classification_table(source_paths.classification)\n   376\t    cell_types_df = _load_cell_types_table(source_paths.cell_types)\n   377\t    nt_df = _load_nt_predictions_table(source_paths.nt_predictions)\n   378\t    synapse_df = _load_synapse_table(source_paths.synapses)\n   379\t    connections_df = _load_connections_table(source_paths.connections)\n   380\t    visual_annotations_df = _load_visual_annotations_table(source_paths.visual_annotations)\n   381\t    visual_columns_df = _load_visual_columns_table(source_paths.visual_columns)\n   382\t    registry_connections_df = connections_df if not connections_df.empty else _aggregate_connections_from_synapses(synapse_df)\n   383\t    if not connections_df.empty:\n   384\t        connectivity_derivation = \"connections_snapshot\"\n   385\t    elif not synapse_df.empty:\n   386\t        connectivity_derivation = \"synapse_snapshot_aggregated\"\n   387\t    else:\n   388\t        connectivity_derivation = \"absent\"\n   389\t\n   390\t    neuron_registry = _build_neuron_registry(\n   391\t        classification_df=classification_df,\n   392\t        cell_types_df=cell_types_df,\n   393\t        nt_df=nt_df,\n   394\t        connections_df=registry_connections_df,\n   395\t        synapse_df=synapse_df,\n   396\t        visual_annotations_df=visual_annotations_df,\n   397\t        visual_columns_df=visual_columns_df,\n   398\t        source_paths=source_paths,\n   399\t        snapshot_version=snapshot_version,\n   400\t        materialization_version=materialization_version,\n   401\t        project_role_rules=project_role_rules,\n   402\t    )\n   403\t    connectivity_registry = _build_connectivity_registry(\n   404\t        connections_df=connections_df,\n   405\t        synapse_df=synapse_df,\n   406\t        source_paths=source_paths,\n   407\t        snapshot_version=snapshot_version,\n   408\t        materialization_version=materialization_version,\n   409\t    )\n   410\t    synapse_summary = materialize_synapse_registry(cfg, scope_label=\"build_registry\")\n   411\t\n   412\t    ensure_dir(neuron_registry_path.parent)\n   413\t    ensure_dir(connectivity_registry_path.parent)\n   414\t    ensure_dir(provenance_path.parent)\n   415\t    neuron_registry.to_csv(neuron_registry_path, index=False)\n   416\t    connectivity_registry.to_csv(connectivity_registry_path, index=False)\n   417\t\n   418\t    provenance = _build_provenance_payload(\n   419\t        source_paths=source_paths,\n   420\t        neuron_registry_path=neuron_registry_path,\n   421\t        connectivity_registry_path=connectivity_registry_path,\n   422\t        synapse_registry_path=synapse_output_paths[\"registry_path\"],\n   423\t        synapse_registry_provenance_path=synapse_output_paths[\"provenance_path\"],\n   424\t        snapshot_version=snapshot_version,\n   425\t        materialization_version=materialization_version,\n   426\t        project_role_rules=project_role_rules,\n   427\t        connectivity_derivation=connectivity_derivation,\n   428\t        synapse_scope=synapse_summary[\"scope\"],\n   429\t    )\n   430\t    write_json(provenance, provenance_path)\n   431\t\n   432\t    return {\n   433\t        \"snapshot_version\": snapshot_version,\n   434\t        \"materialization_version\": materialization_version,\n   435\t        \"neuron_registry_path\": str(neuron_registry_path),\n   436\t        \"connectivity_registry_path\": str(connectivity_registry_path),\n   437\t        \"synapse_registry_path\": synapse_summary[\"synapse_registry_path\"],\n   438\t        \"synapse_registry_provenance_path\": synapse_summary[\"synapse_registry_provenance_path\"],\n   439\t        \"provenance_path\": str(provenance_path),\n   440\t        \"neuron_count\": int(len(neuron_registry)),\n   441\t        \"connection_count\": int(len(connectivity_registry)),\n   442\t        \"synapse_count\": synapse_summary[\"synapse_count\"],\n   443\t        \"missing_optional_sources\": sorted(\n   444\t            name\n   445\t            for name, path in {\n   446\t                \"cell_types\": source_paths.cell_types,\n   447\t                \"nt_predictions\": source_paths.nt_predictions,\n   448\t                \"connections\": source_paths.connections,\n   449\t                \"synapses\": source_paths.synapses,\n   450\t                \"visual_annotations\": source_paths.visual_annotations,\n   451\t                \"visual_columns\": source_paths.visual_columns,\n   452\t            }.items()\n   453\t            if path is None\n   454\t        ),\n   455\t    }\n   456\t\n   457\t\n   458\tdef _resolve_optional_path(\n   459\t    paths_cfg: dict[str, Any],\n   460\t    raw_dir: Path,\n   461\t    override_key: str,\n   462\t    candidate_names: list[str],\n   463\t) -> Path | None:\n   464\t    if override_key in paths_cfg:\n   465\t        override = paths_cfg[override_key]\n   466\t        candidate = Path(override)\n   467\t        if candidate.exists():\n   468\t            return candidate\n   469\t        raise FileNotFoundError(\n   470\t            f\"Config override paths.{override_key} points to a missing file: {candidate}\"\n   471\t        )\n   472\t\n   473\t    for name in candidate_names:\n   474\t        candidate = raw_dir / name\n   475\t        if candidate.exists():\n   476\t            return candidate\n   477\t    return None\n   478\t\n   479\t\n   480\tdef _resolve_codex_raw_dir(paths_cfg: dict[str, Any]) -> Path:\n   481\t    return Path(paths_cfg.get(\"codex_raw_dir\", \"data/raw/codex\"))\n   482\t\n   483\t\n   484\tdef _resolve_synapse_source_path(cfg: dict[str, Any]) -> Path | None:\n   485\t    paths_cfg = cfg.get(\"paths\", {})\n   486\t    raw_dir = _resolve_codex_raw_dir(paths_cfg)\n   487\t    return _resolve_optional_path(paths_cfg, raw_dir, SYNAPSE_SOURCE_OVERRIDE_KEY, OPTIONAL_SOURCE_CANDIDATES[\"synapses\"])\n   488\t\n   489\t\n   490\tdef _resolve_snapshot_and_materialization_versions(cfg: dict[str, Any]) -> tuple[str, str]:\n   491\t    registry_cfg = cfg.get(\"registry\", {})\n   492\t    snapshot_version = str(\n   493\t        registry_cfg.get(\"snapshot_version\")\n   494\t        or cfg.get(\"dataset\", {}).get(\"codex_snapshot_version\")\n   495\t        or cfg.get(\"dataset\", {}).get(\"materialization_version\")\n   496\t        or DEFAULT_DATA_SNAPSHOT_VERSION\n   497\t    )\n   498\t    materialization_version = str(cfg.get(\"dataset\", {}).get(\"materialization_version\", snapshot_version))\n   499\t    return snapshot_version, materialization_version\n   500\t\n   501\t\n   502\tdef _resolve_synapse_registry_artifact_paths(cfg: dict[str, Any]) -> dict[str, Path]:\n   503\t    processed_coupling_dir = cfg.get(\"paths\", {}).get(\"processed_coupling_dir\", \"data/processed/coupling\")\n   504\t    contract_paths = build_coupling_contract_paths(processed_coupling_dir)\n   505\t    return {\n   506\t        \"registry_path\": contract_paths.local_synapse_registry_path,\n   507\t        \"provenance_path\": contract_paths.processed_coupling_dir / \"synapse_registry_provenance.json\",\n   508\t    }\n   509\t\n   510\t\n   511\tdef _load_classification_table(path: Path) -> pd.DataFrame:\n   512\t    df = pd.read_csv(path)\n   513\t    expected = get_classification_file_columns()\n   514\t    _require_columns(df, expected, path)\n   515\t    df = df.loc[:, expected].copy()\n   516\t    df[\"root_id\"] = _normalize_int_series(df[\"root_id\"], \"root_id\")\n   517\t    for column in expected:\n   518\t        if column != \"root_id\":\n   519\t            df[column] = _clean_text_series(df[column])\n   520\t    df = df.drop_duplicates(subset=[\"root_id\"]).reset_index(drop=True)\n   521\t    df[\"has_classification_source\"] = True\n   522\t    return df\n   523\t\n   524\t\n   525\tdef _load_cell_types_table(path: Path | None) -> pd.DataFrame:\n   526\t    if path is None:\n   527\t        return pd.DataFrame(columns=[\"root_id\", \"primary_type\", \"additional_types\", \"has_cell_types_source\"])\n   528\t    df = pd.read_csv(path)\n   529\t    expected = get_cell_types_file_columns()\n   530\t    _require_columns(df, expected, path)\n   531\t    df = df.loc[:, expected].rename(columns={\"additional_type(s)\": \"additional_types\"}).copy()\n   532\t    df[\"root_id\"] = _normalize_int_series(df[\"root_id\"], \"root_id\")\n   533\t    df[\"primary_type\"] = _clean_text_series(df[\"primary_type\"])\n   534\t    df[\"additional_types\"] = _clean_text_series(df[\"additional_types\"])\n   535\t    df = df.drop_duplicates(subset=[\"root_id\"]).reset_index(drop=True)\n   536\t    df[\"has_cell_types_source\"] = True\n   537\t    return df\n   538\t\n   539\t\n   540\tdef _load_nt_predictions_table(path: Path | None) -> pd.DataFrame:\n   541\t    if path is None:\n   542\t        return pd.DataFrame(columns=[\"root_id\", \"group\", \"nt_type\", \"nt_type_score\", \"has_nt_predictions_source\"])\n   543\t    df = pd.read_csv(path)\n   544\t    expected = get_neurons_file_columns()\n   545\t    _require_columns(df, expected, path)\n   546\t    keep_columns = [\"root_id\", \"group\", \"nt_type\", \"nt_type_score\"]\n   547\t    df = df.loc[:, keep_columns].copy()\n   548\t    df[\"root_id\"] = _normalize_int_series(df[\"root_id\"], \"root_id\")\n   549\t    df[\"group\"] = _clean_text_series(df[\"group\"])\n   550\t    df[\"nt_type\"] = _clean_text_series(df[\"nt_type\"]).str.upper()\n   551\t    df[\"nt_type_score\"] = pd.to_numeric(df[\"nt_type_score\"], errors=\"coerce\")\n   552\t    df = df.drop_duplicates(subset=[\"root_id\"]).reset_index(drop=True)\n   553\t    df[\"has_nt_predictions_source\"] = True\n   554\t    return df\n   555\t\n   556\t\n   557\tdef _load_connections_ta