\t                for entry in schedule[\"schedule\"]\n   430\t                if entry[\"stage_id\"] == \"analysis\"\n   431\t            }:\n   432\t                self.assertEqual(\n   433\t                    simulation_plan_ids[(suite_cell_id, \"analysis\")],\n   434\t                    simulation_plan_ids[(suite_cell_id, \"validation\")],\n   435\t                )\n   436\t\n   437\t\n   438\tdef _minimal_execution_suite_block(*, output_root: Path) -> dict[str, object]:\n   439\t    block = copy.deepcopy(\n   440\t        _base_suite_block(\n   441\t            output_root=output_root,\n   442\t            enabled_stage_ids=[\"simulation\", \"analysis\", \"validation\", \"dashboard\"],\n   443\t        )\n   444\t    )\n   445\t    block[\"dimensions\"][\"sweep_axes\"] = []\n   446\t    block[\"ablations\"] = [\n   447\t        {\n   448\t            \"ablation_family_id\": \"no_waves\",\n   449\t            \"variant_id\": \"disabled\",\n   450\t            \"display_name\": \"No Waves\",\n   451\t            \"parameter_snapshot\": {\"mode\": \"disable_surface_wave\"},\n   452\t        }\n   453\t    ]\n   454\t    return block\n   455\t\n   456\t\n   457\tdef _fixture_stage_executor(\n   458\t    stage_id: str,\n   459\t    *,\n   460\t    call_log: list[str],\n   461\t    failure_state: dict[str, bool] | None = None,\n   462\t    fail_once_work_item_id: str | None = None,\n   463\t):\n   464\t    def execute(context: dict[str, object]) -> dict[str, object]:\n   465\t        work_item = context[\"work_item\"]\n   466\t        work_item_id = str(work_item[\"work_item_id\"])\n   467\t        call_log.append(work_item_id)\n   468\t        if (\n   469\t            fail_once_work_item_id is not None\n   470\t            and work_item_id == fail_once_work_item_id\n   471\t            and failure_state is not None\n   472\t            and not failure_state[\"fired\"]\n   473\t        ):\n   474\t            failure_state[\"fired\"] = True\n   475\t            