 fine_operator_available = operator_asset_statuses[FINE_OPERATOR_KEY] == ASSET_STATUS_READY\\\\\\\\\\\\\\\\n    coarse_operator_available = operator_asset_statuses[COARSE_OPERATOR_KEY] == ASSET_STATUS_READY\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    return {\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"contract_version\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": OPERATOR_BUNDLE_CONTRACT_VERSION,\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"status\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": _bundle_status(operator_asset_statuses),\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"realization_mode\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"graph_laplacian_fallback\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"preferred_discretization_family\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": DEFAULT_FINE_DISCRETIZATION_FAMILY,\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"discretization_family\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": FALLBACK_FINE_DISCRETIZATION_FAMILY,\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"mass_treatment\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": FALLBACK_MASS_TREATMENT,\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"normalization\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": FALLBACK_NORMALIZATION,\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"boundary_condition_mode\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": DEFAULT_BOUNDARY_CONDITION_MODE,\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"fallback_policy\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": {\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"allowed\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": True,\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"reason\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"cotangent_operators_not_serialized_in_milestone5_bundle\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"fallback_discretization_family\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": FALLBACK_FINE_DISCRETIZATION_FAMILY,\\\\\\\\\\\\\\\\n        },\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"geodesic_neighborhood\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": {\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"mode\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": FALLBACK_GEODESIC_NEIGHBORHOOD_MODE,\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"patch_hops\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": int(patch_hops) if patch_hops is not None else None,\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"patch_vertex_cap\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": int(patch_vertex_cap) if patch_vertex_cap is not None else None,\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"patch_generation_method\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": (\\\\\\\\\\\\\\\\n                str(patch_generation_method) if patch_generation_method is not None else \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n            ),\\\\\\\\\\\\\\\\n        },\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"transfer_operators\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": {\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"surface_to_patch_membership\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": {\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"available\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": restriction_available,\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"path\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": str(bundle_paths.transfer_operator_path),\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"representation\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"csr_membership_and_surface_to_patch\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n            },\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"fine_to_coarse_restriction\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": {\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"available\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": restriction_available,\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"path\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": str(bundle_paths.transfer_operator_path),\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"normalization\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": FALLBACK_TRANSFER_RESTRICTION,\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"conserves_constant_field\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": restriction_available,\\\\\\\\\\\\\\\\n            },\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"coarse_to_fine_prolongation\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": {\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"available\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": restriction_available,\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"path\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": str(bundle_paths.transfer_operator_path),\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"normalization\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": FALLBACK_TRANSFER_PROLONGATION,\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"partition_of_unity\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": restriction_available,\\\\\\\\\\\\\\\\n            },\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"fine_operator_available\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": fine_operator_available,\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"coarse_operator_available\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": coarse_operator_available,\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"exit_code\\\\\\\\\\\\\\\":0,\\\\\\\\\\\\\\\"status\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"completed\\\\\\\\\\\\\\\"}}\\\\\\\\nagent_tickets/runs/20260321T185349Z/FW-M6-002_Assemble_fine-surface_operators_with_geodesic_neighborhoods_tangent_frames_and_boundary_masks/stdout.jsonl:15:{\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item.completed\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"item\\\\\\\\\\\\\\\":{\\\\\\\\\\\\\\\"id\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item_6\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"command_execution\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"command\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"/bin/bash -lc \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sed -n '1,260p' docs/operator_bundle_design.md\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"aggregated_output\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"# Milestone 6 Operator Bundle Contract And Discretization Choice\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nThis note freezes the first operator-facing contract for Milestone 6 so later\\\\\\\\\\\\\\\\nsimulator work can target explicit archive roles and explicit numerical\\\\\\\\\\\\\\\\nassumptions instead of reverse-engineering Milestone 5 geometry bundles.\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n## Contract summary\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nThe processed manifest now carries `_operator_contract_version:\\\\\\\\\\\\\\\\noperator_bundle.v1` plus a per-root `operator_bundle` block. That block owns:\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n- the fine operator archive\\\\\\\\\\\\\\\\n- the coarse operator archive\\\\\\\\\\\\\\\\n- the transfer-operator archive\\\\\\\\\\\\\\\\n- the operator metadata sidecar\\\\\\\\\\\\\\\\n- the realized discretization family and fallback status\\\\\\\\\\\\\\\\n- normalization / mass treatment\\\\\\\\\\\\\\\\n- boundary-condition mode\\\\\\\\\\\\\\\\n- geodesic-neighborhood settings\\\\\\\\\\\\\\\\n- transfer-operator availability\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nCompatibility during migration is deliberate:\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n- `fine_operator` is currently a manifest alias to the legacy\\\\\\\\\\\\\\\\n  `surface_graph_path`\\\\\\\\\\\\\\\\n- `coarse_operator` is currently a manifest alias to the legacy\\\\\\\\\\\\\\\\n  `patch_graph_path`\\\\\\\\\\\\\\\\n- the legacy `<root_id>_meta.json` sidecar is still written so Milestone 5\\\\\\\\\\\\\\\\n  consumers do not break while downstream code migrates to the new contract\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n## Candidate families\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n### Graph-based surface operators\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nDefinition:\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n- surface adjacency from the simplified mesh connectivity\\\\\\\\\\\\\\\\n- combinatorial or normalized graph Laplacian\\\\\\\\\\\\\\\\n- patch transfers built from patch membership only\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nAdvantages:\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n- robust on imperfect meshes\\\\\\\\\\\\\\\\n- cheap to build and easy to regression test\\\\\\\\\\\\\\\\n- no dependence on cotangent-weight edge cases\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nCosts:\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n- ignores triangle geometry and surface area unless extra weighting is added\\\\\\\\\\\\\\\\n- geodesic distance is only approximated by hop count\\\\\\\\\\\\\\\\n- boundary semantics are implicit and easy to misinterpret\\\\\\\\\\\\\\\\n- convergence to a surface PDE is weaker than for a metric-aware mesh operator\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n### Mesh-based operators\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nDefinition:\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n- triangle-mesh Laplace-Beltrami discretization on the simplified surface\\\\\\\\\\\\\\\\n- cotangent stiffness matrix\\\\\\\\\\\\\\\\n- explicit mass matrix\\\\\\\\\\\\\\\\n- coarse operators derived from fine operators and transfer maps\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nAdvantages:\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n- metric-aware and standard for diffusion / wave equations on surfaces\\\\\\\\\\\\\\\\n- makes conservation and stability statements precise in a mesh inner product\\\\\\\\\\\\\\\\n- clean boundary interpretation when seams or open surfaces exist\\\\\\\\\\\\\\\\n- gives a principled path to Galerkin coarse operators\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nCosts:\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n- requires handling degenerate triangles, non-manifold cases, and negative\\\\\\\\\\\\\\\\n  cotangent edge contributions carefully\\\\\\\\\\\\\\\\n- more implementation work than a graph Laplacian\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n## Decision\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nThe default fine-surface discretization for Milestone 6 is:\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n- `triangle_mesh_cotangent_fem`\\\\\\\\\\\\\\\\n- lumped mass matrix\\\\\\\\\\\\\\\\n- mass-normalized state inner product\\\\\\\\\\\\\\\\n- zero-flux boundary handling on the simplified closed surface\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nThis is the default the later wave engine should treat as scientifically\\\\\\\\\\\\\\\\nauthoritative.\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nThe default coarse construction is:\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n- fine-to-coarse restriction by lumped-mass patch averaging\\\\\\\\\\\\\\\\n- coarse-to-fine prolongation by piecewise-constant patch injection\\\\\\\\\\\\\\\\n- coarse operator by Galerkin projection from the fine operator\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nThis keeps the fine and coarse systems comparable in one inner product instead\\\\\\\\\\\\\\\\nof treating the patch graph as an unrelated second discretization.\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n## Allowed fallback\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nFallback is allowed when the default operator cannot be serialized safely or has\\\\\\\\\\\\\\\\nnot been built yet. The allowed fallback family is:\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n- `surface_graph_uniform_laplacian`\\\\\\\\\\\\\\\\n- counting-measure / uniform-vertex averaging on transfers\\\\\\\\\\\\\\\\n- geodesic neighborhoods represented by surface-graph hop counts\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nUse the fallback only when at least one of these is true:\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n1. the simplified mesh has degeneracies or topology issues that make cotangent\\\\\\\\\\\\\\\\n   assembly unreliable\\\\\\\\\\\\\\\\n2. a build is intentionally limited to the Milestone 5 geometry bundle plus\\\\\\\\\\\\\\\\n   structural transfer data\\\\\\\\\\\\\\\\n3. a regression fixture needs a deterministic structural operator without the\\\\\\\\\\\\\\\\n   full metric machinery\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nWhenever fallback is used, the manifest must say so explicitly through the\\\\\\\\\\\\\\\\nper-root `operator_bundle.discretization_family`, `mass_treatment`,\\\\\\\\\\\\\\\\n`normalization`, and `realization_mode` fields.\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n## Conserved and damped quantities\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nThe later wave engine inherits these expectations:\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n- the constant field remains in the nullspace of the Laplacian\\\\\\\\\\\\\\\\n- zero-flux boundaries do not inject or remove net mass\\\\\\\\\\\\\\\\n- pure diffusion should dissipate energy and preserve total mass\\\\\\\\\\\\\\\\n- undamped wave propagation should not gain energy from the spatial operator\\\\\\\\\\\\\\\\n- any damping operator must be positive semidefinite and separate from the\\\\\\\\\\\\\\\\n  conservative spatial operator\\\\\\\\\\\\\\\\n- fine/coarse restriction and prolongation should preserve constants; no\\\\\\\\\\\\\\\\n  transfer step should create a net source term by itself\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n## Stability-relevant assumptions\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nLater milestones should preserve these assumptions instead of silently changing\\\\\\\\\\\\\\\\nthem:\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n- stiffness operators are symmetric\\\\\\\\\\\\\\\\n- mass operators are positive diagonal after lumping\\\\\\\\\\\\\\\\n- the effective generalized operator is positive semidefinite\\\\\\\\\\\\\\\\n- boundary treatment stays zero-flux unless an experiment explicitly opts into\\\\\\\\\\\\\\\\n  absorbing or clamped boundaries\\\\\\\\\\\\\\\\n- time-step limits should be derived from the largest relevant eigenvalue of\\\\\\\\\\\\\\\\n  `M^{-1}L` rather than an ad hoc graph-degree rule\\\\\\\\\\\\\\\\n- coarse operators and transfer maps should be interpreted in the same inner\\\\\\\\\\\\\\\\n  product as the fine operator\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n## What the current bundle guarantees\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n`operator_bundle.v1` lands before the full cotangent implementation. The\\\\\\\\\\\\\\\\ncurrent repository therefore serializes:\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n- a fine operator alias through the legacy surface-graph archive\\\\\\\\\\\\\\\\n- a coarse operator alias through the legacy patch-graph archive\\\\\\\\\\\\\\\\n- an explicit transfer-operator archive for coarse/fine discovery\\\\\\\\\\\\\\\\n- an operator metadata sidecar that records the realized fallback mode\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nThat is intentional. The contract is frozen now so later tickets can upgrade the\\\\\\\\\\\\\\\\nnumerics without renegotiating filenames, manifest keys, or the default\\\\\\\\\\\\\\\\nstability assumptions.\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"exit_code\\\\\\\\\\\\\\\":0,\\\\\\\\\\\\\\\"status\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"completed\\\\\\\\\\\\\\\"}}\\\\\\\\nagent_tickets/runs/20260321T185349Z/FW-M6-002_Assemble_fine-surface_operators_with_geodesic_neighborhoods_tangent_frames_and_boundary_masks/stdout.jsonl:16:{\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item.completed\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"item\\\\\\\\\\\\\\\":{\\\\\\\\\\\\\\\"id\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item_5\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"command_execution\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"command\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"/bin/bash -lc \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sed -n '1,360p' src/flywire_wave/mesh_pipeline.py\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"aggregated_output\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"from __future__ import annotations\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nfrom collections import deque\\\\\\\\\\\\\\\\nfrom dataclasses import dataclass\\\\\\\\\\\\\\\\nfrom datetime import datetime, timezone\\\\\\\\\\\\\\\\nfrom pathlib import Path\\\\\\\\\\\\\\\\nfrom typing import Any, Callable\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nimport numpy as np\\\\\\\\\\\\\\\\nimport scipy.sparse as sp\\\\\\\\\\\\\\\\nimport trimesh\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nfrom .geometry_contract import (\\\\\\\\\\\\\\\\n    ASSET_STATUS_MISSING,\\\\\\\\\\\\\\\\n    ASSET_STATUS_READY,\\\\\\\\\\\\\\\\n    ASSET_STATUS_SKIPPED,\\\\\\\\\\\\\\\\n    FALLBACK_TRANSFER_PROLONGATION,\\\\\\\\\\\\\\\\n    FALLBACK_TRANSFER_RESTRICTION,\\\\\\\\\\\\\\\\n    FETCH_STATUS_CACHE_HIT,\\\\\\\\\\\\\\\\n    FETCH_STATUS_FAILED,\\\\\\\\\\\\\\\\n    FETCH_STATUS_FETCHED,\\\\\\\\\\\\\\\\n    FETCH_STATUS_SKIPPED,\\\\\\\\\\\\\\\\n    GeometryBundlePaths,\\\\\\\\\\\\\\\\n    OPERATOR_METADATA_KEY,\\\\\\\\\\\\\\\\n    PATCH_GRAPH_KEY,\\\\\\\\\\\\\\\\n    QA_SIDECAR_KEY,\\\\\\\\\\\\\\\\n    RAW_MESH_KEY,\\\\\\\\\\\\\\\\n    RAW_SKELETON_KEY,\\\\\\\\\\\\\\\\n    SIMPLIFIED_MESH_KEY,\\\\\\\\\\\\\\\\n    SURFACE_GRAPH_KEY,\\\\\\\\\\\\\\\\n    TRANSFER_OPERATORS_KEY,\\\\\\\\\\\\\\\\n    DESCRIPTOR_SIDECAR_KEY,\\\\\\\\\\\\\\\\n    build_operator_bundle_metadata,\\\\\\\\\\\\\\\\n)\\\\\\\\\\\\\\\\nfrom .geometry_qa import (\\\\\\\\\\\\\\\\n    build_descriptor_payload,\\\\\\\\\\\\\\\\n    describe_mesh,\\\\\\\\\\\\\\\\n    describe_patch_decomposition,\\\\\\\\\\\\\\\\n    describe_skeleton,\\\\\\\\\\\\\\\\n    evaluate_geometry_qa,\\\\\\\\\\\\\\\\n)\\\\\\\\\\\\\\\\nfrom .io_utils import ensure_dir, write_json\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nclass RawAssetFetchError(RuntimeError):\\\\\\\\\\\\\\\\n    def __init__(\\\\\\\\\\\\\\\\n        self,\\\\\\\\\\\\\\\\n        message: str,\\\\\\\\\\\\\\\\n        *,\\\\\\\\\\\\\\\\n        asset_statuses: dict[str, str],\\\\\\\\\\\\\\\\n        raw_asset_provenance: dict[str, dict[str, Any]],\\\\\\\\\\\\\\\\n    ) -> None:\\\\\\\\\\\\\\\\n        super().__init__(message)\\\\\\\\\\\\\\\\n        self.asset_statuses = asset_statuses\\\\\\\\\\\\\\\\n        self.raw_asset_provenance = raw_asset_provenance\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n@dataclass(frozen=True)\\\\\\\\\\\\\\\\nclass PatchDecomposition:\\\\\\\\\\\\\\\\n    surface_to_patch: np.ndarray\\\\\\\\\\\\\\\\n    patch_seed_vertices: np.ndarray\\\\\\\\\\\\\\\\n    patch_sizes: np.ndarray\\\\\\\\\\\\\\\\n    patch_centroids: np.ndarray\\\\\\\\\\\\\\\\n    member_vertex_indices: np.ndarray\\\\\\\\\\\\\\\\n    member_vertex_indptr: np.ndarray\\\\\\\\\\\\\\\\n    patch_adj: sp.csr_matrix\\\\\\\\\\\\\\\\n    patch_lap: sp.csr_matrix\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef _optional_imports() -> tuple[Any, Any]:\\\\\\\\\\\\\\\\n    try:\\\\\\\\\\\\\\\\n        from fafbseg import flywire  # type: ignore\\\\\\\\\\\\\\\\n    except Exception as exc:  # pragma: no cover\\\\\\\\\\\\\\\\n        raise RuntimeError(\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"fafbseg is required for FlyWire mesh access. Install requirements.txt first.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        ) from exc\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    try:\\\\\\\\\\\\\\\\n        import navis  # type: ignore\\\\\\\\\\\\\\\\n    except Exception as exc:  # pragma: no cover\\\\\\\\\\\\\\\\n        raise RuntimeError(\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"navis is required for exporting skeletons. Install requirements.txt first.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        ) from exc\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    return flywire, navis\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef _faces_to_adjacency(faces: np.ndarray, n_vertices: int) -> sp.csr_matrix:\\\\\\\\\\\\\\\\n    edges = set()\\\\\\\\\\\\\\\\n    for tri in faces:\\\\\\\\\\\\\\\\n        a, b, c = (int(tri[0]), int(tri[1]), int(tri[2]))\\\\\\\\\\\\\\\\n        edges.add(tuple(sorted((a, b))))\\\\\\\\\\\\\\\\n        edges.add(tuple(sorted((b, c))))\\\\\\\\\\\\\\\\n        edges.add(tuple(sorted((a, c))))\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    if not edges:\\\\\\\\\\\\\\\\n        raise ValueError(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"No edges could be built from faces.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    rows = []\\\\\\\\\\\\\\\\n    cols = []\\\\\\\\\\\\\\\\n    for i, j in sorted(edges):\\\\\\\\\\\\\\\\n        rows.extend([i, j])\\\\\\\\\\\\\\\\n        cols.extend([j, i])\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    data = np.ones(len(rows), dtype=np.float32)\\\\\\\\\\\\\\\\n    adj = sp.csr_matrix((data, (rows, cols)), shape=(n_vertices, n_vertices))\\\\\\\\\\\\\\\\n    adj.eliminate_zeros()\\\\\\\\\\\\\\\\n    adj.sort_indices()\\\\\\\\\\\\\\\\n    return adj\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef _uniform_laplacian(adj: sp.csr_matrix) -> sp.csr_matrix:\\\\\\\\\\\\\\\\n    deg = np.asarray(adj.sum(axis=1)).ravel()\\\\\\\\\\\\\\\\n    d = sp.diags(deg)\\\\\\\\\\\\\\\\n    return d - adj\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef _serialize_sparse_matrix(matrix: sp.csr_matrix) -> dict[str, np.ndarray]:\\\\\\\\\\\\\\\\n    matrix = matrix.tocsr().astype(np.float32)\\\\\\\\\\\\\\\\n    matrix.sort_indices()\\\\\\\\\\\\\\\\n    return {\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"data\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": matrix.data.astype(np.float32, copy=False),\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"indices\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": matrix.indices.astype(np.int32, copy=False),\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"indptr\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": matrix.indptr.astype(np.int32, copy=False),\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"shape\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": np.asarray(matrix.shape, dtype=np.int32),\\\\\\\\\\\\\\\\n    }\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef _build_uniform_transfer_operators(\\\\\\\\\\\\\\\\n    *,\\\\\\\\\\\\\\\\n    surface_to_patch: np.ndarray,\\\\\\\\\\\\\\\\n    patch_sizes: np.ndarray,\\\\\\\\\\\\\\\\n) -> tuple[sp.csr_matrix, sp.csr_matrix]:\\\\\\\\\\\\\\\\n    patch_count = int(patch_sizes.shape[0])\\\\\\\\\\\\\\\\n    surface_vertex_count = int(surface_to_patch.shape[0])\\\\\\\\\\\\\\\\n    if patch_count == 0 or surface_vertex_count == 0:\\\\\\\\\\\\\\\\n        empty_restriction = sp.csr_matrix((patch_count, surface_vertex_count), dtype=np.float32)\\\\\\\\\\\\\\\\n        empty_prolongation = sp.csr_matrix((surface_vertex_count, patch_count), dtype=np.float32)\\\\\\\\\\\\\\\\n        return empty_restriction, empty_prolongation\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    vertex_indices = np.arange(surface_vertex_count, dtype=np.int32)\\\\\\\\\\\\\\\\n    patch_indices = surface_to_patch.astype(np.int32, copy=False)\\\\\\\\\\\\\\\\n    prolongation = sp.csr_matrix(\\\\\\\\\\\\\\\\n        (\\\\\\\\\\\\\\\\n            np.ones(surface_vertex_count, dtype=np.float32),\\\\\\\\\\\\\\\\n            (vertex_indices, patch_indices),\\\\\\\\\\\\\\\\n        ),\\\\\\\\\\\\\\\\n        shape=(surface_vertex_count, patch_count),\\\\\\\\\\\\\\\\n    )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    safe_patch_sizes = np.maximum(patch_sizes.astype(np.float32, copy=False), 1.0)\\\\\\\\\\\\\\\\n    restriction_weights = 1.0 / safe_patch_sizes[patch_indices]\\\\\\\\\\\\\\\\n    restriction = sp.csr_matrix(\\\\\\\\\\\\\\\\n        (\\\\\\\\\\\\\\\\n            restriction_weights.astype(np.float32, copy=False),\\\\\\\\\\\\\\\\n            (patch_indices, vertex_indices),\\\\\\\\\\\\\\\\n        ),\\\\\\\\\\\\\\\\n        shape=(patch_count, surface_vertex_count),\\\\\\\\\\\\\\\\n    )\\\\\\\\\\\\\\\\n    prolongation.sort_indices()\\\\\\\\\\\\\\\\n    restriction.sort_indices()\\\\\\\\\\\\\\\\n    return restriction, prolongation\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef _collect_patch_vertices(\\\\\\\\\\\\\\\\n    adj: sp.csr_matrix,\\\\\\\\\\\\\\\\n    *,\\\\\\\\\\\\\\\\n    seed: int,\\\\\\\\\\\\\\\\n    unassigned: np.ndarray,\\\\\\\\\\\\\\\\n    patch_hops: int,\\\\\\\\\\\\\\\\n    cap: int,\\\\\\\\\\\\\\\\n) -> np.ndarray:\\\\\\\\\\\\\\\\n    queue: deque[tuple[int, int]] = deque([(int(seed), 0)])\\\\\\\\\\\\\\\\n    visited = {int(seed)}\\\\\\\\\\\\\\\\n    patch_vertices: list[int] = []\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    while queue and len(patch_vertices) < cap:\\\\\\\\\\\\\\\\n        vertex, distance = queue.popleft()\\\\\\\\\\\\\\\\n        if not bool(unassigned[vertex]):\\\\\\\\\\\\\\\\n            continue\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        patch_vertices.append(vertex)\\\\\\\\\\\\\\\\n        if distance >= patch_hops:\\\\\\\\\\\\\\\\n            continue\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        start = int(adj.indptr[vertex])\\\\\\\\\\\\\\\\n        end = int(adj.indptr[vertex + 1])\\\\\\\\\\\\\\\\n        for neighbor in adj.indices[start:end]:\\\\\\\\\\\\\\\\n            neighbor_idx = int(neighbor)\\\\\\\\\\\\\\\\n            if neighbor_idx in visited or not bool(unassigned[neighbor_idx]):\\\\\\\\\\\\\\\\n                continue\\\\\\\\\\\\\\\\n            visited.add(neighbor_idx)\\\\\\\\\\\\\\\\n            queue.append((neighbor_idx, distance + 1))\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    return np.asarray(patch_vertices, dtype=np.int32)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef _build_patch_membership_arrays(patches: list[np.ndarray]) -> tuple[np.ndarray, np.ndarray]:\\\\\\\\\\\\\\\\n    member_vertex_indptr = np.zeros(len(patches) + 1, dtype=np.int32)\\\\\\\\\\\\\\\\n    if not patches:\\\\\\\\\\\\\\\\n        return np.empty(0, dtype=np.int32), member_vertex_indptr\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    counts = np.asarray([int(patch.size) for patch in patches], dtype=np.int32)\\\\\\\\\\\\\\\\n    member_vertex_indptr[1:] = np.cumsum(counts, dtype=np.int32)\\\\\\\\\\\\\\\\n    member_vertex_indices = np.concatenate(patches).astype(np.int32, copy=False)\\\\\\\\\\\\\\\\n    return member_vertex_indices, member_vertex_indptr\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef _build_patch_adjacency(\\\\\\\\\\\\\\\\n    adj: sp.csr_matrix,\\\\\\\\\\\\\\\\n    surface_to_patch: np.ndarray,\\\\\\\\\\\\\\\\n    *,\\\\\\\\\\\\\\\\n    patch_count: int,\\\\\\\\\\\\\\\\n) -> sp.csr_matrix:\\\\\\\\\\\\\\\\n    if patch_count <= 0:\\\\\\\\\\\\\\\\n        return sp.csr_matrix((0, 0), dtype=np.float32)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    upper_edges = sp.triu(adj, k=1).tocoo()\\\\\\\\\\\\\\\\n    edge_weights: dict[tuple[int, int], float] = {}\\\\\\\\\\\\\\\\n    for row, col, weight in zip(upper_edges.row, upper_edges.col, upper_edges.data):\\\\\\\\\\\\\\\\n        patch_u = int(surface_to_patch[int(row)])\\\\\\\\\\\\\\\\n        patch_v = int(surface_to_patch[int(col)])\\\\\\\\\\\\\\\\n        if patch_u == patch_v:\\\\\\\\\\\\\\\\n            continue\\\\\\\\\\\\\\\\n        if patch_u > patch_v:\\\\\\\\\\\\\\\\n            patch_u, patch_v = patch_v, patch_u\\\\\\\\\\\\\\\\n        edge_weights[(patch_u, patch_v)] = edge_weights.get((patch_u, patch_v), 0.0) + float(weight)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    if not edge_weights:\\\\\\\\\\\\\\\\n        return sp.csr_matrix((patch_count, patch_count), dtype=np.float32)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    rows: list[int] = []\\\\\\\\\\\\\\\\n    cols: list[int] = []\\\\\\\\\\\\\\\\n    data: list[float] = []\\\\\\\\\\\\\\\\n    for (patch_u, patch_v), weight in sorted(edge_weights.items()):\\\\\\\\\\\\\\\\n        rows.extend([patch_u, patch_v])\\\\\\\\\\\\\\\\n        cols.extend([patch_v, patch_u])\\\\\\\\\\\\\\\\n        data.extend([weight, weight])\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    patch_adj = sp.csr_matrix(\\\\\\\\\\\\\\\\n        (np.asarray(data, dtype=np.float32), (rows, cols)),\\\\\\\\\\\\\\\\n        shape=(patch_count, patch_count),\\\\\\\\\\\\\\\\n    )\\\\\\\\\\\\\\\\n    patch_adj.eliminate_zeros()\\\\\\\\\\\\\\\\n    patch_adj.sort_indices()\\\\\\\\\\\\\\\\n    return patch_adj\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef _partition_surface_into_patches(\\\\\\\\\\\\\\\\n    adj: sp.csr_matrix,\\\\\\\\\\\\\\\\n    vertices: np.ndarray,\\\\\\\\\\\\\\\\n    *,\\\\\\\\\\\\\\\\n    patch_hops: int,\\\\\\\\\\\\\\\\n    patch_vertex_cap: int,\\\\\\\\\\\\\\\\n) -> PatchDecomposition:\\\\\\\\\\\\\\\\n    n_vertices = int(adj.shape[0])\\\\\\\\\\\\\\\\n    if patch_hops < 0:\\\\\\\\\\\\\\\\n        raise ValueError(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"patch_hops must be non-negative.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n    if patch_vertex_cap <= 0:\\\\\\\\\\\\\\\\n        raise ValueError(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"patch_vertex_cap must be positive.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n    if n_vertices != int(vertices.shape[0]):\\\\\\\\\\\\\\\\n        raise ValueError(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Surface graph vertex count does not match vertex coordinates.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    unassigned = np.ones(n_vertices, dtype=bool)\\\\\\\\\\\\\\\\n    surface_to_patch = np.full(n_vertices, -1, dtype=np.int32)\\\\\\\\\\\\\\\\n    patches: list[np.ndarray] = []\\\\\\\\\\\\\\\\n    patch_seed_vertices: list[int] = []\\\\\\\\\\\\\\\\n    patch_centroids: list[np.ndarray] = []\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    while bool(np.any(unassigned)):\\\\\\\\\\\\\\\\n        seed = int(np.flatnonzero(unassigned)[0])\\\\\\\\\\\\\\\\n        patch_vertices = _collect_patch_vertices(\\\\\\\\\\\\\\\\n            adj,\\\\\\\\\\\\\\\\n            seed=seed,\\\\\\\\\\\\\\\\n            unassigned=unassigned,\\\\\\\\\\\\\\\\n            patch_hops=patch_hops,\\\\\\\\\\\\\\\\n            cap=patch_vertex_cap,\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n        if patch_vertices.size == 0:\\\\\\\\\\\\\\\\n            patch_vertices = np.asarray([seed], dtype=np.int32)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        patch_id = len(patches)\\\\\\\\\\\\\\\\n        patches.append(patch_vertices)\\\\\\\\\\\\\\\\n        patch_seed_vertices.append(seed)\\\\\\\\\\\\\\\\n        surface_to_patch[patch_vertices] = patch_id\\\\\\\\\\\\\\\\n        unassigned[patch_vertices] = False\\\\\\\\\\\\\\\\n        patch_centroids.append(vertices[patch_vertices].mean(axis=0).astype(np.float32))\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    if np.any(surface_to_patch < 0):\\\\\\\\\\\\\\\\n        raise RuntimeError(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Patch generation did not cover the full surface graph.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    member_vertex_indices, member_vertex_indptr = _build_patch_membership_arrays(patches)\\\\\\\\\\\\\\\\n    patch_adj = _build_patch_adjacency(adj, surface_to_patch, patch_count=len(patches))\\\\\\\\\\\\\\\\n    patch_lap = _uniform_laplacian(patch_adj)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    return PatchDecomposition(\\\\\\\\\\\\\\\\n        surface_to_patch=surface_to_patch,\\\\\\\\\\\\\\\\n        patch_seed_vertices=np.asarray(patch_seed_vertices, dtype=np.int32),\\\\\\\\\\\\\\\\n        patch_sizes=np.asarray([int(patch.size) for patch in patches], dtype=np.int32),\\\\\\\\\\\\\\\\n        patch_centroids=np.asarray(patch_centroids, dtype=np.float32),\\\\\\\\\\\\\\\\n        member_vertex_indices=member_vertex_indices,\\\\\\\\\\\\\\\\n        member_vertex_indptr=member_vertex_indptr,\\\\\\\\\\\\\\\\n        patch_adj=patch_adj,\\\\\\\\\\\\\\\\n        patch_lap=patch_lap,\\\\\\\\\\\\\\\\n    )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef fetch_mesh_and_optional_skeleton(\\\\\\\\\\\\\\\\n    *,\\\\\\\\\\\\\\\\n    root_id: int,\\\\\\\\\\\\\\\\n    bundle_paths: GeometryBundlePaths,\\\\\\\\\\\\\\\\n    flywire_dataset: str = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"public\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n    fetch_skeletons: bool = True,\\\\\\\\\\\\\\\\n    refetch_mesh: bool = False,\\\\\\\\\\\\\\\\n    refetch_skeleton: bool = False,\\\\\\\\\\\\\\\\n    require_skeletons: bool = False,\\\\\\\\\\\\\\\\n    set_default_dataset: Callable[[str], None] | None = None,\\\\\\\\\\\\\\\\n    mesh_fetcher: Callable[[int], Any] | None = None,\\\\\\\\\\\\\\\\n    skeleton_fetcher: Callable[[int], Any] | None = None,\\\\\\\\\\\\\\\\n    skeleton_writer: Callable[[Any, str | Path], None] | None = None,\\\\\\\\\\\\\\\\n) -> dict[str, Any]:\\\\\\\\\\\\\\\\n    needs_default_clients = (\\\\\\\\\\\\\\\\n        set_default_dataset is None\\\\\\\\\\\\\\\\n        or mesh_fetcher is None\\\\\\\\\\\\\\\\n        or (fetch_skeletons and (skeleton_fetcher is None or skeleton_writer is None))\\\\\\\\\\\\\\\\n    )\\\\\\\\\\\\\\\\n    if needs_default_clients:\\\\\\\\\\\\\\\\n        flywire, navis = _optional_imports()\\\\\\\\\\\\\\\\n        set_default_dataset = flywire.set_default_dataset\\\\\\\\\\\\\\\\n        mesh_fetcher = flywire.get_mesh_neuron\\\\\\\\\\\\\\\\n        skeleton_fetcher = flywire.get_skeletons\\\\\\\\\\\\\\\\n        skeleton_writer = navis.write_swc\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    if require_skeletons and not fetch_skeletons:\\\\\\\\\\\\\\\\n        raise ValueError(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Skeletons cannot be required when meshing.fetch_skeletons is disabled.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    ensure_dir(bundle_paths.raw_mesh_path.parent)\\\\\\\\\\\\\\\\n    ensure_dir(bundle_paths.raw_skeleton_path.parent)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    set_default_dataset(flywire_dataset)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    mesh_provenance = _materialize_raw_mesh(\\\\\\\\\\\\\\\\n        root_id=root_id,\\\\\\\\\\\\\\\\n        asset_path=bundle_paths.raw_mesh_path,\\\\\\\\\\\\\\\\n        refetch=refetch_mesh,\\\\\\\\\\\\\\\\n        mesh_fetcher=mesh_fetcher,\\\\\\\\\\\\\\\\n    )\\\\\\\\\\\\\\\\n    skeleton_provenance = _materialize_raw_skeleton(\\\\\\\\\\\\\\\\n        root_id=root_id,\\\\\\\\\\\\\\\\n        asset_path=bundle_paths.raw_skeleton_path,\\\\\\\\\\\\\\\\n        fetch_skeletons=fetch_skeletons,\\\\\\\\\\\\\\\\n        refetch=refetch_skeleton,\\\\\\\\\\\\\\\\n        skeleton_fetcher=skeleton_fetcher,\\\\\\\\\\\\\\\\n        skeleton_writer=skeleton_writer,\\\\\\\\\\\\\\\\n    )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    asset_statuses = {\\\\\\\\\\\\\\\\n        RAW_MESH_KEY: str(mesh_provenance[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"asset_status\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"]),\\\\\\\\\\\\\\\\n        RAW_SKELETON_KEY: str(skeleton_provenance[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"asset_status\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"]),\\\\\\\\\\\\\\\\n    }\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"exit_code\\\\\\\\\\\\\\\":0,\\\\\\\\\\\\\\\"status\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"completed\\\\\\\\\\\\\\\"}}\\\\\\\\nagent_tickets/runs/20260321T185349Z/FW-M6-002_Assemble_fine-surface_operators_with_geodesic_neighborhoods_tangent_frames_and_boundary_masks/stdout.jsonl:17:{\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item.completed\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"item\\\\\\\\\\\\\\\":{\\\\\\\\\\\\\\\"id\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item_7\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"command_execution\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"command\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"/bin/bash -lc \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sed -n '1,260p' tests/test_mesh_pipeline_build.py\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"aggregated_output\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"from __future__ import annotations\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nimport json\\\\\\\\\\\\\\\\nimport sys\\\\\\\\\\\\\\\\nimport tempfile\\\\\\\\\\\\\\\\nimport textwrap\\\\\\\\\\\\\\\\nimport unittest\\\\\\\\\\\\\\\\nfrom pathlib import Path\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nimport numpy as np\\\\\\\\\\\\\\\\nimport scipy.sparse as sp\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nROOT = Path(__file__).resolve().parents[1]\\\\\\\\\\\\\\\\nSRC = ROOT / \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"src\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\nsys.path.insert(0, str(SRC))\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nfrom flywire_wave.geometry_contract import build_geometry_bundle_paths\\\\\\\\\\\\\\\\nfrom flywire_wave.geometry_contract import load_operator_bundle_metadata\\\\\\\\\\\\\\\\nfrom flywire_wave.mesh_pipeline import process_mesh_into_wave_assets\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nclass MeshBuildPipelineTest(unittest.TestCase):\\\\\\\\\\\\\\\\n    def test_process_mesh_builds_explicit_multiresolution_graph_artifacts_deterministically(self) -> None:\\\\\\\\\\\\\\\\n        with tempfile.TemporaryDirectory(dir=ROOT) as tmp_dir_str:\\\\\\\\\\\\\\\\n            tmp_dir = Path(tmp_dir_str)\\\\\\\\\\\\\\\\n            bundle_paths_a = _bundle_paths(tmp_dir / \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"run_a\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n            bundle_paths_b = _bundle_paths(tmp_dir / \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"run_b\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            _write_octahedron_mesh(bundle_paths_a.raw_mesh_path)\\\\\\\\\\\\\\\\n            _write_octahedron_mesh(bundle_paths_b.raw_mesh_path)\\\\\\\\\\\\\\\\n            _write_stub_swc(bundle_paths_a.raw_skeleton_path)\\\\\\\\\\\\\\\\n            _write_stub_swc(bundle_paths_b.raw_skeleton_path)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            outputs_a = process_mesh_into_wave_assets(\\\\\\\\\\\\\\\\n                root_id=101,\\\\\\\\\\\\\\\\n                bundle_paths=bundle_paths_a,\\\\\\\\\\\\\\\\n                simplify_target_faces=8,\\\\\\\\\\\\\\\\n                patch_hops=1,\\\\\\\\\\\\\\\\n                patch_vertex_cap=2,\\\\\\\\\\\\\\\\n                registry_metadata={\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"cell_type\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"T5a\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"project_role\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"surface_simulated\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"},\\\\\\\\\\\\\\\\n            )\\\\\\\\\\\\\\\\n            outputs_b = process_mesh_into_wave_assets(\\\\\\\\\\\\\\\\n                root_id=101,\\\\\\\\\\\\\\\\n                bundle_paths=bundle_paths_b,\\\\\\\\\\\\\\\\n                simplify_target_faces=8,\\\\\\\\\\\\\\\\n                patch_hops=1,\\\\\\\\\\\\\\\\n                patch_vertex_cap=2,\\\\\\\\\\\\\\\\n                registry_metadata={\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"cell_type\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"T5a\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"project_role\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"surface_simulated\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"},\\\\\\\\\\\\\\\\n            )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            surface_graph_a = _read_npz(bundle_paths_a.surface_graph_path)\\\\\\\\\\\\\\\\n            patch_graph_a = _read_npz(bundle_paths_a.patch_graph_path)\\\\\\\\\\\\\\\\n            transfer_ops_a = _read_npz(bundle_paths_a.transfer_operator_path)\\\\\\\\\\\\\\\\n            surface_graph_b = _read_npz(bundle_paths_b.surface_graph_path)\\\\\\\\\\\\\\\\n            patch_graph_b = _read_npz(bundle_paths_b.patch_graph_path)\\\\\\\\\\\\\\\\n            transfer_ops_b = _read_npz(bundle_paths_b.transfer_operator_path)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            expected_surface_keys = {\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"root_id\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"patch_count\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"vertices\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"faces\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"surface_to_patch\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"adj_data\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"adj_indices\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"adj_indptr\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"adj_shape\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"lap_data\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"lap_indices\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"lap_indptr\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"lap_shape\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n            }\\\\\\\\\\\\\\\\n            expected_patch_keys = {\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"root_id\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"patch_count\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"surface_vertex_count\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"surface_to_patch\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"patch_seed_vertices\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"patch_sizes\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"patch_centroids\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"member_vertex_indices\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"member_vertex_indptr\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"adj_data\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"adj_indices\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"adj_indptr\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"adj_shape\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"lap_data\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"la