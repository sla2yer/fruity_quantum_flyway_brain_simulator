   )\n   433\t\n   434\t\n   435\t@dataclass(frozen=True)\n   436\tclass SurfaceWaveMorphologyRuntimeResult:\n   437\t    descriptor: MorphologyRuntimeDescriptor\n   438\t    resolved: ResolvedSurfaceWaveExecutionPlan\n   439\t    surface_result: CoupledSurfaceWaveRunResult\n   440\t\n   441\t    @property\n   442\t    def root_ids(self) -> tuple[int, ...]:\n   443\t        return self.surface_result.root_ids\n   444\t\n   445\t    @property\n   446\t    def timebase(self) -> dict[str, Any]:\n   447\t        return copy.deepcopy(self.surface_result.timebase)\n   448\t\n   449\t    @property\n   450\t    def determinism(self) -> dict[str, Any]:\n   451\t        return copy.deepcopy(self.surface_result.determinism)\n   452\t\n   453\t    @property\n   454\t    def runtime_metadata_by_root(self) -> Sequence[Mapping[str, Any]]:\n   455\t        return self.surface_result.runtime_metadata_by_root\n   456\t\n   457\t    @property\n   458\t    def initial_state_exports_by_root(self) -> Mapping[int, Mapping[str, Any]]:\n   459\t        return self.surface_result.initial_states_by_root\n   460\t\n   461\t    @property\n   462\t    def final_state_exports_by_root(self) -> Mapping[int, Mapping[str, Any]]:\n   463\t        return self.surface_result.final_states_by_root\n   464\t\n   465\t    @property\n   466\t    def coupling_projection_history_by_root(self) -> Mapping[int, np.ndarray]:\n   467\t        return self.surface_result.patch_readout_history_by_root\n   468\t\n   469\t    @property\n   470\t    def shared_readout_history(self) -> Sequence[Mapping[str, Any]]:\n   471\t        return self.surface_result.shared_readout_history\n   472\t\n   473\t    @property\n   474\t    def coupling_application_history(self) -> Sequence[Mapping[str, Any]]:\n   475\t        return self.surface_result.coupling_application_history\n   476\t\n   477\t    @property\n   478\t    def substep_count(self) -> int:\n   479\t        return int(self.surface_result.substep_count)\n   480\t\n   481\t    @property\n   482\t    def shared_step_count(self) -> int:\n   483\t        return int(self.surface_result.shared_step_count)\n   484\t\n   485\t    def export_state_summaries(\n   486\t        self,\n   487\t        *,\n   488\t        state_stage: str,\n   489\t    ) -> tuple[SimulationStateSummaryRow, ...]:\n   490\t        if state_stage == \"initial\":\n   491\t            states_by_root = self.initial_state_exports_by_root\n   492\t            history_index = 0\n   493\t        elif state_stage == \"final\":\n   494\t            states_by_root = self.final_state_exports_by_root\n   495\t            history_index = -1\n   496\t        else:\n   497\t            raise ValueError(\n   498\t                \"state_stage must be 'initial' or 'final', \"\n   499\t                f\"got {state_stage!r}.\"\n   500\t            )\n   501\t        return _build_surface_wave_state_summaries(\n   502\t            root_ids=self.root_ids,\n   503\t            states_by_root=states_by_root,\n   504\t            patch_state_by_root={\n   505\t                int(root_id): np.asarray(\n   506\t                    self.coupling_projection_history_by_root[int(root_id)][history_index],\n   507\t                    dtype=np.float64,\n   508\t                )\n   509\t                for root_id in self.root_ids\n   510\t            },\n   511\t        )\n   512\t\n   513\t    def export_readout_values(\n   514\t        self,\n   515\t        *,\n   516\t        summary: Mapping[str, Any],\n   517\t        readout_catalog: Sequence[SimulationReadoutDefinition],\n   518\t    ) -> np.ndarray:\n   519\t        return _surface_wave_readout_values(\n   520\t            summary=summary,\n   521\t            readout_catalog=readout_catalog,\n   522\t        )\n   523\t\n   524\t    def export_readout_trace_values(\n   525\t        self,\n   526\t        *,\n   527\t        readout_catalog: Sequence[SimulationReadoutDefinition],\n   528\t        sample_count: int,\n   529\t    ) -> np.ndarray:\n   530\t        normalized_sample_count = int(sample_count)\n   531\t        if len(self.shared_readout_history) < normalized_sample_count:\n   532\t            raise ValueError(\n   533\t                \"surface-wave shared_readout_history is shorter than the declared sample_count.\"\n   534\t            )\n   535\t        values = np.empty(\n   536\t            (normalized_sample_count, len(readout_catalog)),\n   537\t            dtype=np.float64,\n   538\t        )\n   539\t        for sample_index in range(normalized_sample_count):\n   540\t            values[sample_index, :] = self.export_readout_values(\n   541\t                summary=self.shared_readout_history[sample_index],\n   542\t                readout_catalog=readout_catalog,\n   543\t            )\n   544\t        return values\n   545\t\n   546\t    def export_dynamic_state_vector(\n   547\t        self,\n   548\t        *,\n   549\t        summary: Mapping[str, Any],\n   550\t    ) -> np.ndarray:\n   551\t        return _surface_wave_dynamic_state_vector(\n   552\t            summary=summary,\n   553\t            root_ids=self.root_ids,\n   554\t        )\n   555\t\n   556\t    def export_projection_trace_payload(self) -> dict[str, np.ndarray]:\n   557\t        history_length = len(\n   558\t            self.coupling_projection_history_by_root[int(self.root_ids[0])]\n   559\t        )\n   560\t        payload: dict[str, np.ndarray] = {\n   561\t            \"substep_time_ms\": (\n   562\t                np.arange(history_length, dtype=np.float64)\n   563\t                * float(self.resolved.integration_timestep_ms)\n   564\t                + float(self.resolved.timebase.time_origin_ms)\n   565\t            ),\n   566\t            \"root_ids\": np.asarray(self.root_ids, dtype=np.int64),\n   567\t        }\n   568\t        for root_id in self.root_ids:\n   569\t            payload[f\"root_{int(root_id)}_patch_activation\"] = np.asarray(\n   570\t                self.coupling_projection_history_by_root[int(root_id)],\n   571\t                dtype=np.float64,\n   572\t            )\n   573\t        return payload\n   574\t\n   575\t\n   576\tclass _SingleRootSkeletonGraphRuntime:\n   577\t    def __init__(\n   578\t        self,\n   579\t        *,\n   580\t        asset: SkeletonRuntimeAsset,\n   581\t        integration_timestep_ms: float,\n   582\t        internal_substep_count: int,\n   583\t        wave_speed_sq_scale: float,\n   584\t        restoring_strength_per_ms2: float,\n   585\t        gamma_per_ms: float,\n   586\t    ) -> None:\n   587\t        self.asset = asset\n   588\t        self.integration_timestep_ms = float(integration_timestep_ms)\n   589\t        self.internal_substep_count = int(internal_substep_count)\n   590\t        self.wave_speed_sq_scale = float(wave_speed_sq_scale)\n   591\t        self.restoring_strength_per_ms2 = float(restoring_strength_per_ms2)\n   592\t        self.gamma_per_ms = float(gamma_per_ms)\n   593\t        self._pending_source_value = 0.0\n   594\t        self._current_state: SkeletonGraphState | None = None\n   595\t        self._initial_state_mapping: dict[str, Any] | None = None\n   596\t        self._projection_history: list[np.ndarray] = []\n   597\t\n   598\t    @property\n   599\t    def root_id(self) -> int:\n   600\t        return int(self.asset.root_id)\n   601\t\n   602\t    @property\n   603\t    def current_state(self) -> SkeletonGraphState:\n   604\t        if self._current_state is None:\n   605\t            raise ValueError(\"Skeleton runtime root has not been initialized.\")\n   606\t        return self._current_state\n   607\t\n   608\t    @property\n   609\t    def projection_history(self) -> np.ndarray:\n   610\t        return np.asarray(self._projection_history, dtype=np.float64)\n   611\t\n   612\t    @property\n   613\t    def initial_state_mapping(self) -> dict[str, Any]:\n   614\t        if self._initial_state_mapping is None:\n   615\t            raise ValueError(\"Skeleton runtime root has not been initialized.\")\n   616\t        return copy.deepcopy(self._initial_state_mapping)\n   617\t\n   618\t    def initialize_zero(self) -> None:\n   619\t        state = SkeletonGraphState.zeros(self.asset.node_count)\n   620\t        self.initialize_state(state)\n   621\t\n   622\t    def initialize_state(self, state: Any) -> None:\n   623\t        normalized_state = self._normalize_state(state)\n   624\t        self._current_state = normalized_state\n   625\t        self._pending_source_value = 0.0\n   626\t        self._projection_history = [\n   627\t            np.asarray(normalized_state.activation, dtype=np.float64).copy()\n   628\t        ]\n   629\t        self._initial_state_mapping = normalized_state.as_mapping(\n   630\t            node_ids=self.asset.node_ids,\n   631\t            node_coordinates=self.asset.node_coordinates,\n   632\t            projection_weights=self.asset.readout_weights,\n   633\t        )\n   634\t\n   635\t    def inject_source(self, value: float | None) -> None:\n   636\t        self._pending_source_value = 0.0 if value is None else float(value)\n   637\t\n   638\t    def step_shared(self) -> None:\n   639\t        state = self.current_state.copy()\n   640\t        source_value = float(self._pending_source_value)\n   641\t        source_vector = np.full(self.asset.node_count, source_value, dtype=np.float64)\n   642\t        operator = self.asset.graph_operator\n   643\t        for _ in range(self.internal_substep_count):\n   644\t            acceleration = (\n   645\t                -self.wave_speed_sq_scale\n   646\t                * np.asarray(operator @ state.activation, dtype=np.float64)\n   647\t                - self.restoring_strength_per_ms2 * np.asarray(state.activation, dtype=np.float64)\n   648\t                - self.gamma_per_ms * np.asarray(state.velocity, dtype=np.float64)\n   649\t                + source_vector\n   650\t            )\n   651\t            updated_velocity = (\n   652\t                np.asarray(state.velocity, dtype=np.float64)\n   653\t                + self.integration_timestep_ms * acceleration\n   654\t            )\n   655\t            updated_activation = (\n   656\t                np.asarray(state.activation, dtype=np.float64)\n   657\t                + self.integration_timestep_ms * updated_velocity\n   658\t            )\n   659\t            state = SkeletonGraphState(\n   660\t                resolution=SKELETON_GRAPH_STATE_RESOLUTION,\n   661\t                activation=updated_activation,\n   662\t                velocity=updated_velocity,\n   663\t            )\n   664\t        self._current_state = state\n   665\t        self._pending_source_value = 0.0\n   666\t        self._projection_history.append(\n   667\t            np.asarray(self.current_state.activation, dtype=np.float64).copy()\n   668\t        )\n   669\t\n   670\t    def export_state_mapping(self) -> dict[str, Any]:\n   671\t        return self.current_state.as_mapping(\n   672\t            node_ids=self.asset.node_ids,\n   673\t            node_coordinates=self.asset.node_coordinates,\n   674\t            projection_weights=self.asset.readout_weights,\n   675\t        )\n   676\t\n   677\t    def runtime_metadata(self) -> dict[str, Any]:\n   678\t        metadata = load_skeleton_runtime_asset_metadata(\n   679\t            self.asset.metadata[\"metadata_path\"]\n   680\t        )\n   681\t        return {\n   682\t            \"root_id\": self.root_id,\n   683\t            \"morphology_class\": SKELETON_NEURON_CLASS,\n   684\t            \"state_layout\": str(metadata[\"state_layout\"]),\n   685\t            \"projection_surface\": str(metadata[\"projection_surface\"]),\n   686\t            \"projection_layout\": str(metadata[\"projection_layout\"]),\n   687\t            \"node_count\": int(metadata[\"counts\"][\"node_count\"]),\n   688\t            \"edge_count\": int(metadata[\"counts\"][\"edge_count\"]),\n   689\t            \"asset_hash\": str(metadata[\"asset_hash\"]),\n   690\t            \"asset_contract_version\": str(metadata[\"contract_version\"]),\n   691\t            \"approximation_family\": str(metadata[\"approximation_family\"]),\n   692\t            \"graph_operator_family\": str(metadata[\"graph_operator_family\"]),\n   693\t            \"source_injection_strategy\": str(metadata[\"source_injection_strategy\"]),\n   694\t            \"spectral_radius\": float(metadata[\"operator\"][\"spectral_radius\"]),\n   695\t            \"integration_timestep_ms\": float(self.integration_timestep_ms),\n   696\t            \"internal_substep_count\": int(self.internal_substep_count),\n   697\t        }\n   698\t\n   699\t    def summary_fragment(self) -> dict[str, Any]:\n   700\t        state = self.current_state\n   701\t        weights = np.asarray(self.asset.readout_weights, dtype=np.float64)\n   702\t        return {\n   703\t            \"mean_activation\": float(np.dot(weights, state.activation)),\n   704\t            \"mean_velocity\": float(np.dot(weights, state.velocity)),\n   705\t            \"projection\": np.asarray(state.activation, dtype=np.float64).copy(),\n   706\t        }\n   707\t\n   708\t    def _normalize_state(self, value: Any) -> SkeletonGraphState:\n   709\t        if isinstance(value, SkeletonGraphState):\n   710\t            normalized = value.copy()\n   711\t        elif isinstance(value, Mapping):\n   712\t            normalized = SkeletonGraphState(\n   713\t                resolution=str(value.get(\"resolution\", SKELETON_GRAPH_STATE_RESOLUTION)),\n   714\t                activation=np.asarray(value[\"activation\"], dtype=np.float64),\n   715\t                velocity=np.asarray(value[\"velocity\"], dtype=np.float64),\n   716\t            )\n   717\t        else:\n   718\t            raise ValueError(\n   719\t                \"Skeleton runtime initialization requires SkeletonGraphState or a \"\n   720\t                \"mapping with activation and velocity arrays.\"\n   721\t            )\n   722\t        if normalized.activation.shape[0] != self.asset.node_count:\n   723\t            raise ValueError(\n   724\t                \"Skeleton runtime initialization state does not match the asset node \"\n   725\t                f\"count for root {self.root_id}: got {normalized.activation.shape[0]} \"\n   726\t                f\"and expected {self.asset.node_count}.\"\n   727\t            )\n   728\t        return normalized\n   729\t\n   730\t\n   731\tclass SurfaceSkeletonMorphologyRuntime:\n   732\t    def __init__(self, arm_plan: Mapping[str, Any]) -> None:\n   733\t        normalized_arm_plan = _require_mapping(arm_plan, field_name=\"arm_plan\")\n   734\t        self._arm_plan = copy.deepcopy(dict(normalized_arm_plan))\n   735\t        model_configuration = _require_mapping(\n   736\t            normalized_arm_plan.get(\"model_configuration\"),\n   737\t            field_name=\"arm_plan.model_configuration\",\n   738\t        )\n   739\t        execution_plan = _require_mapping(\n   740\t            model_configuration.get(\"surface_wave_execution_plan\"),\n   741\t            field_name=\"arm_plan.model_configuration.surface_wave_execution_plan\",\n   742\t        )\n   743\t        runtime = _require_mapping(\n   744\t            normalized_arm_plan.get(\"runtime\"),\n   745\t            field_name=\"arm_plan.runtime\",\n   746\t        )\n   747\t        self._surface_wave_model = parse_surface_wave_model_metadata(\n   748\t            _require_mapping(\n   749\t                model_configuration.get(\"surface_wave_model\"),\n   750\t                field_name=\"arm_plan.model_configuration.surface_wave_model\",\n   751\t            )\n   752\t        )\n   753\t        self._hybrid_morphology = parse_hybrid_morphology_plan_metadata(\n   754\t            _require_mapping(\n   755\t                execution_plan.get(\"hybrid_morphology\"),\n   756\t                field_name=\"surface_wave_execution_plan.hybrid_morphology\",\n   757\t     