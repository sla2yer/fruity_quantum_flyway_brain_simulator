d the retinal lattice response should move together.\ndocs/retinal_inspection.md:42:  If the source changes direction, contrast, or time phase, the sampled retinal\ndocs/retinal_inspection.md:47:  fully uncovered and the bundle is not a trustworthy Milestone 8B handoff.\ndocs/retinal_inspection.md:62:  stop sign for Milestone 8B review until the source setup or sampler behavior\ntests/test_stimulus_contract.py:142:            self.assertEqual(metadata_a[\"spatial_frame\"][\"frame_name\"], \"visual_field_degrees_centered\")\ntests/test_retinal_bundle_workflow.py:15:from flywire_wave.retinal_bundle import load_recorded_retinal_bundle\ntests/test_retinal_bundle_workflow.py:19:    def test_record_and_replay_stimulus_driven_retinal_bundle_deterministically(self) -> None:\ntests/test_retinal_bundle_workflow.py:22:            config_path = _write_retinal_stimulus_config(tmp_dir)\ntests/test_retinal_bundle_workflow.py:35:            metadata_path = Path(first_record[\"retinal_bundle_metadata_path\"])\ntests/test_retinal_bundle_workflow.py:42:                first_record[\"retinal_bundle_metadata_path\"],\ntests/test_retinal_bundle_workflow.py:43:                second_record[\"retinal_bundle_metadata_path\"],\ntests/test_retinal_bundle_workflow.py:52:                / \"retinal\"\ntests/test_retinal_bundle_workflow.py:58:                / first_record[\"retinal_spec_hash\"]\ntests/test_retinal_bundle_workflow.py:61:            self.assertEqual(metadata_path, expected_bundle_dir / \"retinal_input_bundle.json\")\ntests/test_retinal_bundle_workflow.py:62:            self.assertEqual(archive_path, expected_bundle_dir / \"retinal_frames.npz\")\ntests/test_retinal_bundle_workflow.py:65:            replay = load_recorded_retinal_bundle(metadata_path)\ntests/test_retinal_bundle_workflow.py:98:    def test_record_and_replay_scene_driven_retinal_bundle_deterministically(self) -> None:\ntests/test_retinal_bundle_workflow.py:114:            metadata_path = Path(first_record[\"retinal_b