t must be a mapping.\")\n   146\t    return resolve_stimulus_spec(manifest)\n   147\t\n   148\t\n   149\tdef _resolve_processed_stimulus_dir(processed_stimulus_dir: str | Path | None) -> Path:\n   150\t    if processed_stimulus_dir is not None:\n   151\t        return Path(processed_stimulus_dir).resolve()\n   152\t    return (REPO_ROOT / DEFAULT_PROCESSED_STIMULUS_DIR).resolve()\n   153\t\n   154\t\n   155\tdef _validate_manifest_stimulus_declaration(manifest: Mapping[str, Any]) -> None:\n   156\t    nested_stimulus = manifest.get(\"stimulus\")\n   157\t    if nested_stimulus is None:\n   158\t        return\n   159\t    if not isinstance(nested_stimulus, Mapping):\n   160\t        raise ValueError(\"stimulus must be a mapping when provided.\")\n   161\t\n   162\t    nested_has_family = nested_stimulus.get(\"stimulus_family\") is not None\n   163\t    nested_has_name = nested_stimulus.get(\"stimulus_name\") is not None\n   164\t    if nested_has_family != nested_has_name:\n   165\t        raise ValueError(\n   166\t            \"stimulus.stimulus_family and stimulus.stimulus_name must either both be provided \"\n   167\t            \"or both be omitted.\"\n   168\t        )\n   169\t\n   170\t    top_level_seed = manifest.get(\"random_seed\")\n   171\t    determinism = nested_stimulus.get(\"determinism\")\n   172\t    if isinstance(determinism, Mapping) and determinism.get(\"seed\") is not None and top_level_seed is not None:\n   173\t        if int(determinism[\"seed\"]) != int(top_level_seed):\n   174\t            raise ValueError(\"stimulus.determinism.seed must match the top-level random_seed.\")\n   175\t\n   176\t    if nested_has_family and nested_has_name:\n   177\t        top_level_reference = resolve_stimulus_spec(\n   178\t            stimulus_family=manifest.get(\"stimulus_family\"),\n   179\t            stimulus_name=manifest.get(\"stimulus_name\"),\n   180\t        )\n   181\t        nested_reference = resolve_stimulus_spec(stimulus=nested_stimulus)\n   182\t        if (\n   183\t            top_level_reference.stimulus_family != nested_reference.stimulus_family\n   184\t            or top_level_reference.stimulus_name != nested_reference.stimulus_name\n   185\t        ):\n   186\t            raise ValueError(\n   187\t                \"stimulus.stimulus_family/stimulus_name must resolve to the same canonical \"\n   188\t                \"stimulus as the top-level stimulus_family/stimulus_name fields.\"\n   189\t            )\n","exit_code":0,"status":"completed"}}
