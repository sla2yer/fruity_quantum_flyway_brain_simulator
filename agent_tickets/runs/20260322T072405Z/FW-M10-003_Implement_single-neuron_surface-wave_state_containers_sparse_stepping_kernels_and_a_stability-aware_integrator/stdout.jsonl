ator_bundle.prolongation\n            )\n        if projector is None:\n            mode = \"normalized\" if normalized else \"physical\"\n            raise ValueError(\n                f\"{mode} {direction} projection is unavailable in this operator bundle.\"\n","exit_code":0,"status":"completed"}}
