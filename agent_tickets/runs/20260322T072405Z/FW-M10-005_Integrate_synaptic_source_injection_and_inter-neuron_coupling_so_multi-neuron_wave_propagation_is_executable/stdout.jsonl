 in permutation]\n   184\t                for root_id, permutation in sorted(self.target_patch_permutations.items())\n   185\t            },\n   186\t            \"components\": [\n   187\t                component.as_mapping()\n   188\t                for component in self.components\n   189\t            ],\n   190\t        }\n   191\t\n   192\t\n   193\t@dataclass(frozen=True)\n   194\tclass ResolvedSurfaceWaveExecutionPlan:\n   195\t    root_ids: tuple[int, ...]\n   196\t    timebase: SimulationTimebase\n   197\t    determinism: SimulationDeterminismContext\n   198\t    surface_wave_model: dict[str, Any]\n   199\t    surface_wave_execution_plan: dict[str, Any]\n   200\t    operator_assets: tuple[dict[str, Any], ...]\n   201\t    coupling_assets: tuple[dict[str, Any], ...]\n   202\t    operator_bundles: tuple[SurfaceWaveOperatorBundle, ...]\n   203\t    coupling_plan: SurfaceWaveCouplingPlan\n   204\t    execution_version: str = SURFACE_WAVE_EXECUTION_VERSION\n   205\t    arm_plan: dict[str, Any] | None = None\n   206\t\n   207\t    @property\n   208\t    def integration_timestep_ms(self) -> float:\n   209\t        return float(self.surface_wave_execution_plan[\"solver\"][\"integration_timestep_ms\"])\n   210\t\n   211\t    @property\n   212\t    def shared_output_timestep_ms(self) -> float:\n   213\t        return float(self.surface_wave_execution_plan[\"solver\"][\"shared_output_timestep_ms\"])\n   214\t\n   215\t    @property\n   216\t    def internal_substep_count(self) -> int:\n   217\t        return int(self.surface_wave_execution_plan[\"solver\"][\"internal_substep_count\"])\n   218\t\n   219\t    def build_circuit(self) -> CoupledSurfaceWaveCircuit:\n   220\t        return CoupledSurfaceWaveCircuit(self)\n   221\t\n   222\t    def run_to_completion(\n   223\t        self,\n   224\t        *,\n   225\t        shared_step_count: int | None = None,\n   226\t        initial_states_by_root: Mapping[int, SurfaceWaveState] | None = None,\n   227\t    ) -> Coupled