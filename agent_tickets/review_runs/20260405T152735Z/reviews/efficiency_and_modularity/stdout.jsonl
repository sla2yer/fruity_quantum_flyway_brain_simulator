oat64),\n   768\t            \"surface_patch_assets_invalid\",\n   769\t        )\n   770\t    if surface_to_patch.shape != (vertices.shape[0],):\n   771\t        return (\n   772\t            np.empty((0, 3), dtype=np.float64),\n   773\t            np.empty(0, dtype=np.int32),\n   774\t            np.empty((0, 3), dtype=np.float64),\n   775\t            np.empty(0, dtype=np.float64),\n   776\t            \"surface_patch_assets_invalid\",\n   777\t        )\n   778\t\n   779\t    patch_radii = np.zeros(patch_count, dtype=np.float64)\n   780\t    for patch_id in range(patch_count):\n   781\t        start = int(member_vertex_indptr[patch_id])\n   782\t        end = int(member_vertex_indptr[patch_id + 1])\n   783\t        if end <= start:\n   784\t            continue\n   785\t        member_vertices = vertices[member_vertex_indices[start:end]]\n   786\t        distances = np.linalg.norm(member_vertices - patch_centroids[patch_id], axis=1)\n   787\t        patch_radii[patch_id] = float(distances.max(initial=0.0))\n   788\t    return vertices, surface_to_patch, patch_centroids, patch_radii, \"\"\n   789\t\n   790\t\n   791\tdef _load_skeleton_geometry(path: Path) -> tuple[np.ndarray, np.ndarray, np.ndarray, str]:\n   792\t    if not path.exists():\n   793\t        return (\n   794\t            np.empty(0, dtype=np.int64),\n   795\t            np.empty((0, 3), dtype=np.float64),\n   796\t            np.empty(0, dtype=np.float64),\n   797\t            \"skeleton_asset_missing\",\n   798\t        )\n   799\t\n   800\t    nodes: list[tuple[int, np.ndarray, int]] = []\n   801\t    try:\n   802\t        with path.open(\"r\", encoding=\"utf-8\") as handle:\n   803\t            for raw_line in handle:\n   804\t                line = raw_line.strip()\n   805\t                if not line or line.startswith(\"#\"):\n   806\t                    continue\n   807\t                parts = line.split()\n   808\t                if len(parts) != 7:\n   809\t                    return (\n   810\t                        np.empty(0, dtype=np.int64),\n   811\t                        np.empty((0, 3), dtype=np.float64),\n   812\t                        np.empty(0, dtype=np.float64),\n   813\t                        \"skeleton_asset_invalid\",\n   814\t                    )\n   815\t                node_id = int(parts[0])\n   816\t                coords = np.asarray([float(parts[2]), float(parts[3]), float(parts[4])], dtype=np.float64)\n   817\t                parent_id = int(parts[6])\n   818\t                nodes.append((node_id, coords, parent_id))\n   819\t    except Exception:\n   820\t        return (\n   821\t            np.empty(0, dtype=np.int64),\n   822\t            np.empty((0, 3), dtype=np.float64),\n   823\t            np.empty(0, dtype=np.float64),\n   824\t            \"skeleton_asset_invalid\",\n   825\t        )\n   826\t\n   827\t    if not nodes:\n   828\t        return (\n   829\t            np.empty(0, dtype=np.int64),\n   830\t            np.empty((0, 3), dtype=np.float64),\n   831\t            np.empty(0, dtype=np.float64),\n   832\t            \"skeleton_asset_empty\",\n   833\t        )\n   834\t\n   835\t    node_ids = np.asarray([node_id for node_id, _coords, _parent_id in nodes], dtype=np.int64)\n   836\t    points = np.vstack([coords for _node_id, coords, _parent_id in nodes]).astype(np.float64, copy=False)\n   837\t    node_index = {int(node_id): idx for idx, node_id in enumerate(node_ids.tolist())}\n   838\t    incident_lengths: list[list[float]] = [[] for _ in range(len(nodes))]\n   839\t    for idx, (_node_id, coords, parent_id) in enumerate(nodes):\n   840\t        parent_idx = node_index.get(int(parent_id))\n   841\t        if parent_idx is None:\n   842\t            continue\n   843\t        length = float(np.linalg.norm(coords - points[parent_idx]))\n   844\t        incident_lengths[idx].append(length)\n   845\t        incident_lengths[parent_idx].append(length)\n   846\t    local_scales = np.asarray(\n   847\t        [float(np.mean(lengths)) if lengths else 0.0 for lengths in incident_lengths],\n   848\t        dtype=np.float64,\n   849\t    )\n   850\t    return node_ids, points, local_scales, \"\"\n   851\t\n   852\t\n   853\tdef _build_point_anchor_proxy(\n   854\t    root_rows: pd.DataFrame,\n   855\t    *,\n   856\t    relation_to_root: str,\n   857\t) -> tuple[np.ndarray, float, str]:\n   858\t    if root_rows.empty:\n   859\t        return np.full(3, np.nan, dtype=np.float64), float(\"nan\"), \"no_root_local_synapses\"\n   860\t\n   861\t    points: list[np.ndarray] = []\n   862\t    for row in root_rows.itertuples(index=False):\n   863\t        query = _resolve_query_point(row, relation_to_root=relation_to_root)\n   864\t        if query[\"blocked_reason\"]:\n   865\t            continue\n   866\t        points.append(np.asarray(query[\"query_point\"], dtype=np.float64))\n   867\t    if not points:\n   868\t        return np.full(3, np.nan, dtype=np.float64), float(\"nan\"), \"no_query_points_for_point_anchor\"\n   869\t\n   870\t    stacked = np.vstack(points)\n   871\t    anchor = stacked.mean(axis=0).astype(np.float64)\n   872\t    distances = np.linalg.norm(stacked - anchor, axis=1)\n   873\t    radius = float(distances.max(initial=0.0))\n   874\t    return anchor, radius, \"\"\n   875\t\n   876\t\n   877\tdef _build_edge_record(*, row: Any, pre_context: RootContext, post_context: RootContext) -> dict[str, Any]:\n   878\t    pre_query = _resolve_query_point(row, relation_to_root=OUTGOING_RELATION)\n   879\t    post_query = _resolve_query_point(row, relation_to_root=INCOMING_RELATION)\n   880\t    pre_mapping = _map_query_to_anchor(\n   881\t        context=pre_context,\n   882\t        query=pre_query,\n   883\t        relation_to_root=OUTGOING_RELATION,\n   884\t    )\n   885\t    post_mapping = _map_query_to_anchor(\n   886\t        context=post_context,\n   887\t        query=post_query,\n   888\t        relation_to_root=INCOMING_RELATION,\n   889\t    )\n   890\t    return {\n   891\t        \"synapse_row_id\": _text_value(getattr(row, \"synapse_row_id\", \"\")),\n   892\t        \"source_row_number\": _int_value(getattr(row, \"source_row_number\", -1), default=-1),\n   893\t        \"synapse_id\": _text_value(getattr(row, \"synapse_id\", \"\")),\n   894\t        \"pre_root_id\": int(row.pre_root_id),\n   895\t        \"post_root_id\": int(row.post_root_id),\n   896\t        \"synapse_x\": _float_value(getattr(row, \"x\", np.nan)),\n   897\t        \"synapse_y\": _float_value(getattr(row, \"y\", np.nan)),\n   898\t        \"synapse_z\": _float_value(getattr(row, \"z\", np.nan)),\n   899\t        \"pre_source_x\": _float_value(getattr(row, \"pre_x\", np.nan)),\n   900\t        \"pre_source_y\": _float_value(getattr(row, \"pre_y\", np.nan)),\n   901\t        \"pre_source_z\": _float_value(getattr(row, \"pre_z\", np.nan)),\n   902\t        \"post_source_x\": _float_value(getattr(row, \"post_x\", np.nan)),\n   903\t        \"post_source_y\": _float_value(getattr(row, \"post_y\", np.nan)),\n   904\t        \"post_source_z\": _float_value(getattr(row, \"post_z\", np.nan)),\n   905\t        \"neuropil\": _text_value(getattr(row, \"neuropil\", \"\")),\n   906\t        \"nt_type\": _text_value(getattr(row, \"nt_type\", \"\")),\n   907\t        \"sign\": _text_value(getattr(row, \"sign\", \"\")),\n   908\t        \"confidence\": _float_value(getattr(row, \"confidence\", np.nan)),\n   909\t        \"weight\": _float_value(getattr(row, \"weight\", np.nan)),\n   910\t        \"source_file\": _text_value(getattr(row, \"source_file\", \"\")),\n   911\t        \"snapshot_version\": _text_value(getattr(row, \"snapshot_version\", \"\")),\n   912\t        \"materialization_version\": _text_value(getattr(row, \"materialization_version\", \"\")),\n   913\t        **{f\"pre_{key}\": value for key, value in pre_mapping.items()},\n   914\t        **{f\"post_{key}\": value for key, value in post_mapping.items()},\n   915\t    }\n   916\t\n   917\