write_bytes(b\"\")\n    80\t\n    81\t            mesh_fetch_calls = 0\n    82\t\n    83\t            def mesh_fetcher(_root_id: int) -> _MeshNeuron:\n    84\t                nonlocal mesh_fetch_calls\n    85\t                mesh_fetch_calls += 1\n    86\t                return _MeshNeuron(apex_z=2.0)\n    87\t\n    88\t            outputs = fetch_mesh_and_optional_skeleton(\n    89\t                root_id=101,\n    90\t                bundle_paths=bundle_paths,\n    91\t                flywire_dataset=\"public\",\n    92\t                fetch_skeletons=False,\n    93\t                set_default_dataset=lambda _dataset: None,\n    94\t                mesh_fetcher=mesh_fetcher,\n    95\t            )\n    96\t\n    97\t            self.assertEqual(mesh_fetch_calls, 1)\n    98\t            self.assertEqual(outputs[\"asset_statuses\"][RAW_MESH_KEY], ASSET_STATUS_READY)\n    99\t            self.assertEqual(outputs[\"asset_statuses\"][RAW_SKELETON_KEY], ASSET_STATUS_SKIPPED)\n   100\t            self.assertEqual(outputs[\"raw_asset_provenance\"][RAW_MESH_KEY][\"fetch_status\"], FETCH_STATUS_FETCHED)\n   101\t            self.assertEqual(outputs[\"raw_asset_provenance\"][RAW_MESH_KEY][\"fetch_reason\"], \"invalid_cache\")\n   102\t            self.assertEqual(outputs[\"raw_asset_provenance\"][RAW_MESH_KEY][\"cache_before\"][\"reason\"], \"empty_file\")\n   103\t            self.assertGreater(bundle_paths.raw_mesh_path.stat().st_size, 0)\n   104\t            self.assertEqual(outputs[\"raw_asset_provenance\"][RAW_SKELETON_KEY][\"fetch_status\"], FETCH_STATUS_SKIPPED)\n   105\t\n   106\t    def test_force_refetch_bypasses_healthy_cache(self) -> None:\n   107\t        with tempfile.TemporaryDirectory(dir=ROOT) as tmp_dir_str:\n   108\t            bundle_paths = _bundle_paths(Path(tmp_dir_str))\n   109\t            _write_valid_mesh(bundle_paths.raw_mesh_path)\n   110\t            _write_valid_swc(bundle_paths.raw_skeleton_path)\n   111\t\n   112\t            mesh_fetch_c