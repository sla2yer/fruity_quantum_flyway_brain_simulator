abs_error\": {\n   126\t                    \"warn\": 1.0e6,\n   127\t                    \"fail\": 1.0e9,\n   128\t                    \"comparison\": \"max\",\n   129\t                    \"blocking\": True,\n   130\t                },\n   131\t            }\n   132\t            output_dir = build_mixed_fidelity_inspection_output_dir(\n   133\t                mixed_fidelity_inspection_dir=fixture[\"tmp_dir\"] / \"inspection_reports\",\n   134\t                experiment_id=\"milestone_1_demo_motion_patch\",\n   135\t                arm_id=\"surface_wave_intact\",\n   136\t                reference_roots=[\n   137\t                    {\n   138\t                        \"root_id\": 303,\n   139\t                        \"reference_morphology_class\": \"surface_neuron\",\n   140\t                        \"reference_source\": \"policy_recommendation\",\n   141\t                    }\n   142\t                ],\n   143\t                thresholds=thresholds,\n   144\t            )\n   145\t\n   146\t            first = execute_mixed_fidelity_inspection_workflow(\n   147\t                manifest_path=fixture[\"manifest_path\"],\n   148\t                config_path=fixture[\"config_path\"],\n   149\t                schema_path=fixture[\"schema_path\"],\n   150\t                design_lock_path=fixture[\"design_lock_path\"],\n   151\t                arm_id=\"surface_wave_intact\",\n   152\t                thresholds=thresholds,\n   153\t                output_dir=output_dir,\n   154\t            )\n   155\t            report_path = Path(first[\"report_path\"])\n   156\t            summary_path = Path(first[\"summary_path\"])\n   157\t            report_bytes = report_path.read_bytes()\n   158\t            summary_bytes = summary_path.read_bytes()\n   159\t\n   160\t            second = execute_mixed_fidelity_inspection_workflow(\n   161\t                manifest_path=fixture[\"manifest_path\"],\n   162\t                config_path=fixture[\"config_path\"],\n   163\t                schema_path=fixture[\"schema_path\"],\n   164\t                design_lock_path=fixture[\"design_lock_path\"],\n   165\t                arm_id=\"surface_wave_intact\",\n   166\t                thresholds=thresholds,\n   167\t                output_dir=output_dir,\n   168\t            )\n   169\t\n   170\t            self.assertEqual(first, second)\n   171\t            self.assertEqual(first[\"output_dir\"], str(output_dir.resolve()))\n   172\t            self.assertEqual(Path(second[\"report_path\"]).read_bytes(), report_bytes)\n   173\t            self.assertEqual(Path(second[\"summary_path\"]).read_bytes(), summary_bytes)\n   174\t            self.assertEqual(\n   175\t                first[\"mixed_fidelity_plan\"][\"policy_hook\"][\"promotion_recommendation_root_ids\"],\n   176\t                [303],\n   177\t            )\n   178\t            self.assertEqual(first[\"reference_roots\"][0][\"reference_source\"], \"policy_recommendation\")\n   179\t            self.assertEqual(first[\"recommended_promotion_root_ids\"], [303])\n   180\t            self.assertEqual(first[\"review_root_ids\"], [303])\n   181\t            root_summary = first[\"root_summaries\"][0]\n   182\t            self.assertEqual(root_summary[\"root_id\"], 303)\n   183\t            self.assertEqual(root_summary[\"overall_status\"], \"review\")\n   184\t            self.assertTrue(root_summary[\"recommended_promotion\"])\n   185\t            self.assertEqual(\n   186\t                root_summary[\"reference_morphology_class\"],\n   187\t                SURFACE_NEURON_CLASS,\n   188\t            )\n   189\t            detail = json.loads(Path(root_summary[\"detail_path\"]).read_text(encoding=\"utf-8\"))\n   190\t            self.assertEqual(detail[\"policy_evaluation\"][\"matched_rule_ids\"], [\"promote_patch_dense_surrogate\"])\n   191\t            self.assertIn(\"root_mean_trace_mae\", detail[\"metrics\"])\n   192\t            self.assertEqual(detail[\"checks\"][\"root_mean_trace_mae\"][\"status\"], \"review\")\n   193\t\n   194\t\n   195\tdef _materialize_policy_fixture(tmp_dir: Path) -> dict[str, Path]:\n   196\t    manifest_path = _write_manifest_fixture(\n   197\t        tmp_dir,\n   198\t        surface_wave_fidelity_assignment={\n   199\t            \"default_morphology_class\": \"point_neuron\",\n   200\t            \"root_overrides\": [\n   201\t                {\"root_id\": 101, \"morphology_class\": \"surface_neuron\"},\n   202\t            ],\n   203\t        },\n   204\t    )\n   205\t    config_path = _write_simulation_fixture(\n   206\t        tmp_dir,\n   207\t        root_specs=[\n   208\t            {\n   209\t                \"root_id\": 101,\n   210\t                \"project_role\": \"surface_simulated\",\n   211\t                \"asset_profile\": \"surface\",\n   212\t            },\n   213\t            {\n   214\t                \"root_id\": 303,\n   215\t                \"project_role\": \"surface_simulated\",\n   216\t                \"asset_profile\": \"surface\",\n   217\t            },\n   218\t        ],\n   219\t    )\n   220\t    _rewrite_config_with_policy(config_path)\n   221\t    _rewrite_descriptor_fixture(\n   222\t        tmp_dir / \"out\" / \"processed_graphs\" / \"303_descriptors.json\",\n   223\t        root_id=303,\n   224\t        patch_count=4,\n   225\t    )\n   226\t\n   227\t    schema_path = ROOT / \"schemas\" / \"milestone_1_experiment_manifest.schema.json\"\n   228\t    design_lock_path = ROOT / \"config\" / \"milestone_1_design_lock.yaml\"\n   229\t    resolved_input = resolve_stimulus_input(\n   230\t        manifest_path=manifest_path,\n   231\t        schema_path=schema_path,\n   232\t        design_lock_path=design_lock_path,\n   233\t        processed_stimulus_dir=tmp_dir / \"out\" / \"stimuli\",\n   234\t    )\n   235\t    record_stimulus_bundle(resolved_input)\n   236\t    _remove_selected_edges_for_roots(\n   237\t        tmp_dir / \"out\" / \"asset_manifest.json\",\n   238\t        root_ids=[101, 303],\n   239\t    )\n   240\t    return {\n   241\t        \"tmp_dir\": tmp_dir,\n   242\t        \"manifest_path\": manifest_path,\n   243\t        \"config_path\": config_path,\n   244\t        \"schema_path\": schema_path,\n   245\t        \"design_lock_path\": design_lock_path,\n   246\t    }\n   247\t\n   248\t\n   249\tdef _rewrite_config_with_policy(config_path: Path) -> None:\n   250\t    payload = yaml.safe_load(config_path.read_text(encoding=\"utf-8\"))\n   251\t    surface_wave = payload[\"simulation\"][\"surface_wave\"]\n   252\t    surface_wave.setdefault(\"recovery\", {})[\"mode\"] = \"disabled\"\n   253\t    surface_wave.setdefault(\"nonlinearity\", {})[\"mode\"] = \"none\"\n   254\t    surface_wave.setdefault(\"anisotropy\", {})[\"mode\"] = \"isotropic\"\n   255\t    surface_wave.setdefault(\"branching\", {})[\"mode\"] = \"disabled\"\n   256\t    payload[\"simulation\"][\"mixed_fidelity\"] = {\n   257\t        \"assignment_policy\": {\n   258\t            \"promotion_mode\": \"recommend_from_policy\",\n   259\t            \"demotion_mode\": \"disabled\",\n   260\t            \"recommendation_rules\": [\n   261\t                {\n   262\t                    \"rule_id\": \"promote_patch_dense_surrogate\",\n   263\t                    \"minimum_morphology_class\": \"surface_neuron\",\n   264\t                    \"root_ids\": [303],\n   265\t                    \"topology_conditions\": [\"intact\"],\n   266\t                    \"arm_tags_any\": [\"surface_wave\"],\n   267\t                    \"descriptor_thresholds\": {\n   268\t                        \"patch_count\": {\n   269\t                            \"gte\": 2,\n   270\t                        }\n   271\t                    },\n   272\t                }\n   273\t            ],\n   274\t        }\n   275\t    }\n   276\t    config_path.write_text(\n   277\t        yaml.safe_dump(payload, sort_keys=False),\n   278\t        encoding=\"utf-8\",\n   279\t    )\n   280\t\n   281\t\n   282\tdef _rewrite_descriptor_fixture(\n   283\t    descriptor_path: Path,\n   284\t    *,\n   285\t    root_id: int,\n   286\t    patch_count: int,\n   287\t) -> None:\n   288\t    write_json(\n   289\t        {\n   290\t            \"root_id\": int(root_id),\n   291\t            \"descriptor_version\": \"geometry_descriptors.v1\",\n   292\t            \"patch_count\": int(patch_count),\n   293\t            \"n_vertices\": 6,\n   294\t            \"n_faces\": 4,\n   295\t            \"surface_graph_edge_count\": 8,\n   296\t            \"derived_relations\": {\n   297\t                \"simplified_to_raw_face_ratio\": 0.5,\n   298\t                \"simplified_to_raw_vertex_ratio\": 0.5,\n   299\t            },\n   300\t            \"representations\": {\n   301\t                \"coarse_patches\": {\n   302\t                    \"max_patch_vertex_fraction\": 0.4,\n   303\t                    \"singleton_patch_fraction\": 0.0,\n   304\t                },\n   305\t                \"skeleton\": {\n   306\t                    \"available\": True,\n   307\t                    \"node_count\": 3,\n   308\t                    \"segment_count\": 2,\n   309\t                    \"branch_point_count\": 0,\n   310\t                    \"leaf_count\": 2,\n   311\t                    \"total_cable_length\": 2.0,\n   312\t                },\n   313\t            },\n   314\t        },\n   315\t        descriptor_path,\n   316\t    )\n   317\t\n   318\t\n   319\tdef _remove_selected_edges_for_roots(\n   320\t    manifest_path: Path,\n","exit_code":0,"status":"completed"}}
