    end_ms = time_origin_ms + float(normalized_timebase[\"duration_ms\"])\n  1070\t    parameter_snapshot = _require_mapping(\n  1071\t        resolved_stimulus.get(\"parameter_snapshot\"),\n  1072\t        field_name=\"resolved_stimulus.parameter_snapshot\",\n  1073\t    )\n  1074\t    stimulus_onset_ms = float(parameter_snapshot.get(\"onset_ms\", time_origin_ms))\n  1075\t    stimulus_offset_ms = float(parameter_snapshot.get(\"offset_ms\", end_ms))\n  1076\t    clamped_onset_ms = max(time_origin_ms, min(end_ms, stimulus_onset_ms))\n  1077\t    clamped_offset_ms = max(clamped_onset_ms, min(end_ms, stimulus_offset_ms))\n  1078\t    defaults = {\n  1079\t        FULL_TIMEBASE_WINDOW_ID: {\n  1080\t            \"window_id\": FULL_TIMEBASE_WINDOW_ID,\n  1081\t            \"start_ms\": time_origin_ms,\n  1082\t            \"end_ms\": end_ms,\n  1083\t            \"description\": \"Entire declared simulator timebase window.\",\n  1084\t            \"source\": \"simulation.timebase\",\n  1085\t        },\n  1086\t        SHARED_RESPONSE_WINDOW_ID: {\n  1087\t            \"window_id\": SHARED_RESPONSE_WINDOW_ID,\n  1088\t            \"start_ms\": clamped_onset_ms,\n  1089\t            \"end_ms\": clamped_offset_ms,\n  1090\t            \"description\": \"Shared response window derived from the declared stimulus onset/offset.\",\n  1091\t            \"source\": \"resolved_stimulus.parameter_snapshot\",\n  1092\t        },\n  1093\t        TASK_DECODER_WINDOW_ID: {\n  1094\t            \"window_id\": TASK_DECODER_WINDOW_ID,\n  1095\t            \"start_ms\": clamped_onset_ms,\n  1096\t            \"end_ms\": clamped_offset_ms,\n  1097\t            \"description\": \"Task-decoder window derived from the declared stimulus onset/offset.\",\n  1098\t            \"source\": \"resolved_stimulus.parameter_snapshot\",\n  1099\t        },\n  1100\t        WAVE_DIAGNOSTIC_WINDOW_ID: {\n  1101\t            \"window_id\": WAVE_DIAGNOSTIC_WINDOW_ID,\n  1102\t            \"start_ms\": clamped_onset_ms,\n  1103\t            \"end_ms\": clamped_offset_ms,\n  1104\t            \"description\": \"Wave-diagnostic window derived from the declared stimulus onset/offset.\",\n  1105\t            \"source\": \"resolved_stimulus.parameter_snapshot\",\n  1106\t        },\n  1107\t    }\n  1108\t    windows: list[dict[str, Any]] = []\n  1109\t    for window_id in ANALYSIS_WINDOW_ORDER:\n  1110\t        merged = copy.deepcopy(defaults[window_id])\n  1111\t        if window_id in overrides:\n  1112\t            merged.update(copy.deepcopy(dict(overrides[window_id])))\n  1113\t            merged[\"window_id\"] = window_id\n  1114\t        if float(merged[\"end_ms\"]) <= float(merged[\"start_ms\"]):\n  1115\t            raise ValueError(\n  1116\t                f\"analysis window {window_id!r} must have end_ms greater than start_ms.\"\n  1117\t            )\n  1118\t        windows.append(merged)\n  1119\t    return windows\n  1120\t\n  1121\t\n  1122\tdef _resolve_analysis_condition_catalog(\n  1123\t    resolved_stimulus: Mapping[str, Any],\n  1124\t) -> tuple[list[dict[str, Any]], list[dict[str, Any]]]:\n  1125\t    parameter_snapshot = _require_mapping(\n  1126\t        resolved_stimulus.get(\"parameter_snapshot\"),\n  1127\t        field_name=\"resolved_stimulus.parameter_snapshot\",\n  1128\t    )\n  1129\t    conditions: list[dict[str, Any]] = []\n  1130\t    pairs: list[dict[str, Any]] = []\n  1131\t    direction_context = _resolve_direction_condition_context(parameter_snapshot)\n  1132\t    if direction_context is not None:\n  1133\t        conditions.extend(\n  1134\t            [\n  1135\t                {\n  1136\t                    \"condition_id\": PREFERRED_DIRECTION_CONDITION_ID,\n  1137\t                    \"display_name\": \"Preferred Direction\",\n  1138\t                    \"parameter_name\": direction_context[\"parameter_name\"],\n  1139\t                    \"value\": direction_context[\"preferred_value\"],\n  1140\t                },\n  1141\t                {\n  1142\t                    \"condition_id\": NULL_DIRECTION_CONDITION_ID,\n  1143\t                    \"display_name\": \"Null Direction\",\n  1144\t                    \"parameter_name\": direction_context[\"parameter_name\"],\n  1145\t                    \"value\": direction_context[\"null_value\"],\n  1146\t                },\n  1147\t            ]\n  1148\t        )\n  1149\t        pairs.append(\n  1150\t            {\n  1151\t                \"pair_id\": PREFERRED_VS_NULL_PAIR_ID,\n  1152\t                \"pair_kind\": \"direction_opposition\",\n  1153\t                \"left_condition_id\": PREFERRED_DIRECTION_CONDITION_ID,\n  1154\t                \"right_condition_id\": NULL_DIRECTION_CONDITION_ID,\n  1155\t                \"description\": \"Preferred-versus-null directional pairing derived from the declared stimulus direction parameter.\",\n  1156\t            }\n  1157\t        )\n  1158\t    if \"polarity\" in parameter_snapshot:\n  1159\t        conditions.extend(\n  1160\t            [\n  1161\t                {\n  1162\t                    \"condition_id\": ON_POLARITY_CONDITION_ID,\n  1163\t                    \"display_name\": \"ON Polarity\",\n  1164\t                    \"parameter_name\": \"polarity\",\n  1165\t                    \"value\": \"positive\",\n  1166\t                },\n  1167\t                {\n  1168\t                    \"condition_id\": OFF_POLARITY_CONDITION_ID,\n  1169\t                    \"display_name\": \"OFF Polarity\",\n  1170\t                    \"parameter_name\": \"polarity\",\n  1171\t                    \"value\": \"negative\",\n  1172\t                },\n  1173\t            ]\n  1174\t        )\n  1175\t        pairs.append(\n  1176\t            {\n  1177\t                \"pair_id\": ON_VS_OFF_PAIR_ID,\n  1178\t                \"pair_kind\": \"polarity_opposition\",\n  1179\t                \"left_condition_id\": ON_POLARITY_CONDITION_ID,\n  1180\t                \"right_condition_id\": OFF_POLARITY_CONDITION_ID,\n  1181\t                \"description\": \"ON-versus-OFF polarity pairing derived from the declared stimulus polarity semantics.\",\n  1182\t            }\n  1183\t        )\n  1184\t    return conditions, pairs\n  1185\t\n  1186\t\n  1187\tdef _resolve_direction_condition_context(\n  1188\t    parameter_snapshot: Mapping[str, Any],\n  1189\t) -> dict[str, Any] | None:\n  1190\t    if \"direction_deg\" in parameter_snapshot:\n  1191\t        preferred_value = float(parameter_snapshot[\"direction_deg\"])\n  1192\t        return {\n  1193\t            \"parameter_name\": \"direction_deg\",\n  1194\t            \"preferred_value\": preferred_value,\n  1195\t            \"null_value\": round((preferred_value + 180.0) % 360.0, 6),\n  1196\t        }\n  1197\t    if \"drift_direction_deg\" in parameter_snapshot:\n  1198\t        preferred_value = float(parameter_snapshot[\"drift_direction_deg\"])\n  1199\t        return {\n  1200\t            \"parameter_name\": \"drift_direction_deg\",\n  1201\t            \"preferred_value\": preferred_value,\n  1202\t            \"null_value\": round((preferred_value + 180.0) % 360.0, 6),\n  1203\t        }\n  1204\t    if \"rotation_direction\" in parameter_snapshot:\n  1205\t        preferred_value = _normalize_identifier(\n  1206\t            parameter_snapshot[\"rotation_direction\"],\n  1207\t            field_name=\"resolved_stimulus.parameter_snapshot.rotation_direction\",\n  1208\t        )\n  1209\t        if preferred_value == \"clockwise\":\n  1210\t            null_value = \"counterclockwise\"\n  1211\t        elif preferred_value == \"counterclockwise\":\n  1212\t            null_value = \"clockwise\"\n  1213\t        else:\n  1214\t            raise ValueError(\n  1215\t                \"resolved_stimulus.parameter_snapshot.rotation_direction must be \"\n  1216\t                \"'clockwise' or 'counterclockwise'.\"\n  1217\t            )\n  1218\t        return {\n  1219\t            \"parameter_name\": \"rotation_direction\",\n  1220\t            \"preferred_value\": preferred_value,\n  1221\t            \"null_value\": null_value,\n  1222\t        }\n  1223\t    return None\n  1224\t\n  1225\t\n  1226\tdef _resolve_active_shared_readouts(\n  1227\t    shared_readout_catalog: Sequence[Mapping[str, Any]],\n  1228\t    *,\n  1229\t    requested_readout_ids: Sequence[str],\n  1230\t) -> list[dict[str, Any]]:\n  1231\t    catalog_by_id = {\n  1232\t        str(item[\"readout_id\"]): copy.deepcopy(dict(item))\n  1233\t        for item in shared_readout_catalog\n  1234\t    }\n  1235\t    if requested_readout_ids:\n  1236\t        missing_readout_ids = sorted(\n  1237\t            set(requested_readout_ids) - set(catalog_by_id)\n  1238\t        )\n  1239\t        if missing_readout_ids:\n  1240\t            raise ValueError(\n  1241\t                \"analysis.active_readout_ids references readout ids that are not present \"\n  1242\t                f\"in simulation.shared_readout_catalog: {missing_readout_ids!r}.\"\n  1243\t            )\n  1244\t        resolved = [catalog_by_id[readout_id] for readout_id in requested_readout_ids]\n  1245\t    else:\n  1246\t        resolved = [\n  1247\t            copy.deepcopy(dict(item))\n  1248\t            for item in shared_readout_catalog\n  1249\t        ]\n  1250\t    if not resolved:\n  1251\t        raise ValueError(\n  1252\t            \"The readout-analysis plan requires at least one active shared readout.\"\n  1253\t        )\n  1254\t    resolved.sort(key=lambda item: item[\"readout_id\"])\n  1255\t    return resolved\n  1256\t\n  1257\t\n  1258\tdef _build_analysis_arm_pair_catalog(\n  1259\t    arm_plans: Sequence[Mapping[str, Any]],\n  1260\t) -> list[dict[str, Any]]:\n  1261\t    wave_by_topology: dict[str, Mapping[str, Any]] = {}\n  1262\t    baseline_by_family_and_topology: dict[tuple[str, str], Mapping[str, Any]] = {}\n  1263\t    topology_conditions: set[str] = set()\n  1264\t    for arm_plan in arm_plans:\n  1265\t        arm_reference = _require_mapping(\n  1266\t            arm_plan.get(\"arm_reference\"),\n  1267\t            field_name=\"arm_plan.arm_reference\",\n  1268\t        )\n  1269\t        topology_condition = _normalize_identifier(\n  1270\t            arm_plan.get(\"topology_condition\"),\n  1271\t            field_name=\"arm_plan.topology_condition\",\n  1272\t        )\n  1273\t        topology_conditions.add(topology_condition)\n  1274\t        model_mode = _normalize_identifier(\n  1275\t            arm_reference.get(\"model_mode\"),\n  1276\t            field_name=\"arm_plan.arm_reference.model_mode\",\n  1277\t        )\n  1278\t        if model_mode == SURFACE_WAVE_MODEL_MODE:\n  1279\t            wave_by_topology[topology_condition] = arm_plan\n  1280\t            continue\n  1281\t        baseline_family = arm_reference.get(\"baseline_family\")\n  1282\t        if baseline_family is None:\n  1283\t            continue\n  1284\t        normalized_family = _normalize_nonempty_string(\n  1285\t            baseline_family,\n  1286\t            field_name=\"arm_plan.arm_reference.baseline_family\",\n  1287\t        )\n  1288\t        baseline_by_family_and_topology[(normalized_family, topology_condition)] = arm_plan\n  1289\t\n  1290\t    records: list[dict[str, Any]] = []\n  1291\t    for baseline_family in (P0_BASELINE_FAMILY, P1_BASELINE_FAMILY):\n  1292\t        for topology_condition in sorted(topology_conditions, key=_topology_sort_key):\n  1293\t            baseline_arm = baseline_by_family_and_topology.get((baseline_family, topology_condition))\n  1294\t            wave_arm = wave_by_topology.get(topology_condition)\n  1295\t            if baseline_arm is None or wave_arm is None:\n  1296\t                continue\n  1297\t            baseline_arm_id = str(\n  1298\t                _require_mapping(\n  1299\t                    baseline_arm.get(\"arm_reference\"),\n  1300\t                    field_name=\"baseline_arm.arm_reference\",\n  1301\t                )[\"arm_id\"]\n  1302\t            )\n  1303\t            surface_wave_arm_id = str(\n  1304\t                _require_mapping(\n  1305\t                    wave_arm.get(\"arm_reference\"),\n  1306\t                    field_name=\"wave_arm.arm_reference\",\n  1307\t                )[\"arm_id\"]\n  1308\t            )\n  1309\t            records.append(\n  1310\t                {\n  1311\t                    \"group_id\": (\n  1312\t                        f\"matched_surface_wave_vs_{baseline_family.lower()}__\"\n  1313\t                        f\"{topology_condition}\"\n  1314\t                    ),\n  1315\t                    \"group_kind\": \"matched_surface_wave_vs_baseline\",\n  1316\t                    \"baseline_family\": baseline_family,\n  1317\t                    \"topology_condition\": topology_condition,\n  1318\t                    \"baseline_arm_id\": baseline_arm_id,\n  1319\t                    \"surface_wave_arm_id\": surface_wave_arm_id,\n  1320\t                    \"arm_ids\": [baseline_arm_id, surface_wave_arm_id],\n  1321\t                    \"comparison_semantics\": \"surface_wave_minus_baseline\",\n  1322\t                }\n  1323\t            )\n  1324\t    return records\n  1325\t\n  1326\t\n  1327\tdef _build_analysis_comparison_group_catalog(\n  1328\t    arm_pair_catalog: Sequence[Mapping[str, Any]],\n  1329\t) -> list[dict[str, Any]]:\n  1330\t    pairs_by_family_and_topology = {\n  1331\t        (\n  1332\t            str(item[\"baseline_family\"]),\n  1333\t            str(item[\"topology_condition\"]),\n  1334\t        ): item\n  1335\t        for item in arm_pair_catalog\n  1336\t    }\n  1337\t    records: list[dict[str, Any]] = []\n  1338\t    for baseline_family in (P0_BASELINE_FAMILY, P1_BASELINE_FAMILY):\n  1339\t        intact_pair = pairs_by_family_and_topology.get((baseline_family, \"intact\"))\n  1340\t        shuffled_pair = pairs_by_family_and_topology.get((baseline_family, \"shuffled\"))\n  1341\t        if intact_pair is not None and shuffled_pair is not None:\n  1342\t            records.append(\n  1343\t                {\n  1344\t                    \"group_id\": f\"geometry_ablation__{baseline_family.lower()}\",\n  1345\t                    \"group_kind\": \"geometry_ablation\",\n  1346\t                    \"baseline_family\": baseline_family,\n  1347\t                    \"component_group_ids\": [\n  1348\t                        str(intact_pair[\"group_id\"]),\n  1349\t                        str(shuffled_pair[\"group_id\"]),\n  1350\t                    ],\n  1351\t                    \"comparison_semantics\": \"intact_gap_minus_shuffled_gap\",\n  1352\t                }\n  1353\t            )\n  1354\t    topologies = {\n  1355\t        str(item[\"topology_condition\"])\n  1356\t        for item in arm_pair_catalog\n  1357\t    }\n  1358\t    for topology_condition in sorted(topologies, key=_topology_sort_key):\n  1359\t        p0_pair = pairs_by_family_and_topology.get((P0_BASELINE_FAMILY, topology_condition))\n  1360\t        p1_pair = pairs_by_family_and_topology.get((P1_BASELINE_FAMILY, topology_condition))\n  1361\t        if p0_pair is not None and p1_pair is not None:\n  1362\t            records.append(\n  1363\t                {\n  1364\t                    \"group_id\": f\"baseline_strength_challenge__{topology_condition}\",\n  1365\t                    \"group_kind\": \"baseline_strength_challenge\",\n  1366\t                    \"topology_condition\": topology_condition,\n  1367\t                    \"component_group_ids\": [\n  1368\t                        str(p0_pair[\"group_id\"]),\n  1369\t                        str(p1_pair[\"group_id\"]),\n  1370\t                    ],\n  1371\t                    \"comparison_semantics\": \"p1_survival_against_canonical_p0_reference\",\n  1372\t                }\n  1373\t            )\n  1374\t    return records\n  1375\t\n  1376\t\n  1377\tdef _build_seed_aggregation_rules(seed_sweep: Sequence[int]) -> list[dict[str, Any]]:\n  1378\t    rules = [\n  1379\t        {\n  1380\t            \"rule_id\": PER_RUN_SINGLE_SEED_RULE_ID,\n  1381\t            \"aggregation_scope\": \"single_run\",\n  1382\t            \"summary_statistics\": [\"identity\"],\n  1383\t            \"seed_count\": 1,\n  1384\t            \"seed_ordering\": DEFAULT_SEED_SWEEP_ORDERING,\n  1385\t        }\n  1386\t    ]\n  1387\t    if seed_sweep:\n  1388\t        rules.append(\n  1389\t            {\n  1390\t                \"rule_id\": MANIFEST_SEED_SWEEP_ROLLUP_RULE_ID,\n  1391\t                \"aggregation_scope\": \"arm_metric_across_seed_sweep\",\n  1392\t                \"seed_sweep\": [int(seed) for seed in seed_sweep],\n  1393\t                \"seed_count\": len(seed_sweep),\n  1394\t                \"summary_statistics\": [\"mean\", \"median\", \"min\", \"max\", \"std\"],\n  1395\t                \"seed_ordering\": DEFAULT_SEED_SWEEP_ORDERING,\n  1396\t            }\n  1397\t        )\n  1398\t    return rules\n  1399\t\n  1400\t\n  1401\tdef _build_experiment_output_targets(\n  1402\t    *,\n  1403\t    manifest_payload: Mapping[str, Any],\n  1404\t    output_targets: Mapping[str, Any],\n  1405\t    requested_output_ids: Sequence[str],\n  1406\t    configured_output_targets: Sequence[Mapping[str, Any]],\n  1407\t    project_root: Path,\n  1408\t    comparison_group_catalog: Sequence[Mapping[str, Any]],\n  1409\t    arm_pair_catalog: Sequence[Mapping[str, Any]],\n  1410\t    analysis_contract: Mapping[str, Any],\n  1411\t) -> list[dict[str, Any]]:\n  1412\t    del project_root\n  1413\t    del comparison_group_catalog\n  1414\t    del arm_pair_catalog\n  1415\t    declared_targets: dict[str, dict[str, Any]] = {}\n  1416\t    for plot in output_targets.get(\"plots\", []):\n  1417\t        declared_targets[str(plot[\"id\"])] = {\n  1418\t            \"path\": str(plot[\"path\"]),\n  1419\t            \"declared_output_kind\": \"plot\",\n  1420\t        }\n  1421\t    for state in output_targets.get(\"ui_states\", []):\n  1422\t        declared_targets[str(state[\"id\"])] = {\n  1423\t            \"path\": str(state[\"path\"]),\n  1424\t            \"declared_output_kind\": \"ui_state\",\n  1425\t        }\n  1426\t\n  1427\t    records: list[dict[str, Any]] = []\n  1428\t    seen_analysis_output_ids: set[str] = set()\n  1429\t    for output_id in manifest_payload.get(\"must_show_outputs\", []):\n  1430\t        normalized_output_id = _normalize_identifier(\n  1431\t            output_id,\n  1432\t            field_name=\"manifest.must_show_outputs\",\n  1433\t        )\n  1434\t        target = declared_targets.get(normalized_output_id)\n  1435\t        if target is None:\n  1436\t            raise ValueError(\n  1437\t                f\"Manifest must_show_output {normalized_output_id!r} is missing from the resolved output bundle.\"\n  1438\t            )\n  1439\t        analysis_output_id = MANIFEST_TO_ANALYSIS_OUTPUT_ID.get(normalized_output_id)\n  1440\t        record = {\n  1441\t            \"output_id\": normalized_output_id,\n  1442\t            \"analysis_output_id\": analysis_output_id,\n  1443\t            \"path\": target[\"path\"],\n  1444\t            \"source\": \"manifest.output_bundle\",\n  1445\t            \"declared_output_kind\": target[\"declared_output_kind\"],\n  1446\t        }\n  1447\t        if analysis_output_id is not None:\n  1448\t            output_definition = get_experiment_comparison_output_definition(\n  1449\t                analysis_output_id,\n  1450\t                record=analysis_contract,\n  1451\t            )\n  1452\t            record[\"output_kind\"] = output_definition[\"output_kind\"]\n  1453\t            record[\"scope_rule\"] = output_definition[\"scope_rule\"]\n  1454\t            record[\"required_metric_ids\"] = list(output_definition[\"required_metric_ids\"])\n  1455\t            record[\"required_source_artifact_classes\"] = list(\n  1456\t                output_definiti