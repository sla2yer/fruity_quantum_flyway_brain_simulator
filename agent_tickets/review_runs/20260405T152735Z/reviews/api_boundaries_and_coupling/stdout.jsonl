   return copy.deepcopy(dict(explicit_analysis))\n   664\t    if not experiment_id:\n   665\t        raise ValueError(\n   666\t            \"Dashboard session planning requires experiment_id when analysis_bundle metadata \"\n   667\t            \"is not provided explicitly.\"\n   668\t        )\n   669\t    analysis_root = (\n   670\t        processed_simulator_results_dir\n   671\t        / DEFAULT_ANALYSIS_DIRECTORY_NAME\n   672\t        / experiment_id\n   673\t    ).resolve()\n   674\t    candidate_paths = sorted(analysis_root.glob(\"*/experiment_analysis_bundle.json\"))\n   675\t    if not candidate_paths:\n   676\t        raise ValueError(\n   677\t            f\"Dashboard session planning requires a local experiment_analysis_bundle for \"\n   678\t            f\"experiment_id {experiment_id!r} under {analysis_root}.\"\n   679\t        )\n   680\t    candidates = [\n   681\t        load_experiment_analysis_bundle_metadata(path)\n   682\t        for path in candidate_paths\n   683\t    ]\n   684\t    if manifest_path is not None:\n   685\t        requested_manifest_path = str(Path(manifest_path).resolve())\n   686\t        candidates = [\n   687\t            metadata\n   688\t            for metadata in candidates\n   689\t            if str(metadata[\"manifest_reference\"][\"manifest_path\"]) == requested_manifest_path\n   690\t        ]\n   691\t    if not candidates:\n   692\t        raise ValueError(\n   693\t            \"Dashboard session planning could not find an experiment_analysis_bundle that \"\n   694\t            f\"matches manifest_path {Path(manifest_path).resolve()}.\"\n   695\t        )\n   696\t    if len(candidates) > 1:\n   697\t        raise ValueError(\n   698\t            \"Experiment-driven dashboard planning found multiple local experiment_analysis_bundle \"\n   699\t            f\"candidates for experiment_id {experiment_id!r}. Pass analysis_bundle_metadata_path \"\n   700\t            \"or manifest_path explicitly to disambiguate.\"\