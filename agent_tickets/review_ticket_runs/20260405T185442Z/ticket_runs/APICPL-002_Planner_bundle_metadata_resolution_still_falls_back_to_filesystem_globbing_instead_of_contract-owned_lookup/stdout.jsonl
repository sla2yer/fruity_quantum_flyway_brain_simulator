tr, Any],\n) -> dict[str, Any]:\n    required_fields = (\n        \"plan_version\",\n        \"contract_reference\",\n        \"active_metric_ids\",\n        \"active_output_ids\",\n        \"active_null_test_ids\",\n        \"active_shared_readouts\",\n        \"manifest_metric_requests\",\n    )\n    missing_fields = [field for field in required_fields if field not in analysis_plan]\n    if missing_fields:\n        raise ValueError(\n","exit_code":0,"status":"completed"}}
