ht\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nDEFAULT_DELAY_REPRESENTATION = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"nonnegative_delay_ms_per_synapse_or_delay_bin\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nDEFAULT_AGGREGATION_RULE = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sum_over_synapses_preserving_sign_and_delay_bins\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nDEFAULT_MISSING_GEOMETRY_POLICY = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"fallback_or_blocked_with_explicit_reason\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nCOUPLING_ASSEMBLY_CONFIG_VERSION = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"coupling_assembly.v1\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nCOUPLING_DELAY_MODEL_CONFIG_VERSION = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"coupling_delay_model.v1\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nSEPARABLE_RANK_ONE_CLOUD_KERNEL = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"separable_rank_one_cloud\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nPOINT_IMPULSE_KERNEL = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"point_impulse\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nSUPPORTED_COUPLING_KERNEL_FAMILIES = (\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    SEPARABLE_RANK_ONE_CLOUD_KERNEL,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    POINT_IMPULSE_KERNEL,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nDEFAULT_COUPLING_KERNEL_FAMILY = SEPARABLE_RANK_ONE_CLOUD_KERNEL\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nWEIGHT_SIGN_ONLY_REPRESENTATION = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"weight_sign_only\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nSUPPORTED_SIGN_REPRESENTATIONS = (\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    DEFAULT_SIGN_REPRESENTATION,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    WEIGHT_SIGN_ONLY_REPRESENTATION,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nCONSTANT_ZERO_DELAY_MODEL = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"constant_zero_ms\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nEUCLIDEAN_ANCHOR_DISTANCE_DELAY_MODEL = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"euclidean_anchor_distance_over_velocity\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nSUPPORTED_DELAY_MODELS = (\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    CONSTANT_ZERO_DELAY_MODEL,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    EUCLIDEAN_ANCHOR_DISTANCE_DELAY_MODEL,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nDEFAULT_DELAY_MODEL = CONSTANT_ZERO_DELAY_MODEL\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nCOLLAPSE_DELAY_WITH_WEIGHTED_MEAN_AGGREGATION = (\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sum_over_synapses_preserving_sign_with_weighted_mean_delay\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nSUPPORTED_AGGREGATION_RULES = (\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    DEFAULT_AGGREGATION_RULE,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    COLLAPSE_DELAY_WITH_WEIGHTED_MEAN_AGGREGATION,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nSUM_TO_ONE_PER_COMPONENT_NORMALIZATION = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sum_to_one_per_component\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nNO_CLOUD_NORMALIZATION = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"none\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nSUPPORTED_CLOUD_NORMALIZATIONS = (\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    SUM_TO_ONE_PER_COMPONENT_NORMALIZATION,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    NO_CLOUD_NORMALIZATION,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nDEFAULT_SOURCE_CLOUD_NORMALIZATION = SUM_TO_ONE_PER_COMPONENT_NORMALIZATION\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nDEFAULT_TARGET_CLOUD_NORMALIZATION = SUM_TO_ONE_PER_COMPONENT_NORMALIZATION\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nLOCAL_SYNAPSE_REGISTRY_KEY = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"local_synapse_registry\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nINCOMING_ANCHOR_MAP_KEY = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"incoming_anchor_map\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nOUTGOING_ANCHOR_MAP_KEY = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"outgoing_anchor_map\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nCOUPLING_INDEX_KEY = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"coupling_index\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nREQUIRED_COUPLING_ASSET_KEYS = (\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    LOCAL_SYNAPSE_REGISTRY_KEY,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    INCOMING_ANCHOR_MAP_KEY,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    OUTGOING_ANCHOR_MAP_KEY,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    COUPLING_INDEX_KEY