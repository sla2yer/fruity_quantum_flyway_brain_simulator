VERSION,\\n   742\\t        \\\"_coupling_contract\\\": build_coupling_contract_manifest_metadata(\\n   743\\t            coupling_bundle_metadata=coupling_contract_seed,\\n   744\\t            processed_coupling_dir=processed_coupling_dir,\\n   745\\t        ),\\n   746\\t    }\\n   747\\t    for root_id, record in bundle_records.items():\\n   748\\t        manifest[str(int(root_id))] = copy.deepcopy(record)\\n   749\\t    return manifest\\n   750\\t\\n   751\\t\\n   752\\tdef write_geometry_manifest(\\n   753\\t    *,\\n   754\\t    manifest_path: str | Path,\\n   755\\t    bundle_records: dict[int | str, dict[str, Any]],\\n   756\\t    dataset_name: str,\\n   757\\t    materialization_version: int | str | None,\\n   758\\t    meshing_config_snapshot: dict[str, Any],\\n   759\\t    processed_coupling_dir: str | Path | None = None,\\n   760\\t) -> Path:\\n   761\\t    manifest = build_geometry_manifest(\\n   762\\t        bundle_records=bundle_records,\\n   763\\t        dataset_name=dataset_name,\\n   764\\t        materialization_version=materialization_version,\\n   765\\t        meshing_config_snapshot=meshing_config_snapshot,\\n   766\\t        processed_coupling_dir=processed_coupling_dir,\\n   767\\t    )\\n   768\\t    return write_json(manifest, manifest_path)\\n   769\\t\\n   770\\t\\n   771\\tdef load_geometry_manifest(manifest_path: str | Path) -> dict[str, Any]:\\n   772\\t    path = Path(manifest_path)\\n   773\\t    if not path.exists():\\n   774\\t        return {}\\n   775\\t    with path.open(\\\"r\\\", encoding=\\\"utf-8\\\") as handle:\\n   776\\t        payload = json.load(handle)\\n   777\\t    if not isinstance(payload, dict):\\n   778\\t        raise ValueError(f\\\"Geometry manifest at {path} is not a mapping.\\\")\\n   779\\t    return payload\\n   780\\t\\n\",\"exit_code\":0,\"status\":\"completed\"}}\nagent_tickets/runs/20260321T222203Z/FW-M7-001_Freeze_a_versioned_synapse_asset_contract_and_inter-neuron_coupling_design_note/stdout.jsonl