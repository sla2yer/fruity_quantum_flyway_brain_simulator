ts/test_milestone6_readiness.py:83:                processed_mesh_dir=bundle_paths.simplified_mesh_path.parent,\ntests/test_milestone6_readiness.py:213:                processed_mesh_dir=bundle_paths_ready.simplified_mesh_path.parent,\nsrc/flywire_wave/operator_qa.py:342:            \"processed_mesh_path\": str(bundle_paths.simplified_mesh_path),\nsrc/flywire_wave/operator_qa.py:513:            \"processed_mesh_path\": str(bundle_paths.simplified_mesh_path),\nsrc/flywire_wave/mesh_pipeline.py:780:        processed_mesh_path=bundle_paths.simplified_mesh_path,\nsrc/flywire_wave/geometry_contract.py:702:        \"processed_mesh_path\": str(bundle_paths.simplified_mesh_path),\n","exit_code":0,"status":"completed"}}
