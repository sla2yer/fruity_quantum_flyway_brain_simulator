_count = int(csr.shape[0])\\n   442\\t    all_indices: list[int] = []\\n   443\\t    all_distances: list[float] = []\\n   444\\t    all_hops: list[int] = []\\n   445\\t    indptr = np.zeros(vertex_count + 1, dtype=np.int32)\\n   446\\t    row_nnz_max = 0\\n   447\\t\\n   448\\t    for source in range(vertex_count):\\n   449\\t        indices, distances, hops = _limited_dijkstra_row(\\n   450\\t            csr,\\n   451\\t            source=source,\\n   452\\t            max_hops=max_hops,\\n   453\\t            max_vertices=max_vertices_per_seed,\\n   454\\t        )\\n   455\\t        all_indices.extend(indices)\\n   456\\t        all_distances.extend(distances)\\n   457\\t        all_hops.extend(hops)\\n   458\\t        row_nnz_max = max(row_nnz_max, len(indices))\\n   459\\t        indptr[source + 1] = len(all_indices)\\n   460\\t\\n   461\\t    return {\\n   462\\t        \\\"indices\\\": np.asarray(all_indices, dtype=np.int32),\\n   463\\t        \\\"indptr\\\": indptr,\\n   464\\t        \\\"distances\\\": np.asarray(all_distances, dtype=np.float64),\\n   465\\t        \\\"hops\\\": np.asarray(all_hops, dtype=np.int32),\\n   466\\t        \\\"row_nnz_max\\\": row_nnz_max,\\n   467\\t    }\\n   468\\t\\n   469\\t\\n   470\\tdef _limited_dijkstra_row(\\n   471\\t    csr: sp.csr_matrix,\\n   472\\t    *,\\n   473\\t    source: int,\\n   474\\t    max_hops: int,\\n   475\\t    max_vertices: int,\\n   476\\t) -> tuple[list[int], list[float], list[int]]:\\n   477\\t    heap: list[tuple[float, int, int]] = [(0.0, 0, int(source))]\\n   478\\t    finalized: set[int] = set()\\n   479\\t    indices: list[int] = []\\n   480\\t    distances: list[float] = []\\n   481\\t    hops_list: list[int] = []\\n   482\\t\\n   483\\t    while heap and len(indices) < max_vertices:\\n   484\\t        distance, hops, vertex = heapq.heappop(heap)\\n   485\\t        if vertex in finalized:\\n   486\\t            continue\\n   487\\t        finalized.add(vertex)\\n   488\\t        indices.a