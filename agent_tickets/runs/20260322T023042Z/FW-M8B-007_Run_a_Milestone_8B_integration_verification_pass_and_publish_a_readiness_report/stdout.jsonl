        root_id=int(bundle_paths.root_id),\\nsrc/flywire_wave/geometry_contract.py:700:        \\\"raw_mesh_path\\\": str(bundle_paths.raw_mesh_path),\\nsrc/flywire_wave/geometry_contract.py:701:        \\\"raw_skeleton_path\\\": str(bundle_paths.raw_skeleton_path),\\nsrc/flywire_wave/geometry_contract.py:702:        \\\"processed_mesh_path\\\": str(bundle_paths.simplified_mesh_path),\\nsrc/flywire_wave/geometry_contract.py:703:        \\\"processed_graph_path\\\": str(bundle_paths.surface_graph_path),\\nsrc/flywire_wave/geometry_contract.py:704:        \\\"surface_graph_path\\\": str(bundle_paths.surface_graph_path),\\nsrc/flywire_wave/geometry_contract.py:705:        \\\"patch_graph_path\\\": str(bundle_paths.patch_graph_path),\\nsrc/flywire_wave/geometry_contract.py:706:        \\\"transfer_operator_path\\\": str(bundle_paths.transfer_operator_path),\\nsrc/flywire_wave/geometry_contract.py:707:        \\\"operator_metadata_path\\\": str(bundle_paths.operator_metadata_path),\\nsrc/flywire_wave/geometry_contract.py:708:        \\\"descriptor_sidecar_path\\\": str(bundle_paths.descriptor_sidecar_path),\\nsrc/flywire_wave/geometry_contract.py:709:        \\\"qa_sidecar_path\\\": str(bundle_paths.qa_sidecar_path),\\nsrc/flywire_wave/geometry_contract.py:710:        \\\"meta_json_path\\\": str(bundle_paths.legacy_meta_json_path),\\nsrc/flywire_wave/geometry_contract.py:716:    if bundle_metadata:\\nsrc/flywire_wave/geometry_contract.py:717:        record[\\\"bundle_metadata\\\"] = copy.deepcopy(bundle_metadata)\\nsrc/flywire_wave/geometry_contract.py:719:        record[\\\"raw_asset_provenance\\\"] = copy.deepcopy(raw_asset_provenance)\\nsrc/flywire_wave/geometry_contract.py:720:    return record\\nsrc/flywire_wave/geometry_contract.py:725:    bundle_records: dict[int | str, dict[str, Any]],\\nsrc/flywire_wave/geometry_contract.py:732:    coupling_contract_seed = _first_coupling_bundle_metadata(bundle_records)\\nsrc/flywire_wave/geometry_contract.py:741:        \\\"_op