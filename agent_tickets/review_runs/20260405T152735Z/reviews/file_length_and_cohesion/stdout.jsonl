query_reason = None if selected_context_root_ids else \"No context roots fit the declared reduction budget.\"\n   393\t\n   394\t    highlight_root_ids = {\n   395\t        root_id\n   396\t        for item in highlight_path_records\n   397\t        for root_id in item[\"node_root_ids\"]\n   398\t    }\n   399\t    highlight_edge_keys = {\n   400\t        tuple(item)\n   401\t        for record in highlight_path_records\n   402\t        for item in record[\"edge_key_pairs\"]\n   403\t    }\n   404\t\n   405\t    base_node_records = _build_base_node_records(\n   406\t        active_root_ids=active_root_ids,\n   407\t        active_root_set=active_root_set,\n   408\t        selected_context_root_ids=selected_context_root_ids,\n   409\t        active_anchor_records=active_anchor_records,\n   410\t        metadata_by_root=metadata_by_root,\n   411\t        query_family=query_family,\n   412\t        enabled_overlays=enabled_overlays,\n   413\t        enabled_facets=enabled_facets,\n   414\t        directional_membership=directional_membership,\n   415\t        path_registry=path_registry,\n   416\t        highlight_root_ids=highlight_root_ids,\n   417\t    )\n   418\t    highlight_node_records = _build_highlight_node_records(\n   419\t        highlight_root_ids=highlight_root_ids,\n   420\t        active_root_set=active_root_set,\n   421\t        metadata_by_root=metadata_by_root,\n   422\t        enabled_overlays=enabled_overlays,\n   423\t        enabled_facets=enabled_facets,\n   424\t    )\n   425\t    base_edge_records = _build_base_edge_records(\n   426\t        selected_biological_edges=selected_biological_edges,\n   427\t        active_root_set=active_root_set,\n   428\t        query_family=query_family,\n   429\t        enabled_overlays=enabled_overlays,\n   430\t        directional_membership=directional_membership,\n   431\t        highlight_edge_keys=highlight_edge_keys,\n   432\t    )\n   433\t    highlight_edge_records = _build_highlight_edge_records(\n   434\t        selected_biological_edges=selected_biological_edges,\n   435\t        highlight_edge_keys=highlight_edge_keys,\n   436\t    )\n   437\t    downstream_module_records = _build_downstream_module_records(\n   438\t        plan=normalized_plan,\n   439\t        metadata_by_root=metadata_by_root,\n   440\t        selected_context_root_ids=selected_context_root_ids,\n   441\t        directional_membership=directional_membership,\n   442\t        path_registry=path_registry,\n   443\t        reduction_controls=resolved_reduction_controls,\n   444\t        query_profile_id=query_profile_id,\n   445\t        query_family=query_family,\n   446\t        enabled_overlays=enabled_overlays,\n   447\t        enabled_facets=enabled_facets,\n   448\t        highlight_path_records=highlight_path_records,\n   449\t    )\n   450\t\n   451\t    overview_node_records = _sort_node_records(base_node_records + highlight_node_records)\n   452\t    overview_edge_records = _sort_edge_records(base_edge_records + highlight_edge_records)\n   453\t    overview_graph = _build_graph_view(\n   454\t        view_id=\"overview_graph\",\n   455\t        display_name=\"Overview Graph\",\n   456\t        description=\"Budgeted Milestone 17 neighborhood around the active subset.\",\n   457\t        node_records=overview_node_records,\n   458\t        edge_records=overview_edge_records,\n   459\t        downstream_module_records=downstream_module_records,\n   460\t        highlight_path_records=highlight_path_records,\n   461\t    )\n   462\t    representative_context = {\n   463\t        \"node_records\": copy.deepcopy(_sort_node_records(base_node_records)),\n   464\t        \"edge_records\": copy.deepcopy(overview_edge_records),\n   465\t        \"downstream_module_records\": copy.deepcopy(downstream_module_records),\n   466\t    }\n   467\t    focused_subgraph = _build_focused_subgraph(\n   468\t        base_node_records=base_node_records,\n   469\t        highlight_node_records=highlight_node_records,\n   470\t        base_edge_records=base_edge_records,\n   471\t        highlight_edge_records=highlight_edge_records,\n   472\t        downstream_module_records=downstream_module_records,\n   473\t        focused_path_records=focused_path_records,\n   474\t    )\n   475\t    overview_graph = _augment_graph_view_with_explanation_layer(\n   476\t        graph_view=overview_graph,\n   477\t        query_profile_id=query_profile_id,\n   478\t        query_family=query_family,\n   479\t        active_root_ids=active_root_ids,\n   480\t        enabled_overlays=enabled_overlays,\n   481\t        enabled_facets=enabled_facets,\n   482\t        metadata_by_root=metadata_by_root,\n   483\t        highlight_path_records=highlight_path_records,\n   484\t    )\n   485\t    focused_subgraph = _augment_graph_view_with_explanation_layer(\n   486\t        graph_view=focused_subgraph,\n   487\t        query_profile_id=query_profile_id,\n   488\t        query_family=query_family,\n   489\t        active_root_ids=active_root_ids,\n   490\t        enabled_overlays=enabled_overlays,\n   491\t        enabled_facets=enabled_facets,\n   492\t        metadata_by_root=metadata_by_root,\n   493\t        highlight_path_records=highlight_path_records,\n   494\t    )\n   495\t    summary = {\n   496\t        \"status\": query_status,\n   497\t        \"reason\": query_reason,\n   498\t        \"active_root_count\": len(active_root_ids),\n   499\t        \"context_root_count\": len(selected_context_root_ids),\n   500\t        \"overview_node_record_count\": len(overview_node_records),\n   501\t        \"overview_edge_record_count\": len(overview_edge_records),\n   502\t        \"highlight_path_count\": len(highlight_path_records),\n   503\t        \"downstream_module_count\": len(downstream_module_records),\n   504\t        \"synapse_row_count_considered\": int(len(synapse_df)),\n   505\t        \"biological_edge_count_considered\": int(len(aggregated_edges)),\n   506\t        \"context_candidate_count\": int(\n   507\t            0 if query_family == LOCAL_SHELL_QUERY_FAMILY else len(path_registry)\n   508\t        ),\n   509\t        \"active_internal_edge_count\": len(active_internal_edges),\n   510\t    }\n   511\t    return {\n   512\t        \"format_version\": WHOLE_BRAIN_CONTEXT_QUERY_RESULT_VERSION,\n   513\t        \"query_profile_id\": query_profile_id,\n   514\t        \"query_family\": query_family,\n   515\t        \"reduction_controls\": resolved_reduction_controls,\n   516\t        \"input_sources\": {\n   517\t            \"synapse_registry\": synapse_source,\n   518\t            \"node_metadata_registry\": node_metadata_source,\n   519\t        },\n   520\t        \"execution_summary\": summary,\n   521\t        \"representative_context\": representative_context,\n   522\t        \"overview_graph\": overview_graph,\n   523\t        \"focused_subgraph\": focused_subgraph,\n   524\t        \"pathway_highlights\": highlight_path_records,\n   525\t    }\n   526\t\n   527\t\n   528\tdef _resolve_synapse_registry(\n   529\t    plan: Mapping[str, Any],\n   530\t    *,\n   531\t    query_family: str,\n   532\t    override: str | Path | pd.DataFrame | Sequence[Mapping[str, Any]] | None,\n   533\t    reduction_controls: Mapping[str, Any],\n   534\t) -> tuple[pd.DataFrame, dict[str, Any]]:\n   535\t    source = override\n   536\t    source_path = None\n   537\t    if source is None:\n   538\t        registry_sources = plan.get(\"registry_sources\")\n   539\t        if isinstance(registry_sources, Mapping):\n   540\t            synapse_source = registry_sources.get(\"synapse_registry\")\n   541\t            if isinstance(synapse_source, Mapping):\n   542\t                source_path = synapse_source.get(\"path\")\n   543\t    if source is None and source_path is not None:\n   544\t        source = source_path\n   545\t    if source is None:\n   546\t        if query_family == LOCAL_SHELL_QUERY_FAMILY:\n   547\t            return (\n   548\t                pd.DataFrame(columns=[\"pre_root_id\", \"post_root_id\"]),\n   549\t                {\n   550\t                    \"availability\": \"absent\",\n   551\t                    \"path\": None,\n   552\t                    \"reason\": \"local_shell_query_does_not_require_synapse_registry\",\n   553\t                },\n   554\t            )\n   555\t        raise WholeBrainContextQueryError(\n   556\t            \"Whole-brain context query execution requires a local synapse registry for \"\n   557\t            f\"query_family {query_family!r}.\"\n   558\t        )\n   559\t    frame = _coerce_synapse_registry_frame(source)\n   560\t    filtered = frame.copy()\n   561\t    if reduction_controls[\"allowed_neuropils\"]:\n   562\t        neuropil_allow = {str(item).upper() for item in reduction_controls[\"allowed_neuropils\"]}\n   563\t        neuropil_series = (\n   564\t            filtered[\"neuropil\"].fillna(\"\").astype(\"string\").str.upper()\n   565\t            if \"neuropil\" in filtered.columns\n   566\t            else pd.Series(\"\", index=filtered.index, dtype=\"string\")\n   567\t        )\n   568\t        filtered = filtered.loc[neuropil_series.isin(neuropil_allow)].copy()\n   569\t    return (\n   570\t        filtered,\n   571\t        {\n   572\t            \"availability\": \"available\",\n   573\t            \"path\": None if not isinstance(source, (str, Path)) else str(Path(source).resolve()),\n   574\t            \"row_count\": int(len(filtered)),\n   575\t            \"filtered_by_neuropils\": list(reduction_controls[\"allowed_neuropils\"]),\n   576\t        },\n   577\t    )\n   578\t\n   579\t\n   580\tdef _resolve_node_metadata_registry(\n   581\t    plan: Mapping[str, Any],\n   582\t    *,\n   583\t    override: str | Path | pd.DataFrame | Sequence[Mapping[str, Any]] | None,\n   584\t) -> tuple[pd.DataFrame | None, dict[str, Any]]:\n   585\t    source = override\n   586\t    if source is not None:\n   587\t        frame = _coerce_node_metadata_frame(source)\n   588\t        return (\n   589\t            frame,\n   590\t            {\n   591\t                \"availability\": \"available\",\n   592\t                \"path\": None if not isinstance(source, (str, Path)) else str(Path(source).resolve()),\n   593\t                \"row_count\": int(len(frame)),\n   594\t                \"source_kind\": \"override\",\n   595\t            },\n   596\t        )\n   597\t    config_path = plan.get(\"config_path\")\n   598\t    if config_path is None:\n   599\t        return (None, {\"availability\": \"absent\", \"path\": None, \"source_kind\": \"none\"})\n   600\t    try:\n   601\t        cfg = load_config(config_path)\n   602\t    except Exception:\n   603\t        return (None, {\"availability\": \"absent\", \"path\": None, \"source_kind\": \"none\"})\n   604\t    paths_cfg = _require_mapping(cfg.get(\"paths\", {}), field_name=\"config.paths\")\n   605\t    neuron_registry_path = _existing_path(paths_cfg.get(\"neuron_registry_csv\"))\n   606\t    if neuron_registry_path is not None:\n   607\t        frame = _coerce_node_metadata_frame(neuron_registry_path)\n   608\t        return (\n   609\t            frame,\n   610\t            {\n   611\t                \"availability\": \"available\",\n   612\t                \"path\": str(neuron_registry_path.resolve()),\n   613\t                \"row_count\": int(len(frame)),\n   614\t                \"source_kind\": \"neuron_registry\",\n   615\t            },\n   616\t        )\n   617\t    merged = _load_raw_node_metadata(paths_cfg)\n   618\t    if merged is None:\n   619\t        return (None, {\"availability\": \"absent\", \"path\": None, \"source_kind\": \"none\"})\n   620\t    return (\n   621\t        merged,\n   622\t        {\n   623\t            \"availability\": \"available\",\n   624\t            \"path\": merged.attrs.get(\"source_path\"),\n   625\t            \"row_count\": int(len(merged)),\n   626\t            \"source_kind\": \"raw_codex_metadata\",\n   627\t        },\n   628\t    )\n   629\t\n   630\t\n   631\tdef _load_raw_node_metadata(paths_cfg: Mapping[str, Any]) -> pd.DataFrame | None:\n   632\t    classification_path = _existing_path(paths_cfg.get(\"classification_csv\"))\n   633\t    if classification_path is None:\n   634\t        return None\n   635\t    classification = pd.read_csv(classification_path)\n   636\t    if \"root_id\" not in classification.columns:\n   637\t        raise WholeBrainContextQueryError(\n   638\t            f\"Raw node metadata at {classification_path} is missing a root_id column.\"\n   639\t        )\n   640\t    normalized = classification.copy()\n   641\t    normalized[\"root_id\"] = _coerce_root_id_series(normalized[\"root_id\"], \"classification.root_id\")\n   642\t    keep_columns = [\n   643\t        column\n   644\t        for column in (\n   645\t            \"root_id\",\n   646\t            \"super_class\",\n   647\t            \"class\",\n   648\t            \"sub_class\",\n   649\t            \"hemilineage\",\n   650\t            \"side\",\n   651\t            \"nerve\",\n   652\t        )\n   653\t        if column in normalized.columns\n   654\t    ]\n   655\t    result = normalized.loc[:, keep_columns].drop_duplicates(subset=[\"root_id\"]).copy()\n   656\t    cell_type_path = _discover_optional_raw_metadata_path(\n   657\t        paths_cfg,\n   658\t        explicit_key=\"cell_types_csv\",\n   659\t        file_names=[\n   660\t            \"cell_types.csv\",\n   661\t            \"cell_types.csv.gz\",\n   662\t            \"consolidated_cell_types.csv\",\n   663\t            \"consolidated_cell_types.csv.gz\",\n   664\t        ],\n   665\t    )\n   666\t    if cell_type_path is not None:\n   667\t        cell_types = pd.read_csv(cell_type_path)\n   668\t        if \"root_id\" in cell_types.columns:\n   669\t            cell_types = cell_types.copy()\n   670\t            cell_types[\"root_id\"] = _coerce_root_id_series(\n   671\t                cell_types[\"root_id\"],\n   672\t                \"cell_types.root_id\",\n   673\t            )\n   674\t            rename_map = {}\n   675\t            if \"primary_type\" in cell_types.columns:\n   676\t                rename_map[\"primary_type\"] = \"primary_type\"\n   677\t            if \"additional_type(s)\" in cell_types.columns:\n   678\t                rename_map[\"additional_type(s)\"] = \"additional_types\"\n   679\t            cell_types = cell_types.rename(columns=rename_map)\n   680\t            keep = [\n   681\t                column\n   682\t                for column in (\"root_id\", \"primary_type\", \"additional_types\")\n   683\t                if column in cell_types.columns\n   684\t            ]\n   685\t            result = result.merge(\n   686\t                cell_types.loc[:, keep].drop_duplicates(subset=[\"root_id\"]),\n   687\t                on=\"root_id\",\n   688\t                how=\"left\",\n   689\t            )\n   690\t    nt_path = _discover_optional_raw_metadata_path(\n   691\t        paths_cfg,\n   692\t        explicit_key=\"neurotransmitter_predictions_csv\",\n   693\t        file_names=[\n   694\t            \"neurotransmitter_type_predictions.csv\",\n   695\t            \"neurons.csv\",\n   696\t            \"neurons.csv.gz\",\n   697\t        ],\n   698\t    )\n   699\t    if nt_path is not None:\n   700\t        nt_df = pd.read_csv(nt_path)\n   701\t        if \"root_id\" in nt_df.columns:\n   702\t            nt_df = nt_df.copy()\n   703\t            nt_df[\"root_id\"] = _coerce_root_id_series(nt_df[\"root_id\"], \"nt_predictions.root_id\")\n   704\t            keep = [column for column in (\"root_id\", \"nt_type\") if column in nt_df.columns]\n   705\t            result = result.merge(\n   706\t                nt_df.loc[:, keep].drop_duplicates(subset=[\"root_id\"]),\n   707\t                on=\"root_id\",\n   708\t                how=\"left\",\n   709\t            )\n   710\t    result.attrs[\"source_path\"] = str(classification_path.resolve())\n   711\t    return _coerce_node_metadata_frame(result)\n   712\t\n   713\t\n   714\tdef _discover_optional_raw_metadata_path(\n   715\t    paths_cfg: Mapping[str, Any],\n   716\t    *,\n   717\t    explicit_key: str,\n   718\t    file_names: Sequence[str],\n   719\t) -> Path | None:\n   720\t    explicit_path = _existing_path(paths_cfg.get(explicit_key))\n   721\t    if explicit_path is not None:\n   722\t        return explicit_path\n   723\t    raw_dir = _existing_path(paths_cfg.get(\"codex_raw_dir\"))\n   724\t    if raw_dir is None:\n   725\t        return None\n   726\t    for file_name in file_names:\n   727\t        candidate = raw_dir / file_name\n   728\t        if candidate.exists():\n   729\t            return candidate\n   730\t    return None\n   731\t\n   732\t\n   733\tdef _coerce_synapse_registry_frame(\n   734\t    source: str | Path | pd.DataFrame | Sequence[Mapping[str, Any]],\n   735\t) -> pd.DataFrame:\n   736\t    if isinstance(source, pd.DataFrame):\n   737\t        df = source.copy()\n   738\t    elif isinstance(source, (str, Path)):\n   739\t        path = Path(source).resolve()\n   740\t        try:\n   741\t            df = load_synapse_registry(path)\n   742\t        except Exception:\n   743\t            df = pd.read_csv(path)\n   744\t    elif isinstance(source, Sequence) and not isinstance(source, (str, bytes)):\n   745\t        df = pd.DataFrame([copy.deepcopy(dict(item)) for item in source])\n   746\t    else:\n   747\t        raise WholeBrainContextQueryError(\n   748\t            f\"Unsupported synapse_registry source {type(source)!r}.\"\n   749\t        )\n   750\t    required_columns = (\"pre_root_id\", \"post_root_id\")\n   751\t    missing = [column for column in required_columns if column not in df.columns]\n   752\t    if missing:\n   753\t        raise WholeBrainContextQueryError(\n   754\t            \"Whole-brain context synapse input is missing required columns \"\n   755\t            f\"{missing!r}.\"\n   756\t        )\n   757\t    normalized = df.copy()\n   758\t    normalized[\"pre_root_id\"] = _coerce_root_id_series(\n   759\t        normalized[\"pre_root_id\"],\n   760\t        \"synapse_registry.pre_root_id\",\n   761\t    )\n   762\t    normalized[\"post_root_id\"] = _coerce_root_id_series(\n   763\t        normalized[\"post_root_id\"],\n   764\t        \"synapse_registry.post_root_id\",\n   765\t    )\n   766\t    if \"weight\" not in normalized.columns:\n   767\t        normalized[\"weight\"] = 1.0\n   768\t    normalized[\"weight\"] = pd.to_numeric(normalized[\"weight\"], errors=\"coerce\").fillna(1.0)\n   769\t    if \"confidence\" not in normalized.columns:\n   770\t        normalized[\"confidence\"] = pd.NA\n   771\t    normalized[\"confidence\"] = pd.to_numeric(normalized[\"confidence\"], errors=\"coerce\")\n   772\t    if \"neuropil\" not in normalized.columns:\n   773\t        normalized[\"neuropil\"] = \"\"\n   774\t    normalized[\"neuropil\"] = normalized[\"neuropil\"].fillna(\"\").astype(\"string\")\n   775\t    if \"nt_type\" not in normalized.columns:\n   776\t        normalized[\"nt_type\"] = \"\"\n   777\t    normalized[\"nt_type\"] = normalized[\"nt_type\"].fillna(\"\").astype(\"string\").str.upper()\n   778\t    if \"synapse_row_id\" not in normalized.columns:\n   779\t        normalized[\"synapse_row_id\"] = [\n   780\t            f\"row-{index:06d}\" for index in range(1, len(normalized) + 1)\n   781\t        ]\n   782\t    normalized[\"synapse_row_id\"] = normalized[\"synapse_row_id\"].fillna(\"\").astype(\"string\")\n   783\t    if \"source_row_number\" not in normalized.columns:\n   784\t        normalized[\"source_row_number\"] = list(range(1, len(normalized) + 1))\n   785\t    source_row_numbers = pd.to_numeric(\n   786\t        normalized[\"source_row_number\"],\n   787\t        errors=\"coerce\",\n   788\t    )\n   789\t    if source_row_numbers.isna().any():\n   790\t        fallback_numbers = pd.Series(\n   791\t     