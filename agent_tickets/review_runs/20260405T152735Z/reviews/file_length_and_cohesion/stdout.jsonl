      else (\n  3043\t                float(\n  3044\t                    skeleton_runtime_by_root[int(item[\"root_id\"])].integration_timestep_ms\n  3045\t                )\n  3046\t                if int(item[\"root_id\"]) in skeleton_runtime_by_root\n  3047\t                else float(\n  3048\t                    point_runtime_by_root[int(item[\"root_id\"])].integration_timestep_ms\n  3049\t                )\n  3050\t            )\n  3051\t        )\n  3052\t        for item in hybrid_morphology[\"per_root_class_metadata\"]\n  3053\t    }\n  3054\t    per_root_internal_substep_count = {\n  3055\t        str(int(item[\"root_id\"])): (\n  3056\t            int(surface_runtime.descriptor.solver_metadata[\"internal_substep_count\"])\n  3057\t            if int(item[\"root_id\"]) in surface_root_ids\n  3058\t            else (\n  3059\t                int(\n  3060\t                    skeleton_runtime_by_root[int(item[\"root_id\"])].internal_substep_count\n  3061\t                )\n  3062\t                if int(item[\"root_id\"]) in skeleton_runtime_by_root\n  3063\t                else int(\n  3064\t                    point_runtime_by_root[int(item[\"root_id\"])].runtime_metadata()[\n  3065\t                        \"internal_substep_count\"\n  3066\t                    ]\n  3067\t                )\n  3068\t            )\n  3069\t        )\n  3070\t        for item in hybrid_morphology[\"per_root_class_metadata\"]\n  3071\t    }\n  3072\t    integration_timestep_ms = min(\n  3073\t        [float(timebase.dt_ms)]\n  3074\t        + [\n  3075\t            float(value)\n  3076\t            for value in per_root_integration_timestep_ms.values()\n  3077\t        ]\n  3078\t    )\n  3079\t    internal_substep_count = max(\n  3080\t        [1]\n  3081\t        + [\n  3082\t            int(value)\n  3083\t            for value in per_root_internal_substep_count.values()\n  3084\t        ]\n  3085\t    )\n  3086\t    component_count = int(hybrid_coupling_plan[\"component_