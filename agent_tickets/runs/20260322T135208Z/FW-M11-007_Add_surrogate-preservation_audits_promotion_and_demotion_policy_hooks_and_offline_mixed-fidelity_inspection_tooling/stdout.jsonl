.asarray(reference_root_payload[\"projection_time_ms\"], dtype=np.float64),\n   539\t        values_b=_mean_projection_trace(reference_root_payload[\"projection_trace\"]),\n   540\t    )\n   541\t    shared_time_ms, surrogate_shared_trace, reference_shared_trace = _align_scalar_traces(\n   542\t        time_ms_a=np.asarray(base_shared_payload[\"time_ms\"], dtype=np.float64),\n   543\t        values_a=_select_shared_trace(base_shared_payload),\n   544\t        time_ms_b=np.asarray(reference_shared_payload[\"time_ms\"], dtype=np.float64),\n   545\t        values_b=_select_shared_trace(reference_shared_payload),\n   546\t    )\n   547\t\n   548\t    metrics = {\n   549\t        \"root_mean_trace_mae\": float(\n   550\t            np.mean(np.abs(surrogate_root_trace - reference_root_trace))\n   551\t        ),\n   552\t        \"root_peak_abs_error\": float(\n   553\t            abs(\n   554\t                np.max(np.abs(surrogate_root_trace))\n   555\t                - np.max(np.abs(reference_root_trace))\n   556\t            )\n   557\t        ),\n   558\t        \"root_final_abs_error\": float(\n   559\t            abs(surrogate_root_trace[-1] - reference_root_trace[-1])\n   560\t        ),\n   561\t        \"root_peak_time_delta_ms\": float(\n   562\t            abs(\n   563\t                root_time_ms[int(np.argmax(np.abs(surrogate_root_trace)))]\n   564\t                - root_time_ms[int(np.argmax(np.abs(reference_root_trace)))]\n   565\t            )\n   566\t        ),\n   567\t        \"shared_output_trace_mae\": float(\n   568\t            np.mean(np.abs(surrogate_shared_trace - reference_shared_trace))\n   569\t        ),\n   570\t        \"shared_output_peak_abs_error\": float(\n   571\t            abs(\n   572\t                np.max(np.abs(surrogate_shared_trace))\n   573\t                - np.max(np.abs(reference_shared_trace))\n   574\t            )\n   575\t        ),\n   576\t    }\n   577\t    checks, evaluation = evaluate_mixed_fidelity_inspection_metrics(\n   578\t        metrics=metrics,\n   579\t        thresholds=thresholds,\n   580\t    )\n   581\t    recommended_promotion = bool(\n   582\t        evaluation[\"overall_status\"] in {STATUS_REVIEW, STATUS_BLOCKING}\n   583\t        and _morphology_class_rank(str(reference_root[\"reference_morphology_class\"]))\n   584\t        > _morphology_class_rank(str(assignment[\"realized_morphology_class\"]))\n   585\t    )\n   586\t    return {\n   587\t        \"root_id\": int(root_id),\n   588\t        \"cell_type\": str(assignment[\"cell_type\"]),\n   589\t        \"realized_morphology_class\": str(assignment[\"realized_morphology_class\"]),\n   590\t        \"reference_morphology_class\": str(reference_root[\"reference_morphology_class\"]),\n   591\t        \"reference_source\": str(reference_root[\"reference_source\"]),\n   592\t        \"overall_status\": str(evaluation[\"overall_status\"]),\n   593\t        \"review_deviation_count\": int(evaluation[\"review_deviation_count\"]),\n   594\t        \"blocking_deviation_count\": int(evaluation[\"blocking_deviation_count\"]),\n   595\t        \"recommended_promotion\": recommended_promotion,\n   596\t        \"metrics\": metrics,\n   597\t        \"checks\": checks,\n   598\t        \"assignment_provenance\": copy.deepcopy(dict(assignment[\"assignment_provenance\"])),\n   599\t        \"approximation_route\": copy.deepcopy(dict(assignment[\"approximation_route\"])),\n   600\t        \"policy_evaluation\": copy.deepcopy(dict(assignment[\"policy_evaluation\"])),\n   601\t        \"base_run\": {\n   602\t            \"metadata_path\": str(base_run_summary[\"metadata_path\"]),\n   603\t            \"bundle_id\": str(base_metadata[\"bundle_id\"]),\n   604\t            \"run_spec_hash\": str(base_metadata[\"run_spec_hash\"]),\n   605\t        },\n   606\t        \"reference_run\": {\n   607\t            \"metadata_path\": str(reference_run_summary[\"metadata_path\"]),\n   608\t            \"bundle_id\": str(reference_metadata[\"bundle_id\"]),\n   609\t            \"run_spec_hash\": str(reference_metadata[\"run_spec_hash\"]),\n   610\t            \"variant_manifest_path\": str(variant_manifest_path.resolve()),\n   611\t        },\n   612\t        \"comparison_trace_summary\": {\n   613\t            \"root_time_sample_count\": int(root_time_ms.shape[0]),\n   614\t            \"shared_time_sample_count\": int(shared_time_ms.shape[0]),\n   615\t            \"root_time_start_ms\": float(root_time_ms[0]),\n   616\t            \"root_time_end_ms\": float(root_time_ms[-1]),\n   617\t            \"shared_time_start_ms\": float(shared_time_ms[0]),\n   618\t            \"shared_time_end_ms\": float(shared_time_ms[-1]),\n   619\t        },\n   620\t    }\n","exit_code":0,"status":"completed"}}
