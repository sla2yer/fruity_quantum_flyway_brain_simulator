   except Exception:\\n   820\\t        return (\\n   821\\t            np.empty(0, dtype=np.int64),\\n   822\\t            np.empty((0, 3), dtype=np.float64),\\n   823\\t            np.empty(0, dtype=np.float64),\\n   824\\t            \\\"skeleton_asset_invalid\\\",\\n   825\\t        )\\n   826\\t\\n   827\\t    if not nodes:\\n   828\\t        return (\\n   829\\t            np.empty(0, dtype=np.int64),\\n   830\\t            np.empty((0, 3), dtype=np.float64),\\n   831\\t            np.empty(0, dtype=np.float64),\\n   832\\t            \\\"skeleton_asset_empty\\\",\\n   833\\t        )\\n   834\\t\\n   835\\t    node_ids = np.asarray([node_id for node_id, _coords, _parent_id in nodes], dtype=np.int64)\\n   836\\t    points = np.vstack([coords for _node_id, coords, _parent_id in nodes]).astype(np.float64, copy=False)\\n   837\\t    node_index = {int(node_id): idx for idx, node_id in enumerate(node_ids.tolist())}\\n   838\\t    incident_lengths: list[list[float]] = [[] for _ in range(len(nodes))]\\n   839\\t    for idx, (_node_id, coords, parent_id) in enumerate(nodes):\\n   840\\t        parent_idx = node_index.get(int(parent_id))\\n   841\\t        if parent_idx is None:\\n   842\\t            continue\\n   843\\t        length = float(np.linalg.norm(coords - points[parent_idx]))\\n   844\\t        incident_lengths[idx].append(length)\\n   845\\t        incident_lengths[parent_idx].append(length)\\n   846\\t    local_scales = np.asarray(\\n   847\\t        [float(np.mean(lengths)) if lengths else 0.0 for lengths in incident_lengths],\\n   848\\t        dtype=np.float64,\\n   849\\t    )\\n   850\\t    return node_ids, points, local_scales, \\\"\\\"\\n   851\\t\\n   852\\t\\n   853\\tdef _build_point_anchor_proxy(\\n   854\\t    root_rows: pd.DataFrame,\\n   855\\t    *,\\n   856\\t    relation_to_root: str,\\n   857\\t) -> tuple[np.ndarray, float, str]:\\n   858\\t    if root_rows.empty:\\n   859\\t        return np.full(3, np.nan, dtype=np.float64), float(\\\"