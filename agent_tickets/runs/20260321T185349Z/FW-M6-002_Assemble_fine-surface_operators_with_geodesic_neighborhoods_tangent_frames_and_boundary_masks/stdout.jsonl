    74\\t\\n    75\\t\\n    76\\tdef _faces_to_adjacency(faces: np.ndarray, n_vertices: int) -> sp.csr_matrix:\\n    77\\t    edges = set()\\n    78\\t    for tri in faces:\\n    79\\t        a, b, c = (int(tri[0]), int(tri[1]), int(tri[2]))\\n    80\\t        edges.add(tuple(sorted((a, b))))\\n    81\\t        edges.add(tuple(sorted((b, c))))\\n    82\\t        edges.add(tuple(sorted((a, c))))\\n    83\\t\\n    84\\t    if not edges:\\n    85\\t        raise ValueError(\\\"No edges could be built from faces.\\\")\\n    86\\t\\n    87\\t    rows = []\\n    88\\t    cols = []\\n    89\\t    for i, j in sorted(edges):\\n    90\\t        rows.extend([i, j])\\n    91\\t        cols.extend([j, i])\\n    92\\t\\n    93\\t    data = np.ones(len(rows), dtype=np.float32)\\n    94\\t    adj = sp.csr_matrix((data, (rows, cols)), shape=(n_vertices, n_vertices))\\n    95\\t    adj.eliminate_zeros()\\n    96\\t    adj.sort_indices()\\n    97\\t    return adj\\n    98\\t\\n    99\\t\\n   100\\tdef _uniform_laplacian(adj: sp.csr_matrix) -> sp.csr_matrix:\\n   101\\t    deg = np.asarray(adj.sum(axis=1)).ravel()\\n   102\\t    d = sp.diags(deg)\\n   103\\t    return d - adj\\n   104\\t\\n   105\\t\\n   106\\tdef _serialize_sparse_matrix(matrix: sp.csr_matrix) -> dict[str, np.ndarray]:\\n   107\\t    matrix = matrix.tocsr().astype(np.float32)\\n   108\\t    matrix.sort_indices()\\n   109\\t    return {\\n   110\\t        \\\"data\\\": matrix.data.astype(np.float32, copy=False),\\n   111\\t        \\\"indices\\\": matrix.indices.astype(np.int32, copy=False),\\n   112\\t        \\\"indptr\\\": matrix.indptr.astype(np.int32, copy=False),\\n   113\\t        \\\"shape\\\": np.asarray(matrix.shape, dtype=np.int32),\\n   114\\t    }\\n   115\\t\\n   116\\t\\n   117\\tdef _collect_patch_vertices(\\n   118\\t    adj: sp.csr_matrix,\\n   119\\t    *,\\n   120\\t    seed: int,\\n   121\\t    unassigned: np.ndarray,\\n   122\\t    patch_hops: int,\\n   123\\t    cap: int,\\n   124\\t) -> np.ndarray:\\n   125\\t    queue: deque[tuple[int, int]] = deque([(int(seed), 0)])\\n   126\\t    visited = {int(seed)}\\n   127\\t    patch_vertices: list[int] = []\\n   128\\t\\n   129\\t    while queue and len(patch_vertices) < cap:\\n   130\\t        vertex, distance = queue.popleft()\\n   131\\t        if not bool(unassigned[vertex]):\\n   132\\t            continue\\n   133\\t\\n   134\\t        patch_vertices.append(vertex)\\n   135\\t        if distance >= patch_hops:\\n   136\\t            continue\\n   137\\t\\n   138\\t        start = int(adj.indptr[vertex])\\n   139\\t        end = int(adj.indptr[vertex + 1])\\n   140\\t        for neighbor in adj.indices[start:end]:\\n   141\\t            neighbor_idx = int(neighbor)\\n   142\\t            if neighbor_idx in visited or not bool(unassigned[neighbor_idx]):\\n   143\\t                continue\\n   144\\t            visited.add(neighbor_idx)\\n   145\\t            queue.append((neighbor_idx, distance + 1))\\n   146\\t\\n   147\\t    return np.asarray(patch_vertices, dtype=np.int32)\\n   148\\t\\n   149\\t\\n   150\\tdef _build_patch_membership_arrays(patches: list[np.ndarray]) -> tuple[np.ndarray, np.ndarray]:\\n   151\\t    member_vertex_indptr = np.zeros(len(patches) + 1, dtype=np.int32)\\n   152\\t    if not patches:\\n   153\\t        return np.empty(0, dtype=np.int32), member_vertex_indptr\\n   154\\t\\n   155\\t    counts = np.asarray([int(patch.size) for patch in patches], dtype=np.int32)\\n   156\\t    member_vertex_indptr[1:] = np.cumsum(counts, dtype=np.int32)\\n   157\\t    member_vertex_indices = np.concatenate(patches).astype(np.int32, copy=False)\\n   158\\t    return member_vertex_indices, member_vertex_indptr\\n   159\\t\\n   160\\t\\n   161\\tdef _build_patch_adjacency(\\n   162\\t    adj: sp.csr_matrix,\\n   163\\t    surface_to_patch: np.ndarray,\\n   164\\t    *,\\n   165\\t    patch_count: int,\\n   166\\t) -> sp.csr_matrix:\\n   167\\t    if patch_count <= 0:\\n   168\\t        return sp.csr_matrix((0, 0), dtype=np.float32)\\n   169\\t\\n   170\\t    upper_edges = sp.triu(adj, k=1).tocoo()\\n   171\\t    edge_weights: dict[tuple[int, int], float] = {}\\n   172\\t    for row, col, weight in zip(upper_edges.row, upper_edges.col, upper_edges.data):\\n   173\\t        patch_u = int(surface_to_patch[int(row)])\\n   174\\t        patch_v = int(surface_to_patch[int(col)])\\n   175\\t        if patch_u == patch_v:\\n   176\\t            continue\\n   177\\t        if patch_u > patch_v:\\n   178\\t            patch_u, patch_v = patch_v, patch_u\\n   179\\t        edge_weights[(patch_u, patch_v)] = edge_weights.get((patch_u, patch_v), 0.0) + float(weight)\\n   180\\t\\n   181\\t    if not edge_weights:\\n   182\\t        return sp.csr_matrix((patch_count, patch_count), dtype=np.float32)\\n   183\\t\\n   184\\t    rows: list[int] = []\\n   185\\t    cols: list[int] = []\\n   186\\t    data: list[float] = []\\n   187\\t    for (patch_u, patch_v), weight in sorted(edge_weights.items()):\\n   188\\t        rows.extend([patch_u, patch_v])\\n   189\\t        cols.extend([patch_v, patch_u])\\n   190\\t        data.extend([weight, weight])\\n   191\\t\\n   192\\t    patch_adj = sp.csr_matrix(\\n   193\\t        (np.asarray(data, dtype=np.float32), (rows, cols)),\\n   194\\t        shape=(patch_count, patch_count),\\n   195\\t    )\\n   196\\t    patch_adj.eliminate_zeros()\\n   197\\t    patch_adj.sort_indices()\\n   198\\t    return patch_adj\\n   199\\t\\n   200\\t\\n   201\\tdef _partition_surface_into_patches(\\n   202\\t    adj: sp.csr_matrix,\\n   203\\t    vertices: np.ndarray,\\n   204\\t    *,\\n   205\\t    patch_hops: int,\\n   206\\t    patch_vertex_cap: int,\\n   207\\t) -> PatchDecomposition:\\n   208\\t    n_vertices = int(adj.shape[0])\\n   209\\t    if patch_hops < 0:\\n   210\\t        raise ValueError(\\\"patch_hops must be non-negative.\\\")\\n   211\\t    if patch_vertex_cap <= 0:\\n   212\\t        raise ValueError(\\\"patch_vertex_cap must be positive.\\\")\\n   213\\t    if n_vertices != int(vertices.shape[0]):\\n   214\\t        raise ValueError(\\\"Surface graph vertex count does not match vertex coordinates.\\\")\\n   215\\t\\n   216\\t    unassigned = np.ones(n_vertices, dtype=bool)\\n   217\\t    surface_to_patch = np.full(n_vertices, -1, dtype=np.int32)\\n   218\\t    patches: list[np.ndarray] = []\\n   219\\t    patch_seed_vertices: list[int] = []\\n   220\\t    patch_centroids: list[np.ndarray] = []\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n./agent_tickets/runs/20260321T170513Z/FW-M5-003_Build_explicit_surface-graph_and_patch-graph_artifacts_for_the_multiresolution_morphology_bundle/stdout.jsonl:80:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_48\",\"type\":\"command_execution\",\"command\":\"/bin/bash -lc \\\"nl -ba docs/pipeline_notes.md | sed -n '30,90p'\\\"\",\"aggregated_output\":\"    30\\tThe active preset also refreshes the path named by `config.paths.selected_root_ids`\\n    31\\tso downstream pipeline steps can switch subsets without code changes.\\n    32\\t\\n    33\\t### Geometry handoff contract\\n    34\\t\\n    35\\tMilestone 5 uses the versioned geometry bundle contract\\n    36\\t`geometry_bundle.v1`. One canonical library path builder owns the\\n    37\\tfilenames below, and both `scripts/02_fetch_meshes.py` plus\\n    38\\t`scripts/03_build_wave_assets.py` use it directly.\\n    39\\t\\n    40\\tPer neuron, the bundle layout is:\\n    41\\t\\n    42\\t- `config.paths.meshes_raw_dir/<root_id>.ply`: raw mesh\\n    43\\t- `config.paths.skeletons_raw_dir/<root_id>.swc`: raw skeleton\\n    44\\t- `config.paths.processed_mesh_dir/<root_id>.ply`: simplified mesh\\n    45\\t- `config.paths.processed_graph_dir/<root_id>_graph.npz`: surface graph\\n    46\\t- `config.paths.processed_graph_dir/<root_id>_patch_graph.npz`: patch graph\\n    47\\t- `config.paths.processed_graph_dir/<root_id>_descriptors.json`: derived descriptor sidecar\\n    48\\t- `config.paths.processed_graph_dir/<root_id>_qa.json`: QA sidecar\\n    49\\t\\n    50\\tThe processed graph archives intentionally separate fine and coarse data:\\n    51\\t\\n    52\\t- the surface graph stores the simplified mesh vertices/faces, sparse surface adjacency/Laplacian arrays, and `surface_to_patch` so every surface vertex has an explicit coarse patch assignment\\n    53\\t- the patch graph stores sparse coarse adjacency/Laplacian arrays plus `patch_sizes`, `patch_centroids`, `patch_seed_vertices`, and CSR-style `member_vertex_indices` / `member_vertex_indptr` arrays for reconstructing patch membership deterministically\\n    54\\t\\n    55\\t`config.paths.manifest_json` records the bundle contract version, dataset,\\n    56\\tmaterialization version, meshing-config snapshot, and per-root asset\\n    57\\tstatuses/paths. Raw fetch runs also record `raw_asset_provenance` per\\n    58\\troot ID so cache hits, refetches, skips, validation failures, and\\n    59\\toptional skeleton fetch errors can be audited without reading console\\n    60\\tlogs. Processed bundle records also expose `artifact_sources` so each\\n    61\\tsimplified mesh, surface graph, patch graph, and sidecar points back to\\n    62\\tthe raw mesh and skeleton inputs it was built against.\\n    63\\t\\n    64\\tCompatibility shim:\\n    65\\t\\n    66\\t- `config.paths.processed_graph_dir/<root_id>_meta.json` is still written as\\n    67\\t  a legacy metadata pointer so older consumers can keep reading the prior\\n    68\\t  sidecar name during migration.\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n./agent_tickets/runs/20260321T170513Z/FW-M5-003_Build_explicit_surface-graph_and_patch-graph_artifacts_for_the_multiresolution_morphology_bundle/stdout.jsonl:85:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_51\",\"type\":\"command_execution\",\"command\":\"/bin/bash -lc \\\"nl -ba src/flywire_wave/mesh_pipeline.py | sed -n '440,620p'\\\"\",\"aggregated_output\":\"   440\\t        return provenance\\n   441\\t    except Exception as exc:\\n   442\\t        cache_after = _cache_snapshot(asset_path, validator)\\n   443\\t        provenance[\\\"cache_after\\\"] = cache_after\\n   444\\t        provenance[\\\"error\\\"] = f\\\"{type(exc).__name__}: {exc}\\\"\\n   445\\t        if cache_after[\\\"state\\\"] == \\\"valid\\\":\\n   446\\t            provenance[\\\"asset_status\\\"] = ASSET_STATUS_READY\\n   447\\t            provenance[\\\"size_bytes\\\"], provenance[\\\"mtime_utc\\\"] = _file_metadata(asset_path)\\n   448\\t        elif not fetch_enabled:\\n   449\\t            provenance[\\\"asset_status\\\"] = ASSET_STATUS_SKIPPED\\n   450\\t        else:\\n   451\\t            provenance[\\\"asset_status\\\"] = ASSET_STATUS_MISSING\\n   452\\t        return provenance\\n   453\\t\\n   454\\t\\n   455\\tdef _cache_snapshot(path: Path, validator: Callable[[Path], tuple[bool, str]]) -> dict[str, str]:\\n   456\\t    valid, reason = validator(path)\\n   457\\t    if valid:\\n   458\\t        state = \\\"valid\\\"\\n   459\\t    elif path.exists():\\n   460\\t        state = \\\"invalid\\\"\\n   461\\t    else:\\n   462\\t        state = \\\"missing\\\"\\n   463\\t    return {\\n   464\\t        \\\"state\\\": state,\\n   465\\t        \\\"reason\\\": reason,\\n   466\\t    }\\n   467\\t\\n   468\\t\\n   469\\tdef _validate_cached_mesh(path: Path) -> tuple[bool, str]:\\n   470\\t    if not path.exists():\\n   471\\t        return False, \\\"missing_file\\\"\\n   472\\t    if path.stat().st_size <= 0:\\n   473\\t        return False, \\\"empty_file\\\"\\n   474\\t    try:\\n   475\\t        mesh = trimesh.load_mesh(path, process=False)\\n   476\\t    except Exception as exc:\\n   477\\t        return False, f\\\"load_failed:{type(exc).__name__}\\\"\\n   478\\t    if not isinstance(mesh, trimesh.Trimesh):\\n   479\\t        return False, f\\\"unexpected_type:{type(mesh).__name__}\\\"\\n   480\\t    vertices = np.asarray(mesh.vertices)\\n   481\\t    faces = np.asarray(mesh.faces)\\n   482\\t    if vertices.ndim != 2 or vertices.shape[0] == 0 or vertices.shape[1] != 3:\\n   483\\t        return False, \\\"invalid_vertices\\\"\\n   484\\t    if faces.ndim != 2 or faces.shape[0] == 0 or faces.shape[1] < 3:\\n   485\\t        return False, \\\"invalid_faces\\\"\\n   486\\t    return True, \\\"validated_trimesh\\\"\\n   487\\t\\n   488\\t\\n   489\\tdef _validate_cached_skeleton(path: Path) -> tuple[bool, str]:\\n   490\\t    if not path.exists():\\n   491\\t        return False, \\\"missing_file\\\"\\n   492\\t    if path.stat().st_size <= 0:\\n   493\\t        return False, \\\"empty_file\\\"\\n   494\\t\\n   495\\t    data_lines = 0\\n   496\\t    with path.open(\\\"r\\\", encoding=\\\"utf-8\\\") as handle:\\n   497\\t        for raw_line in handle:\\n   498\\t            line = raw_line.strip()\\n   499\\t            if not line or line.startswith(\\\"#\\\"):\\n   500\\t                continue\\n   501\\t            parts = line.split()\\n   502\\t            if len(parts) != 7:\\n   503\\t                return False, \\\"invalid_swc_columns\\\"\\n   504\\t            try:\\n   505\\t                int(parts[0])\\n   506\\t                int(parts[1])\\n   507\\t                float(parts[2])\\n   508\\t                float(parts[3])\\n   509\\t                float(parts[4])\\n   510\\t                float(parts[5])\\n   511\\t                int(parts[6])\\n   512\\t            except ValueError:\\n   513\\t                return False, \\\"invalid_swc_values\\\"\\n   514\\t            data_lines += 1\\n   515\\t    if data_lines == 0:\\n   516\\t        return False, \\\"missing_swc_nodes\\\"\\n   517\\t    return True, \\\"validated_swc\\\"\\n   518\\t\\n   519\\t\\n   520\\tdef _write_mesh_atomically(mesh: trimesh.Trimesh, path: Path) -> None:\\n   521\\t    tmp_path = path.with_suffix(f\\\".tmp{path.suffix}\\\")\\n   522\\t    try:\\n   523\\t        mesh.export(tmp_path)\\n   524\\t        tmp_path.replace(path)\\n   525\\t    finally:\\n   526\\t        if tmp_path.exists():\\n   527\\t            tmp_path.unlink(missing_ok=True)\\n   528\\t\\n   529\\t\\n   530\\tdef _write_skeleton_atomically(\\n   531\\t    skeleton: Any,\\n   532\\t    path: Path,\\n   533\\t    skeleton_writer: Callable[[Any, str | Path], None],\\n   534\\t) -> None:\\n   535\\t    tmp_path = path.with_suffix(f\\\".tmp{path.suffix}\\\")\\n   536\\t    try:\\n   537\\t        skeleton_writer(skeleton, tmp_path)\\n   538\\t        tmp_path.replace(path)\\n   539\\t    finally:\\n   540\\t        if tmp_path.exists():\\n   541\\t            tmp_path.unlink(missing_ok=True)\\n   542\\t\\n   543\\t\\n   544\\tdef _file_metadata(path: Path) -> tuple[int | None, str | None]:\\n   545\\t    if not path.exists():\\n   546\\t        return None, None\\n   547\\t    stat = path.stat()\\n   548\\t    mtime = datetime.fromtimestamp(stat.st_mtime, tz=timezone.utc).replace(microsecond=0).isoformat()\\n   549\\t    return int(stat.st_size), mtime\\n   550\\t\\n   551\\t\\n   552\\tdef _utc_now() -> str:\\n   553\\t    return datetime.now(timezone.utc).replace(microsecond=0).isoformat()\\n   554\\t\\n   555\\t\\n   556\\tdef process_mesh_into_wave_assets(\\n   557\\t    *,\\n   558\\t    root_id: int,\\n   559\\t    bundle_paths: GeometryBundlePaths,\\n   560\\t    simplify_target_faces: int = 15000,\\n   561\\t    patch_hops: int = 6,\\n   562\\t    patch_vertex_cap: int = 2500,\\n   563\\t    registry_metadata: dict[str, Any] | None = None,\\n   564\\t) -> dict[str, Any]:\\n   565\\t    ensure_dir(bundle_paths.simplified_mesh_path.parent)\\n   566\\t    ensure_dir(bundle_paths.surface_graph_path.parent)\\n   567\\t\\n   568\\t    raw_mesh = trimesh.load_mesh(bundle_paths.raw_mesh_path, process=False)\\n   569\\t    if not isinstance(raw_mesh, trimesh.Trimesh):\\n   570\\t        raise TypeError(f\\\"Expected a Trimesh at {bundle_paths.raw_mesh_path}, got {type(raw_mesh)!r}\\\")\\n   571\\t\\n   572\\t    mesh = raw_mesh.copy()\\n   573\\t    original_face_count = int(len(mesh.faces))\\n   574\\t    target_faces = min(int(simplify_target_faces), int(len(mesh.faces)))\\n   575\\t    if 4 <= target_faces < original_face_count:\\n   576\\t        try:\\n   577\\t            mesh = mesh.simplify_quadric_decimation(target_faces)\\n   578\\t        except Exception:\\n   579\\t            # Fallback: keep original mesh if local environment lacks simplification backend.\\n   580\\t            pass\\n   581\\t\\n   582\\t    vertices = np.asarray(mesh.vertices, dtype=np.float32)\\n   583\\t    faces = np.asarray(mesh.faces, dtype=np.int32)\\n   584\\t    adj = _faces_to_adjacency(faces, vertices.shape[0])\\n   585\\t    lap = _uniform_laplacian(adj)\\n   586\\t    patch_decomposition = _partition_surface_into_patches(\\n   587\\t        adj,\\n   588\\t        vertices,\\n   589\\t        patch_hops=patch_hops,\\n   590\\t        patch_vertex_cap=patch_vertex_cap,\\n   591\\t    )\\n   592\\t    surface_graph_payload = {\\n   593\\t        \\\"root_id\\\": np.asarray(int(root_id), dtype=np.int64),\\n   594\\t        \\\"patch_count\\\": np.asarray(int(patch_decomposition.patch_sizes.size), dtype=np.int32),\\n   595\\t        \\\"vertices\\\": vertices,\\n   596\\t        \\\"faces\\\": faces,\\n   597\\t        \\\"surface_to_patch\\\": patch_decomposition.surface_to_patch,\\n   598\\t    }\\n   599\\t    surface_graph_payload.update(\\n   600\\t        {\\n   601\\t            f\\\"adj_{key}\\\": value\\n   602\\t            for key, value in _serialize_sparse_matrix(adj).items()\\n   603\\t        }\\n   604\\t    )\\n   605\\t    surface_graph_payload.update(\\n   606\\t        {\\n   607\\t            f\\\"lap_{key}\\\": value\\n   608\\t            for key, value in _serialize_sparse_matrix(lap).items()\\n   609\\t        }\\n   610\\t    )\\n   611\\t\\n   612\\t    patch_graph_payload = {\\n   613\\t        \\\"root_id\\\": np.asarray(int(root_id), dtype=np.int64),\\n   614\\t        \\\"patch_coun