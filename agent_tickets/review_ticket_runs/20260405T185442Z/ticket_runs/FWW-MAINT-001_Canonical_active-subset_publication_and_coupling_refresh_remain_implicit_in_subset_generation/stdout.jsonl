is not None else None,\n   459\t        \"active_preset\": active_preset,\n   460\t        \"publication\": publication_summary,\n   461\t        \"generated_presets\": artifact_summaries,\n   462\t    }\n   463\t    write_json(index_payload, subset_output_dir / SUBSET_INDEX_FILENAME)\n   464\t    return index_payload\n   465\t\n   466\t\n   467\tdef _generate_preset_artifacts(\n   468\t    *,\n   469\t    neuron_registry: pd.DataFrame,\n   470\t    connectivity_registry: pd.DataFrame,\n   471\t    preset_name: str,\n   472\t    spec: dict[str, Any],\n   473\t    registry_path: str | Path,\n   474\t    connectivity_registry_path: str | Path | None,\n   475\t    config_path: str | Path | None,\n   476\t    subset_output_dir: Path,\n   477\t) -> GeneratedPresetArtifacts:\n   478\t    selected_df, stats_payload, manifest_payload, preview_markdown = build_subset_artifacts(\n   479\t        neuron_registry=neuron_registry,\n   480\t        connectivity_registry=connectivity_registry,\n   481\t        preset_name=preset_name,\n   482\t        spec=spec,\n   483\t        registry_path=registry_path,\n   484\t        connectivity_registry_path=connectivity_registry_path,\n   485\t        config_path=config_path,\n   486\t    )\n   487\t    artifact_paths = _artifact_paths_for_preset(subset_output_dir, preset_name)\n   488\t    _write_subset_outputs(\n   489\t        selected_df=selected_df,\n   490\t        stats_payload=stats_payload,\n   491\t        manifest_payload=manifest_payload,\n   492\t        preview_markdown=preview_markdown,\n   493\t        artifact_paths=artifact_paths,\n   494\t    )\n   495\t    return GeneratedPresetArtifacts(\n   496\t        preset_name=preset_name,\n   497\t        description=spec.get(\"description\"),\n   498\t        root_ids=tuple(extract_root_ids(selected_df)),\n   499\t        artifact_paths=artifact_paths,\n   500\t    )\n   501\t\n   502\t\n   503\tdef _publish_canonical_active_subset(\n   504\t    *,\n   505\t    cfg: dict[str, Any],\n   506\t    active_preset: str,\n   507\t    generated_presets: dict[str, GeneratedPresetArtifacts],\n   508\t) -> dict[str, Any]:\n   509\t    published_preset = generated_presets.get(active_preset)\n   510\t    if published_preset is None:\n   511\t        raise ValueError(\n   512\t            f\"Active preset {active_preset!r} was not generated and cannot be published.\"\n   513\t        )\n   514\t\n   515\t    paths_cfg = cfg.get(\"paths\", {})\n   516\t    published_root_ids = list(published_preset.root_ids)\n   517\t    selected_root_ids_path = _normalize_optional_path(paths_cfg.get(\"selected_root_ids\"))\n   518\t    selected_root_ids_updated = False\n   519\t    if selected_root_ids_path is not None:\n   520\t        selected_root_ids_updated = _publish_selected_root_ids_alias(\n   521\t            root_ids=published_root_ids,\n   522\t            selected_root_ids_path=selected_root_ids_path,\n   523\t        )\n   524\t\n   525\t    coupling_refresh_enabled = _publishes_subset_scoped_coupling(paths_cfg)\n   526\t    coupling_refresh_summary = None\n   527\t    if coupling_refresh_enabled:\n   528\t        if selected_root_ids_path is not None:\n   529\t            coupling_refresh_summary = materialize_synapse_registry(\n   530\t                cfg,\n   531\t                root_ids_path=selected_root_ids_path,\n   532\t                scope_label=f\"selection:{active_preset}\",\n   533\t            )\n   534\t        else:\n   535\t            coupling_refresh_summary = materialize_synapse_registry(\n   536\t                cfg,\n   537\t                root_ids=published_root_ids,\n   538\t                scope_label=f\"selection:{active_preset}\",\n   539\t            )\n   540\t\n   541\t    return {\n   542\t        \"preset_name\": active_preset,\n   543\t        \"root_id_count\": int(len(published_root_ids)),\n   544\t        \"artifact_root_ids_path\": str(published_preset.artifact_paths.root_ids),\n   545\t        \"selected_root_ids_path\": (\n   546\t            str(selected_root_ids_path)\n   547\t            if selected_root_ids_path is not None\n   548\t            else None\n   549\t        ),\n   550\t        \"selected_root_ids_updated\": selected_root_ids_updated,\n   551\t        \"subset_scoped_coupling_refreshed\": coupling_refresh_summary is not None,\n   552\t        \"subset_scoped_coupling\": coupling_refresh_summary,\n   553\t    }\n   554\t\n   555\t\n   556\tdef _generated_preset_summary(\n   557\t    generated: GeneratedPresetArtifacts,\n   558\t    *,\n   559\t    publication_summary: dict[str, Any] | None,\n   560\t) -> dict[str, Any]:\n   561\t    publication_metadata = {\n   562\t        \"published_as_active_subset\": False,\n   563\t        \"selected_root_ids_updated\": False,\n   564\t        \"subset_scoped_coupling_refreshed\": False,\n   565\t    }\n   566\t    if publication_summary is not None:\n   567\t        publication_metadata = {\n   568\t            \"published_as_active_subset\": True,\n   569\t            \"selected_root_ids_updated\": bool(\n   570\t                publication_summary[\"selected_root_ids_updated\"]\n   571\t            ),\n   572\t            \"subset_scoped_coupling_refreshed\": bool(\n   573\t                publication_summary[\"subset_scoped_coupling_refreshed\"]\n   574\t            ),\n   575\t        }\n   576\t\n   577\t    artifact_paths = generated.artifact_paths\n   578\t    return {\n   579\t        \"preset_name\": generated.preset_name,\n   580\t        \"description\": generated.description,\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_53","type":"agent_message","text":"Implemented in [selection.py](/home/jack/Documents/github/personal/fly_neural_simulation/flywire_wave_repo/src/flywire_wave/selection.py#L390). `generate_subsets_from_config()` now has two explicit phases: preset artifact generation and `_publish_canonical_active_subset()` publication of the downstream active subset in [selection.py](/home/jack/Documents/github/personal/fly_neural_simulation/flywire_wave_repo/src/flywire_wave/selection.py#L503). The publish step now owns `paths.selected_root_ids` updates and any subset-scoped synapse-registry refresh, while preserving the existing artifact files and CLI behavior. The returned `subset_index` summary now includes a top-level `publication` record plus per-preset `publication` metadata indicating whether the active preset was published, whether `selected_root_ids` was updated, and whether subset-scoped coupling artifacts were refreshed.\n\nCoverage was updated in [test_selection.py](/home/jack/Documents/github/personal/fly_neural_simulation/flywire_wave_repo/tests/test_selection.py#L21) to assert the new publication metadata, the active-preset coupling refresh path, and the no-op alias case on repeated publication.\n\nVerified with `make test` under the repo virtualenv: 330 tests passed."}}
