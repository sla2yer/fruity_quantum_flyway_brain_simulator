6\tfrom .stimulus_contract import (\n    47\t    DEFAULT_RNG_FAMILY,\n    48\t    DEFAULT_TIME_UNIT,\n    49\t    build_stimulus_bundle_reference,\n    50\t    load_stimulus_bundle_metadata,\n    51\t    _normalize_float,\n    52\t    _normalize_identifier,\n    53\t    _normalize_nonempty_string,\n    54\t    _normalize_positive_float,\n    55\t    _normalize_positive_int,\n    56\t)\n    57\tfrom .surface_wave_contract import (\n    58\t    DEFAULT_PROCESSED_SURFACE_WAVE_DIR,\n    59\t    build_surface_wave_model_metadata,\n    60\t    build_surface_wave_model_reference,\n    61\t)\n    62\t\n    63\t\n    64\tSIMULATION_PLAN_VERSION = \"simulation_plan.v1\"\n    65\tSIMULATION_RUNTIME_CONFIG_VERSION = \"simulation_runtime.v1\"\n    66\t\n    67\tSTIMULUS_BUNDLE_INPUT_SOURCE = \"stimulus_bundle\"\n    68\tRETINAL_BUNDLE_INPUT_SOURCE = \"retinal_bundle\"\n    69\tSUPPORTED_INPUT_SOURCE_KINDS = (\n    70\t    STIMULUS_BUNDLE_INPUT_SOURCE,\n    71\t    RETINAL_BUNDLE_INPUT_SOURCE,\n    72\t)\n    73\t\n    74\tDEFAULT_REQUIRE_RECORDED_INPUT_BUNDLE = False\n    75\tDEFAULT_SEED_SCOPE = \"all_stochastic_simulator_components\"\n    76\tDEFAULT_STABLE_ARM_ORDERING = \"manifest_declaration_order\"\n    77\tDEFAULT_SEED_SWEEP_ORDERING = \"manifest_declared_seed_order\"\n    78\tSHARED_READOUT_VALUE_SEMANTICS = \"shared_downstream_activation\"\n    79\t\n    80\tSELECTED_ROOT_IDS_ASSET_ROLE = \"selected_root_ids\"\n    81\tINPUT_BUNDLE_ASSET_ROLE = \"input_bundle\"\n    82\tGEOMETRY_MANIFEST_ASSET_ROLE = \"geometry_manifest\"\n    83\tCOUPLING_REGISTRY_ASSET_ROLE = \"coupling_synapse_registry\"\n    84\t\n    85\tSUBSET_MANIFEST_FILENAME = \"subset_manifest.json\"\n    86\tALLOWED_SIMULATION_CONFIG_KEYS = {\n    87\t    \"version\",\n    88\t    \"input\",\n    89\t    \"timebase\",\n    90\t    \"readout_catalog\",\n    91\t    \"baseline_families\",\n    92\t    \"surface_wave\",\n    93\t    \"determinism\",\n    94\t}\n    95\tALLOWED_INPUT_CONFIG_KEYS = {\n    96\t    \"source_kind\",\n    97\t    \"require_recorded_bundle\",\n    98\t    \"retinal_config_path\",\n    99\t}\n   100\tALLOWED_DETERMINISM_CONFIG_KEYS = {\n   101\t    \"rng_family\",\n   102\t    \"seed_scope\",\n   103\t}\n   104\t\n   105\t_P0_ALLOWED_KEYS = {\n   106\t    \"membrane_time_constant_ms\",\n   107\t    \"resting_potential\",\n   108\t    \"input_gain\",\n   109\t    \"recurrent_gain\",\n   110\t}\n   111\t_P1_ALLOWED_KEYS = {\n   112\t    \"membrane_time_constant_ms\",\n   113\t    \"synaptic_current_time_constant_ms\",\n   114\t    \"resting_potential\",\n   115\t    \"input_gain\",\n   116\t    \"recurrent_gain\",\n   117\t    \"delay_handling\",\n   118\t}\n   119\t_P1_DELAY_ALLOWED_KEYS = {\n   120\t    \"mode\",\n   121\t    \"max_supported_delay_steps\",\n   122\t}\n   123\t\n   124\t\n   125\tdef default_shared_readout_catalog() -> list[dict[str, Any]]:\n   126\t    return [\n   127\t        build_simulator_readout_definition(\n   128\t            readout_id=\"shared_output_mean\",\n   129\t            scope=\"circuit_output\",\n   130\t            aggregation=\"mean_over_root_ids\",\n   131\t            units=\"activation_au\",\n   132\t            value_semantics=\"shared_downstream_activation\",\n   133\t            description=(\n   134\t                \"Shared downstream output mean for matched baseline-versus-wave \"\n   135\t                \"manifest-arm comparisons.\"\n   136\t            ),\n   137\t        )\n   138\t    ]\n   139\t\n   140\t\n   141\tdef default_baseline_family_configs() -> dict[str, dict[str, Any]]:\n   142\t    return {\n   143\t        P0_BASELINE_FAMILY: {\n   144\t            \"family\": P0_BASELINE_FAMILY,\n   145\t            \"model_family\": \"passive_linear_single_compartment\",\n   146\t            \"state_layout\": \"scalar_state_per_selected_root\",\n   147\t            \"integration_scheme\": \"forward_euler\",\n   148\t            \"readout_state\": \"membrane_state\",\n   149\t            \"initial_state\": \"all_zero\",\n   150\t            \"parameters\": {\n   151\t                \"membrane_time_constant_ms\": 10.0,\n   152\t                \"resting_potential\": 0.0,\n   153\t                \"input_gain\": 1.0,\n   154\t                \"recurrent_gain\": 1.0,\n   155\t            },\n   156\t        },\n   157\t        P1_BASELINE_FAMILY: {\n   158\t            \"family\": P1_BASELINE_FAMILY,\n   159\t            \"model_family\": \"reduced_linear_with_synaptic_current\",\n   160\t            \"state_layout\": \"membrane_state_and_synaptic_current_per_selected_root\",\n   161\t            \"integration_scheme\": \"forward_euler\",\n   162\t            \"readout_state\": \"membrane_state\",\n   163\t            \"initial_state\": \"all_zero\",\n   164\t            \"parameters\": {\n   165\t                \"membrane_time_constant_ms\": 10.0,\n   166\t                \"synaptic_current_time_constant_ms\": 5.0,\n   167\t                \"resting_potential\": 0.0,\n   168\t                \"input_gain\": 1.0,\n   169\t                \"recurrent_gain\": 1.0,\n   170\t                \"delay_handling\": {\n   171\t                    \"mode\": \"from_coupling_bundle\",\n   172\t                    \"max_supported_delay_steps\": 64,\n   173\t                },\n   174\t            },\n   175\t        },\n   176\t    }\n   177\t\n   178\t\n   179\tdef default_simulation_runtime_config(\n   180\t    *,\n   181\t    default_timebase: Mapping[str, Any],\n   182\t    project_root: str | Path | None = None,\n   183\t) -> dict[str, Any]:\n   184\t    return normalize_simulation_runtime_config(\n   185\t        {},\n   186\t        default_timebase=default_timebase,\n   187\t        project_root=project_root,\n   188\t    )\n   189\t\n   190\t\n   191\tdef normalize_simulation_runtime_config(\n   192\t    payload: Mapping[str, Any] | None,\n   193\t    *,\n   194\t    default_timebase: Mapping[str, Any],\n   195\t    project_root: str | Path | None = None,\n   196\t) -> dict[str, Any]:\n   197\t    raw_payload = dict(payload or {})\n   198\t    unknown_top_level_keys = sorted(set(raw_payload) - ALLOWED_SIMULATION_CONFIG_KEYS)\n   199\t    if unknown_top_level_keys:\n   200\t        raise ValueError(\n   201\t            \"simulation contains unsupported keys: \"\n   202\t            f\"{unknown_top_level_keys!r}.\"\n   203\t        )\n   204\t\n   205\t    resolved_project_root = _resolve_project_root(project_root)\n   206\t    version = raw_payload.get(\"version\", SIMULATION_RUNTIME_CONFIG_VERSION)\n   207\t    normalized_version = _normalize_nonempty_string(version, field_name=\"simulation.version\")\n   208\t    if normalized_version != SIMULATION_RUNTIME_CONFIG_VERSION:\n   209\t        raise ValueError(\n   210\t            \"simulation.version must be \"\n   211\t            f\"{SIMULATION_RUNTIME_CONFIG_VERSION!r}.\"\n   212\t        )\n   213\t\n   214\t    normalized_timebase = _normalize_runtime_timebase(\n   215\t        raw_payload.get(\"timebase\"),\n   216\t        default_timebase=default_timebase,\n   217\t    )\n   218\t    normalized_input = _normalize_input_config(\n   219\t        raw_payload.get(\"input\"),\n   220\t        project_root=resolved_project_root,\n   221\t    )\n   222\t    normalized_determinism = _normalize_runtime_determinism(raw_payload.get(\"determinism\"))\n   223\t    normalized_readout_catalog = _normalize_readout_catalog(\n   224\t        raw_payload.get(\"readout_catalog\")\n   225\t    )\n   226\t    normalized_shared_readout_catalog = _normalize_shared_readout_catalog(\n   227\t        normalized_readout_catalog\n   228\t    )\n   229\t    normalized_baseline_families = _normalize_baseline_family_configs(\n   230\t        raw_payload.get(\"baseline_families\")\n   231\t    )\n   232\t    normalized_surface_wave_model = build_surface_wave_model_metadata(\n   233\t        processed_surface_wave_dir=resolved_project_root / DEFAULT_PROCESSED_SURFACE_WAVE_DIR,\n   234\t        parameter_bundle=raw_payload.get(\"surface_wave\"),\n   235\t    )\n   236\t\n   237\t    return {\n   238\t        \"version\": normalized_version,\n   239\t        \"time_unit\": DEFAULT_TIME_UNIT,\n   240\t        \"timebase\": normalized_timebase,\n   241\t        \"input\": normalized_input,\n   242\t        \"determinism\": normalized_determinism,\n   243\t        \"readout_catalog\": normalized_readout_catalog,\n   244\t        \"shared_readout_catalog\": normalized_shared_readout_catalog,\n   245\t        \"baseline_families\": normalized_baseline_families,\n   246\t        \"surface_wave_model\": normalized_surface_wave_model,\n   247\t    }\n   248\t\n   249\t\n   250\tdef resolve_manifest_simulation_plan(\n   251\t    *,\n   252\t    manifest_path: str | Path,\n   253\t    config_path: str | Path,\n   254\t    schema_path: str | Path,\n   255\t    design_lock_path: str | Path,\n   256\t) -> dict[str, Any]:\n   257\t    manifest_file = Path(manifest_path).resolve()\n   258\t    schema_file = Path(schema_path).resolve()\n   259\t    design_lock_file = Path(design_lock_path).resolve()\n   260\t\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_75","type":"command_execution","command":"/bin/bash -lc \"nl -ba docs/surface_wave_model_design.md | sed -n '1,260p'\"","aggregated_output":"     1\t# Surface Wave Model Design\n     2\t\n     3\t## Purpose\n     4\t\n     5\tMilestone 10 needs one first-class wave-model contract before solver code,\n     6\tplanning, result serialization, and validation start encoding scientific choices\n     7\tin incompatible places. The versioned software contract is\n     8\t`surface_wave_model.v1`, implemented in `flywire_wave.surface_wave_contract`.\n     9\t\n    10\tThis note reuses three earlier milestone decisions instead of reopening them:\n    11\t\n    12\t- Milestone 1 fixes the fairness claim. The wave mode may add morphology-bound\n    13\t  intraneuronal state and nothing else that trivially explains a comparison gap.\n    14\t- Milestone 6 fixes the operator assumptions. The spatial operator is symmetric,\n    15\t  positive semidefinite after mass normalization, and any stable time-step rule\n    16\t  must derive from the relevant operator spectrum rather than graph-degree\n    17\t  heuristics.\n    18\t- Milestone 9 fixes the shared comparison surface. Wave-only state details may\n    19\t  add metadata or extension artifacts, but shared readouts still land on the\n    20\t  same declared simulator timebase.\n    21\t\n    22\t## Candidate Model Families\n    23\t\n    24\tMilestone 10 named five viable families. The contract compares them at the\n    25\tlevel needed to choose a default:\n    26\t\n    27\t| Roadmap family | Strength | Reason not chosen as the v1 default |\n    28\t| --- | --- | --- |\n    29\t| `damped_wave_system` | Clean finite-speed propagation and direct use of Milestone 6 operators | Too narrow by itself: recovery, synaptic source semantics, and later readout coupling would still need a second informal layer |\n    30\t| `diffusion_like_neural_field` | Simple and stable | Parabolic spread blurs finite-speed wavefront claims and makes Milestone 10 less diagnostic relative to baseline mode |\n    31\t| `excitable_medium` | Natural refractory structure and traveling fronts | Too nonlinear and parameter-heavy for the first fairness-locked implementation |\n    32\t| `reaction_diffusion_system` | Rich morphology-sensitive dynamics | Strong scientific flexibility, but too much freedom for the first contract and too much risk of fitting morphology-specific effects |\n    33\t| `hybrid_field_readout_system` | Keeps one auditable surface field while naming optional recovery and readout mechanics explicitly | Chosen default |\n    34\t\n    35\t## Chosen Family\n    36\t\n    37\tThe selected roadmap family is `hybrid_field_readout_system`.\n    38\t\n    39\t`surface_wave_model.v1` realizes that family as one canonical software model\n    40\tfamily:\n    41\t\n    42\t- model family: `hybrid_damped_wave_recovery`\n    43\t- default state layout: `surface_activation_velocity_optional_recovery`\n    44\t- default readout state: `surface_activation`\n    45\t- default solver family: `semi_implicit_velocity_split`\n    46\t\n    47\tThis is intentionally conservative. The core is a damped surface-wave system,\n    48\twhile recovery, nonlinearity, anisotropy, and branching are named extension\n    49\tslots with explicit mode identifiers. Disabled or identity modes are part of the\n    50\tcontract, not informal omissions.\n    51\t\n    52\t## State Variables\n    53\t\n    54\tThe canonical state catalog is:\n    55\t\n    56\t- `surface_activation` (`u`, units `activation_au`): the primary\n    57\t  morphology-bound activation field\n    58\t- `surface_velocity` (`v`, units `activation_au_per_ms`): the time derivative\n    59\t  of `surface_activation`\n    60\t- `recovery_state` (`r`, units `unitless`): an optional local refractory budget\n    61\t  that is disabled in the default v1 preset but already named in the contract\n    62\t\n    63\tThe shared comparison readout samples `surface_activation`. Wave-only auxiliary\n    64\tstate remains wave-only metadata unless a later contract revision explicitly\n    65\tpromotes it.\n    66\t\n    67\t## Canonical Dynamics\n    68\t\n    69\tThe contract freezes the meaning of the terms even before the full solver lands.\n    70\tIn words, the v1 family evolves\n    71\t\n    72\t- one primary surface field `u`\n    73\t- one velocity-like auxiliary field `v`\n    74\t- one optional recovery field `r`\n    75\t\n    76\twith the intended continuous-time structure\n    77\t\n    78\t`du/dt = v`\n    79\t\n    80\t`dv/dt = -c_prop^2 A u - gamma v - k_rest u - k_rec r + I_syn + I_ext - N(u)`\n    81\t\n    82\t`tau_rec dr/dt = G(u) - r` when recovery is enabled\n    83\t\n    84\twhere:\n    85\t\n    86\t- `A` is the positive semidefinite mass-normalized surface operator from\n    87\t  Milestone 6\n    88\t- `c_prop^2` is the contract's `wave_speed_sq_scale`\n    89\t- `gamma` is linear velocity damping\n    90\t- `k_rest` is a weak restoring sink used to suppress unbounded DC drift\n    91\t- `k_rec r` is the optional recovery-mediated sink\n    92\t- `I_syn` is the connectome-constrained synaptic source term\n    93\t- `N(u)` is an optional saturating nonlinearity\n    94\t\n    95\tThe default v1 preset keeps recovery disabled, nonlinearity disabled,\n    96\tanisotropy isotropic, and branching disabled. Those choices are deliberate:\n    97\tthey keep the first solver auditable while still reserving stable mode names for\n    98\tlater Milestone 10 tickets.\n    99\t\n   100\t## Synaptic Source Semantics\n   101\t\n   102\t`surface_wave_model.v1` does not invent a new coupling contract. It reuses the\n   103\tMilestone 7 sign, delay, aggregation, and fallback semantics and only fixes how\n   104\tthose sources enter the wave state:\n   105\t\n   106\t- presynaptic source state: `surface_activation`\n   107\t- postsynaptic injection target: `surface_velocity`\n   108\t- source mode: `coupling_anchor_current`\n   109\t- delay semantics: taken from `coupling_bundle.v1`\n   110\t- sign semantics: taken from `coupling_bundle.v1`\n   111\t- aggregation semantics: preserve sign and delay bins before summation\n   112\t- landing support: the postsynaptic patch cloud or whichever contract-approved\n   113\t  landing anchor the coupling bundle records\n   114\t\n   115\tThe wave model is not allowed to add hand-fitted per-synapse delays, extra\n   116\tedges, or extra signs. Those remain Milestone 1 fairness violations.\n   117\t\n   118\t## Optional Mechanics\n   119\t\n   120\t### Recovery\n   121\t\n   122\tSupported recovery modes:\n   123\t\n   124\t- `disabled`\n   125\t- `activity_driven_first_order`\n   126\t\n   127\tThe first enabled recovery mode is intentionally modest: it uses rectified local\n   128\tactivation as the drive and relaxes back to baseline with one time constant.\n   129\tLater tickets may implement that mode, but they may not silently change what the\n   130\tmode means.\n   131\t\n   132\t### Nonlinearity\n   133\t\n   134\tSupported nonlinearity modes:\n   135\t\n   136\t- `none`\n   137\t- `tanh_soft_clip`\n   138\t\n   139\tThe first nonlinear mode is a bounded amplitude soft clip. It is meant to limit\n   140\tobviously unphysical amplitude blow-up, not to create a second hidden decoder.\n   141\t\n   142\t### Anisotropy\n   143\t\n   144\tSupported anisotropy modes:\n   145\t\n   146\t- `isotropic`\n   147\t- `operator_embedded`\n   148\t\n   149\t`operator_embedded` must consume declared Milestone 6 anisotropy metadata or an\n   150\tequivalent contract-approved operator realization. It may not change topology or\n   151\t invent new directions unavailable in the operator bundle.\n   152\t\n   153\t### Branching\n   154\t\n   155\tSupported branching modes:\n   156\t\n   157\t- `disabled`\n   158\t- `descriptor_scaled_damping`\n   159\t\n   160\tThe first branching extension is deliberately narrow. It may scale a local\n   161\tdamping-like modifier from existing geometry descriptors, but it may not become\n   162\ta free per-neuron fitting channel.\n   163\t\n   164\t## Stability-Relevant Assumptions\n   165\t\n   166\tLater execution and validation tickets may rely on these assumptions:\n   167\t\n   168\t- the realized surface operator is symmetric and positive semidefinite in the\n   169\t  same inner product documented by Milestone 6\n   170\t- damping, recovery, nonlinearity, and branching modifiers are dissipative or\n   171\t  neutral in their default or identity modes\n   172\t- the main time-step guard is spectral: any explicit or split-step stability\n   173\t  bound is derived from the largest relevant eigenvalue of the realized operator\n   174\t- identity anisotropy and disabled branching must reproduce the simpler isotropic\n   175\t  no-branching dynamics within solver tolerance\n   176\t- shared readouts must be emitted on the Milestone 9 simulator timebase even if\n   177\t  the wave solver later uses internal substeps\n   178\t- any source injection must preserve Milestone 7 sign, delay, and aggregation\n   179\t  semantics\n   180\t\n   181\tRecommended review ranges for the first local sweeps:\n   182\t\n   183\t- `cfl_safety_factor`: `(0, 1]`, with `0.2` to `0.8` preferred\n   184\t- `wave_speed_sq_scale`: positive and order-one relative to the realized\n   185\t  operator spectrum\n   186\t- `gamma_per_ms`: non-negative, usually small enough that propagation still\n   187\t  remains visible\n   188\t- `restoring_strength_per_ms2`: non-negative and weaker than the main spatial\n   189\t  term\n   190\t- recovery coupling and branching gains: non-negative and modest enough that\n   191\t  they perturb, not dominate, the linear core\n   192\t\n   193\t## Physically Meaningful Behavior Versus Numerical Artifact\n   194\t\n   195\tLater tickets should classify results with the following distinction in mind.\n   196\t\n   197\tPhysically meaningful, contract-compatible behavior:\n   198\t\n   199\t- finite-speed spread shaped by morphology and geodesic structure\n   200\t- damped decay in the absence of persistent drive\n   201\t- small but reproducible timing differences between intact and geometry-shuffled\n   202\t  conditions\n   203\t- optional anisotropy or branching effects that disappear when those modes are\n   204\t  reset to identity\n   205\t- stability conclusions that persist when the same run is repeated with the same\n   206\t  seed and contract metadata\n   207\t\n   208\tNumerical artifact warnings:\n   209\t\n   210\t- growth from rest without source, declared instability, or enabled positive\n   211\t  feedback\n   212\t- checkerboard or mesh-local oscillations that track vertex layout rather than\n   213\t  morphology\n   214\t- strong dependence on update ordering, serialization order, or dictionary key\n   215\t  order\n   216\t- sign reversals or delay shifts caused only by the timestep choice\n   217\t- effects that disappear when `dt` is reduced modestly or when identity\n   218\t  anisotropy/branching modes are restored\n   219\t- morphology effects that can only be reproduced by undocumented per-neuron\n   220\t  tuning\n   221\t\n   222\t## Invariants For Later Milestone 10 Tickets\n   223\t\n   224\tLater Milestone 10 execution, sweep, metrics, and validation work must preserve\n   225\tthese invariants unless the contract version changes:\n   226\t\n   227\t- `surface_wave` remains the simulator `model_mode`, and\n   228\t  `hybrid_damped_wave_recovery` remains the default wave model family for\n   229\t  `surface_wave_model.v1`\n   230\t- state IDs, units, and the default readout state do not drift\n   231\t- the meaning of the named modes\n   232\t  `semi_implicit_velocity_split`, `activity_driven_first_order`,\n   233\t  `tanh_soft_clip`, `operator_embedded`, and `descriptor_scaled_damping` stays\n   234\t  fixed\n   235\t- wave-only metadata remains discoverable from contract-owned metadata rather\n   236\t  than solver-local constants or hardcoded filenames\n   237\t- any future change that alters the family name, state catalog, parameter\n   238\t  schema, or mode semantics is a new contract version, not a silent edit\n","exit_code":0,"status":"completed"}}
