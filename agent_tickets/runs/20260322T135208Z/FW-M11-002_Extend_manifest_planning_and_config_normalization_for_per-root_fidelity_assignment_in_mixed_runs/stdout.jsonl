n\\\\\\\\\\\\\\\\nCOLLAPSE_DELAY_WITH_WEIGHTED_MEAN_AGGREGATION = (\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sum_over_synapses_preserving_sign_with_weighted_mean_delay\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n)\\\\\\\\\\\\\\\\nSUPPORTED_AGGREGATION_RULES = (\\\\\\\\\\\\\\\\n    DEFAULT_AGGREGATION_RULE,\\\\\\\\\\\\\\\\n    COLLAPSE_DELAY_WITH_WEIGHTED_MEAN_AGGREGATION,\\\\\\\\\\\\\\\\n)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nSUM_TO_ONE_PER_COMPONENT_NORMALIZATION = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sum_to_one_per_component\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\nNO_CLOUD_NORMALIZATION = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"none\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\nSUPPORTED_CLOUD_NORMALIZATIONS = (\\\\\\\\\\\\\\\\n    SUM_TO_ONE_PER_COMPONENT_NORMALIZATION,\\\\\\\\\\\\\\\\n    NO_CLOUD_NORMALIZATION,\\\\\\\\\\\\\\\\n)\\\\\\\\\\\\\\\\nDEFAULT_SOURCE_CLOUD_NORMALIZATION = SUM_TO_ONE_PER_COMPONENT_NORMALIZATION\\\\\\\\\\\\\\\\nDEFAULT_TARGET_CLOUD_NORMALIZATION = SUM_TO_ONE_PER_COMPONENT_NORMALIZATION\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nLOCAL_SYNAPSE_REGISTRY_KEY = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"local_synapse_registry\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\nINCOMING_ANCHOR_MAP_KEY = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"incoming_anchor_map\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\nOUTGOING_ANCHOR_MAP_KEY = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"outgoing_anchor_map\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\nCOUPLING_INDEX_KEY = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"coupling_index\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nREQUIRED_COUPLING_ASSET_KEYS = (\\\\\\\\\\\\\\\\n    LOCAL_SYNAPSE_REGISTRY_KEY,\\\\\\\\\\\\\\\\n    INCOMING_ANCHOR_MAP_KEY,\\\\\\\\\\\\\\\\n    OUTGOING_ANCHOR_MAP_KEY,\\\\\\\\\\\\\\\\n    COUPLING_INDEX_KEY,\\\\\\\\\\\\\\\\n)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n@dataclass(frozen=True)\\\\\\\\\\\\\\\\nclass CouplingContractPaths:\\\\\\\\\\\\\\\\n    processed_coupling_dir: Path\\\\\\\\\\\\\\\\