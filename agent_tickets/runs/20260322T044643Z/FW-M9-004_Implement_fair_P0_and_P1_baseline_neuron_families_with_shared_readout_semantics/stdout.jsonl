{"type":"item.completed","item":{"id":"item_50","type":"command_execution","command":"/bin/bash -lc \"nl -ba tests/test_baseline_families.py | sed -n '1,260p'\"","aggregated_output":"     1\tfrom __future__ import annotations\n     2\t\n     3\timport copy\n     4\timport sys\n     5\timport unittest\n     6\tfrom pathlib import Path\n     7\t\n     8\timport numpy as np\n     9\t\n    10\tROOT = Path(__file__).resolve().parents[1]\n    11\tSRC = ROOT / \"src\"\n    12\tsys.path.insert(0, str(SRC))\n    13\t\n    14\tfrom flywire_wave.baseline_families import (\n    15\t    DELAY_FROM_COUPLING_BUNDLE_MODE,\n    16\t    MEMBRANE_READOUT_STATE,\n    17\t    SYNAPTIC_CURRENT_STATE,\n    18\t    resolve_baseline_neuron_family,\n    19\t    resolve_baseline_neuron_family_from_arm_plan,\n    20\t)\n    21\tfrom flywire_wave.simulation_planning import default_baseline_family_configs\n    22\tfrom flywire_wave.simulator_result_contract import (\n    23\t    P0_BASELINE_FAMILY,\n    24\t    P1_BASELINE_FAMILY,\n    25\t    build_simulator_arm_reference,\n    26\t    build_simulator_determinism,\n    27\t    build_simulator_manifest_reference,\n    28\t    build_simulator_readout_definition,\n    29\t)\n    30\tfrom flywire_wave.simulator_runtime import (\n    31\t    SimulationRunBlueprint,\n    32\t    SimulationRuntimeState,\n    33\t    SimulationStepContext,\n    34\t    SimulatorRun,\n    35\t)\n    36\t\n    37\t\n    38\tclass BaselineFamiliesTest(unittest.TestCase):\n    39\t    def test_p0_family_uses_passive_membrane_dynamics_with_shared_readout_aggregations(self) -> None:\n    40\t        family_spec = copy.deepcopy(default_baseline_family_configs()[P0_BASELINE_FAMILY])\n    41\t        family_spec[\"parameters\"][\"membrane_time_constant_ms\"] = 4.0\n    42\t        family_spec[\"parameters\"][\"input_gain\"] = 2.0\n    43\t        family_spec[\"parameters\"][\"recurrent_gain\"] = 0.0\n    44\t        arm_plan = _build_arm_plan(\n    45\t            family_spec=family_spec,\n    46\t            readout_catalog=[\n    47\t                build_simulator_readout_definition(\n    48\t                    readout_id=\"shared_output_mean\",\n    49\t                    scope=\"circuit_output\",\n    50\t                    aggregation=\"mean_over_root_ids\",\n    51\t                    units=\"activation_au\",\n    52\t                    value_semantics=\"shared_downstream_activation\",\n    53\t                    description=\"Shared downstream mean output.\",\n    54\t                ),\n    55\t                build_simulator_readout_definition(\n    56\t                    readout_id=\"shared_output_sum\",\n    57\t                    scope=\"circuit_output\",\n    58\t                    aggregation=\"sum_over_root_ids\",\n    59\t                    units=\"activation_au\",\n    60\t                    value_semantics=\"shared_downstream_activation\",\n    61\t                    description=\"Shared downstream summed output.\",\n    62\t                ),\n    63\t            ],\n    64\t            root_ids=[101, 202],\n    65\t            sample_count=4,\n    66\t            dt_ms=1.0,\n    67\t        )\n    68\t\n    69\t        family = resolve_baseline_neuron_family_from_arm_plan(arm_plan)\n    70\t        self.assertEqual(family.spec.family, P0_BASELINE_FAMILY)\n    71\t        self.assertEqual(\n    72\t            tuple(variable.state_id for variable in family.state_variables),\n    73\t            (MEMBRANE_READOUT_STATE,),\n    74\t        )\n    75\t        self.assertEqual(\n    76\t            {\n    77\t                mapping.readout_id: mapping.aggregation\n    78\t                for mapping in family.shared_readout_mappings\n    79\t            },\n    80\t            {\n    81\t                \"shared_output_mean\": \"mean_over_root_ids\",\n    82\t                \"shared_output_sum\": \"sum_over_root_ids\",\n    83\t            },\n    84\t        )\n    85\t\n    86\t        run = SimulatorRun(\n    87\t            run_blueprint=SimulationRunBlueprint.from_arm_plan(arm_plan),\n    88\t            engine=family.build_engine(),\n    89\t            drive_provider=_SequenceDriveProvider(\n    90\t                [\n    91\t                    [1.0, 0.0],\n    92\t                    [1.0, 0.0],\n    93\t                    [1.0, 0.0],\n    94\t                    [1.0, 0.0],\n    95\t                ]\n    96\t            ),\n    97\t        )\n    98\t        result = run.run_to_completion()\n    99\t\n   100\t        np.testing.assert_allclose(\n   101\t            result.readout_traces.values,\n   102\t            [\n   103\t                [0.0, 0.0],\n   104\t                [0.25, 0.5],\n   105\t                [0.4375, 0.875],\n   106\t                [0.578125, 1.15625],\n   107\t            ],\n   108\t        )\n   109\t        np.testing.assert_allclose(\n   110\t            result.final_snapshot.dynamic_state,\n   111\t            [1.3671875, 0.0],\n   112\t        )\n   113\t        np.testing.assert_allclose(\n   114\t            result.final_snapshot.readout_values,\n   115\t            [0.68359375, 1.3671875],\n   116\t        )\n   117\t        summary_by_state = {\n   118\t            row[\"state_id\"]: row[\"value\"] for row in result.final_snapshot.state_summary_records()\n   119\t        }\n   120\t        self.assertEqual(\n   121\t            sorted(summary_by_state),\n   122\t            [\n   123\t                \"circuit_membrane_state\",\n   124\t                \"root_101_membrane_state\",\n   125\t                \"root_202_membrane_state\",\n   126\t            ],\n   127\t        )\n   128\t        self.assertAlmostEqual(summary_by_state[\"circuit_membrane_state\"], 0.68359375)\n   129\t        self.assertAlmostEqual(summary_by_state[\"root_101_membrane_state\"], 1.3671875)\n   130\t        self.assertAlmostEqual(summary_by_state[\"root_202_membrane_state\"], 0.0)\n   131\t\n   132\t    def test_p1_family_adds_synaptic_current_and_identity_shared_readout(self) -> None:\n   133\t        family_spec = copy.deepcopy(default_baseline_family_configs()[P1_BASELINE_FAMILY])\n   134\t        family_spec[\"parameters\"][\"membrane_time_constant_ms\"] = 4.0\n   135\t        family_spec[\"parameters\"][\"synaptic_current_time_constant_ms\"] = 2.0\n   136\t        family_spec[\"parameters\"][\"input_gain\"] = 1.0\n   137\t        family_spec[\"parameters\"][\"recurrent_gain\"] = 0.0\n   138\t        arm_plan = _build_arm_plan(\n   139\t            family_spec=family_spec,\n   140\t            readout_catalog=[\n   141\t                build_simulator_readout_definition(\n   142\t                    readout_id=\"shared_output_identity\",\n   143\t                    scope=\"circuit_output\",\n   144\t                    aggregation=\"identity\",\n   145\t                    units=\"activation_au\",\n   146\t                    value_semantics=\"shared_downstream_activation\",\n   147\t                    description=\"Shared downstream output for a one-root fixture.\",\n   148\t                )\n   149\t            ],\n   150\t            root_ids=[101],\n   151\t            sample_count=4,\n   152\t            dt_ms=1.0,\n   153\t        )\n   154\t\n   155\t        family = resolve_baseline_neuron_family_from_arm_plan(arm_plan)\n   156\t        self.assertEqual(family.spec.family, P1_BASELINE_FAMILY)\n   157\t        self.assertEqual(\n   158\t            tuple(variable.state_id for variable in family.state_variables),\n   159\t            (MEMBRANE_READOUT_STATE, SYNAPTIC_CURRENT_STATE),\n   160\t        )\n   161\t        self.assertEqual(\n   162\t            family.spec.parameters.delay_handling.mode,\n   163\t            DELAY_FROM_COUPLING_BUNDLE_MODE,\n   164\t        )\n   165\t\n   166\t        run = SimulatorRun(\n   167\t            run_blueprint=SimulationRunBlueprint.from_arm_plan(arm_plan),\n   168\t            engine=family.build_engine(),\n   169\t            drive_provider=_SequenceDriveProvider(\n   170\t                [\n   171\t                    [1.0],\n   172\t                    [0.0],\n   173\t                    [0.0],\n   174\t                    [0.0],\n   175\t                ]\n   176\t            ),\n   177\t        )\n   178\t        result = run.run_to_completion()\n   179\t\n   180\t        np.testing.assert_allclose(\n   181\t            result.readout_traces.values[:, 0],\n   182\t            [0.0, 0.125, 0.15625, 0.1484375],\n   183\t        )\n   184\t        np.testing.assert_allclose(\n   185\t            result.final_snapshot.dynamic_state,\n   186\t            [0.126953125],\n   187\t        )\n   188\t        np.testing.assert_allclose(\n   189\t            result.final_snapshot.readout_values,\n   190\t            [0.126953125],\n   191\t        )\n   192\t        summary_by_state = {\n   193\t            row[\"state_id\"]: row[\"value\"] for row in result.final_snapshot.state_summary_records()\n   194\t        }\n   195\t        self.assertAlmostEqual(summary_by_state[\"circuit_membrane_state\"], 0.126953125)\n   196\t        self.assertAlmostEqual(summary_by_state[\"root_101_membrane_state\"], 0.126953125)\n   197\t        self.assertAlmostEqual(summary_by_state[\"circuit_synaptic_current_state\"], 0.0625)\n   198\t        self.assertAlmostEqual(summary_by_state[\"root_101_synaptic_current_state\"], 0.0625)\n   199\t\n   200\t    def test_invalid_or_non_shared_specs_fail_clearly(self) -> None:\n   201\t        p0_spec = copy.deepcopy(default_baseline_family_configs()[P0_BASELINE_FAMILY])\n   202\t        p0_spec[\"parameters\"][\"resting_potential\"] = 1.0\n   203\t        with self.assertRaises(ValueError) as resting_ctx:\n   204\t            resolve_baseline_neuron_family(\n   205\t                p0_spec,\n   206\t                readout_catalog=[_shared_mean_readout()],\n   207\t            )\n   208\t        self.assertIn(\"resting_potential == 0.0\", str(resting_ctx.exception))\n   209\t\n   210\t        p1_spec = copy.deepcopy(default_baseline_family_configs()[P1_BASELINE_FAMILY])\n   211\t        p1_spec[\"parameters\"][\"delay_handling\"][\"mode\"] = \"mystery_delay\"\n   212\t        with self.assertRaises(ValueError) as delay_ctx:\n   213\t            resolve_baseline_neuron_family(\n   214\t                p1_spec,\n   215\t                readout_catalog=[_shared_mean_readout()],\n   216\t            )\n   217\t        self.assertIn(\"Unsupported P1.delay_handling.mode\", str(delay_ctx.exception))\n   218\t\n   219\t        with self.assertRaises(ValueError) as readout_ctx:\n   220\t            resolve_baseline_neuron_family(\n   221\t                default_baseline_family_configs()[P0_BASELINE_FAMILY],\n   222\t                readout_catalog=[\n   223\t                    build_simulator_readout_definition(\n   224\t                        readout_id=\"direction_selectivity_index\",\n   225\t                        scope=\"comparison_panel\",\n   226\t                        aggregation=\"identity\",\n   227\t                        units=\"unitless\",\n   228\t                        value_semantics=\"direction_selectivity_index\",\n   229\t                        description=\"Derived metric, not a shared per-step readout.\",\n   230\t                    )\n   231\t                ],\n   232\t            )\n   233\t        self.assertIn(\"support only shared readout semantics\", str(readout_ctx.exception))\n   234\t\n   235\t\n   236\tclass _SequenceDriveProvider:\n   237\t    def __init__(self, samples: list[list[float]]) -> None:\n   238\t        self._samples = [np.asarray(sample, dtype=np.float64) for sample in samples]\n   239\t\n   240\t    def resolve_exogenous_drive(\n   241\t        self,\n   242\t        *,\n   243\t        run_blueprint: SimulationRunBlueprint,\n   244\t        runtime_state: SimulationRuntimeState[object],\n   245\t        context: SimulationStepContext,\n   246\t    ) -> np.ndarray:\n   247\t        del run_blueprint, context\n