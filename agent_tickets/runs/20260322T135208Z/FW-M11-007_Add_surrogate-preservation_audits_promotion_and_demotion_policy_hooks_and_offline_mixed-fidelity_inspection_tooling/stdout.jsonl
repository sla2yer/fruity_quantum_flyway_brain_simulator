: registry_default_morphology_class,\n  2263\t        \"arm_default_morphology_class\": arm_default_morphology_class,\n  2264\t        \"arm_root_override_morphology_class\": arm_root_override_morphology_class,\n  2265\t        \"promotion_mode\": str(assignment_policy[\"promotion_mode\"]),\n  2266\t        \"demotion_mode\": str(assignment_policy[\"demotion_mode\"]),\n  2267\t        \"policy_applied\": False,\n  2268\t        \"policy_evaluated\": True,\n  2269\t        \"policy_recommended_morphology_class\": str(\n  2270\t            policy_evaluation[\"recommended_morphology_class\"]\n  2271\t        ),\n  2272\t        \"policy_recommendation_relation\": str(\n  2273\t            policy_evaluation[\"recommended_relation_to_realized\"]\n  2274\t        ),\n  2275\t        \"resolved_from\": resolved_from,\n  2276\t    }\n  2277\t\n  2278\t\n  2279\tdef _build_approximation_route(\n  2280\t    *,\n  2281\t    registry_default_morphology_class: str,\n  2282\t    realized_morphology_class: str,\n  2283\t    policy_evaluation: Mapping[str, Any],\n  2284\t) -> dict[str, Any]:\n  2285\t    rank_delta = (\n  2286\t        _morphology_class_rank(realized_morphology_class)\n  2287\t        - _morphology_class_rank(registry_default_morphology_class)\n  2288\t    )\n  2289\t    if rank_delta == 0:\n  2290\t        relation = \"same_as_registry_default\"\n  2291\t    elif rank_delta > 0:\n  2292\t        relation = \"promoted_from_registry_default\"\n  2293\t    else:\n  2294\t        relation = \"demoted_from_registry_default\"\n  2295\t    return {\n  2296\t        \"route_id\": (\n  2297\t            f\"{registry_default_morphology_class}_to_\"\n  2298\t            f\"{realized_morphology_class}\"\n  2299\t        ),\n  2300\t        \"registry_default_morphology_class\": registry_default_morphology_class,\n  2301\t        \"realized_morphology_class\": realized_morphology_class,\n  2302\t        \"relation_to_registry_default\": relation,\n  2303\t        \"promotion_rank_delta\": rank_delta,\n  2304\t        \"policy_action\": str(policy_evaluation[\"recommended_relation_to_realized\"]),\n  2305\t        \"policy_recommended_morphology_class\": str(\n  2306\t            policy_evaluation[\"recommended_morphology_class\"]\n  2307\t        ),\n  2308\t    }\n  2309\t\n  2310\t\n  2311\tdef _morphology_class_rank(value: str) -> int:\n  2312\t    return HYBRID_MORPHOLOGY_PROMOTION_ORDER.index(value)\n  2313\t\n  2314\t\n  2315\tdef _build_local_asset_reference_map(\n","exit_code":0,"status":"completed"}}
