     capture_output=True,\\n   175\\t            text=True,\\n   176\\t            check=False,\\n   177\\t        )\\n   178\\t        if expect_success and result.returncode != 0:\\n   179\\t            self.fail(\\n   180\\t                f\\\"{script_name} failed with code {result.returncode}\\\\n\\\"\\n   181\\t                f\\\"stdout:\\\\n{result.stdout}\\\\n\\\"\\n   182\\t                f\\\"stderr:\\\\n{result.stderr}\\\"\\n   183\\t            )\\n   184\\t        return result\\n   185\\t\\n   186\\t\\n   187\\tdef _write_pipeline_fixture(fixture_dir: Path, fixture_rel: Path) -> Path:\\n   188\\t    raw_dir = fixture_dir / \\\"raw\\\" / \\\"codex\\\"\\n   189\\t    raw_dir.mkdir(parents=True)\\n   190\\t\\n   191\\t    (raw_dir / \\\"classification.csv\\\").write_text(\\n   192\\t        \\\"\\\\n\\\".join(\\n   193\\t            [\\n   194\\t                \\\"root_id,flow,super_class,class,sub_class,hemilineage,side,nerve\\\",\\n   195\\t                \\\"101,intrinsic,optic,optic_lobe_intrinsic,t5_neuron,,right,\\\",\\n   196\\t                \\\"102,intrinsic,optic,optic_lobe_intrinsic,transmedullary,,right,\\\",\\n   197\\t            ]\\n   198\\t        )\\n   199\\t        + \\\"\\\\n\\\",\\n   200\\t        encoding=\\\"utf-8\\\",\\n   201\\t    )\\n   202\\t    (raw_dir / \\\"cell_types.csv\\\").write_text(\\n   203\\t        \\\"\\\\n\\\".join(\\n   204\\t            [\\n   205\\t                \\\"root_id,primary_type,additional_type(s)\\\",\\n   206\\t                \\\"101,T5a,\\\",\\n   207\\t                \\\"102,Tm1,\\\",\\n   208\\t            ]\\n   209\\t        )\\n   210\\t        + \\\"\\\\n\\\",\\n   211\\t        encoding=\\\"utf-8\\\",\\n   212\\t    )\\n   213\\t    (raw_dir / \\\"connections_filtered.csv\\\").write_text(\\n   214\\t        \\\"\\\\n\\\".join(\\n   215\\t            [\\n   216\\t                \\\"pre_root_id,post_root_id,neuropil,syn_count,nt_type\\\",\\n   217\\t                \\\"101,102,LOP_R,12,ACH\\\",\\n   218\\t            ]\\n   219\\t        )\\n   220\\t        + \\\"\\\\n\\\",\\n   221\\t        encoding=\\\"utf-8\\\",\\n   222\\t    )\\n   223\\t    (raw_dir / \\\"neurotransmitter_type_predictions.csv\\\").write_text(\\n   224\\t        \\\"\\\\n\\\".join(\\n   225\\t            [\\n   226\\t                \\\"root_id,group,nt_type,nt_type_score,da_avg,ser_avg,gaba_avg,glut_avg,ach_avg,oct_avg\\\",\\n   227\\t                \\\"101,LO.LOP,ACH,0.71,0.0,0.0,0.0,0.0,0.71,0.0\\\",\\n   228\\t                \\\"102,ME,ACH,0.61,0.0,0.0,0.0,0.0,0.61,0.0\\\",\\n   229\\t            ]\\n   230\\t        )\\n   231\\t        + \\\"\\\\n\\\",\\n   232\\t        encoding=\\\"utf-8\\\",\\n   233\\t    )\\n   234\\t\\n   235\\t    rel_prefix = fixture_rel.as_posix()\\n   236\\t    config_path = fixture_dir / \\\"config.yaml\\\"\\n   237\\t    config_path.write_text(\\n   238\\t        textwrap.dedent(\\n   239\\t            f\\\"\\\"\\\"\\n   240\\t            dataset:\\n   241\\t              materialization_version: 783\\n   242\\t              flywire_dataset: public\\n   243\\t\\n   244\\t            paths:\\n   245\\t              codex_raw_dir: {rel_prefix}/raw/codex\\n   246\\t              classification_csv: {rel_prefix}/raw/codex/classification.csv\\n   247\\t              neuron_registry_csv: {rel_prefix}/out/registry/neuron_registry.csv\\n   248\\t              connectivity_registry_csv: {rel_prefix}/out/registry/connectivity_registry.csv\\n   249\\t              registry_provenance_json: {rel_prefix}/out/registry/registry_provenance.json\\n   250\\t              selected_root_ids: {rel_prefix}/out/root_ids.txt\\n   251\\t              subset_output_dir: {rel_prefix}/out/subsets\\n   252\\t              meshes_raw_dir: {rel_prefix}/out/meshes_raw\\n   253\\t              skeletons_raw_dir: {rel_prefix}/out/skeletons_raw\\n   254\\t              processed_mesh_dir: {rel_prefix}/out/processed_meshes\\n   255\\t              processed_graph_dir: 