s.shape, (4, 4))\n    52\t        self.assertEqual(operator.shape, (4, 4))\n    53\t        self.assertEqual(int(payload[\"root_id\"]), 202)\n    54\t        self.assertEqual(payload[\"edge_vertex_indices\"].shape[0], 5)\n    55\t        self.assertEqual(int(np.count_nonzero(payload[\"boundary_vertex_mask\"])), 4)\n    56\t        self.assertEqual(int(np.count_nonzero(payload[\"boundary_edge_mask\"])), 4)\n    57\t        self.assertEqual(int(np.count_nonzero(payload[\"boundary_face_mask\"])), 2)\n    58\t        self.assertEqual(int(np.count_nonzero(payload[\"edge_face_counts\"] == 2)), 1)\n    59\t        self.assertTrue(np.all(payload[\"mass_diagonal\"] > 0.0))\n    60\t        self.assertTrue(np.allclose(stiffness.toarray(), stiffness.toarray().T, atol=1e-6))\n    61\t        self.assertTrue(np.allclose(operator.toarray(), operator.toarray().T, atol=1e-6))\n    62\t        self.assertTrue(np.allclose(np.asarray(stiffness.sum(axis=1)).ravel(), 0.0, atol=1e-6))\n    63\t        self.assertTrue(np.allclose(np.cross(payload[\"tangent_u\"], payload[\"tangent_v\"]), payload[\"vertex_normals\"], atol=1e-5))\n    64\t        self.assertTrue(np.allclose(np.linalg.norm(payload[\"vertex_normals\"], axis=1), 1.0, atol=1e-5))\n    65\t\n    66\t        eigenvalues = np.linalg.eigvalsh(operator.toarray())\n    67\t        self.assertGreaterEqual(float(eigenvalues.min()), -1e-5)\n    68\t\n    69\t        geodesic_indptr = payload[\"geodesic_neighbor_indptr\"]\n    70\t        geodesic_indices = payload[\"geodesic_neighbor_indices\"]\n    71\t        geodesic_distances = payload[\"geodesic_neighbor_distances\"]\n    72\t        geodesic_hops = payload[\"geodesic_neighbor_hops\"]\n    73\t        self.assertEqual(geodesic_indptr.shape, (5,))\n    74\t        for vertex_index in range(4):\n    75\t            start = int(geodesic_indptr[vertex_index])\n    76\t            end = int(geodesic_indptr[vertex_index + 1])\n    77\t            self.assertGreaterEqual(end - start, 1)\n    78\t            self.assertLessEqual(end - start, 4)\n    79\t            self.assertEqual(int(geodesic_indices[start]), vertex_index)\n    80\t            self.assertEqual(float(geodesic_distances[start]), 0.0)\n    81\t            self.assertEqual(int(geodesic_hops[start]), 0)\n    82\t            self.assertTrue(np.all(np.diff(geodesic_distances[start:end]) >= -1e-7))\n    83\t\n    84\t        self.assertEqual(metadata[\"discretization_family\"], \"triangle_mesh_cotangent_fem\")\n    85\t        self.assertEqual(metadata[\"mass_treatment\"], \"lumped_mass\")\n    86\t        self.assertEqual(metadata[\"normalization\"], \"mass_normalized\")\n    87\t        self.assertEqual(metadata[\"boundary_condition_mode\"], \"closed_surface_zero_flux\")\n    88\t        self.assertEqual(metadata[\"geodesic_neighborhood\"][\"mode\"], \"edge_path_dijkstra_hop_capped\")\n    89\t        self.assertEqual(metadata[\"counts\"][\"boundary_edge_count\"], 4)\n    90\t        self.assertEqual(metadata[\"counts\"][\"boundary_vertex_count\"], 4)\n    91\t\n    92\t\n    93\tdef _load_csr(payload: dict[str, np.ndarray], *, prefix: str) -> sp.csr_matrix:\n    94\t    shape = tuple(int(value) for value in payload[f\"{prefix}_shape\"])\n    95\t    return sp.csr_matrix(\n    96\t        (\n    97\t            payload[f\"{prefix}_data\"],\n    98\t            payload[f\"{prefix}_indices\"],\n    99\t            payload[f\"{prefix}_indptr\"],\n   100\t        ),\n   101\t        shape=shape,\n   102\t    )\n   103\t\n   104\t\n   105\tif __name__ == \"__main__\":\n   106\t    unittest.main()\n","exit_code":0,"status":"completed"}}
