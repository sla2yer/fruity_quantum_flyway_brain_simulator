  1351\t) -> np.ndarray:\n  1352\t    array = np.asarray(value, dtype=np.float64)\n  1353\t    if array.ndim != ndim:\n  1354\t        raise ValueError(f\"{field_name} must be a {ndim}D float array.\")\n  1355\t    if expected_length is not None and array.shape[0] != int(expected_length):\n  1356\t        raise ValueError(\n  1357\t            f\"{field_name} must have leading length {expected_length}, got {array.shape[0]}.\"\n  1358\t        )\n  1359\t    frozen = np.asarray(array, dtype=np.float64).copy()\n  1360\t    frozen.setflags(write=False)\n  1361\t    return frozen\n  1362\t\n  1363\t\n  1364\tdef _freeze_int_array(\n  1365\t    value: Sequence[int] | np.ndarray,\n  1366\t    *,\n  1367\t    field_name: str,\n  1368\t    ndim: int,\n  1369\t) -> np.ndarray:\n  1370\t    array = np.asarray(value, dtype=np.int64)\n  1371\t    if array.ndim != ndim:\n  1372\t        raise ValueError(f\"{field_name} must be a {ndim}D integer array.\")\n  1373\t    frozen = np.asarray(array, dtype=np.int64).copy()\n  1374\t    frozen.setflags(write=False)\n  1375\t    return frozen\n  1376\t\n  1377\t\n  1378\tdef _normalize_topology_condition(value: Any, *, field_name: str) -> str:\n  1379\t    normalized = _normalize_nonempty_string(value, field_name=field_name)\n  1380\t    if normalized not in SUPPORTED_TOPOLOGY_CONDITIONS:\n  1381\t        raise ValueError(\n  1382\t            f\"{field_name} must be one of {list(SUPPORTED_TOPOLOGY_CONDITIONS)!r}, got {normalized!r}.\"\n  1383\t        )\n  1384\t    return normalized\n  1385\t\n  1386\t\n  1387\tdef _normalize_nonempty_string(value: Any, *, field_name: str) -> str:\n  1388\t    if not isinstance(value, str):\n  1389\t        raise ValueError(f\"{field_name} must be a non-empty string.\")\n  1390\t    normalized = value.strip()\n  1391\t    if not normalized:\n  1392\t        raise ValueError(f\"{field_name} must be a non-empty string.\")\n  1393\t    return normalized\n  1394\t\n  1395\t\n  1396\tdef _require_mapping(va