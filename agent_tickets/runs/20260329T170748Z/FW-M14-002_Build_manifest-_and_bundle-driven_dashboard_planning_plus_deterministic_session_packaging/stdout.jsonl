ashboard_session.v1 metadata.\",\nsrc/flywire_wave/dashboard_session_contract.py:2371:            contract_metadata=build_dashboard_session_contract_metadata(),\nsrc/flywire_wave/dashboard_session_contract.py:2464:def _normalize_dashboard_session_artifacts(\nsrc/flywire_wave/dashboard_session_contract.py:2484:            \"json_dashboard_session_metadata.v1\",\nsrc/flywire_wave/dashboard_session_contract.py:2631:    result = [parse_dashboard_session_artifact_reference(item) for item in payload]\nsrc/flywire_wave/dashboard_session_contract.py:2906:    if isinstance(record.get(\"dashboard_session_contract\"), Mapping):\nsrc/flywire_wave/dashboard_session_contract.py:2907:        return record[\"dashboard_session_contract\"]\nsrc/flywire_wave/dashboard_session_contract.py:2911:def _extract_dashboard_session_mapping(record: Mapping[str, Any]) -> Mapping[str, Any]:\nsrc/flywire_wave/dashboard_session_contract.py:2914:    if isinstance(record.get(\"dashboard_session\"), Mapping):\nsrc/flywire_wave/dashboard_session_contract.py:2915:        return record[\"dashboard_session\"]\nsrc/flywire_wave/__init__.py:10:    \"dashboard_session_contract\",\n","exit_code":0,"status":"completed"}}
