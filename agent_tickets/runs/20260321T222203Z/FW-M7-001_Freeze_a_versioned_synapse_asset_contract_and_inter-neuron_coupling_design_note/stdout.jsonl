ge_coupling_bundle_reference(\n    86\t                    root_id=101,\n    87\t                    pre_root_id=101,\n    88\t                    post_root_id=303,\n    89\t                    processed_coupling_dir=processed_coupling_dir,\n    90\t                    status=ASSET_STATUS_READY,\n    91\t                ),\n    92\t            ],\n    93\t            topology_family=DISTRIBUTED_PATCH_CLOUD_TOPOLOGY,\n    94\t        )\n    95\t        bundle_paths = build_geometry_bundle_paths(\n    96\t            101,\n    97\t            meshes_raw_dir=ROOT / \"data\" / \"interim\" / \"meshes_raw\",\n    98\t            skeletons_raw_dir=ROOT / \"data\" / \"interim\" / \"skeletons_raw\",\n    99\t            processed_mesh_dir=ROOT / \"data\" / \"processed\" / \"meshes\",\n   100\t            processed_graph_dir=ROOT / \"data\" / \"processed\" / \"graphs\",\n   101\t        )\n   102\t\n   103\t        asset_statuses = default_asset_statuses(fetch_skeletons=False)\n   104\t        asset_statuses.update(\n   105\t            {\n   106\t                RAW_MESH_KEY: ASSET_STATUS_READY,\n   107\t                SIMPLIFIED_MESH_KEY: ASSET_STATUS_READY,\n   108\t                SURFACE_GRAPH_KEY: ASSET_STATUS_READY,\n   109\t                PATCH_GRAPH_KEY: ASSET_STATUS_READY,\n   110\t                DESCRIPTOR_SIDECAR_KEY: ASSET_STATUS_READY,\n   111\t                QA_SIDECAR_KEY: ASSET_STATUS_READY,\n   112\t                TRANSFER_OPERATORS_KEY: ASSET_STATUS_READY,\n   113\t                OPERATOR_METADATA_KEY: ASSET_STATUS_READY,\n   114\t            }\n   115\t        )\n   116\t\n   117\t        record = build_geometry_manifest_record(\n   118\t            bundle_paths=bundle_paths,\n   119\t            asset_statuses=asset_statuses,\n   120\t            dataset_name=\"public\",\n   121\t            materialization_version=783,\n   122\t            meshing_config_snapshot={\"fetch_skeletons\": False, \"patch_hops\": 2},\n   123\t            registry_metadat