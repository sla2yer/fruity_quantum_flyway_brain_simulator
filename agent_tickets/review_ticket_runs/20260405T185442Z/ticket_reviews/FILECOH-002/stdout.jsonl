    *,\n  3951\t    showcase_steps: Sequence[Mapping[str, Any]],\n  3952\t    dashboard_context: Mapping[str, Any],\n  3953\t    showcase_session: Mapping[str, Any],\n  3954\t) -> dict[str, Any]:\n  3955\t    first_step = dict(showcase_steps[0])\n  3956\t    return {\n  3957\t        \"current_step_id\": str(first_step[\"step_id\"]),\n  3958\t        \"current_preset_id\": str(first_step[\"preset_id\"]),\n  3959\t        \"auto_advance\": False,\n  3960\t        \"rehearsal_mode\": True,\n  3961\t        \"default_export_target_role_id\": str(showcase_session[\"default_export_target_role_id\"]),\n  3962\t        \"selected_readout_id\": str(\n  3963\t            dashboard_context[\"payload\"][\"pane_inputs\"][TIME_SERIES_PANE_ID][\"selected_readout_id\"]\n  3964\t        ),\n  3965\t        \"selected_neuron_id\": dashboard_context[\"payload\"][\"pane_inputs\"][MORPHOLOGY_PANE_ID][\"selected_neuron_id\"],\n  3966\t    }\n  3967\t\n  3968\t\n  3969\tdef _initial_showcase_runtime_mode(operator_defaults: Mapping[str, Any]) -> str:\n  3970\t    rehearsal_mode = bool(operator_defaults.get(\"rehearsal_mode\", True))\n  3971\t    auto_advance = bool(operator_defaults.get(\"auto_advance\", False))\n  3972\t    if rehearsal_mode and not auto_advance:\n  3973\t        return PRESENTER_REHEARSAL_MODE\n  3974\t    return GUIDED_AUTOPLAY_MODE\n  3975\t\n  3976\t\n  3977\tdef _build_showcase_presentation_state(\n  3978\t    *,\n  3979\t    showcase_session: Mapping[str, Any],\n  3980\t    dashboard_context: Mapping[str, Any],\n  3981\t    showcase_steps: Sequence[Mapping[str, Any]],\n  3982\t    operator_defaults: Mapping[str, Any],\n  3983\t) -> dict[str, Any]:\n  3984\t    return {\n  3985\t        \"format_version\": JSON_SHOWCASE_STATE_FORMAT,\n  3986\t        \"contract_version\": SHOWCASE_SESSION_CONTRACT_VERSION,\n  3987\t        \"plan_version\": SHOWCASE_SESSION_PLAN_VERSION,\n  3988\t        \"bundle_reference\": {\n  3989\t            \"bundle_id\": str(showcase_sessio