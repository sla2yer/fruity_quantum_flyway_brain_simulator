{"type":"item.completed","item":{"id":"item_49","type":"command_execution","command":"/bin/bash -lc \"nl -ba src/flywire_wave/baseline_families.py | sed -n '1,260p'\"","aggregated_output":"     1\t\"\"\"Canonical Milestone 9 baseline neuron families.\n     2\t\n     3\tThe library-owned software realizations are:\n     4\t\n     5\t- P0: tau_m * dV/dt = -(V - V_rest) + g_in * U + g_rec * R\n     6\t- P1: tau_s * dI/dt = -I + g_in * U + g_rec * R\n     7\t       tau_m * dV/dt = -(V - V_rest) + I\n     8\t\n     9\tBoth families expose the same shared readout source: the membrane-state\n    10\treadout `V`. This keeps downstream shared-observable comparisons on one fair\n    11\tsurface instead of family-specific decoders.\n    12\t\"\"\"\n    13\t\n    14\tfrom __future__ import annotations\n    15\t\n    16\tfrom collections.abc import Mapping, Sequence\n    17\tfrom dataclasses import dataclass\n    18\tfrom typing import Any\n    19\t\n    20\timport numpy as np\n    21\t\n    22\tfrom .simulator_result_contract import (\n    23\t    P0_BASELINE_FAMILY,\n    24\t    P1_BASELINE_FAMILY,\n    25\t)\n    26\tfrom .simulator_runtime import (\n    27\t    PerNeuronRuntimeState,\n    28\t    SimulationEngine,\n    29\t    SimulationReadoutDefinition,\n    30\t    SimulationRunBlueprint,\n    31\t    SimulationRuntimeState,\n    32\t    SimulationStateSummaryRow,\n    33\t    SimulationStepContext,\n    34\t)\n    35\tfrom .stimulus_contract import (\n    36\t    _normalize_float,\n    37\t    _normalize_identifier,\n    38\t    _normalize_nonempty_string,\n    39\t    _normalize_positive_float,\n    40\t    _normalize_positive_int,\n    41\t)\n    42\t\n    43\t\n    44\tP0_MODEL_FAMILY = \"passive_linear_single_compartment\"\n    45\tP1_MODEL_FAMILY = \"reduced_linear_with_synaptic_current\"\n    46\t\n    47\tP0_STATE_LAYOUT = \"scalar_state_per_selected_root\"\n    48\tP1_STATE_LAYOUT = \"membrane_state_and_synaptic_current_per_selected_root\"\n    49\t\n    50\tFORWARD_EULER_INTEGRATION = \"forward_euler\"\n    51\tZERO_INITIAL_STATE = \"all_zero\"\n    52\tMEMBRANE_READOUT_STATE = \"membrane_state\"\n    53\tSYNAPTIC_CURRENT_STATE = \"synaptic_current_state\"\n    54\t\n    55\tDELAY_DISABLED_MODE = \"disabled\"\n    56\tDELAY_FROM_COUPLING_BUNDLE_MODE = \"from_coupling_bundle\"\n    57\tSUPPORTED_P1_DELAY_MODES = (\n    58\t    DELAY_DISABLED_MODE,\n    59\t    DELAY_FROM_COUPLING_BUNDLE_MODE,\n    60\t)\n    61\t\n    62\tSHARED_DOWNSTREAM_ACTIVATION = \"shared_downstream_activation\"\n    63\tSUPPORTED_SHARED_READOUT_SEMANTICS = (SHARED_DOWNSTREAM_ACTIVATION,)\n    64\tSUPPORTED_SHARED_READOUT_AGGREGATIONS = (\n    65\t    \"identity\",\n    66\t    \"max_over_root_ids\",\n    67\t    \"mean_over_root_ids\",\n    68\t    \"sum_over_root_ids\",\n    69\t)\n    70\tACTIVATION_UNITS = \"activation_au\"\n    71\t\n    72\t_SPEC_REQUIRED_KEYS = {\n    73\t    \"family\",\n    74\t    \"model_family\",\n    75\t    \"state_layout\",\n    76\t    \"integration_scheme\",\n    77\t    \"readout_state\",\n    78\t    \"initial_state\",\n    79\t    \"parameters\",\n    80\t}\n    81\t_P0_PARAMETER_KEYS = {\n    82\t    \"membrane_time_constant_ms\",\n    83\t    \"resting_potential\",\n    84\t    \"input_gain\",\n    85\t    \"recurrent_gain\",\n    86\t}\n    87\t_P1_PARAMETER_KEYS = {\n    88\t    \"membrane_time_constant_ms\",\n    89\t    \"synaptic_current_time_constant_ms\",\n    90\t    \"resting_potential\",\n    91\t    \"input_gain\",\n    92\t    \"recurrent_gain\",\n    93\t    \"delay_handling\",\n    94\t}\n    95\t_P1_DELAY_HANDLING_KEYS = {\n    96\t    \"mode\",\n    97\t    \"max_supported_delay_steps\",\n    98\t}\n    99\t\n   100\t\n   101\t@dataclass(frozen=True)\n   102\tclass P0BaselineParameters:\n   103\t    membrane_time_constant_ms: float\n   104\t    resting_potential: float\n   105\t    input_gain: float\n   106\t    recurrent_gain: float\n   107\t\n   108\t\n   109\t@dataclass(frozen=True)\n   110\tclass P1DelayHandling:\n   111\t    mode: str\n   112\t    max_supported_delay_steps: int\n   113\t\n   114\t\n   115\t@dataclass(frozen=True)\n   116\tclass P1BaselineParameters:\n   117\t    membrane_time_constant_ms: float\n   118\t    synaptic_current_time_constant_ms: float\n   119\t    resting_potential: float\n   120\t    input_gain: float\n   121\t    recurrent_gain: float\n   122\t    delay_handling: P1DelayHandling\n   123\t\n   124\t\n   125\t@dataclass(frozen=True)\n   126\tclass BaselineStateVariable:\n   127\t    state_id: str\n   128\t    units: str\n   129\t    description: str\n   130\t\n   131\t\n   132\t@dataclass(frozen=True)\n   133\tclass BaselineReadoutMapping:\n   134\t    readout_id: str\n   135\t    source_state: str\n   136\t    aggregation: str\n   137\t    units: str\n   138\t    value_semantics: str\n   139\t    description: str | None = None\n   140\t\n   141\t\n   142\t@dataclass(frozen=True)\n   143\tclass BaselineFamilySpec:\n   144\t    family: str\n   145\t    model_family: str\n   146\t    state_layout: str\n   147\t    integration_scheme: str\n   148\t    readout_state: str\n   149\t    initial_state: str\n   150\t    parameters: P0BaselineParameters | P1BaselineParameters\n   151\t\n   152\t    @classmethod\n   153\t    def from_mapping(cls, payload: Mapping[str, Any]) -> BaselineFamilySpec:\n   154\t        if not isinstance(payload, Mapping):\n   155\t            raise ValueError(\"baseline model_spec must be a mapping.\")\n   156\t        raw_payload = dict(payload)\n   157\t        unknown_keys = sorted(set(raw_payload) - _SPEC_REQUIRED_KEYS)\n   158\t        if unknown_keys:\n   159\t            raise ValueError(\n   160\t                \"baseline model_spec contains unsupported keys: \"\n   161\t                f\"{unknown_keys!r}.\"\n   162\t            )\n   163\t        missing_keys = sorted(_SPEC_REQUIRED_KEYS - set(raw_payload))\n   164\t        if missing_keys:\n   165\t            raise ValueError(\n   166\t                \"baseline model_spec is missing required keys: \"\n   167\t                f\"{missing_keys!r}.\"\n   168\t            )\n   169\t\n   170\t        family = _normalize_nonempty_string(\n   171\t            raw_payload[\"family\"],\n   172\t            field_name=\"model_spec.family\",\n   173\t        )\n   174\t        model_family = _normalize_identifier(\n   175\t            raw_payload[\"model_family\"],\n   176\t            field_name=\"model_spec.model_family\",\n   177\t        )\n   178\t        state_layout = _normalize_identifier(\n   179\t            raw_payload[\"state_layout\"],\n   180\t            field_name=\"model_spec.state_layout\",\n   181\t        )\n   182\t        integration_scheme = _normalize_identifier(\n   183\t            raw_payload[\"integration_scheme\"],\n   184\t            field_name=\"model_spec.integration_scheme\",\n   185\t        )\n   186\t        readout_state = _normalize_identifier(\n   187\t            raw_payload[\"readout_state\"],\n   188\t            field_name=\"model_spec.readout_state\",\n   189\t        )\n   190\t        initial_state = _normalize_identifier(\n   191\t            raw_payload[\"initial_state\"],\n   192\t            field_name=\"model_spec.initial_state\",\n   193\t        )\n   194\t        raw_parameters = raw_payload[\"parameters\"]\n   195\t        if not isinstance(raw_parameters, Mapping):\n   196\t            raise ValueError(\"model_spec.parameters must be a mapping.\")\n   197\t\n   198\t        if family == P0_BASELINE_FAMILY:\n   199\t            parameters = _normalize_p0_parameters(raw_parameters)\n   200\t            _validate_supported_layout(\n   201\t                family=family,\n   202\t                model_family=model_family,\n   203\t                expected_model_family=P0_MODEL_FAMILY,\n   204\t                state_layout=state_layout,\n   205\t                expected_state_layout=P0_STATE_LAYOUT,\n   206\t                integration_scheme=integration_scheme,\n   207\t                readout_state=readout_state,\n   208\t                initial_state=initial_state,\n   209\t            )\n   210\t        elif family == P1_BASELINE_FAMILY:\n   211\t            parameters = _normalize_p1_parameters(raw_parameters)\n   212\t            _validate_supported_layout(\n   213\t                family=family,\n   214\t                model_family=model_family,\n   215\t                expected_model_family=P1_MODEL_FAMILY,\n   216\t                state_layout=state_layout,\n   217\t                expected_state_layout=P1_STATE_LAYOUT,\n   218\t                integration_scheme=integration_scheme,\n   219\t                readout_state=readout_state,\n   220\t                initial_state=initial_state,\n   221\t            )\n   222\t        else:\n   223\t            raise ValueError(\n   224\t                \"Unsupported baseline family \"\n   225\t                f\"{family!r}. Supported families: {[P0_BASELINE_FAMILY, P1_BASELINE_FAMILY]!r}.\"\n   226\t            )\n   227\t\n   228\t        # The Milestone 9 normalized family specs only support zero-initialized\n   229\t        # runs. A nonzero resting potential would silently introduce a hidden\n   230\t        # initial offset, so reject that configuration instead of mutating it.\n   231\t        if parameters.resting_potential != 0.0:\n   232\t            raise ValueError(\n   233\t                \"baseline model_spec.initial_state='all_zero' requires \"\n   234\t                \"parameters.resting_potential == 0.0.\"\n   235\t            )\n   236\t\n   237\t        return cls(\n   238\t            family=family,\n   239\t            model_family=model_family,\n   240\t            state_layout=state_layout,\n   241\t            integration_scheme=integration_scheme,\n   242\t            readout_state=readout_state,\n   243\t            initial_state=initial_state,\n   244\t            parameters=parameters,\n   245\t        )\n   246\t\n   247\t    @property\n   248\t    def state_variables(self) -> tuple[BaselineStateVariable, ...]:\n   249\t        if self.family == P0_BASELINE_FAMILY:\n   250\t            return (\n   251\t                BaselineStateVariable(\n   252\t                    state_id=MEMBRANE_READOUT_STATE,\n   253\t                    units=ACTIVATION_UNITS,\n   254\t                    description=(\n   255\t                        \"Per-neuron passive membrane state used for the shared readout.\"\n   256\t                    ),\n   257\t                ),\n   258\t            )\n   259\t        return (\n   260\t            BaselineStateVariable(\n","exit_code":0,"status":"completed"}}
