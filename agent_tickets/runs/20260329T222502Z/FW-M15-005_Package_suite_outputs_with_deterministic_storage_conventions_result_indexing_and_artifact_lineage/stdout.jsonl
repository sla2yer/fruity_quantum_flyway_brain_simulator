      \"path\": str(artifact_path),\n                    \"artifact_role_id\": str(work_item[\"artifact_role_ids\"][0]),\n                    \"artifact_kind\": f\"fixture_{stage_id}_metadata\",\n                    \"status\": \"ready\",\n                }\n            ],\n        }\n\n    return execute\n\n\nif __name__ == \"__main__\":\n    unittest.main()\n","exit_code":0,"status":"completed"}}
