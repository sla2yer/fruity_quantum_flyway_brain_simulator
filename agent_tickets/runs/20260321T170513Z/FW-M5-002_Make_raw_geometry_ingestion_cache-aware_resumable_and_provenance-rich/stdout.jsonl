\t    return {\n   303\t        \"state\": state,\n   304\t        \"reason\": reason,\n   305\t    }\n   306\t\n   307\t\n   308\tdef _validate_cached_mesh(path: Path) -> tuple[bool, str]:\n   309\t    if not path.exists():\n   310\t        return False, \"missing_file\"\n   311\t    if path.stat().st_size <= 0:\n   312\t        return False, \"empty_file\"\n   313\t    try:\n   314\t        mesh = trimesh.load_mesh(path, process=False)\n   315\t    except Exception as exc:\n   316\t        return False, f\"load_failed:{type(exc).__name__}\"\n   317\t    if not isinstance(mesh, trimesh.Trimesh):\n   318\t        return False, f\"unexpected_type:{type(mesh).__name__}\"\n   319\t    vertices = np.asarray(mesh.vertices)\n   320\t    faces = np.asarray(mesh.faces)\n","exit_code":0,"status":"completed"}}
