UPLING_EVENTS_ARTIFACT_ID,\n   277\t            ],\n   278\t        },\n   279\t    )\n   280\t\n   281\t\n   282\tdef _build_ready_bundle_metadata(\n   283\t    arm_plan: Mapping[str, Any],\n   284\t    *,\n   285\t    extra_artifact_specs: Sequence[Mapping[str, Any]] = (),\n   286\t) -> dict[str, Any]:\n   287\t    base_metadata = _resolve_bundle_metadata(arm_plan)\n   288\t    runtime = _require_mapping(arm_plan.get(\"runtime\"), field_name=\"arm_plan.runtime\")\n   289\t    bundle_paths = build_simulator_result_bundle_paths(\n   290\t        experiment_id=base_metadata[\"manifest_reference\"][\"experiment_id\"],\n   291\t        arm_id=base_metadata[\"arm_reference\"][\"arm_id\"],\n   292\t        run_spec_hash=base_metadata[\"run_spec_hash\"],\n   293\t        processed_simulator_results_dir=_resolve_processed_simulator_results_dir(\n   294\t            runtime=runtime,\n   295\t            base_metadata=base_metadata,\n   296\t        ),\n   297\t    )\n   298\t    artifact_specs = list(_default_extension_artifact_specs()) + [\n   299\t        copy.deepcopy(dict(spec))\n   300\t        for spec in extra_artifact_specs\n   301\t    ]\n   302\t    execution_artifacts = [\n   303\t        build_simulator_extension_artifact_record(\n   304\t            bundle_paths=bundle_paths,\n   305\t            artifact_id=spec[\"artifact_id\"],\n   306\t            file_name=spec[\"file_name\"],\n   307\t            format=spec[\"format\"],\n   308\t            status=spec.get(\"status\", ASSET_STATUS_READY),\n   309\t            artifact_scope=spec[\"artifact_scope\"],\n   310\t            description=spec[\"description\"],\n   311\t        )\n   312\t        for spec in artifact_specs\n   313\t    ]\n   314\t\n   315\t    updated = copy.deepcopy(base_metadata)\n   316\t    updated[\"artifacts\"][STATE_SUMMARY_KEY][\"status\"] = ASSET_STATUS_READY\n   317\t    updated[\"artifacts\"][READOUT_TRACES_KEY][\"status\"] = ASSET_STATUS_READY\n   318\t    updated[\"artifacts\"][MET