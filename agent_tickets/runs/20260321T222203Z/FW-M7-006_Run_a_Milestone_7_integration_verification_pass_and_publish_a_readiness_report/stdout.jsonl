{"type":"item.started","item":{"id":"item_73","type":"command_execution","command":"/bin/bash -lc \"./.venv/bin/python - <<'PY'\nfrom pathlib import Path\nimport numpy as np\n\ndef read_ply_points(path):\n    with open(path, 'r', encoding='utf-8') as f:\n        line = f.readline().strip()\n        if line \"'!= '\"'ply':\n            raise SystemExit(f'{path}: not ascii ply header start')\n        vertex_count = None\n        in_header = True\n        while in_header:\n            line = f.readline().strip()\n            if line.startswith('element vertex'):\n                vertex_count = int(line.split()[-1])\n            elif line == 'end_header':\n                in_header = False\n        pts = []\n        for _ in range(vertex_count):\n            vals = f.readline().split()\n            pts.append([float(vals[0]), float(vals[1]), float(vals[2])])\n    pts = np.asarray(pts)\n    return pts\n\nfor root in [720575940602483424,720575940603372460,720575940603402412,720575940603452384]:\n    pts = read_ply_points(Path('data/interim/meshes_raw')/f'{root}.ply')\n    print('mesh', root, 'n', len(pts), 'min', pts.min(axis=0).tolist(), 'max', pts.max(axis=0).tolist(), 'mean', pts.mean(axis=0).tolist())\n    print('sample', pts[:5].tolist())\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
