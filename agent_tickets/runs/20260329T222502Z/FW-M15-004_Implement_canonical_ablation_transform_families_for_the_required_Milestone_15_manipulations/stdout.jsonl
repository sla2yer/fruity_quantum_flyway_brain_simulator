: \"string\",\n        \"minLength\": 1\n      }\n    },\n    \"success_criteria_ids\": {\n      \"type\": \"array\",\n      \"minItems\": 3,\n      \"uniqueItems\": true,\n      \"items\": {\n        \"type\": \"string\",\n        \"pattern\": \"^m1_[a-z0-9_]+$\"\n      }\n    },\n    \"must_show_outputs\": {\n      \"type\": \"array\",\n      \"minItems\": 4,\n      \"uniqueItems\": true,\n      \"items\": {\n        \"type\": \"string\",\n        \"enum\": [\n          \"stimulus_overview\",\n          \"surface_vs_baseline_split_view\",\n          \"shared_output_trace_overlay\",\n          \"null_direction_suppression_comparison\",\n          \"latency_shift_comparison\",\n          \"topology_ablation_comparison\",\n          \"baseline_challenge_comparison\",\n          \"milestone_decision_panel\"\n        ]\n      }\n    },\n    \"random_seed\": {\n      \"type\": \"integer\"\n    },\n    \"seed_sweep\": {\n      \"type\": \"array\",\n      \"minItems\": 1,\n      \"uniqueItems\": true,\n      \"items\": {\n        \"type\": \"integer\"\n      }\n    },\n    \"notes\": {\n      \"type\": \"string\"\n    },\n    \"tags\": {\n      \"type\": \"array\",\n      \"uniqueItems\": true,\n      \"items\": {\n        \"type\": \"string\",\n        \"minLength\": 1\n      }\n    },\n    \"comparison_arms\": {\n      \"type\": \"array\",\n      \"minItems\": 4,\n      \"items\": {\n        \"$ref\": \"#/$defs/comparisonArm\"\n      }\n    },\n    \"output_bundle\": {\n      \"$ref\": \"#/$defs/outputBundle\"\n    }\n  },\n  \"anyOf\": [\n    {\n      \"required\": [\n        \"subset_name\"\n      ]\n    },\n    {\n      \"required\": [\n        \"circuit_name\"\n      ]\n    }\n  ],\n  \"allOf\": [\n    {\n      \"properties\": {\n        \"comparison_arms\": {\n          \"contains\": {\n            \"properties\": {\n              \"model_mode\": {\n                \"const\": \"baseline\"\n              }\n            },\n            \"required\": [\n              \"model_mode\"\n            ]\n          }\n        }\n      }\n    },\n    {\n      \"properties\": {\n        \"comparison_arms\": {\n          \"contains\": {\n            \"properties\": {\n              \"model_mode\": {\n                \"const\": \"surface_wave\"\n              }\n            },\n            \"required\": [\n              \"model_mode\"\n            ]\n          }\n        }\n      }\n    },\n    {\n      \"properties\": {\n        \"comparison_arms\": {\n          \"contains\": {\n            \"properties\": {\n              \"topology_condition\": {\n                \"const\": \"intact\"\n              }\n            },\n            \"required\": [\n              \"topology_condition\"\n            ]\n          }\n        }\n      }\n    },\n    {\n      \"properties\": {\n        \"comparison_arms\": {\n          \"contains\": {\n            \"properties\": {\n              \"topology_condition\": {\n                \"const\": \"shuffled\"\n              }\n            },\n            \"required\": [\n              \"topology_condition\"\n            ]\n          }\n        }\n      }\n    }\n  ],\n  \"$defs\": {\n    \"jsonValue\": {\n      \"oneOf\": [\n        {\n          \"type\": [\n            \"string\",\n            \"number\",\n            \"boolean\",\n            \"null\"\n          ]\n        },\n        {\n          \"type\": \"array\",\n          \"items\": {\n            \"$ref\": \"#/$defs/jsonValue\"\n          }\n        },\n        {\n          \"type\": \"object\",\n          \"additionalProperties\": {\n            \"$ref\": \"#/$defs/jsonValue\"\n          }\n        }\n      ]\n    },\n    \"temporalSampling\": {\n      \"type\": \"object\",\n      \"additionalProperties\": false,\n      \"properties\": {\n        \"dt_ms\": {\n          \"type\": \"number\"\n        },\n        \"duration_ms\": {\n          \"type\": \"number\"\n        },\n        \"frame_count\": {\n          \"type\": \"integer\"\n        },\n  