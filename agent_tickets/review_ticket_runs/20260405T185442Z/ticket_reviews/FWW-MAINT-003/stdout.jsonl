ed[\"artifact_role_id\"])\n   127\t        )\n   128\t        mutated[\"source_kind\"] = _humanize_identifier(str(mutated[\"source_kind\"]))\n   129\t        mutated[\"artifact_scope\"] = _humanize_identifier(str(mutated[\"artifact_scope\"]))\n   130\t        artifact_role_definitions.append(mutated)\n   131\t\n   132\t    reproducibility_hook_definitions: list[dict[str, object]] = []\n   133\t    for entry in metadata[\"reproducibility_hook_catalog\"]:\n   134\t        mutated = copy.deepcopy(entry)\n   135\t        mutated[\"hook_id\"] = _humanize_identifier(str(mutated[\"hook_id\"]))\n   136\t        reproducibility_hook_definitions.append(mutated)\n   137\t\n   138\t    if reverse:\n   139\t        dimension_definitions.reverse()\n   140\t        ablation_family_definitions.reverse()\n   141\t        lineage_definitions.reverse()\n   142\t        work_item_status_definitions.reverse()\n   143\t        artifact_role_definitions.reverse()\n   144\t        reproducibility_hook_definitions.reverse()\n   145\t\n   146\t    return {\n   147\t        \"dimension_definitions\": dimension_definitions,\n   148\t        \"ablation_family_definitions\": ablation_family_definitions,\n   149\t        \"lineage_definitions\": lineage_definitions,\n   150\t        \"work_item_status_definitions\": work_item_status_definitions,\n   151\t        \"artifact_role_definitions\": artifact_role_definitions,\n   152\t        \"reproducibility_hook_definitions\": reproducibility_hook_definitions,\n   153\t    }\n   154\t\n   155\t\n   156\tdef _mutate_suite_fixture(\n   157\t    suite_cells: list[dict[str, object]],\n   158\t    work_items: list[dict[str, object]],\n   159\t    upstream_references: list[dict[str, object]],\n   160\t    artifact_references: list[dict[str, object]],\n   161\t    *,\n   162\t    reverse: bool,\n   163\t) -> dict[str, list[dict[str, object]]]:\n   164\t    mutated_cells: list[dict[str, object]] = []\n   165\t    for entry in suite_cells:\n   166\t        mu