 217\t    coarse_operator_available = operator_asset_statuses[COARSE_OPERATOR_KEY] == ASSET_STATUS_READY\n   218\t\n   219\t    return {\n   220\t        \"contract_version\": OPERATOR_BUNDLE_CONTRACT_VERSION,\n   221\t        \"status\": _bundle_status(operator_asset_statuses),\n   222\t        \"realization_mode\": \"graph_laplacian_fallback\",\n   223\t        \"preferred_discretization_family\": DEFAULT_FINE_DISCRETIZATION_FAMILY,\n   224\t        \"discretization_family\": FALLBACK_FINE_DISCRETIZATION_FAMILY,\n   225\t        \"mass_treatment\": FALLBACK_MASS_TREATMENT,\n   226\t        \"normalization\": FALLBACK_NORMALIZATION,\n   227\t        \"boundary_condition_mode\": DEFAULT_BOUNDARY_CONDITION_MODE,\n   228\t        \"fallback_policy\": {\n   229\t            \"allowed\": True,\n   230\t            \"reason\": \"cotangent_operators_not_serialized_in_milestone5_bundle\",\n   231\t            \"fallback_discretization_family\": FALLBACK_FINE_DISCRETIZATION_FAMILY,\n   232\t        },\n   233\t        \"geodesic_neighborhood\": {\n   234\t            \"mode\": FALLBACK_GEODESIC_NEIGHBORHOOD_MODE,\n   235\t            \"patch_hops\": int(patch_hops) if patch_hops is not None else None,\n   236\t            \"patch_vertex_cap\": int(patch_vertex_cap) if patch_vertex_cap is not None else None,\n   237\t            \"patch_generation_method\": (\n   238\t                str(patch_generation_method) if patch_generation_method is not None else \"\"\n   239\t            ),\n   240\t        },\n   241\t        \"transfer_operators\": {\n   242\t            \"surface_to_patch_membership\": {\n   243\t                \"available\": restriction_available,\n   244\t                \"path\": str(bundle_paths.transfer_operator_path),\n   245\t                \"representation\": \"csr_membership_and_surface_to_patch\",\n   246\t            },\n   247\t            \"fine_to_coarse_restriction\": {\n   248\t                \"available\": restriction_available,\n   249\t                \"path\": str(bundle_paths.transfer_operator_path),\n   250\t                \"normalization\": FALLBACK_TRANSFER_RESTRICTION,\n   251\t                \"conserves_constant_field\": restriction_available,\n   252\t            },\n   253\t            \"coarse_to_fine_prolongation\": {\n   254\t                \"available\": restriction_available,\n   255\t                \"path\": str(bundle_paths.transfer_operator_path),\n   256\t                \"normalization\": FALLBACK_TRANSFER_PROLONGATION,\n   257\t                \"partition_of_unity\": restriction_available,\n   258\t            },\n   259\t            \"fine_operator_available\": fine_operator_available,\n   260\t            \"coarse_operator_available\": coarse_operator_available,\n","exit_code":0,"status":"completed"}}
