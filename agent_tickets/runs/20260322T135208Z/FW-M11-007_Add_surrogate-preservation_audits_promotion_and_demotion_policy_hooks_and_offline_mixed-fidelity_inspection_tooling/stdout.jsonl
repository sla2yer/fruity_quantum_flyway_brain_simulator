str(coupling_asset[\"topology_family\"]),\n  2182\t                    \"fallback_hierarchy\": copy.deepcopy(\n  2183\t                        coupling_asset[\"fallback_hierarchy\"]\n  2184\t                    ),\n  2185\t                },\n  2186\t                \"required_local_assets\": required_local_assets,\n  2187\t                \"optional_local_assets\": optional_local_assets,\n  2188\t                \"surface_operator_asset\": (\n  2189\t                    None if operator_asset is None else copy.deepcopy(operator_asset)\n  2190\t                ),\n  2191\t                \"skeleton_runtime_asset\": (\n  2192\t                    None\n  2193\t                    if skeleton_runtime_asset is None\n  2194\t                    else copy.deepcopy(skeleton_runtime_asset)\n  2195\t                ),\n  2196\t                \"coupling_asset\": copy.deepcopy(coupling_asset),\n  2197\t            }\n  2198\t        )\n  2199\t    policy_hook = build_mixed_fidelity_policy_hook_summary(\n  2200\t        assignment_policy=assignment_policy,\n  2201\t        policy_evaluations=policy_evaluations,\n  2202\t    )\n  2203\t\n  2204\t    return {\n  2205\t        \"hybrid_morphology\": hybrid_morphology,\n  2206\t        \"mixed_fidelity\": {\n  2207\t            \"plan_version\": MIXED_FIDELITY_PLAN_VERSION,\n  2208\t            \"assignment_ordering\": normalized_config[\"assignment_ordering\"],\n  2209\t            \"assignment_policy\": copy.deepcopy(assignment_policy),\n  2210\t            \"policy_hook\": policy_hook,\n  2211\t            \"point_neuron_model_spec\": copy.deepcopy(\n  2212\t                _require_mapping(\n  2213\t                    point_neuron_model_spec,\n  2214\t                    field_name=\"simulation.baseline_families.P0\",\n  2215\t                )\n  2216\t            ),\n  2217\t            \"arm_overrides\": {\n  2218\t                \"default_morphology_class\": arm_fidelity_assignment[\n  2219\t                    \"defaul