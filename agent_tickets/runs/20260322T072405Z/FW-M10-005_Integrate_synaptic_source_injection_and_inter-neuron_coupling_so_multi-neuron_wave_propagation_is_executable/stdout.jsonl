apping[int, Sequence[float] | np.ndarray] | None = None,\n   419\t        patch_drives_by_root: Mapping[int, Sequence[float] | np.ndarray] | None = None,\n   420\t    ) -> dict[str, Any]:\n   421\t        self._require_initialized()\n   422\t        if self._final_result is not None:\n   423\t            raise ValueError(\"surface-wave circuit has already been finalized.\")\n   424\t\n   425\t        coupling_patch_drives = {\n   426\t            root_id: np.zeros(self._patch_count_by_root[root_id], dtype=np.float64)\n   427\t            for root_id in self.root_ids\n   428\t        }\n   429\t        coupling_events = self._resolve_coupling_patch_drives(coupling_patch_drives)\n   430\t\n   431\t        snapshots_by_root: dict[int, dict[str, Any]] = {}\n   432\t        for root_id in self.root_ids:\n   433\t            surface_drive = self._normalize_surface_drive(\n   434\t                root_id=root_id,\n   435\t                drives_by_root=surface_drives_by_root,\n   436\t            )\n   437\t            patch_drive = self._normalize_patch_drive(\n   438\t                root_id=root_id,\n   439\t                drives_by_root=patch_drives_by_root,\n   440\t            )\n   441\t            if patch_drive is None:\n   442\t                patch_drive = coupling_patch_drives[root_id]\n   443\t            else:\n   444\t                patch_drive = patch_drive + coupling_patch_drives[root_id]\n   445\t            snapshot = self._solver_by_root[root_id].step(\n   446\t                surface_drive=surface_drive,\n   447\t                patch_drive=patch_drive,\n   448\t            )\n   449\t            snapshots_by_root[root_id] = snapshot.as_mapping()\n   450\t\n   451\t        self._substep_index += 1\n   452\t        self._capture_patch_readouts()\n   453\t        if self._substep_index % self._plan.internal_substep_count == 0:\n   454\t            self._shared_step_count += 1\n   455\t            self._shared_readout_history.append(\n   456\t          