x_count\": int(patch_vertices.size),\n   190\t        \"patch_graph_edge_count\": int(patch_adj.nnz // 2),\n   191\t        \"patch_hops\": int(patch_hops),\n   192\t        \"patch_vertex_cap\": int(patch_vertex_cap),\n   193\t        \"simplify_target_faces\": int(simplify_target_faces),\n   194\t        \"raw_mesh_face_count\": original_face_count,\n   195\t        \"surface_area\": float(mesh.area),\n   196\t        \"volume\": float(mesh.volume),\n   197\t        \"bounds_min\": vertices.min(axis=0).tolist(),\n   198\t        \"bounds_max\": vertices.max(axis=0).tolist(),\n   199\t        \"raw_mesh_path\": str(bundle_paths.raw_mesh_path),\n   200\t        \"processed_mesh_path\": str(bundle_paths.simplified_mesh_path),\n   201\t        \"surface_graph_path\": str(bundle_paths.surface_graph_path),\n   202\t        \"patch_graph_path\": str(bundle_paths.patch_graph_path),\n   203\t        \"registry_metadata\": registry_metadata or {},\n   204\t    }\n   205\t    write_json(descriptor_payload, bundle_paths.descriptor_sidecar_path)\n   206\t\n   207\t    qa_payload = {\n   208\t        \"root_id\": int(root_id),\n   209\t        \"raw_mesh_available\": bundle_paths.raw_mesh_path.exists(),\n   210\t        \"raw_skeleton_available\": bundle_paths.raw_skeleton_path.exists(),\n   211\t        \"simplified_mesh_available\": bundle_paths.simplified_mesh_path.exists(),\n   212\t        \"surface_graph_available\": bundle_paths.surface_graph_path.exists(),\n   213\t        \"patch_graph_available\": bundle_paths.patch_graph_path.exists(),\n   214\t        \"descriptor_sidecar_available\": bundle_paths.descriptor_sidecar_path.exists(),\n   215\t        \"is_watertight\": bool(mesh.is_watertight),\n   216\t        \"vertex_count_matches_surface_graph\": int(vertices.shape[0]) == int(adj.shape[0]),\n   217\t        \"patch_vertex_count\": int(patch_vertices.size),\n   218\t        \"patch_is_nonempty\": bool(patch_vertices.size),\n   219\t    }\n   220\t    write_json(qa_p