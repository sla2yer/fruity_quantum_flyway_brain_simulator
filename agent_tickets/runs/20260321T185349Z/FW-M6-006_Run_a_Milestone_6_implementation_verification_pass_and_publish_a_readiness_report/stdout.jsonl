ace_mask\\\": boundary_face_mask,\\n   312\\t    }\\n   313\\t\\n   314\\t\\n   315\\tdef _cotangent(vertex: np.ndarray, other_a: np.ndarray, other_b: np.ndarray, *, face_index: int) -> float:\\n   316\\t    edge_a = other_a - vertex\\n   317\\t    edge_b = other_b - vertex\\n   318\\t    cross_norm = float(np.linalg.norm(np.cross(edge_a, edge_b)))\\n   319\\t    if cross_norm <= _GEOMETRY_EPSILON:\\n   320\\t        raise FineSurfaceOperatorAssemblyError(\\n   321\\t            f\\\"Degenerate angle detected during fine operator assembly at face index {face_index}.\\\"\\n   322\\t        )\\n   323\\t    return float(np.dot(edge_a, edge_b) / cross_norm)\\n   324\\t\\n   325\\t\\n   326\\tdef _build_tangent_frames(vertex_normals: np.ndarray) -> tuple[np.ndarray, np.ndarray]:\\n   327\\t    candidate_axes = np.asarray(\\n   328\\t        [\\n   329\\t            [1.0, 0.0, 0.0],\\n   330\\t            [0.0, 1.0, 0.0],\\n   331\\t            [0.0, 0.0, 1.0],\\n   332\\t        ],\\n   333\\t        dtype=np.float64,\\n   334\\t    )\\n   335\\t    tangent_u = np.zeros_like(vertex_normals)\\n   336\\t    tangent_v = np.zeros_like(vertex_normals)\\n   337\\t\\n   338\\t    for vertex_index, normal in enumerate(vertex_normals):\\n   339\\t        alignments = np.abs(candidate_axes @ normal)\\n   340\\t        axis = candidate_axes[int(np.argmin(alignments))]\\n   341\\t        tangent = axis - float(np.dot(axis, normal)) * normal\\n   342\\t        tangent_norm = float(np.linalg.norm(tangent))\\n   343\\t        if tangent_norm <= _GEOMETRY_EPSILON:\\n   344\\t            raise FineSurfaceOperatorAssemblyError(\\n   345\\t                f\\\"Could not construct a tangent frame at vertex index {vertex_index}.\\\"\\n   346\\t            )\\n   347\\t        tangent_u[vertex_index] = tangent / tangent_norm\\n   348\\t        tangent_v[vertex_index] = np.cross(normal, tangent_u[vertex_index])\\n   349\\t\\n   350\\t    tangent_v = _normalize_vectors(tangent_v, label=\\\"secondary tangent vectors\\\")\\n   351\\t    return tangent_u, tangent_v\\n   352\\t\\n   353\\t\\n   354\\tdef _normalize_vectors(vectors: np.ndarray, *, label: str) -> np.ndarray:\\n   355\\t    norms = np.linalg.norm(vectors, axis=1)\\n   356\\t    if np.any(norms <= _GEOMETRY_EPSILON):\\n   357\\t        raise FineSurfaceOperatorAssemblyError(f\\\"Could not normalize {label}; at least one vector had near-zero norm.\\\")\\n   358\\t    return vectors / norms[:, None]\\n   359\\t\\n   360\\t\\n   361\\tdef _build_symmetric_edge_matrix(\\n   362\\t    *,\\n   363\\t    vertex_count: int,\\n   364\\t    edge_vertex_indices: np.ndarray,\\n   365\\t    edge_values: np.ndarray,\\n   366\\t) -> sp.csr_matrix:\\n   367\\t    rows = np.concatenate((edge_vertex_indices[:, 0], edge_vertex_indices[:, 1]))\\n   368\\t    cols = np.concatenate((edge_vertex_indices[:, 1], edge_vertex_indices[:, 0]))\\n   369\\t    data = np.concatenate((edge_values, edge_values)).astype(np.float64, copy=False)\\n   370\\t    matrix = sp.csr_matrix((data, (rows, cols)), shape=(vertex_count, vertex_count), dtype=np.float64)\\n   371\\t    matrix.eliminate_zeros()\\n   372\\t    matrix.sort_indices()\\n   373\\t    return matrix\\n   374\\t\\n   375\\t\\n   376\\tdef _assemble_stiffness_matrix(\\n   377\\t    *,\\n   378\\t    vertex_count: int,\\n   379\\t    edge_vertex_indices: np.ndarray,\\n   380\\t    cotangent_weights: np.ndarray,\\n   381\\t) -> sp.csr_matrix:\\n   382\\t    diagonal = np.zeros(vertex_count, dtype=np.float64)\\n   383\\t    rows: list[int] = []\\n   384\\t    cols: list[int] = []\\n   385\\t    data: list[float] = []\\n   386\\t\\n   387\\t    for (i, j), weight in zip(edge_vertex_indices, cotangent_weights):\\n   388\\t        i_idx = int(i)\\n   389\\t        j_idx = int(j)\\n   390\\t        w = float(weight)\\n   391\\t        diagonal[i_idx] += w\\n   392\\t        diagonal[j_idx] += w\\n   393\\t        rows.extend([i_idx, j_idx])\\n   394\\t        cols.extend([j_idx,