aged local session artifacts.\"\n    50\t        )\n    51\t    )\n    52\t    subparsers = parser.add_subparsers(dest=\"command\", required=True)\n    53\t\n    54\t    build = subparsers.add_parser(\n    55\t        \"build\",\n    56\t        help=(\n    57\t            \"Resolve a dashboard session from packaged local artifacts, write the \"\n    58\t            \"deterministic app shell, and optionally open the result.\"\n    59\t        ),\n    60\t    )\n    61\t    build.add_argument(\"--config\", required=True, help=\"Path to the runtime config YAML.\")\n    62\t    build.add_argument(\"--manifest\", help=\"Optional manifest path for manifest-driven planning.\")\n    63\t    build.add_argument(\"--schema\", help=\"Manifest schema JSON path for manifest-driven planning.\")\n    64\t    build.add_argument(\n    65\t        \"--design-lock\",\n    66\t        help=\"Design-lock YAML path for manifest-driven planning.\",\n    67\t    )\n    68\t    build.add_argument(\"--experiment-id\", help=\"Experiment id for experiment-driven planning.\")\n    69\t    build.add_argument(\n    70\t        \"--baseline-bundle-metadata\",\n    71\t        help=\"Path to one baseline simulator_result_bundle.json.\",\n    72\t    )\n    73\t    build.add_argument(\n    74\t        \"--wave-bundle-metadata\",\n    75\t        help=\"Path to one wave simulator_result_bundle.json.\",\n    76\t    )\n    77\t    build.add_argument(\n    78\t        \"--analysis-bundle-metadata\",\n    79\t        help=\"Path to one experiment_analysis_bundle.json.\",\n    80\t    )\n    81\t    build.add_argument(\n    82\t        \"--validation-bundle-metadata\",\n    83\t        help=\"Path to one validation_bundle.json.\",\n    84\t    )\n    85\t    build.add_argument(\n    86\t        \"--whole-brain-context-metadata\",\n    87\t        help=\"Optional path to one whole_brain_context_session.json for Milestone 17 circuit context rendering.\",\n    88\t    )\n    89\t    build.add_argument(\"--b