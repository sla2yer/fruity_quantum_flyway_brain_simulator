SUITE_SUMMARY_TABLE_ROLE_ID,\n  3905\t                source_kind=\"experiment_suite_package\",\n  3906\t                path=summary_table[\"path\"],\n  3907\t                contract_version=EXPERIMENT_SUITE_CONTRACT_VERSION,\n  3908\t                bundle_id=suite_bundle_id,\n  3909\t                artifact_id=str(summary_table[\"artifact_id\"]),\n  3910\t                format=\"csv_experiment_suite_summary_table.v1\",\n  3911\t                artifact_scope=SUITE_ROLLUP_SCOPE,\n  3912\t            )\n  3913\t        )\n  3914\t    if suite_context is not None and suite_context.get(\"comparison_plot_artifact\") is not None:\n  3915\t        comparison_plot = suite_context[\"comparison_plot_artifact\"]\n  3916\t        discovered.append(\n  3917\t            build_showcase_session_artifact_reference(\n  3918\t                artifact_role_id=SUITE_COMPARISON_PLOT_ROLE_ID,\n  3919\t                source_kind=\"experiment_suite_package\",\n  3920\t                path=comparison_plot[\"path\"],\n  3921\t                contract_version=EXPERIMENT_SUITE_CONTRACT_VERSION,\n  3922\t                bundle_id=_suite_bundle_id(suite_context),\n  3923\t                artifact_id=str(comparison_plot[\"artifact_id\"]),\n  3924\t                format=\"svg_experiment_suite_comparison_plot.v1\",\n  3925\t                artifact_scope=SUITE_ROLLUP_SCOPE,\n  3926\t            )\n  3927\t        )\n  3928\t    if suite_context is not None and suite_context.get(\"review_artifact\") is not None:\n  3929\t        review_artifact = suite_context[\"review_artifact\"]\n  3930\t        discovered.append(\n  3931\t            build_showcase_session_artifact_reference(\n  3932\t                artifact_role_id=SUITE_REVIEW_ARTIFACT_ROLE_ID,\n  3933\t                source_kind=\"experiment_suite_package\",\n  3934\t                path=review_artifact[\"path\"],\n  3935\t                contract_version=EXPERIMENT_SUITE_CONTRACT_VERSION,\n  3936\t                bundle_id=_suite_bundle_id(suite_context),\n  3937\t                artifact_id=str(review_artifact[\"artifact_id\"]),\n  3938\t                format=\"json_experiment_suite_review_artifact.v1\",\n  3939\t                artifact_scope=SUITE_ROLLUP_SCOPE,\n  3940\t            )\n  3941\t        )\n  3942\t    return _merge_explicit_artifact_overrides(\n  3943\t        discovered,\n  3944\t        raw_explicit_artifacts=raw_explicit_artifacts,\n  3945\t        contract_metadata=contract_metadata,\n  3946\t    )\n  3947\t\n  3948\t\n  3949\tdef _build_operator_defaults(\n  3950\t    *,\n  3951\t    showcase_steps: Sequence[Mapping[str, Any]],\n  3952\t    dashboard_context: Mapping[str, Any],\n  3953\t    showcase_session: Mapping[str, Any],\n  3954\t) -> dict[str, Any]:\n  3955\t    first_step = dict(showcase_steps[0])\n  3956\t    return {\n  3957\t        \"current_step_id\": str(first_step[\"step_id\"]),\n  3958\t        \"current_preset_id\": str(first_step[\"preset_id\"]),\n  3959\t        \"auto_advance\": False,\n  3960\t        \"rehearsal_mode\": True,\n  3961\t        \"default_export_target_role_id\": str(showcase_session[\"default_export_target_role_id\"]),\n  3962\t        \"selected_readout_id\": str(\n  3963\t            dashboard_context[\"payload\"][\"pane_inputs\"][TIME_SERIES_PANE_ID][\"selected_readout_id\"]\n  3964\t        ),\n  3965\t        \"selected_neuron_id\": dashboard_context[\"payload\"][\"pane_inputs\"][MORPHOLOGY_PANE_ID][\"selected_neuron_id\"],\n  3966\t    }\n  3967\t\n  3968\t\n  3969\tdef _initial_showcase_runtime_mode(operator_defaults: Mapping[str, Any]) -> str:\n  3970\t    rehearsal_mode = bool(operator_defaults.get(\"rehearsal_mode\", True))\n  3971\t    auto_advance = bool(operator_defaults.get(\"auto_advance\", False))\n  3972\t    if rehearsal_mode and not auto_advance:\n  3973\t        return PRESENTER_REHEARSAL_MODE\n  3974\t    return GUIDED_AUTOPLAY_MODE\n  3975\t\n  3976\t\n  3977\tdef _build_showcase_presentation_state(\n  3978\t    *,\n  3979\t    showcase_session: Mapping[str, Any],\n  3980\t    dashboard_context: Mapping[str, Any],\n  3981\t    showcase_steps: Sequence[Mapping[str, Any]],\n  3982\t    operator_defaults: Mapping[str, Any],\n  3983\t) -> dict[str, Any]:\n  3984\t    return {\n  3985\t        \"format_version\": JSON_SHOWCASE_STATE_FORMAT,\n  3986\t        \"contract_version\": SHOWCASE_SESSION_CONTRACT_VERSION,\n  3987\t        \"plan_version\": SHOWCASE_SESSION_PLAN_VERSION,\n  3988\t        \"bundle_reference\": {\n  3989\t            \"bundle_id\": str(showcase_session[\"bundle_id\"]),\n  3990\t            \"showcase_spec_hash\": str(showcase_session[\"showcase_spec_hash\"]),\n  3991\t        },\n  3992\t        \"manifest_reference\": copy.deepcopy(\n  3993\t            dict(dashboard_context[\"metadata\"][\"manifest_reference\"])\n  3994\t        ),\n  3995\t        \"presentation_status\": str(showcase_session[\"presentation_status\"]),\n  3996\t        \"current_step_id\": str(operator_defaults[\"current_step_id\"]),\n  3997\t        \"current_preset_id\": str(operator_defaults[\"current_preset_id\"]),\n  3998\t        \"active_pane_id\": DEFAULT_ACTIVE_PANE_BY_STEP[str(operator_defaults[\"current_step_id\"])],\n  3999\t        \"focus_root_ids\": list(\n  4000\t            dashboard_context[\"payload\"][\"pane_inputs\"][CIRCUIT_PANE_ID][\"selected_root_ids\"]\n  4001\t        ),\n  4002\t        \"dashboard_state_source\": {\n  4003\t            \"artifact_role_id\": DASHBOARD_SESSION_STATE_ROLE_ID,\n  4004\t            \"bundle_id\": str(dashboard_context[\"metadata\"][\"bundle_id\"]),\n  4005\t            \"state_path\": str(\n  4006\t                discover_dashboard_session_bundle_paths(dashboard_context[\"metadata\"])[\n  4007\t                    SESSION_STATE_ARTIFACT_ID\n  4008\t                ]\n  4009\t            ),\n  4010\t        },\n  4011\t        \"base_dashboard_session_state\": copy.deepcopy(dict(dashboard_context[\"state\"])),\n  4012\t        \"operator_defaults\": copy.deepcopy(dict(operator_defaults)),\n  4013\t        \"step_statuses\": {\n  4014\t            str(step[\"step_id\"]): str(step[\"presentation_status\"]) for step in showcase_steps\n  4015\t        },\n  4016\t    }\n  4017\t\n  4018\t\n  4019\tdef _build_showcase_script_payload(\n  4020\t    *,\n  4021\t    showcase_session: Mapping[str, Any],\n  4022\t    showcase_steps: Sequence[Mapping[str, Any]],\n  4023\t    saved_presets: Sequence[Mapping[str, Any]],\n  4024\t    operator_defaults: Mapping[str, Any],\n  4025\t) -> dict[str, Any]:\n  4026\t    initial_runtime_mode = _initial_showcase_runtime_mode(operator_defaults)\n  4027\t    return {\n  4028\t        \"format_version\": JSON_SHOWCASE_SCRIPT_FORMAT,\n  4029\t        \"contract_version\": SHOWCASE_SESSION_CONTRACT_VERSION,\n  4030\t        \"plan_version\": SHOWCASE_SESSION_PLAN_VERSION,\n  4031\t        \"runtime_version\": SHOWCASE_PLAYER_RUNTIME_VERSION,\n  4032\t        \"bundle_reference\": {\n  4033\t            \"bundle_id\": str(showcase_session[\"bundle_id\"]),\n  4034\t            \"showcase_spec_hash\": str(showcase_session[\"showcase_spec_hash\"]),\n  4035\t        },\n  4036\t        \"showcase_id\": str(showcase_session[\"showcase_id\"]),\n  4037\t        \"display_name\": str(showcase_session[\"display_name\"]),\n  4038\t        \"presentation_status\": str(showcase_session[\"presentation_status\"]),\n  4039\t        \"operator_defaults\": copy.deepcopy(dict(operator_defaults)),\n  4040\t        \"supported_runtime_modes\": list(SUPPORTED_SHOWCASE_PLAYER_MODES),\n  4041\t        \"supported_commands\": list(SUPPORTED_SHOWCASE_PLAYER_COMMANDS),\n  4042\t        \"step_order\": [str(step[\"step_id\"]) for step in showcase_steps],\n  4043\t        \"initial_checkpoint\": {\n  4044\t            \"step_id\": str(operator_defaults[\"current_step_id\"]),\n  4045\t            \"preset_id\": str(operator_defaults[\"current_preset_id\"]),\n  4046\t            \"runtime_mode\": initial_runtime_mode,\n  4047\t        },\n  4048\t        \"step_sequence\": [\n  4049\t            {\n  4050\t                \"sequence_index\": index,\n  4051\t                \"step_id\": str(step[\"step_id\"]),\n  4052\t                \"preset_id\": str(step[\"preset_id\"]),\n  4053\t                \"cue_kind_id\": str(step[\"cue_kind_id\"]),\n  4054\t                \"presentation_status\": str(step[\"presentation_status\"]),\n  4055\t                \"fallback_preset_id\": step.get(\"fallback_preset_id\"),\n  4056\t                \"operator_control_ids\": list(step[\"operator_control_ids\"]),\n  4057\t                \"supports_seek\": SCRUB_TIME_CONTROL_ID in step[\"operator_control_ids\"],\n  4058\t                \"supports_direct_jump\": str(step[\"presentation_status\"])\n  4059\t                not in {\n  4060\t                    PRESENTATION_STATUS_BLOCKED,\n  4061\t                    PRESENTATION_STATUS_SCIENTIFIC_REVIEW_REQUIRED,\n  4062\t                },\n  4063\t                \"export_target_role_ids\": list(step[\"export_target_role_ids\"]),\n  4064\t                \"annotation_ids\": [\n  4065\t                    str(annotation[\"annotation_id\"])\n  4066\t                    for annotation in step[\"narrative_annotations\"]\n  4067\t                ],\n  4068\t                \"evidence_role_ids\": [\n  4069\t                    str(reference[\"evidence_role_id\"])\n  4070\t                    for reference in step[\"evidence_references\"]\n  4071\t                ],\n  4072\t            }\n  4073\t            for index, step in enumerate(showcase_steps)\n  4074\t        ],\n  4075\t        \"saved_preset_ids\": [str(item[\"preset_id\"]) for item in saved_presets],\n  4076\t    }\n  4077\t\n  4078\t\n  4079\tdef _build_narrative_preset_catalog(\n  4080\t    *,\n  4081\t    showcase_session: Mapping[str, Any],\n  4082\t    dashboard_context: Mapping[str, Any],\n  4083\t    fixture_mode: str,\n  4084\t    narrative_context: Mapping[str, Any],\n  4085\t    showcase_steps: Sequence[Mapping[str, Any]],\n  4086\t    saved_presets: Sequence[Mapping[str, Any]],\n  4087\t) -> dict[str, Any]:\n  4088\t    preset_discovery_order = [str(item[\"preset_id\"]) for item in saved_presets]\n  4089\t    highlight_step = next(\n  4090\t        item\n  4091\t        for item in showcase_steps\n  4092\t        if str(item[\"step_id\"]) == APPROVED_WAVE_HIGHLIGHT_STEP_ID\n  4093\t    )\n  4094\t    return {\n  4095\t        \"format_version\": JSON_NARRATIVE_PRESET_CATALOG_FORMAT,\n  4096\t        \"contract_version\": SHOWCASE_SESSION_CONTRACT_VERSION,\n  4097\t        \"bundle_reference\": {\n  4098\t            \"bundle_id\": str(showcase_session[\"bundle_id\"]),\n  4099\t            \"showcase_spec_hash\": str(showcase_session[\"showcase_spec_hash\"]),\n  4100\t        },\n  4101\t        \"dashboard_state_source\": {\n  4102\t            \"artifact_role_id\": DASHBOARD_SESSION_STATE_ROLE_ID,\n  4103\t            \"bundle_id\": str(dashboard_context[\"metadata\"][\"bundle_id\"]),\n  4104\t        },\n  4105\t        \"preset_library_id\": DEFAULT_NARRATIVE_PRESET_LIBRARY_ID,\n  4106\t        \"fixture_profile\": {\n  4107\t            \"fixture_mode\": fixture_mode,\n  4108\t            \"keeps_readiness_fixtures_fast\": True,\n  4109\t            \"workflow_kind\": \"local_showcase_rehearsal\",\n  4110\t        },\n  4111\t        \"story_arc_preset_ids\": _story_arc_preset_ids(),\n  4112\t        \"preset_discovery_order\": preset_discovery_order,\n  4113\t        \"comparison_act\": copy.deepcopy(dict(narrative_context[\"comparison_act\"])),\n  4114\t        \"highlight_metadata\": copy.deepcopy(dict(narrative_context[\"highlight_selection\"])),\n  4115\t        \"highlight_presentation\": copy.deepcopy(\n  4116\t            dict(narrative_context[\"highlight_presentation\"])\n  4117\t        ),\n  4118\t        \"summary_analysis_landing\": copy.deepcopy(\n  4119\t            dict(narrative_context[\"summary_analysis_landing\"])\n  4120\t        ),\n  4121\t        \"highlight_step_evidence_references\": copy.deepcopy(\n  4122\t            list(highlight_step[\"evidence_references\"])\n  4123\t        ),\n  4124\t        \"saved_presets\": [copy.deepcopy(dict(item)) for item in saved_presets],\n  4125\t    }\n  4126\t\n  4127\t\n  4128\tdef _build_showcase_export_manifest(\n  4129\t    *,\n  4130\t    showcase_session: Mapping[str, Any],\n  4131\t    output_locations: Mapping[str, Any],\n  4132\t    contract_metadata: Mapping[str, Any],\n  4133\t) -> dict[str, Any]:\n  4134\t    role_definitions = {\n  4135\t        str(item[\"export_target_role_id\"]): dict(item)\n  4136\t        for item in discover_showcase_export_target_roles(contract_metadata)\n  4137\t    }\n  4138\t    export_targets = []\n  4139\t    for role_id in showcase_session[\"enabled_export_target_role_ids\"]:\n  4140\t        definition = role_definitions[str(role_id)]\n  4141\t        path = output_locations[\"export_target_paths\"][str(role_id)]\n  4142\t        export_targets.append(\n  4143\t            {\n  4144\t                \"export_target_role_id\": str(role_id),\n  4145\t                \"target_kind\": str(definition[\"target_kind\"]),\n  4146\t                \"path\": str(path),\n  4147\t                \"status\": PRESENTATION_STATUS_PLANNED,\n  4148\t            }\n  4149\t        )\n  4150\t    return {\n  4151\t        \"format_version\": JSON_SHOWCASE_EXPORT_MANIFEST_FORMAT,\n  4152\t        \"contract_version\": SHOWCASE_SESSION_CONTRACT_VERSION,\n  4153\t        \"bundle_reference\": {\n  4154\t            \"bundle_id\": str(showcase_session[\"bundle_id\"]),\n  4155\t            \"showcase_spec_hash\": str(showcase_session[\"showcase_spec_hash\"]),\n  4156\t        },\n  4157\t        \"default_export_target_role_id\": str(showcase_session[\"default_export_target_role_id\"]),\n  4158\t        \"export_targets\": export_targets,\n  4159\t    }\n  4160\t\n  4161\t\n  4162\tdef _build_output_locations(\n  4163\t    *,\n  4164\t    showcase_session: Mapping[str, Any],\n  4165\t    contract_metadata: Mapping[str, Any],\n  4166\t) -> dict[str, Any]:\n  4167\t    bundle_paths = discover_showcase_session_bundle_paths(showcase_session)\n  4168\t    bundle_directory = Path(showcase_session[\"bundle_layout\"][\"bundle_directory\"]).resolve()\n  4169\t    exports_directory = Path(showcase_session[\"bundle_layout\"][\"exports_directory\"]).resolve()\n  4170\t    role_definitions = {\n  4171\t        str(item[\"export_target_role_id\"]): dict(item)\n  4172\t        for item in discover_showcase_export_target_roles(contract_metadata)\n  4173\t    }\n  4174\t    export_target_paths: dict[str, str] = {}\n  4175\t    for role_id in showcase_session[\"enabled_export_target_role_ids\"]:\n  4176\t        file_name = DEFAULT_EXPORT_FILE_NAMES[str(role_id)]\n  4177\t        target_path = (exports_directory / file_name).resolve()\n  4178\t        export_target_paths[str(role_id)] = str(target_path)\n  4179\t    return {\n  4180\t        \"bundle_directory\": str(bundle_directory),\n  4181\t        \"exports_directory\": str(exports_directory),\n  4182\t        \"metadata_path\": str(bundle_paths[METADATA_JSON_KEY].resolve()),\n  4183\t        \"showcase_script_path\": str(\n  4184\t            bundle_paths[SHOWCASE_SCRIPT_PAYLOAD_ARTIFACT_ID].resolve()\n  4185\t        ),\n  4186\t        \"showcase_state_path\": str(\n  4187\t            bundle_paths[SHOWCASE_PRESENTATION_STATE_ARTIFACT_ID].resolve()\n  4188\t        ),\n  4189\t        \"narrative_preset_catalog_path\": str(\n  4190\t            bundle_paths[NARRATIVE_PRESET_CATALOG_ARTIFACT_ID].resolve()\n  4191\t        ),\n  4192\t        \"showcase_export_manifest_path\": str(\n  4193\t            bundle_paths[SHOWCASE_EXPORT_MANIFEST_ARTIFACT_ID].resolve()\n  4194\t        ),\n  4195\t        \"export_target_paths\": export_target_paths,\n  4196\t        \"export_target_kinds\": {\n  4197\t            str(role_id): str(role_definitions[str(role_id)][\"target_kind\"])\n  4198\t            for role_id in showcase_session[\"enabled_export_target_role_ids\"]\n  4199\t        },\n  4200\t    }\n  4201\t\n  4202\t\n  4203\tdef _merge_explicit_artifact_overrides(\n  4204\t    discovered: Sequence[Mapping[str, Any]],\n  4205\t    *,\n  4206\t    raw_explicit_artifacts: Mapping[str, Mapping[str, Any]],\n  4207\t    contract_metadata: Mapping[str, Any],\n  4208\t) -> list[dict[str, Any]]:\n  4209\t    hooks = {\n  4210\t        str(item[\"artifact_role_id\"]): dict(item)\n  4211\t        for item in contract_metadata[\"artifact_hook_catalog\"]\n  4212\t    }\n  4213\t    merged = {\n  4214\t        str(item[\"artifact_role_id\"]): copy.deepcopy(dict(item)) for item in discovered\n  4215\t    }\n  4216\t    for role_id, raw in raw_explicit_artifacts.items():\n  4217\t        base = merged.get(role_id, {})\n  4218\t        hook = hooks[role_id]\n  4219\t        merged[role_id] = build_showcase_session_artifact_reference(\n  4220\t            artifact_role_id=role_id,\n  4221\t            source_kind=str(raw.get(\"source_kind\", base.get(\"source_kind\", hook[\"source_kind\"]))),\n  4222\t            path=raw.get(\"path\", base[\"path\"]),\n  4223\t            contract_version=str(\n  4224\t                raw.get(\n  4225\t                    \"contract_version\",\n  4226\t                    base.get(\"contract_version\", hook[\"required_contract_version\"]),\n  4227\t                )\n  4228\t            ),\n  4229\t            bundle_id=str(raw.get(\"bundle_id\", base.get(\"bundle_id\", f\"explicit:{role_id}\"))),\n  4230\t            artifact_id=str(raw.get(\"artifact_id\", base.get(\"artifact_id\", hook[\"artifact_id\"]))),\n  4231\t            format=(\n  4232\t                None\n  4233\t                if raw.get(\"format\", base.get(\"format\")) is None\n  4234\t                else str(raw.get(\"format\", base.get(\"format\")))\n  4235\t            ),\n  4236\t            artifact_scope=str(\n  4237\t                raw.get(\"artifact_scope\", base.get(\"artifact_scope\", hook[\"artifact_scope\"]))\n  4238\t            ),\n  4239\t            status=str(raw.get(\"status\", base.get(\"status\", ASSET_STATUS_READY))),\n  4240\t        )\n  4241\t    return list(merged.values())\n  4242\t\n  4243\t\n  4244\tdef _discover_dashboard_metadata_from_suite_package(\n  4245\t    package_metadata: Mapping[str, Any],\n","exit_code":0,"status":"completed"}}
