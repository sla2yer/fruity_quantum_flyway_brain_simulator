ed FLYWIRE_TOKEN into local FlyWire secret storage for fafbseg.\")\n    88\t        except Exception as exc:\n    89\t            raise RuntimeError(\"Could not set FlyWire token for fafbseg.\") from exc\n    90\t\n    91\t    root_ids = read_root_ids(paths[\"selected_root_ids\"])\n    92\t    if not root_ids:\n    93\t        raise RuntimeError(\"No root IDs found. Run scripts/01_select_subset.py first.\")\n    94\t\n    95\t    registry = load_neuron_registry(registry_path)\n    96\t    validate_selected_root_ids(root_ids, registry, registry_path)\n    97\t\n    98\t    print(f\"Fetching {len(root_ids)} neurons validated against {registry_path}.\")\n    99\t\n   100\t    existing_records = load_geometry_manifest_records(paths[\"manifest_json\"])\n   101\t    manifest_records: dict[int, dict[str, object]] = {}\n   102\t    failures: list[str] = []\n   103\t    fetch_status_counts = {\n   104\t        RAW_MESH_KEY: Counter(),\n   105\t        RAW_SKELETON_KEY: Counter(),\n   106\t    }\n   107\t    for root_id in tqdm(root_ids, desc=\"Fetching meshes\"):\n   108\t        bundle_paths = build_geometry_bundle_paths(\n   109\t            root_id,\n   110\t            meshes_raw_dir=paths[\"meshes_raw_dir\"],\n   111\t            skeletons_raw_dir=paths[\"skeletons_raw_dir\"],\n   112\t            processed_mesh_dir=paths[\"processed_mesh_dir\"],\n   113\t            processed_graph_dir=paths[\"processed_graph_dir\"],\n   114\t        )\n   115\t        asset_statuses = default_asset_statuses(fetch_skeletons=fetch_skeletons)\n   116\t        raw_asset_provenance: dict[str, object] = {}\n   117\t        try:\n   118\t            fetch_outputs = fetch_mesh_and_optional_skeleton(\n   119\t                root_id=root_id,\n   120\t                bundle_paths=bundle_paths,\n   121\t                flywire_dataset=dataset,\n   122\t                fetch_skeletons=fetch_skeletons,\n   123\t                refetch_mesh=refetch_meshes,\n   124\t                refetch_skeleton=