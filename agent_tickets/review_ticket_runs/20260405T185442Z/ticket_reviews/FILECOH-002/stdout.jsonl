\n  4026\t    initial_runtime_mode = _initial_showcase_runtime_mode(operator_defaults)\n  4027\t    return {\n  4028\t        \"format_version\": JSON_SHOWCASE_SCRIPT_FORMAT,\n  4029\t        \"contract_version\": SHOWCASE_SESSION_CONTRACT_VERSION,\n  4030\t        \"plan_version\": SHOWCASE_SESSION_PLAN_VERSION,\n  4031\t        \"runtime_version\": SHOWCASE_PLAYER_RUNTIME_VERSION,\n  4032\t        \"bundle_reference\": {\n  4033\t            \"bundle_id\": str(showcase_session[\"bundle_id\"]),\n  4034\t            \"showcase_spec_hash\": str(showcase_session[\"showcase_spec_hash\"]),\n  4035\t        },\n  4036\t        \"showcase_id\": str(showcase_session[\"showcase_id\"]),\n  4037\t        \"display_name\": str(showcase_session[\"display_name\"]),\n  4038\t        \"presentation_status\": str(showcase_session[\"presentation_status\"]),\n  4039\t        \"operator_defaults\": copy.deepcopy(dict(operator_defaults)),\n  4040\t        \"supported_runtime_modes\": list(SUPPORTED_SHOWCASE_PLAYER_MODES),\n  4041\t        \"supported_commands\": list(SUPPORTED_SHOWCASE_PLAYER_COMMANDS),\n  4042\t        \"step_order\": [str(step[\"step_id\"]) for step in showcase_steps],\n  4043\t        \"initial_checkpoint\": {\n  4044\t            \"step_id\": str(operator_defaults[\"current_step_id\"]),\n  4045\t            \"preset_id\": str(operator_defaults[\"current_preset_id\"]),\n  4046\t            \"runtime_mode\": initial_runtime_mode,\n  4047\t        },\n  4048\t        \"step_sequence\": [\n  4049\t            {\n  4050\t                \"sequence_index\": index,\n  4051\t                \"step_id\": str(step[\"step_id\"]),\n  4052\t                \"preset_id\": str(step[\"preset_id\"]),\n  4053\t                \"cue_kind_id\": str(step[\"cue_kind_id\"]),\n  4054\t                \"presentation_status\": str(step[\"presentation_status\"]),\n  4055\t                \"fallback_preset_id\": step.get(\"fallback_preset_id\"),\n  4056\t                \"operator_control_ids\": list(step[\"operator_control_ids\"]),\n  4057\t                \"supports_seek\": SCRUB_TIME_CONTROL_ID in step[\"operator_control_ids\"],\n  4058\t                \"supports_direct_jump\": str(step[\"presentation_status\"])\n  4059\t                not in {\n  4060\t                    PRESENTATION_STATUS_BLOCKED,\n  4061\t                    PRESENTATION_STATUS_SCIENTIFIC_REVIEW_REQUIRED,\n  4062\t                },\n  4063\t                \"export_target_role_ids\": list(step[\"export_target_role_ids\"]),\n  4064\t                \"annotation_ids\": [\n  4065\t                    str(annotation[\"annotation_id\"])\n  4066\t                    for annotation in step[\"narrative_annotations\"]\n  4067\t                ],\n  4068\t                \"evidence_role_ids\": [\n  4069\t                    str(reference[\"evidence_role_id\"])\n  4070\t                    for reference in step[\"evidence_references\"]\n  4071\t                ],\n  4072\t            }\n  4073\t            for index, step in enumerate(showcase_steps)\n  4074\t        ],\n  4075\t        \"saved_preset_ids\": [str(item[\"preset_id\"]) for item in saved_presets],\n  4076\t    }\n  4077\t\n  4078\t\n  4079\tdef _build_narrative_preset_catalog(\n  4080\t    *,\n  4081\t    showcase_session: Mapping[str, Any],\n  4082\t    dashboard_context: Mapping[str, Any],\n  4083\t    fixture_mode: str,\n  4084\t    narrative_context: Mapping[str, Any],\n  4085\t    showcase_steps: Sequence[Mapping[str, Any]],\n  4086\t    saved_presets: Sequence[Mapping[str, Any]],\n  4087\t) -> dict[str, Any]:\n  4088\t    preset_discovery_order = [str(item[\"preset_id\"]) for item in saved_presets]\n  4089\t    highlight_step = next(\n  4090\t        item\n  4091\t        for item in showcase_steps\n  4092\t        if str(item[\"step_id\"]) == APPROVED_WAVE_HIGHLIGHT_STEP_ID\n  4093\t    )\n  4094\t    return {\n  4095\t        \"format_version\": JSON_NARRATIVE_PRESET_CATALOG_FORMAT,\n  4096\t        \"contract_vers