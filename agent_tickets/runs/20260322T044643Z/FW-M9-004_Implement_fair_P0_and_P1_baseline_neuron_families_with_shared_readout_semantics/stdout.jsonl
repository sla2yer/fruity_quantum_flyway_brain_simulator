  166\\t\\n   167\\t\\n   168\\tdef manifest_artifact_sources(\\n   169\\t    bundle_paths: GeometryBundlePaths,\\n   170\\t    *,\\n   171\\t    asset_statuses: dict[str, str],\\n   172\\t) -> dict[str, dict[str, str]]:\\n   173\\t    raw_mesh_status = str(asset_statuses.get(RAW_MESH_KEY, ASSET_STATUS_MISSING))\\n   174\\t    raw_skeleton_status = str(asset_statuses.get(RAW_SKELETON_KEY, ASSET_STATUS_MISSING))\\n   175\\t    asset_paths = bundle_paths.asset_paths()\\n   176\\t    return {\\n   177\\t        asset_key: {\\n   178\\t            \\\"path\\\": str(asset_paths[asset_key]),\\n   179\\t            \\\"raw_mesh_path\\\": str(bundle_paths.raw_mesh_path),\\n   180\\t            \\\"raw_mesh_status\\\": raw_mesh_status,\\n   181\\t            \\\"raw_skeleton_path\\\": str(bundle_paths.raw_skeleton_path),\\n   182\\t            \\\"raw_skeleton_status\\\": raw_skeleton_status,\\n   183\\t        }\\n   184\\t        for asset_key in PROCESSED_ASSET_KEYS\\n   185\\t    }\\n   186\\t\\n   187\\t\\n   188\\tdef build_operator_bundle_manifest_metadata() -> dict[str, Any]:\\n   189\\t    return {\\n   190\\t        \\\"version\\\": OPERATOR_BUNDLE_CONTRACT_VERSION,\\n   191\\t        \\\"design_note\\\": OPERATOR_BUNDLE_DESIGN_NOTE,\\n   192\\t        \\\"preferred_discretization_family\\\": DEFAULT_FINE_DISCRETIZATION_FAMILY,\\n   193\\t        \\\"preferred_mass_treatment\\\": DEFAULT_MASS_TREATMENT,\\n   194\\t        \\\"preferred_normalization\\\": DEFAULT_NORMALIZATION,\\n   195\\t        \\\"preferred_boundary_condition_mode\\\": DEFAULT_BOUNDARY_CONDITION_MODE,\\n   196\\t        \\\"fallback_discretization_family\\\": FALLBACK_FINE_DISCRETIZATION_FAMILY,\\n   197\\t        \\\"fallback_mass_treatment\\\": FALLBACK_MASS_TREATMENT,\\n   198\\t        \\\"fallback_normalization\\\": FALLBACK_NORMALIZATION,\\n   199\\t    }\\n   200\\t\\n   201\\t\\n   202\\tdef build_operator_bundle_metadata(\\n   203\\t    *,\\n   204\\t    bundle_paths: GeometryBundlePaths,\\n   205\\t    asset_statuses: Mapping[str, str],\\n   206\\t    meshing_config_snapshot: Mapping[str, Any],\\n   207\\t    bundle_metadata: Mapping[str, Any] | None = None,\\n   208\\t) -> dict[str, Any]:\\n   209\\t    operator_asset_statuses = _operator_asset_statuses(asset_statuses)\\n   210\\t    bundle_metadata = dict(bundle_metadata or {})\\n   211\\t\\n   212\\t    patch_hops = meshing_config_snapshot.get(\\\"patch_hops\\\")\\n   213\\t    patch_vertex_cap = meshing_config_snapshot.get(\\\"patch_vertex_cap\\\")\\n   214\\t    patch_generation_method = bundle_metadata.get(\\\"patch_generation_method\\\")\\n   215\\t    restriction_available = operator_asset_statuses[TRANSFER_OPERATORS_KEY] == ASSET_STATUS_READY\\n   216\\t    fine_operator_available = operator_asset_statuses[FINE_OPERATOR_KEY] == ASSET_STATUS_READY\\n   217\\t    coarse_operator_available = operator_asset_statuses[COARSE_OPERATOR_KEY] == ASSET_STATUS_READY\\n   218\\t\\n   219\\t    return {\\n   220\\t        \\\"contract_version\\\": OPERATOR_BUNDLE_CONTRACT_VERSION,\\n   221\\t        \\\"status\\\": _bundle_status(operator_asset_statuses),\\n   222\\t        \\\"realization_mode\\\": \\\"graph_laplacian_fallback\\\",\\n   223\\t        \\\"preferred_discretization_family\\\": DEFAULT_FINE_DISCRETIZATION_FAMILY,\\n   224\\t        \\\"discretization_family\\\": FALLBACK_FINE_DISCRETIZATION_FAMILY,\\n   225\\t        \\\"mass_treatment\\\": FALLBACK_MASS_TREATMENT,\\n   226\\t        \\\"normalization\\\": FALLBACK_NORMALIZATION,\\n   227\\t        \\\"boundary_condition_mode\\\": DEFAULT_BOUNDARY_CONDITION_MODE,\\n   228\\t        \\\"fallback_policy\\\": {\\n   229\\t            \\\"allowed\\\": True,\\n   230\\t            \\\"reason\\\": \\\"cotangent_operators_not_serialized_in_milestone5_bundle\\\",\\n   231\\t            \\\"fallback_discretization_family\\\": FALLBACK_FINE_DISCRETIZATION_FAMILY,\\n   232\\t        },\\n   233\\t        \\\"geodesic_neighborhood\\\": {\\n   234\\t            \\\"mode\\\": FALLBACK_GEODESIC_NEIGHBORHOOD_MODE,\\n   235\\t            \\\"patch_hops\\\": int(patch_hops) if patch_hops is not None else None,\\n   236\\t            \\\"patch_vertex_cap\\\": int(patch_vertex_cap) if patch_vertex_cap is not None else None,\\n   237\\t            \\\"patch_generation_method\\\": (\\n   238\\t                str(patch_generation_method) if patch_generation_method is not None else \\\"\\\"\\n   239\\t            ),\\n   240\\t        },\\n   241\\t        \\\"transfer_operators\\\": {\\n   242\\t            \\\"surface_to_patch_membership\\\": {\\n   243\\t                \\\"available\\\": restriction_available,\\n   244\\t                \\\"path\\\": str(bundle_paths.transfer_operator_path),\\n   245\\t                \\\"representation\\\": \\\"csr_membership_and_surface_to_patch\\\",\\n   246\\t            },\\n   247\\t            \\\"fine_to_coarse_restriction\\\": {\\n   248\\t                \\\"available\\\": restriction_available,\\n   249\\t                \\\"path\\\": str(bundle_paths.transfer_operator_path),\\n   250\\t                \\\"normalization\\\": FALLBACK_TRANSFER_RESTRICTION,\\n   251\\t                \\\"conserves_constant_field\\\": restriction_available,\\n   252\\t            },\\n   253\\t            \\\"coarse_to_fine_prolongation\\\": {\\n   254\\t                \\\"available\\\": restriction_available,\\n   255\\t                \\\"path\\\": str(bundle_paths.transfer_operator_path),\\n   256\\t                \\\"normalization\\\": FALLBACK_TRANSFER_PROLONGATION,\\n   257\\t                \\\"partition_of_unity\\\": restriction_available,\\n   258\\t            },\\n   259\\t            \\\"fine_operator_available\\\": fine_operator_available,\\n   260\\t            \\\"coarse_operator_available\\\": coarse_operator_available,\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n./agent_tickets/runs/20260321T185349Z/FW-M6-001_Freeze_a_versioned_operator_bundle_contract_and_discretization_design_note/stdout.jsonl:109:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_66\",\"type\":\"command_execution\",\"command\":\"/bin/bash -lc \\\"nl -ba docs/operator_bundle_design.md | sed -n '1,220p'\\\"\",\"aggregated_output\":\"     1\\t# Milestone 6 Operator Bundle Contract And Discretization Choice\\n     2\\t\\n     3\\tThis note freezes the first operator-facing contract for Milestone 6 so later\\n     4\\tsimulator work can target explicit archive roles and explicit numerical\\n     5\\tassumptions instead of reverse-engineering Milestone 5 geometry bundles.\\n     6\\t\\n     7\\t## Contract summary\\n     8\\t\\n     9\\tThe processed manifest now carries `_operator_contract_version:\\n    10\\toperator_bundle.v1` plus a per-root `operator_bundle` block. That block owns:\\n    11\\t\\n    12\\t- the fine operator archive\\n    13\\t- the coarse operator archive\\n    14\\t- the transfer-operator archive\\n    15\\t- the operator metadata sidecar\\n    16\\t- the realized discretization family and fallback status\\n    17\\t- normalization / mass treatment\\n    18\\t- boundary-condition mode\\n    19\\t- geodesic-neighborhood settings\\n    20\\t- transfer-operator availability\\n    21\\t\\n    22\\tCompatibility during migration is deliberate:\\n    23\\t\\n    24\\t- `fine_operator` is currently a manifest alias to the legacy\\n    25\\t  `surface_graph_path`\\n    26\\t- `coarse_operator` is currently a manifest alias to the legacy\\n    27\\t  `patch_graph_path`\\n    28\\t- the legacy `<root_id>_meta.json` sidecar is still written so Milestone 5\\n    29\\t  consumers do not break while downstream code migrates to the new contract\\n    30\\t\\n    31\\t## Candidate families\\n    32\\t\\n    33\\t### Graph-based surface operators\\n    34\\t\\n    35\\tDefinition:\\n    36\\t\\n    37\\t- surface adjacency from the simplified mesh connectivity\\n    38\\t- combinatorial or normalized graph Laplacian\\n    39\\t- patch transfers built from patch membership only\\n    40\\t\\n    41\\tAdvantages:\\n    42\\t\\n    43\\t- robust on imperfect meshes\\n    44\\t- cheap to build and easy to regression test\\n    45\\t- no dependence on cotangent-weight edge cases\\n    46\\t\\n    47\\tCosts:\\n    48\\t\\n    49\\t- ignores triangle geometry and surface area unless extra weighting is added\\n    50\\t- geodesic distance is only approximated by hop count\\n    51\\t- boundary semantics are implicit and easy to misinterpret\\n    52\\t- convergence to a surface PDE is weaker than for a metric-aware mesh operator\\n    53\\t\\n    54\\t### Mesh-based operators\\n    55\\t\\n    56\\tDefinition:\\n    57\\t\\n    58\\t- triangle-mesh Laplace-Beltrami discretization on the simplified surface\\n    59\\t- cotangent stiffness matrix\\n    60\\t- explicit mass matrix\\n    61\\t- coarse operators derived from fine operators and transfer maps\\n    62\\t\\n    63\\tAdvantages:\\n    64\\t\\n    65\\t- metric-aware and standard for diffusion / wave equations on surfaces\\n    66\\t- makes conservation and stability statements precise in a mesh inner product\\n    67\\t- clean boundary interpretation when seams or open surfaces exist\\n    68\\t- gives a principled path to Galerkin coarse operators\\n    69\\t\\n    70\\tCosts:\\n    71\\t\\n    72\\t- requires handling degenerate triangles, non-manifold cases, and negative\\n    73\\t  cotangent edge contributions carefully\\n    74\\t- more implementation work than a graph Laplacian\\n    75\\t\\n    76\\t## Decision\\n    77\\t\\n    78\\tThe default fine-surface discretization for Milestone 6 is:\\n    79\\t\\n    80\\t- `triangle_mesh_cotangent_fem`\\n    81\\t- lumped mass matrix\\n    82\\t- mass-normalized state inner product\\n    83\\t- zero-flux boundary handling on the simplified closed surface\\n    84\\t\\n    85\\tThis is the default the later wave engine should treat as scientifically\\n    86\\tauthoritative.\\n    87\\t\\n    88\\tThe default coarse construction is:\\n    89\\t\\n    90\\t- fine-to-coarse restriction by lumped-mass patch averaging\\n    91\\t- coarse-to-fine prolongation by piecewise-constant patch injection\\n    92\\t- coarse operator by Galerkin projection from the fine operator\\n    93\\t\\n    94\\tThis keeps the fine and coarse systems comparable in one inner product instead\\n    95\\tof treating the patch graph as an unrelated second discretization.\\n    96\\t\\n    97\\t## Allowed fallback\\n    98\\t\\n    99\\tFallback is allowed when the default operator cannot be serialized safely or has\\n   100\\tnot been built yet. The allowed fallback family is:\\n   101\\t\\n   102\\t- `surface_graph_uniform_laplacian`\\n   103\\t- counting-measure / uniform-vertex averaging on transfers\\n   104\\t- geodesic neighborhoods represented by surface-graph hop counts\\n   105\\t\\n   106\\tUse the fallback only when at least one of these is true:\\n   107\\t\\n   108\\t1. the simplified mesh has degeneracies or topology issues that make cotangent\\n   109\\t   assembly unreliable\\n   110\\t2. a build is intentionally limited to the Milestone 5 geometry bundle plus\\n   111\\t   structural transfer data\\n   112\\t3. a regression fixture needs a deterministic structural operator without the\\n   113\\t   full metric machinery\\n   114\\t\\n   115\\tWhenever fallback is used, the manifest must say so explicitly through the\\n   116\\tper-root `operator_bundle.discretization_family`, `mass_treatment`,\\n   117\\t`normalization`, and `realization_mode` fields.\\n   118\\t\\n   119\\t## Conserved and damped quantities\\n   120\\t\\n   121\\tThe later wave engine inherits these expectations:\\n   122\\t\\n   123\\t- the constant field remains in the nullspace of the Laplacian\\n   124\\t- zero-flux boundaries do not inject or remove net mass\\n   125\\t- pure diffusion should dissipate energy and preserve total mass\\n   126\\t- undamped wave propagation should not gain energy from the spatial operator\\n   127\\t- any damping operator must be positive semidefinite and separate from the\\n   128\\t  conservative spatial operator\\n   129\\t- fine/coarse restriction and prolongation should preserve constants; no\\n   130\\t  transfer step should create a net source term by itself\\n   131\\t\\n   132\\t## Stability-relevant assumptions\\n   133\\t\\n   134\\tLater milestones should preserve these assumptions instead of silently changing\\n   135\\tthem:\\n   136\\t\\n   137\\t- stiffness operators are symmetric\\n   138\\t- mass operators are positive diagonal after lumping\\n   139\\t- the effective generalized operator is positive semidefinite\\n   140\\t- boundary treatment stays zero-flux unless an experiment explicitly opts into\\n   141\\t  absorbing or clamped boundaries\\n   142\\t- time-step limits should be derived from the largest relevant eigenvalue of\\n   143\\t  `M^{-1}L` rather than an ad hoc graph-degree rule\\n   144\\t- coarse operators and transfer maps should be interpreted in the same inner\\n   145\\t  product as the fine operator\\n   146\\t\\n   147\\t## What the current bundle guarantees\\n   148\\t\\n   149\\t`operator_bundle.v1` lands before the full cotangent implementation. The\\n   150\\tcurrent repository therefore serializes:\\n   151\\t\\n   152\\t- a fine operator alias through the legacy surface-graph archive\\n   153\\t- a coarse operator alias through the legacy patch-graph archive\\n   154\\t- an explicit transfer-operator archive for coarse/fine discovery\\n   155\\t- an operator metadata sidecar that records the realized fallback mode\\n   156\\t\\n   157\\tThat is intentional. The contract is frozen now so later tickets can upgrade the\\n   158\\tnumerics without renegotiating filenames, manifest keys, or the default\\n   159\\tstability assumptions.\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n./agent_tickets/milestone_5_geometry_pipeline_tickets.md:98:Add a descriptor and QA stage that computes wave-relevant geometry summaries for raw, simplified, and coarse representations, then compares them against configurable error budgets. Capture both the implemented metrics and the reasoning behind them in a short markdown design note so later milestones have a documented baseline for what counts as an acceptable morphology approximation.\n./agent_tickets/runs/20260322T044643Z/FW-M9-003_Implement_the_core_simulator_execution_framework_state_containers_and_deterministic_stepping_loop/stdout.jsonl:4:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_0\",\"type\":\"agent_message\",\"text\":\"I’m implementing the Milestone 9 simulator runtime in the library, then I’ll wire in tests around deterministic stepping and lifecycle behavior before running the repo validation loop.\"}}\n./agent_tickets/runs/20260322T044643Z/FW-M9-003_Implement_the_core_simulator_execution_framework_state_containers_and_deterministic_stepping_loop/stdout.jsonl:6:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_1\",\"type\":\"command_execution\",\"command\":\"/bin/bash -lc 'pwd && rg --files'\",\"aggregated_output\":\"/home/jack/Documents/github/personal/fly_neural_simulation/flywire_wave_repo\\nscripts/04_validate_manifest.py\\nscripts/11_milestone8a_readiness.py\\nscripts/10_stimulus_bundle.py\\nscripts/build_registry.py\\nscripts/08_coupling_inspection.py\\nscripts/01_select_subset.py\\nscripts/00_verify_access.py\\nscripts/05_preview_geometry.py\\nscripts/07_milestone6_readiness.py\\nscripts/run_agent_tickets.py\\nscripts/09_milestone7_readiness.py\\nscripts/setup_flywire_token.py\\nscripts/03_build_wave_assets.py\\nscripts/02_fetch_meshes.py\\nscripts/13_milestone8b_readiness.py\\nscripts/06_operator_qa.py\\nscripts/12_retinal_bundle.py\\nagent_tickets/milestone_8b_retinal_ommatidial_sampler_tickets.md\\nagent_tickets/milestone_10_surface_wave_engine_tickets.md\\nsrc/flywire_wave/stimulus_registry.py\\nsrc/flywire_wave/stimulus_bundle.py\\nsrc/flywire_wave/scene_playback.py\\nsrc/flywire_wave/simulator_res