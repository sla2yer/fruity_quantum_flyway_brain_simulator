{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/milestone_1_experiment_manifest.schema.json",
  "title": "Milestone 1 Experiment Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "experiment_id",
    "milestone",
    "brief_version",
    "hypothesis_version",
    "model_scope",
    "stimulus_family",
    "stimulus_name",
    "primary_metric",
    "companion_metrics",
    "success_criteria_ids",
    "must_show_outputs",
    "random_seed",
    "comparison_arms",
    "output_bundle"
  ],
  "properties": {
    "experiment_id": {
      "type": "string",
      "minLength": 1
    },
    "milestone": {
      "const": "milestone_1"
    },
    "brief_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "hypothesis_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "subset_name": {
      "type": "string",
      "minLength": 1
    },
    "circuit_name": {
      "type": "string",
      "minLength": 1
    },
    "model_scope": {
      "type": "string",
      "minLength": 1
    },
    "stimulus_family": {
      "type": "string",
      "minLength": 1
    },
    "stimulus_name": {
      "type": "string",
      "minLength": 1
    },
    "primary_metric": {
      "type": "string",
      "minLength": 1
    },
    "companion_metrics": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "success_criteria_ids": {
      "type": "array",
      "minItems": 3,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^m1_[a-z0-9_]+$"
      }
    },
    "must_show_outputs": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "stimulus_overview",
          "surface_vs_baseline_split_view",
          "shared_output_trace_overlay",
          "null_direction_suppression_comparison",
          "latency_shift_comparison",
          "topology_ablation_comparison",
          "baseline_challenge_comparison",
          "milestone_decision_panel"
        ]
      }
    },
    "random_seed": {
      "type": "integer"
    },
    "seed_sweep": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "integer"
      }
    },
    "notes": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "comparison_arms": {
      "type": "array",
      "minItems": 4,
      "items": {
        "$ref": "#/$defs/comparisonArm"
      }
    },
    "output_bundle": {
      "$ref": "#/$defs/outputBundle"
    }
  },
  "anyOf": [
    {
      "required": [
        "subset_name"
      ]
    },
    {
      "required": [
        "circuit_name"
      ]
    }
  ],
  "allOf": [
    {
      "properties": {
        "comparison_arms": {
          "contains": {
            "properties": {
              "model_mode": {
                "const": "baseline"
              }
            },
            "required": [
              "model_mode"
            ]
          }
        }
      }
    },
    {
      "properties": {
        "comparison_arms": {
          "contains": {
            "properties": {
              "model_mode": {
                "const": "surface_wave"
              }
            },
            "required": [
              "model_mode"
            ]
          }
        }
      }
    },
    {
      "properties": {
        "comparison_arms": {
          "contains": {
            "properties": {
              "topology_condition": {
                "const": "intact"
              }
            },
            "required": [
              "topology_condition"
            ]
          }
        }
      }
    },
    {
      "properties": {
        "comparison_arms": {
          "contains": {
            "properties": {
              "topology_condition": {
                "const": "shuffled"
              }
            },
            "required": [
              "topology_condition"
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "comparisonArm": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "arm_id",
        "model_mode",
        "baseline_family",
        "topology_condition",
        "morphology_condition",
        "notes"
      ],
      "properties": {
        "arm_id": {
          "type": "string",
          "minLength": 1
        },
        "model_mode": {
          "type": "string",
          "enum": [
            "baseline",
            "surface_wave"
          ]
        },
        "baseline_family": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "P0",
            "P1",
            null
          ]
        },
        "topology_condition": {
          "type": "string",
          "enum": [
            "intact",
            "shuffled"
          ]
        },
        "morphology_condition": {
          "type": "string",
          "minLength": 1
        },
        "random_seed": {
          "type": "integer"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "model_mode": {
                "const": "surface_wave"
              }
            },
            "required": [
              "model_mode"
            ]
          },
          "then": {
            "properties": {
              "baseline_family": {
                "const": null
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "model_mode": {
                "const": "baseline"
              }
            },
            "required": [
              "model_mode"
            ]
          },
          "then": {
            "properties": {
              "baseline_family": {
                "enum": [
                  "P0",
                  "P1"
                ]
              }
            }
          }
        }
      ]
    },
    "plotOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "uiOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "outputBundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metrics_json",
        "summary_table_csv",
        "plots",
        "ui_states"
      ],
      "properties": {
        "metrics_json": {
          "type": "string",
          "minLength": 1
        },
        "summary_table_csv": {
          "type": "string",
          "minLength": 1
        },
        "plots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/plotOutput"
          }
        },
        "ui_states": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/uiOutput"
          }
        }
      }
    }
  }
}
