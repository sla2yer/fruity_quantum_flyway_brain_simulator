ssets,\n  3192\t    }\n  3193\t\n  3194\t\n  3195\tdef _resolve_output_targets(\n  3196\t    *,\n  3197\t    output_bundle: Mapping[str, Any],\n  3198\t    project_root: Path,\n  3199\t) -> dict[str, Any]:\n  3200\t    plots = []\n  3201\t    for plot in output_bundle.get(\"plots\", []):\n  3202\t        plots.append(\n  3203\t            {\n  3204\t                \"id\": _normalize_identifier(plot[\"id\"], field_name=\"output_bundle.plots.id\"),\n  3205\t                \"path\": str(_resolve_project_path(plot[\"path\"], project_root)),\n  3206\t            }\n  3207\t        )\n  3208\t    ui_states = []\n  3209\t    for state in output_bundle.get(\"ui_states\", []):\n  3210\t        ui_states.append(\n  3211\t            {\n  3212\t                \"id\": _normalize_identifier(state[\"id\"], field_name=\"output_bundle.ui_states.id\"),\n  3213\t                \"path\": str(_resolve_project_path(state[\"path\"], project_root)),\n  3214\t            }\n  3215\t        )\n  3216\t    return {\n  3217\t        \"metrics_json\": str(_resolve_project_path(output_bundle[\"metrics_json\"], project_root)),\n  3218\t        \"summary_table_csv\": str(\n  3219\t            _resolve_project_path(output_bundle[\"summary_table_csv\"], project_root)\n  3220\t        ),\n  3221\t        \"plots\": plots,\n  3222\t        \"ui_states\": ui_states,\n  3223\t    }\n  3224\t\n  3225\t\n  3226\tdef _resolve_arm_seed_handling(\n  3227\t    *,\n  3228\t    arm: Mapping[str, Any],\n  3229\t    arm_index: int,\n  3230\t    manifest_random_seed: int,\n  3231\t    seed_sweep: list[int],\n  3232\t) -> dict[str, Any]:\n  3233\t    arm_seed = arm.get(\"random_seed\")\n  3234\t    if arm_seed is None:\n  3235\t        default_seed = int(manifest_random_seed)\n  3236\t        seed_source = \"manifest.random_seed\"\n  3237\t    else:\n  3238\t        default_seed = int(arm_seed)\n  3239\t        seed_source = f\"comparison_arms[{arm_index}].random_seed\"\n  3240\t    return {\n  3241\t        \"default_seed\": default_seed,\n  3242\t        \"default_seed_source\": seed_source,\n  3243\t        \"manifest_random_seed\": int(manifest_random_seed),\n  3244\t        \"seed_sweep\": list(seed_sweep),\n  3245\t        \"seed_sweep_ordering\": DEFAULT_SEED_SWEEP_ORDERING,\n  3246\t    }\n  3247\t\n  3248\t\n  3249\tdef _build_model_configuration(\n  3250\t    *,\n  3251\t    arm_reference: Mapping[str, Any],\n  3252\t    arm_payload: Mapping[str, Any],\n  3253\t    runtime_config: Mapping[str, Any],\n  3254\t    circuit_assets: Mapping[str, Any],\n  3255\t    topology_condition: str,\n  3256\t) -> dict[str, Any]:\n  3257\t    model_mode = str(arm_reference[\"model_mode\"])\n  3258\t    baseline_family = arm_reference.get(\"baseline_family\")\n  3259\t    if model_mode == BASELINE_MODEL_MODE:\n  3260\t        assert isinstance(baseline_family, str)\n  3261\t        return {\n  3262\t            \"model_mode\": model_mode,\n  3263\t            \"baseline_family\": baseline_family,\n  3264\t            \"baseline_parameters\": copy.deepcopy(\n  3265\t                runtime_config[\"baseline_families\"][baseline_family]\n  3266\t            ),\n  3267\t        }\n  3268\t    surface_wave_model = copy.deepcopy(runtime_config[\"surface_wave_model\"])\n  3269\t    return {\n  3270\t        \"model_mode\": model_mode,\n  3271\t        \"baseline_family\": None,\n  3272\t        \"baseline_parameters\": None,\n  3273\t        \"surface_wave_model\": surface_wave_model,\n  3274\t        \"surface_wave_reference\": build_surface_wave_model_reference(surface_wave_model),\n  3275\t        \"surface_wave_execution_plan\": _build_surface_wave_execution_plan(\n  3276\t            arm_reference=arm_reference,\n  3277\t            arm_payload=arm_payload,\n  3278\t            point_neuron_model_spec=runtime_config[\"baseline_families\"][P0_BASELINE_FAMILY],\n  3279\t            topology_condition=topology_condition,\n  3280\t            runtime_timebase=runtime_config[\"timebase\"],\n  3281\t            circuit_assets=circuit_assets,\n  3282\t            surface_wave_model=surface_wave_model,\n  3283\t            mixed_fidelity_config=runtime_config[\"mixed_fidelity\"],\n  3284\t        ),\n  3285\t    }\n  3286\t\n  3287\t\n  3288\tdef _build_selected_assets(\n  3289\t    *,\n  3290\t    selection_reference: Mapping[str, Any],\n  3291\t    input_reference: Mapping[str, Any],\n  3292\t    circuit_assets: Mapping[str, Any],\n  3293\t    arm_reference: Mapping[str, Any],\n  3294\t    model_configuration: Mapping[str, Any],\n  3295\t    config_path: Path,\n  3296\t) -> list[dict[str, Any]]:\n  3297\t    selected_input_reference = input_reference[\"selected_input_reference\"]\n  3298\t    selected_input_kind = str(input_reference[\"selected_input_kind\"])\n  3299\t    selected_assets = [\n  3300\t        build_selected_asset_reference(\n  3301\t            asset_role=SELECTED_ROOT_IDS_ASSET_ROLE,\n  3302\t            artifact_type=\"root_id_roster\",\n  3303\t            path=selection_reference[\"selected_root_ids_path\"],\n  3304\t            contract_version=None,\n  3305\t            artifact_id=f\"root_id_roster:{selection_reference['selected_root_ids_hash']}\",\n  3306\t            bundle_id=None,\n  3307\t        ),\n  3308\t        build_selected_asset_reference(\n  3309\t            asset_role=INPUT_BUNDLE_ASSET_ROLE,\n  3310\t            artifact_type=selected_input_kind,\n  3311\t            path=input_reference[\"selected_input_metadata_path\"],\n  3312\t            contract_version=selected_input_reference[\"contract_version\"],\n  3313\t            artifact_id=selected_input_reference[\"bundle_id\"],\n  3314\t            bundle_id=selected_input_reference[\"bundle_id\"],\n  3315\t        ),\n  3316\t        build_selected_asset_reference(\n  3317\t            asset_role=GEOMETRY_MANIFEST_ASSET_ROLE,\n  3318\t            artifact_type=\"geometry_bundle_manifest\",\n  3319\t            path=circuit_assets[\"geometry_manifest_path\