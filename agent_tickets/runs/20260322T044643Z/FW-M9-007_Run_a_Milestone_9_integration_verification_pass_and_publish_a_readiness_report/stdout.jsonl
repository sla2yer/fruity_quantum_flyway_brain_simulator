    95\\t\\n    96\\t                manifest = json.loads(manifest_path.read_text(encoding=\\\"utf-8\\\"))\\n    97\\t                self.assertEqual(manifest[\\\"_asset_contract_version\\\"], \\\"geometry_bundle.v1\\\")\\n    98\\t                self.assertEqual(manifest[\\\"_dataset\\\"][\\\"flywire_dataset\\\"], \\\"public\\\")\\n    99\\t                self.assertEqual(manifest[\\\"_dataset\\\"][\\\"materialization_version\\\"], 783)\\n   100\\t                self.assertEqual(manifest[\\\"_meshing_config_snapshot\\\"][\\\"patch_hops\\\"], 2)\\n   101\\t                self.assertIn(\\\"101\\\", manifest)\\n   102\\t                self.assertEqual(manifest[\\\"101\\\"][\\\"processed_mesh_path\\\"], str(processed_mesh_path.resolve()))\\n   103\\t                self.assertEqual(manifest[\\\"101\\\"][\\\"surface_graph_path\\\"], str(surface_graph_path.resolve()))\\n   104\\t                self.assertEqual(manifest[\\\"101\\\"][\\\"patch_graph_path\\\"], str(patch_graph_path.resolve()))\\n   105\\t                self.assertEqual(manifest[\\\"101\\\"][\\\"descriptor_sidecar_path\\\"], str(descriptor_path.resolve()))\\n   106\\t                self.assertEqual(manifest[\\\"101\\\"][\\\"qa_sidecar_path\\\"], str(qa_path.resolve()))\\n   107\\t                self.assertEqual(manifest[\\\"101\\\"][\\\"meta_json_path\\\"], str(legacy_meta_path.resolve()))\\n   108\\t                self.assertEqual(manifest[\\\"101\\\"][\\\"project_role\\\"], \\\"surface_simulated\\\")\\n   109\\t                self.assertEqual(manifest[\\\"101\\\"][\\\"bundle_version\\\"], \\\"geometry_bundle.v1\\\")\\n   110\\t                self.assertEqual(manifest[\\\"101\\\"][\\\"bundle_status\\\"], \\\"ready\\\")\\n   111\\t                self.assertEqual(manifest[\\\"101\\\"][\\\"assets\\\"][\\\"raw_mesh\\\"][\\\"status\\\"], \\\"ready\\\")\\n   112\\t                self.assertEqual(manifest[\\\"101\\\"][\\\"assets\\\"][\\\"raw_skeleton\\\"][\\\"status\\\"], \\\"skipped\\\")\\n   113\