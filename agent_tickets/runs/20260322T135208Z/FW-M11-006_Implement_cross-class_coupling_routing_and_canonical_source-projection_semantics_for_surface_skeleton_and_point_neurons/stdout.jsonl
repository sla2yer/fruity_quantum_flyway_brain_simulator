rays.\"\n   918\t        )\n   919\t\n   920\t\n   921\tclass SurfaceSkeletonMorphologyRuntime:\n   922\t    def __init__(self, arm_plan: Mapping[str, Any]) -> None:\n   923\t        normalized_arm_plan = _require_mapping(arm_plan, field_name=\"arm_plan\")\n   924\t        self._arm_plan = copy.deepcopy(dict(normalized_arm_plan))\n   925\t        model_configuration = _require_mapping(\n   926\t            normalized_arm_plan.get(\"model_configuration\"),\n   927\t            field_name=\"arm_plan.model_configuration\",\n   928\t        )\n   929\t        execution_plan = _require_mapping(\n   930\t            model_configuration.get(\"surface_wave_execution_plan\"),\n","exit_code":0,"status":"completed"}}
