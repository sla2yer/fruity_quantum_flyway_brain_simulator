{"type":"item.completed","item":{"id":"item_31","type":"command_execution","command":"/bin/bash -lc \"nl -ba src/flywire_wave/registry.py | sed -n '952,980p'\"","aggregated_output":"   952\t\n   953\tdef _build_synapse_registry_provenance(\n   954\t    *,\n   955\t    synapse_source_path: Path | None,\n   956\t    synapse_registry_path: Path,\n   957\t    snapshot_version: str,\n   958\t    materialization_version: str,\n   959\t    row_count: int,\n   960\t    root_ids: list[int] | None,\n   961\t    root_ids_path: Path | None,\n   962\t    scope_label: str | None,\n   963\t) -> dict[str, Any]:\n   964\t    scope_mode = \"root_id_subset\" if root_ids is not None else \"all_rows\"\n   965\t    return {\n   966\t        \"built_at_utc\": datetime.now(timezone.utc).replace(microsecond=0).isoformat(),\n   967\t        \"snapshot_version\": snapshot_version,\n   968\t        \"materialization_version\": materialization_version,\n   969\t        \"row_count\": int(row_count),\n   970\t        \"source\": _file_provenance(synapse_source_path),\n   971\t        \"output\": {\n   972\t            \"path\": str(synapse_registry_path),\n   973\t        },\n   974\t        \"scope\": {\n   975\t            \"mode\": scope_mode,\n   976\t            \"label\": scope_label,\n   977\t            \"filter_mode\": SYNAPSE_SUBSET_FILTER_MODE,\n   978\t            \"root_ids_path\": str(root_ids_path) if root_ids_path is not None else None,\n   979\t            \"root_ids\": sorted({int(root_id) for root_id in root_ids}) if root_ids is not None else None,\n   980\t        },\n","exit_code":0,"status":"completed"}}
