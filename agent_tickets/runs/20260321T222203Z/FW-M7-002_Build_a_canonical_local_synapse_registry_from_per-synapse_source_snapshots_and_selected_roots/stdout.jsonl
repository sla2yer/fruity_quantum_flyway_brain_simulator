\"categorical_sign_with_signed_weight\\\"\\n    43\\tDEFAULT_DELAY_REPRESENTATION = \\\"nonnegative_delay_ms_per_synapse_or_delay_bin\\\"\\n    44\\tDEFAULT_AGGREGATION_RULE = \\\"sum_over_synapses_preserving_sign_and_delay_bins\\\"\\n    45\\tDEFAULT_MISSING_GEOMETRY_POLICY = \\\"fallback_or_blocked_with_explicit_reason\\\"\\n    46\\t\\n    47\\tLOCAL_SYNAPSE_REGISTRY_KEY = \\\"local_synapse_registry\\\"\\n    48\\tINCOMING_ANCHOR_MAP_KEY = \\\"incoming_anchor_map\\\"\\n    49\\tOUTGOING_ANCHOR_MAP_KEY = \\\"outgoing_anchor_map\\\"\\n    50\\tCOUPLING_INDEX_KEY = \\\"coupling_index\\\"\\n    51\\t\\n    52\\tREQUIRED_COUPLING_ASSET_KEYS = (\\n    53\\t    LOCAL_SYNAPSE_REGISTRY_KEY,\\n    54\\t    INCOMING_ANCHOR_MAP_KEY,\\n    55\\t    OUTGOING_ANCHOR_MAP_KEY,\\n    56\\t    COUPLING_INDEX_KEY,\\n    57\\t)\\n    58\\t\\n    59\\t\\n    60\\t@dataclass(frozen=True)\\n    61\\tclass CouplingContractPaths:\\n    62\\t    processed_coupling_dir: Path\\n    63\\t    local_synapse_registry_path: Path\\n    64\\t    root_asset_directory: Path\\n    65\\t    edge_bundle_directory: Path\\n    66\\t\\n    67\\t\\n    68\\t@dataclass(frozen=True)\\n    69\\tclass RootCouplingBundlePaths:\\n    70\\t    root_id: int\\n    71\\t    local_synapse_registry_path: Path\\n    72\\t    incoming_anchor_map_path: Path\\n    73\\t    outgoing_anchor_map_path: Path\\n    74\\t    coupling_index_path: Path\\n    75\\t\\n    76\\t    @property\\n    77\\t    def root_label(self) -> str:\\n    78\\t        return str(int(self.root_id))\\n    79\\t\\n    80\\t    def asset_paths(self) -> dict[str, Path]:\\n    81\\t        return {\\n    82\\t            LOCAL_SYNAPSE_REGISTRY_KEY: self.local_synapse_registry_path,\\n    83\\t            INCOMING_ANCHOR_MAP_KEY: self.incoming_anchor_map_path,\\n    84\\t            OUTGOING_ANCHOR_MAP_KEY: self.outgoing_anchor_map_path,\\n    85\\t            COUPLING_INDEX_KEY: self.coupling_index_path,\\n    86\\t        }\\n    87\\t\\n    88\\t\\n    89\\tdef build_coupling_contract_paths(processed_coupling_dir: str | Path) -> CouplingContractPaths:\\n    90\\t    coupling_dir = Path(processed_coupling_dir).resolve()\\n    91\\t    return CouplingContractPaths(\\n    92\\t        processed_coupling_dir=coupling_dir,\\n    93\\t        local_synapse_registry_path=coupling_dir / \\\"synapse_registry.csv\\\",\\n    94\\t        root_asset_directory=coupling_dir / \\\"roots\\\",\\n    95\\t        edge_bundle_directory=coupling_dir / \\\"edges\\\",\\n    96\\t    )\\n    97\\t\\n    98\\t\\n    99\\tdef build_root_coupling_bundle_paths(\\n   100\\t    root_id: int,\\n   101\\t    *,\\n   102\\t    processed_coupling_dir: str | Path,\\n   103\\t) -> RootCouplingBundlePaths:\\n   104\\t    root_label = str(int(root_id))\\n   105\\t    contract_paths = build_coupling_contract_paths(processed_coupling_dir)\\n   106\\t    return RootCouplingBundlePaths(\\n   107\\t        root_id=int(root_id),\\n   108\\t        local_synapse_registry_path=contract_paths.local_synapse_registry_path,\\n   109\\t        incoming_anchor_map_path=contract_paths.root_asset_directory / f\\\"{root_label}_incoming_anchor_map.npz\\\",\\n   110\\t        outgoing_anchor_map_path=contract_paths.root_asset_directory / f\\\"{root_label}_outgoing_anchor_map.npz\\\",\\n   111\\t        coupling_index_path=contract_paths.root_asset_directory / f\\\"{root_label}_coupling_index.json\\\",\\n   112\\t    )\\n   113\\t\\n   114\\t\\n   115\\tdef build_edge_coupling_bundle_path(\\n   116\\t    pre_root_id: int,\\n   117\\t    post_root_id: int,\\n   118\\t    *,\\n   119\\t    processed_coupling_dir: str | Path,\\n   120\\t) -> Path:\\n   121\\t    contract_paths = build_coupling_contract_paths(processed_coupling_dir)\\n   122\\t    return contract_paths.edge_bundle_directory / f\\\"{int(pre_root_id)}__to__{int(post_root_id)}_coupling.npz\\\"\\n   123\\t\\n   124\\t\\n   125\\tdef build_edge_coupling_bundle_reference(\\n   126\\t    *,\\n   127\\t    root_id: int,\\n   128\\t    pre_root_id: int,\\n   129\\t    post_root_id: int,\\n   130\\t    processed_coupling_dir: str | Path,\\n   131\\t    status: str = ASSET_STATUS_MISSING,\\n   132\\t) -> dict[str, Any]:\\n   133\\t    normalized_root_id = int(root_id)\\n   134\\t    normalized_pre_root_id = int(pre_root_id)\\n   135\\t    normalized_post_root_id = int(post_root_id)\\n   136\\t    if normalized_root_id == normalized_pre_root_id:\\n   137\\t        relation_to_root = \\\"outgoing\\\"\\n   138\\t        peer_root_id = normalized_post_root_id\\n   139\\t    elif normalized_root_id == normalized_post_root_id:\\n   140\\t        relation_to_root = \\\"incoming\\\"\\n   141\\t        peer_root_id = normalized_pre_root_id\\n   142\\t    else:\\n   143\\t        raise ValueError(\\n   144\\t            \\\"Root-local coupling bundle references must include edges where root_id \\\"\\n   145\\t            \\\"matches either pre_root_id or post_root_id.\\\"\\n   146\\t        )\\n   147\\t    return {\\n   148\\t        \\\"pre_root_id\\\": normalized_pre_root_id,\\n   149\\t        \\\"post_root_id\\\": normalized_post_root_id,\\n   150\\t        \\\"peer_root_id\\\": peer_root_id,\\n   151\\t        \\\"relation_to_root\\\": relation_to_root,\\n   152\\t        \\\"path\\\": str(\\n   153\\t            build_edge_coupling_bundle_path(\\n   154\\t                normalized_pre_root_id,\\n   155\\t                normalized_post_root_id,\\n   156\\t                processed_coupling_dir=processed_coupling_dir,\\n   157\\t            )\\n   158\\t        ),\\n   159\\t        \\\"status\\\": str(status),\\n   160\\t    }\\n   161\\t\\n   162\\t\\n   163\\tdef build_coupling_contract_manifest_metadata(\\n   164\\t    *,\\n   165\\t    processed_coupling_dir: str | Path | None = None,\\n   166\\t    coupling_bundle_metadata: Mapping[str, Any] | None = None,\\n   167\\t) -> dict[str, Any]:\\n   168\\t    local_synapse_registry_status = ASSET_STATUS_MISSING\\n   169\\t    resolved_processed_coupling_dir = processed_coupling_dir\\n   170\\t    if coupling_bundle_metadata is not None:\\n   171\\t        normalized_bundle = parse_coupling_bundle_metadata(coupling_bundle_metadata)\\n   172\\t        local_synapse_registry = dict(normalized_bundle[\\\"assets\\\"][LOCAL_SYNAPSE_REGISTRY_KEY])\\n   173\\t        resolved_processed_coupling_dir = Path(local_synapse_registry[\\\"path\\\"]).resolve().parent\\n   174\\t        local_synapse_registry_status = str(local_synapse_registry[\\\"status\\\"])\\n   175\\t    if resolved_processed_coupling_dir is None:\\n   176\\t        raise ValueError(\\n   177\\t            \\\"processed_coupling_dir must be provided when coupling_bundle_metadata is unavailable.\\\"\\n   178\\t        )\\n   179\\t\\n   180\\t    contract_paths = build_coupling_contract_paths(resolved_processed_coupling_dir)\\n   181\\t    return {\\n   182\\t        \\\"version\\\": COUPLING_BUNDLE_CONTRACT_VERSION,\\n   183\\t        \\\"design_note\\\": COUPLING_BUNDLE_DESIGN_NOTE,\\n   184\\t        \\\"design_note_version\\\": COUPLING_BUNDLE_DESIGN_NOTE_VERSION,\\n   185\\t        \\\"default_topology_family\\\": DEFAULT_COUPLING_TOPOLOGY_FAMILY,\\n   186\\t        \\\"supported_topology_families\\\": list(SUPPORTED_COUPLING_TOPOLOGY_FAMILIES),\\n   187\\t        \\\"supported_fallback_modes\\\": list(SUPPORTED_FALLBACK_MODES),\\n   188\\t        \\\"default_fallback_hierarchy\\\": copy.deepcopy(DEFAULT_FALLBACK_HIERARCHY),\\n   189\\t        \\\"default_sign_representation\\\": DEFAULT_SIGN_REPRESENTATION,\\n   190\\t        \\\"default_delay_representation\\\": DEFAULT_DELAY_REPRESENTATION,\\n   191\\t        \\\"default_aggregation_rule\\\": DEFAULT_AGGREGATION_RULE,\\n   192\\t        \\\"default_missing_geometry_policy\\\": DEFAULT_MISSING_GEOMETRY_POLICY,\\n   193\\t        \\\"local_synapse_registry\\\": {\\n   194\\t            \\\"path\\\": str(contract_paths.local_synapse_registry_path),\\n   195\\t            \\\"status\\\": local_synapse_registry_status,\\n   196\\t        },\\n   197\\t        \\\"root_asset_directory\\\": str(contract_paths.root_asset_directory),\\n   198\\t        \\\"edge_bundle_directory\\\": str(contract_paths.edge_bundle_directory),\\n   199\\t    }\\n   200\\t\\n   201\\t\\n   202\\tdef build_coupling_bundle_metadata(\\n   203\\t    *,\\n   204\\t    root_id: int,\\n   205\\t    processed_coupling_dir: str | Path,\\n   206\\t    local_synapse_registry_status: str = ASSET_STATUS_MISSING,\\n   207\\t    incoming_anchor_map_status: str = ASSET_STATUS_MISSING,\\n   208\\t    outgoing_anchor_map_status: str = ASSET_STATUS_MISSING,\\n   209\\t    coupling_index_status: str = ASSET_STATUS_MISSING,\\n   210\\t    edge_bundles: Sequence[Mapping[str, Any]] | None = None,\\n   211\\t    topology_family: str = DEFAULT_COUPLING_TOPOLOGY_FAMILY,\\n   212\\t    fallback_hierarchy: Sequence[str] | None = None,\\n   213\\t    sign_representation: str = DEFAULT_SIGN_REPRESENTATION,\\n   214\\t    delay_representation: str = DEFAULT_DELAY_REPRESENTATION,\\n   215\\t    aggregation_rule: str = DEFAULT_AGGREGATION_RULE,\\n   216\\t    missing_geometry_policy: str = DEFAULT_MISSING_GEOMETRY_POLICY,\\n   217\\t) -> dict[str, Any]:\\n   218\\t    normalized_topology_family = _normalize_topology_family(topology_family)\\n   219\\t    normalized_fallback_hierarchy = _normalize_fallback_hierarchy(fallback_hierarchy)\\n   220\\t    bundle_paths = build_root_coupling_bundle_paths(root_id, processed_coupling_dir=processed_coupling_dir)\\n   221\\t    assets = {\\n   222\\t        LOCAL_SYNAPSE_REGISTRY_KEY: {\\n   223\\t            \\\"path\\\": str(bundle_paths.local_synapse_registry_path),\\n   224\\t            \\\"status\\\": str(local_synapse_registry_status),\\n   225\\t        },\\n   226\\t        INCOMING_ANCHOR_MAP_KEY: {\\n   227\\t            \\\"path\\\": str(bundle_paths.incoming_anchor_map_path),\\n   228\\t            \\\"status\\\": str(incoming_anchor_map_status),\\n   229\\t        },\\n   230\\t        OUTGOING_ANCHOR_MAP_KEY: {\\n   231\\t            \\\"path\\\": str(bundle_paths.outgoing_anchor_map_path),\\n   232\\t            \\\"status\\\": str(outgoing_anchor_map_status),\\n   233\\t        },\\n   234\\t        COUPLING_INDEX_KEY: {\\n   235\\t            \\\"path\\\": str(bundle_paths.coupling_index_path),\\n   236\\t            \\\"status\\\": str(coupling_index_status),\\n   237\\t        },\\n   238\\t    }\\n   239\\t    normalized_edge_bundles = _normalize_edge_bundles(edge_bundles)\\n   240\\t    bundle_status = _bundle_status(\\n   241\\t        [\\n   242\\t            *(str(asset[\\\"status\\\"]) for asset in assets.values()),\\n   243\\t            *(str(edge_bundle[\\\"status\\\"]) for edge_bundle in normalized_edge_bundles),\\n   244\\t        ]\\n   245\\t    )\\n   246\\t    return {\\n   247\\t        \\\"contract_version\\\": COUPLING_BUNDLE_CONTRACT_VERSION,\\n   248\\t        \\\"design_note\\\": COUPLING_BUNDLE_DESIGN_NOTE,\\n   249\\t        \\\"design_note_version\\\": COUPLING_BUNDLE_DESIGN_NOTE_VERSION,\\n   250\\t        \\\"status\\\": bundle_status,\\n   251\\t        \\\"topology_family\\\": normalized_topology_family,\\n   252\\t        \\\"fallback_hierarchy\\\": normalized_fallback_hierarchy,\\n   253\\t        \\\"sign_representation\\\": str(sign_representation),\\n   254\\t        \\\"delay_representation\\\": str(delay_representation),\\n   255\\t        \\\"aggregation_rule\\\": str(aggregation_rule),\\n   256\\t        \\\"missing_geometry_policy\\\": str(missing_geometry_policy),\\n   257\\t        \\\"assets\\\": assets,\\n   258\\t        \\\"edge_bundles\\\": normalized_edge_bundles,\\n   259\\t    }\\n   260\\t\\n\",\"exit_code\":0,\"status\":\"completed\"}}\nagent_tickets/runs/20260321T222203Z/FW-M7-001_Freeze_a_versioned_synapse_asset_contract_and_inter-neuron_coupling_design_note/stdout.jsonl:116:{\"type\":\"item.started\",\"item\":{\"id\":\"item_71\",\"type\":\"command_execution\",\"command\":\"/bin/bash -lc \\\"nl -ba docs/coupling_bundle_design.md | sed -n '1,240p'\\\"\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\nagent_tickets/runs/20260321T222203Z/FW-M7-001_Freeze_a_versioned_synapse_asset_contract_and_inter-neuron_coupling_design_note/stdout.jsonl:118:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_70\",\"type\":\"command_execution\",\"command\":\"/bin/bash -lc \\\"nl -ba docs/pipeline_notes.md | sed -n '80,140p'\\\"\",\"aggregated_output\":\"    80\\t  a legacy metadata pointer so older consumers can keep reading the prior\\n    81\\t  sidecar name during migration.\\n    82\\t- `docs/operator_bundle_design.md` is the authoritative Milestone 6 operator\\n    83\\t  decision note; later tickets should cite it instead of re-litigating the\\n    84\\t  default discretization family.\\n    85\\t\\n    86\\t### Synapse and coupling handoff contract\\n    87\\t\\n    88\\tMilestone 7 now reserves one explicit synapse/coupling discovery surface under\\n    89\\tthe versioned contract `coupling_bundle.v1`.\\n    90\\t\\n    91\\tThe canonical layout is:\\n    92\\t\\n    93\\t- `config.paths.processed_coupling_dir/synapse_registry.csv`: local,\\n    94\\t  simulator-facing synapse registry owned by the library contract\\n    95\\t- `config.paths.processed_coupling_dir/roots/<root_id>_incoming_anchor_map.npz`:\\n    96\\t  postsynaptic landing-anchor lookup for one root\\n    97\\t- `config.paths.processed_coupling_dir/roots/<root_id>_outgoing_anchor_map.npz`:\\n    98\\t  presynaptic readout-anchor lookup for one root\\n    99\\t- `config.paths.processed_coupling_dir/roots/<root_id>_coupling_index.json`:\\n   100\\t  root-local coupling discovery index that can enumerate realized edge bundles\\n   101\\t- `config.paths.processed_coupling_dir/edges/<pre_root_id>__to__<post_root_id>_coupling.npz`:\\n   102\\t  canonical edge-level coupling bundle path\\n   103\\t\\n   104\\t`config.paths.manifest_json` now also records:\\n   105\\t\\n   106\\t- `_coupling_contract_version` and `_coupling_contract` at the manifest header\\n   107\\t- a per-root `coupling_bundle` block that points to the local synapse registry,\\n   108\\t  root-local anchor maps, the root-local coupling index, and any explicit\\n   109\\t  edge-bundle references already built for that root\\n   110\\t- the design-note path and design-note version each bundle conforms to\\n   111\\t\\n   112\\tThe default Milestone 7 semantics are intentionally fixed early:\\n   113\\t\\n   114\\t- topology family: `distributed_patch_cloud`\\n   115\\t- fallback hierarchy: `surface_patch_cloud` ->\\n   116\\t  `skeleton_segment_cloud` -> `point_neuron_lumped`\\n   117\\t- sign representation: `categorical_sign_with_signed_weight`\\n   118\\t- delay representation: `nonnegative_delay_ms_per_synapse_or_delay_bin`\\n   119\\t- multi-synapse aggregation: `sum_over_synapses_preserving_sign_and_delay_bins`\\n   120\\t\\n   121\\t`docs/coupling_bundle_design.md` is the authoritative Milestone 7 decision note;\\n   122\\tlater tickets should cite it instead of re-litigating the default coupling\\n   123\\tfamily, fallback hierarchy, or sign/delay/aggregation invariants.\\n   124\\t\\n   125\\t### Offline operator QA contract\\n   126\\t\\n   127\\tMilestone 6 also now defines one deterministic offline inspection workflow for\\n   128\\toperator bundles:\\n   129\\t\\n   130\\t- `scripts/06_operator_qa.py` reads the local fine operator, coarse operator,\\n   131\\t  transfer bundle, patch graph, and operator metadata for one or more root IDs\\n   132\\t- output goes to `config.paths.operator_qa_dir/root-ids-<sorted-root-ids>/`\\n   133\\t- the report is static: `index.html`, `report.md`, `summary.json`,\\n   134\\t  per-root detail JSON, and SVG panels for pulse initialization, boundary-mask\\n   135\\t  inspection, patch decomposition, smoke-evolved fine/coarse fields, and coarse\\n   136\\t  reconstruction error\\n   137\\t- the report summary includes pass / warn / fail checks plus an\\n   138\\t  `operator_readiness_gate` of `go`, `review`, or `hold`\\n   139\\t- `scripts/07_milestone6_readiness.py` layers a fixture-suite check plus a\\n   140\\t  manifest/operator-contract audit on top of the operator QA bundle and writes\\n\",\"exit_code\":0,\"status\":\"completed\"}}\nagent_tickets/runs/20260321T222203Z/FW-M7-001_Freeze_a_versioned_synapse_asset_contract_and_inter-neuron_coupling_design_note/stdout.jsonl:119:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_71\",\"type\":\"command_execution\",\"command\":\"/bin/bash -lc \\\"nl -ba docs/coupling_bundle_design.md | sed -n '1,240p'\\\"\",\"aggregated_output\":\"     1\\t# Milestone 7 Synapse Asset Contract And Coupling Topology Choice\\n     2\\t\\n     3\\tThis note freezes the Milestone 7 synapse and inter-neuron coupling handoff so\\n     4\\tlater simulator and UI work can target one explicit manifest contract, one\\n     5\\texplicit bundle layout, and one explicit coupling interpretation.\\n     6\\t\\n     7\\t## Contract summary\\n     8\\t\\n     9\\tThe processed manifest now carries `_coupling_contract_version:\\n    10\\tcoupling_bundle.v1` plus a per-root `coupling_bundle` block.\\n    11\\t\\n    12\\tThe top-level contract owns:\\n    13\\t\\n    14\\t- the authoritative local synapse-registry path\\n    15\\t- the versioned design-note reference and design-note version\\n    16\\t- the supported coupling-topology families\\n    17\\t- the supported fallback modes\\n    18\\t- the default sign, delay, aggregation, and missing-geometry policies\\n    19\\t- the canonical root-asset and edge-bundle directories\\n    20\\t\\n    21\\tEach per-root `coupling_bundle` block owns:\\n    22\\t\\n    23\\t- the same contract and design-note versions\\n    24\\t- the realized topology family for that root-local handoff\\n    25\\t- the fallback hierarchy the later mapping/assembly stages must follow\\n    26\\t- the sign and