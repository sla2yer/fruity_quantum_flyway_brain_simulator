{"type":"item.started","item":{"id":"item_60","type":"command_execution","command":"/bin/bash -lc \"python3 - <<'PY'\nimport sys, json, tempfile\nfrom pathlib import Path\nroot=Path('/home/jack/Documents/github/personal/fly_neural_simulation/flywire_wave_repo')\nsys.path.insert(0, str(root/'src'))\nfrom flywire_wave.validation_task import run_task_validation_suite\nfrom flywire_wave.experiment_comparison_analysis import EXPERIMENT_COMPARISON_SUMMARY_VERSION\n\nbase_summary = {\n    'summary_version': EXPERIMENT_COMPARISON_SUMMARY_VERSION,\n    'manifest_reference': {'experiment_id': 'fixture_validation_ladder_smoke'},\n    'bundle_set': {\n        'expected_arm_ids': ['baseline_arm', 'surface_wave_arm'],\n        'expected_seeds_by_arm_id': {\n            'baseline_arm': [11,17],\n            'surface_wave_arm': [11,17],\n        },\n    },\n    'analysis_results': {\n        'task_decoder_analysis': {\n            'metric_rows': [],\n            'decoder_summaries': [],\n        },\n    },\n    'comparison_group_catalog': [\n        {\n            'group_id': 'matched_surface_wave_vs_baseline',\n            'group_kind': 'matched_surface_wave_vs_baseline',\n            'arm_ids': ['surface_wave_arm', 'baseline_arm'],\n            'component_group_ids': [],\n        },\n    ],\n    'group_metric_seed_rows': [],\n    'group_metric_rollups': [],\n    'null_test_results': [],\n    'task_scores': [],\n    'wave_metric_rollups': [],\n}\nfor group_id, kind, mean in [\n    ('matched_surface_wave_vs_baseline', 'matched_surface_wave_vs_baseline', 0.2),\n    ('geometry_ablation_demo', 'geometry_ablation', 0.1),\n]:\n    if group_id == 'geometry_ablation_demo':\n        base_summary['comparison_group_catalog'].append({\n            'group_id': group_id,\n            'group_kind': kind,\n            'arm_ids': ['surface_wave_arm', 'baseline_arm'],\n            'component_group_ids': [],\n        })\n    base_summary['group_metric_rollups'].append({\n        'group_id': group_id,\n        'group_kind': kind,\n        'metric_id': 'direction_selectivity_index',\n        'summary_statistics': {'mean': mean},\n        'seeds': [11,17],\n        'seed_count': 2,\n        'sign_consistency': True,\n        'effect_direction': 'positive',\n    })\nfor null_test_id in ['geometry_shuffle_collapse','seed_stability','stronger_baseline_survival']:\n    base_summary['null_test_results'].append({'null_test_id': null_test_id, 'status': 'pass', 'metric_outcomes': []})\nmetric_values = {\n    'motion_vector_heading_deg': {'baseline_arm':[1.0,2.0],'surface_wave_arm':[3.0,4.0]},\n    'optic_flow_heading_deg': {'baseline_arm':[1.5,2.5],'surface_wave_arm':[4.0,5.0]},\n    'motion_vector_speed_deg_per_s': {'baseline_arm':[1.0,1.02],'surface_wave_arm':[1.4,1.45]},\n    'optic_flow_speed_deg_per_s': {'baseline_arm':[0.9,0.93],'surface_wave_arm':[1.3,1.34]},\n}\nfor arm_id, decoder_id, readout_id in [('baseline_arm','decoder_baseline','shared_output_mean'),('surface_wave_arm','decoder_wave','shared_output_mean')]:\n    for seed in [11,17]:\n        base_summary['analysis_results']['task_decoder_analysis']['decoder_summaries'].append({\n            'arm_id': arm_id, 'decoder_id': decoder_id, 'status': 'ok', 'seed': seed, 'readout_id': readout_id,\n        })\nfor metric_id, arms in metric_values.items():\n    for arm_id, values in arms.items():\n        for seed, value in zip([11,17], values):\n            base_summary['analysis_results']['task_decoder_analysis']['metric_rows'].append({\n                'arm_id': arm_id, 'metric_id': metric_id, 'seed': seed, 'value': value,\n            })\n    # group rollup mean as difference-ish value\n    base_summary['group_metric_rollups'].append({\n        'group_id': 'matched_surface_wave_vs_baseline',\n        'group_kind': 'matched_surface_wave_vs_baseline',\n        'metric_id': metric_id,\n        'summary_statistics': {'mean': 2.0 if 'heading' in metric_id else 0.3},\n        'seeds': [11,17],\n        'seed_count': 2,\n        'sign_consistency': True,\n        'effect_direction': 'positive',\n    })\n\nnoise0 = json.loads(json.dumps(base_summary))\nnoise1 = json.loads(json.dumps(base_summary))\nfor row in noise1['analysis_results']['task_decoder_analysis']['metric_rows']:\n    if 'heading' in row['metric_id']:\n        row['value'] += 3.0\n    else:\n        row['value'] *= 0.9\nfor rollup in noise1['group_metric_rollups']:\n    if 'heading' in rollup['metric_id']:\n        rollup['summary_statistics']['mean'] += 3.0\n    elif rollup['metric_id'] == 'direction_selectivity_index':\n        rollup['summary_statistics']['mean'] *= 0.9\n    else:\n        rollup['summary_statistics']['mean'] *= 0.9\n\nwith tempfile.TemporaryDirectory() as td:\n    result = run_task_validation_suite(\n        analysis_summary=base_summary,\n        perturbation_analysis_bundle_specs=[\n            {'suite_id':'noise_robustness','variant_id':'seed_11__noise_0p0','analysis_summary': noise0},\n            {'suite_id':'noise_robustness','variant_id':'seed_11__noise_0p1','analysis_summary': noise1},\n        ],\n        processed_simulator_results_dir=Path(td)/'out',\n        experiment_id='fixture_validation_ladder_smoke',\n    )\n    print(json.dumps(result, indent=2, sort_keys=True))\n    print(Path(result['summary_path']).read_text())\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
