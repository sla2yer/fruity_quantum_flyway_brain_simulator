rr_path.write_text(\"\", encoding=\"utf-8\")\n   311\t        if not staging_last_message_path.exists():\n   312\t            staging_last_message_path.write_text(\"\", encoding=\"utf-8\")\n   313\t\n   314\t        _sync_prompt_artifacts(staging_dir, output_dir)\n   315\t\n   316\t    return {\n   317\t        \"job_name\": job_name,\n   318\t        \"command\": cmd,\n   319\t        \"returncode\": int(return_code),\n   320\t        \"output_dir\": str(output_dir),\n   520\t    summary_path = output_dir / SUMMARY_FILENAME\n   521\t    summary[\"summary_path\"] = str(summary_path)\n   522\t    write_review_run_summary(summary, output_dir)\n   523\t    return summary\n   524\t\n   525\t\n   526\tdef execute_review_prompt_workflow(\n   527\t    prompt_sets: Sequence[ReviewPromptSet],\n   528\t    *,\n   529\t    repo_root: str | Path,\n   530\t    runner: str,\n   531\t    output_dir: str | Path,\n   532\t    sandbox: str,\n   533\t    specializer_model: str | None = None,\n   534\t    review_model: str | None = None,\n   535\t    extra_args: list[str] | None = None,\n   536\t    max_workers: int | None = None,\n   537\t    continue_on_error: bool = False,\n   538\t    heartbeat_seconds: float = 20.0,\n   539\t    progress_callback: Callable[[str], None] | None = None,\n   540\t    job_runner: PromptJobRunner | None = None,\n   541\t) -> dict[str, Any]:\n   542\t    selected_prompt_sets = list(prompt_sets)\n   543\t    if not selected_prompt_sets:\n   544\t        raise RuntimeError(\"No prompt sets selected.\")\n   545\t\n   546\t    repo_root = Path(repo_root).resolve()\n   547\t    output_dir = Path(output_dir).resolve()\n   548\t    output_dir.mkdir(parents=True, exist_ok=True)\n   549\t    job_runner = job_runner or run_prompt_job\n   550\t    worker_count = _worker_count(len(selected_prompt_sets), max_workers)\n   551\t\n   552\t    def run_specialization(prompt_set: ReviewPromptSet) -> dict[str, Any]:\n   553\t        stage_output_dir = output_dir / \"special