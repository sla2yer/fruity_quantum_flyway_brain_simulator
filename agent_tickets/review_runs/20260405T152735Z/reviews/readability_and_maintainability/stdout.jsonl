{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"/bin/bash -lc \"nl -ba tests/test_manifest_validation.py | sed -n '1,260p'\"","aggregated_output":"     1\tfrom __future__ import annotations\n     2\t\n     3\timport copy\n     4\timport sys\n     5\timport unittest\n     6\tfrom pathlib import Path\n     7\t\n     8\tROOT = Path(__file__).resolve().parents[1]\n     9\tSRC = ROOT / \"src\"\n    10\tsys.path.insert(0, str(SRC))\n    11\t\n    12\tfrom flywire_wave.manifests import load_json, load_yaml, validate_manifest, validate_manifest_payload\n    13\t\n    14\t\n    15\tclass ManifestValidationTest(unittest.TestCase):\n    16\t    @classmethod\n    17\t    def setUpClass(cls) -> None:\n    18\t        cls.schema = load_json(ROOT / \"schemas/milestone_1_experiment_manifest.schema.json\")\n    19\t        cls.design_lock = load_yaml(ROOT / \"config/milestone_1_design_lock.yaml\")\n    20\t        cls.base_manifest = load_yaml(ROOT / \"manifests/examples/milestone_1_demo.yaml\")\n    21\t        cls.stimulus_cases = load_yaml(ROOT / \"tests/fixtures/manifest_stimulus_cases.yaml\")\n    22\t\n    23\t    def test_example_manifest_validates_against_schema_and_design_lock(self) -> None:\n    24\t        summary = validate_manifest(\n    25\t            manifest_path=ROOT / \"manifests/examples/milestone_1_demo.yaml\",\n    26\t            schema_path=ROOT / \"schemas/milestone_1_experiment_manifest.schema.json\",\n    27\t            design_lock_path=ROOT / \"config/milestone_1_design_lock.yaml\",\n    28\t        )\n    29\t\n    30\t        self.assertEqual(summary[\"milestone\"], \"milestone_1\")\n    31\t        self.assertEqual(summary[\"comparison_arm_count\"], 6)\n    32\t        self.assertEqual(summary[\"success_criteria_count\"], 5)\n    33\t        self.assertEqual(summary[\"stimulus_contract_version\"], \"stimulus_bundle.v1\")\n    34\t        self.assertEqual(summary[\"stimulus_bundle_reference\"][\"stimulus_family\"], \"translated_edge\")\n    35\t        self.assertEqual(summary[\"stimulus_bundle_reference\"][\"stimulus_name\"], \"simple_translated_edge\")\n    36\t        self.assertEqual(\n    37\t            summary[\"stimulus_bundle\"][\"parameter_hash\"],\n    38\t            summary[\"resolved_stimulus_parameter_hash\"],\n    39\t        )\n    40\t\n    41\t    def test_thresholds_remain_intentionally_unspecified(self) -> None:\n    42\t        design_lock = load_yaml(ROOT / \"config/milestone_1_design_lock.yaml\")\n    43\t        for criterion in design_lock[\"success_criteria\"]:\n    44\t            self.assertIsNone(criterion[\"metric\"][\"threshold\"])\n    45\t            self.assertEqual(criterion[\"metric\"][\"threshold_status\"], \"intentionally_unspecified\")\n    46\t\n    47\t    def test_fixture_manifest_resolves_normalized_stimulus_metadata(self) -> None:\n    48\t        manifest = self._build_manifest_fixture(\n    49\t            self.stimulus_cases[\"valid_cases\"][\"nested_stimulus_overrides\"]\n    50\t        )\n    51\t\n    52\t        summary = validate_manifest_payload(\n    53\t            manifest=manifest,\n    54\t            schema=self.schema,\n    55\t            design_lock=self.design_lock,\n    56\t            processed_stimulus_dir=ROOT / \"data/processed/test_manifest_stimuli\",\n    57\t        )\n    58\t\n    59\t        self.assertEqual(summary[\"resolved_stimulus_family\"], \"translated_edge\")\n    60\t        self.assertEqual(summary[\"resolved_stimulus_name\"], \"simple_translated_edge\")\n    61\t        self.assertEqual(summary[\"resolved_stimulus\"][\"determinism\"][\"seed\"], 17)\n    62\t        self.assertEqual(summary[\"resolved_stimulus\"][\"determinism\"][\"seed_source\"], \"random_seed\")\n    63\t        self.assertEqual(summary[\"resolved_stimulus\"][\"parameter_snapshot\"][\"background_level\"], 0.45)\n    64\t        self.assertEqual(summary[\"resolved_stimulus\"][\"parameter_snapshot\"][\"velocity_deg_per_s\"], 55.0)\n    65\t        self.assertEqual(summary[\"resolved_stimulus\"][\"temporal_sampling\"][\"frame_count\"], 25)\n    66\t        self.assertEqual(summary[\"resolved_stimulus\"][\"spatial_frame\"][\"width_px\"], 64)\n    67\t        self.assertEqual(summary[\"stimulus_bundle_reference\"][\"contract_version\"], \"stimulus_bundle.v1\")\n    68\t        self.assertEqual(summary[\"stimulus_bundle_reference\"][\"parameter_hash\"], summary[\"resolved_stimulus_parameter_hash\"])\n    69\t        self.assertEqual(\n    70\t            Path(summary[\"stimulus_bundle_metadata_path\"]),\n    71\t            (\n    72\t                ROOT\n    73\t                / \"data/processed/test_manifest_stimuli/bundles/translated_edge/simple_translated_edge\"\n    74\t                / summary[\"resolved_stimulus_parameter_hash\"]\n    75\t                / \"stimulus_bundle.json\"\n    76\t            ).resolve(),\n    77\t        )\n    78\t\n    79\t    def test_fixture_manifest_invalid_stimulus_references_fail_clearly(self) -> None:\n    80\t        for case_name, case in self.stimulus_cases[\"invalid_cases\"].items():\n    81\t            with self.subTest(case=case_name):\n    82\t                manifest = self._build_manifest_fixture(case)\n    83\t                with self.assertRaises(ValueError) as ctx:\n    84\t                    validate_manifest_payload(\n    85\t                        manifest=manifest,\n    86\t                        schema=self.schema,\n    87\t                        design_lock=self.design_lock,\n    88\t                    )\n    89\t                self.assertIn(case[\"error_substring\"], str(ctx.exception))\n    90\t\n    91\t    def _build_manifest_fixture(self, patch: dict[str, object]) -> dict[str, object]:\n    92\t        manifest = copy.deepcopy(self.base_manifest)\n    93\t        patch_payload = {key: value for key, value in patch.items() if key != \"error_substring\"}\n    94\t        return _deep_merge(manifest, patch_payload)\n 