tch_vertices(\n   179\t    adj: sp.csr_matrix,\n   180\t    *,\n   181\t    seed: int,\n   182\t    unassigned: np.ndarray,\n   183\t    patch_hops: int,\n   184\t    cap: int,\n   185\t) -> np.ndarray:\n   186\t    queue: deque[tuple[int, int]] = deque([(int(seed), 0)])\n   187\t    visited = {int(seed)}\n   188\t    patch_vertices: list[int] = []\n   189\t\n   190\t    while queue and len(patch_vertices) < cap:\n   191\t        vertex, distance = queue.popleft()\n   192\t        if not bool(unassigned[vertex]):\n   193\t            continue\n   194\t\n   195\t        patch_vertices.append(vertex)\n   196\t        if distance >= patch_hops:\n   197\t            continue\n   198\t\n   199\t        start = int(adj.indptr[vertex])\n   200\t        end = int(adj.indptr[vertex + 1])\n   201\t        for neighbor in adj.indices[start:end]:\n   202\t            neighbor_idx = int(neighbor)\n   203\t            if neighbor_idx in visited or not bool(unassigned[neighbor_idx]):\n   204\t                continue\n   205\t            visited.add(neighbor_idx)\n   206\t            queue.append((neighbor_idx, distance + 1))\n   207\t\n   208\t    return np.asarray(patch_vertices, dtype=np.int32)\n   209\t\n   210\t\n   211\tdef _build_patch_membership_arrays(patches: list[np.ndarray]) -> tuple[np.ndarray, np.ndarray]:\n   212\t    member_vertex_indptr = np.zeros(len(patches) + 1, dtype=np.int32)\n   213\t    if not patches:\n   214\t        return np.empty(0, dtype=np.int32), member_vertex_indptr\n   215\t\n   216\t    counts = np.asarray([int(patch.size) for patch in patches], dtype=np.int32)\n   217\t    member_vertex_indptr[1:] = np.cumsum(counts, dtype=np.int32)\n   218\t    member_vertex_indices = np.concatenate(patches).astype(np.int32, copy=False)\n   219\t    return member_vertex_indices, member_vertex_indptr\n   220\t\n   221\t\n   222\tdef _build_patch_adjacency(\n   223\t    adj: sp.csr_matrix,\n   224\t    surface_to_patch: np.ndarray,\n   225\t    *,\n   226\t    patch_count: int,\n   227\t) -> sp.csr_matrix:\n   228\t    if patch_count <= 0:\n   229\t        return sp.csr_matrix((0, 0), dtype=np.float32)\n   230\t\n   231\t    upper_edges = sp.triu(adj, k=1).tocoo()\n   232\t    edge_weights: dict[tuple[int, int], float] = {}\n   233\t    for row, col, weight in zip(upper_edges.row, upper_edges.col, upper_edges.data):\n   234\t        patch_u = int(surface_to_patch[int(row)])\n   235\t        patch_v = int(surface_to_patch[int(col)])\n   236\t        if patch_u == patch_v:\n   237\t            continue\n   238\t        if patch_u > patch_v:\n   239\t            patch_u, patch_v = patch_v, patch_u\n   240\t        edge_weights[(patch_u, patch_v)] = edge_weights.get((patch_u, patch_v), 0.0) + float(weight)\n   241\t\n   242\t    if not edge_weights:\n   243\t        return sp.csr_matrix((patch_count, patch_count), dtype=np.float32)\n   244\t\n   245\t    rows: list[int] = []\n   246\t    cols: list[int] = []\n   247\t    data: list[float] = []\n   248\t    for (patch_u, patch_v), weight in sorted(edge_weights.items()):\n   249\t        rows.extend([patch_u, patch_v])\n   250\t        cols.extend([patch_v, patch_u])\n   251\t        data.extend([weight, weight])\n   252\t\n   253\t    patch_adj = sp.csr_matrix(\n   254\t        (np.asarray(data, dtype=np.float32), (rows, cols)),\n   255\t        shape=(patch_count, patch_count),\n   256\t    )\n   257\t    patch_adj.eliminate_zeros()\n   258\t    patch_adj.sort_indices()\n   259\t    return patch_adj\n   260\t\n","exit_code":0,"status":"completed"}}
