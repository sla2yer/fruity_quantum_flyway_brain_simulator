ed_root_set)\n  3105\t        & touching[\"post_root_id\"].isin(selected_root_set)\n  3106\t    ]\n  3107\t    outgoing = touching[\n  3108\t        touching[\"pre_root_id\"].isin(selected_root_set)\n  3109\t        & ~touching[\"post_root_id\"].isin(selected_root_set)\n  3110\t    ]\n  3111\t    incoming = touching[\n  3112\t        ~touching[\"pre_root_id\"].isin(selected_root_set)\n  3113\t        & touching[\"post_root_id\"].isin(selected_root_set)\n  3114\t    ]\n  3115\t    context_root_ids = set(int(root_id) for root_id in outgoing[\"post_root_id\"].tolist())\n  3116\t    context_root_ids |= set(int(root_id) for root_id in incoming[\"pre_root_id\"].tolist())\n  3117\t    return {\n  3118\t        \"synapse_row_count\": int(len(synapse_registry)),\n  3119\t        \"touching_active_subset_row_count\": int(len(touching)),\n  3120\t        \"selected_to_selected_row_count\": int(len(internal)),\n  3121\t        \"selected_to_context_row_count\": int(len(outgoing)),\n  3122\t        \"context_to_selected_row_count\": int(len(incoming)),\n  3123\t        \"context_neighbor_root_count\": int(len(context_root_ids)),\n  3124\t        \"context_neighbor_root_ids_preview\": sorted(context_root_ids)[:12],\n  3125\t    }\n  3126\t\n  3127\t\n  3128\tdef _load_synapse_evidence_registry(path: Path) -> pd.DataFrame:\n  3129\t    try:\n  3130\t        return load_synapse_registry(path)\n  3131\t    except ValueError as exc:\n  3132\t        df = pd.read_csv(path)\n  3133\t        required_columns = [\"pre_root_id\", \"post_root_id\"]\n  3134\t        missing_columns = [\n  3135\t            column for column in required_columns if column not in df.columns\n  3136\t        ]\n  3137\t        if missing_columns:\n  3138\t            raise ValueError(\n  3139\t                \"Local synapse registry is incompatible with whole-brain context \"\n  3140\t                f\"planning at {path}: missing required columns {missing_columns!r}.\"\n  3141\t            ) from exc\n  3142\t        normalized = df.loc[:, required_columns].copy()\n  3143\t        for column in required_columns:\n  3144\t            numeric = pd.to_numeric(normalized[column], errors=\"coerce\")\n  3145\t            if numeric.isna().any():\n  3146\t                raise ValueError(\n  3147\t                    \"Local synapse registry is incompatible with whole-brain context \"\n  3148\t                    f\"planning at {path}: column {column!r} contains non-integer values.\"\n  3149\t                ) from exc\n  3150\t            normalized[column] = numeric.astype(int)\n  3151\t        return normalized\n  3152\t\n  3153\t\n  3154\tdef _default_active_query_profile(available_query_profile_ids: Sequence[str]) -> str:\n  3155\t    for candidate in _ACTIVE_QUERY_PRIORITY:\n  3156\t        if candidate in set(available_query_profile_ids):\n  3157\t            return candidate\n  3158\t    return str(available_query_profile_ids[0])\n  3159\t\n  3160\t\n  3161\tdef _normalize_requested_query_profiles(\n  3162\t    *,\n  3163\t    requested_query_profile_ids: Sequence[str] | None,\n  3164\t    active_query_profile_id: str,\n  3165\t    available_query_profile_ids: Sequence[str],\n  3166\t) -> list[str]:\n  3167\t    available_set = set(available_query_profile_ids)\n  3168\t    if requested_query_profile_ids is None:\n  3169\t        return [active_query_profile_id]\n  3170\t    normalized = _normalize_identifier_sequence(\n  3171\t        requested_query_profile_ids,\n  3172\t        field_name=\"query_profile_ids\",\n  3173\t    )\n  3174\t    if active_query_profile_id not in normalized:\n  3175\t        normalized = [active_query_profile_id, *normalized]\n  3176\t    selected = [profile_id for profile_id in available_query_profile_ids if profile_id in set(normalized)]\n  3177\t    missing = [profile_id for profile_id in normalized if profile_id not in available_set]\n  3178\t    if missing:\n  3179\t        raise ValueError(\n  3180\t            \"Requested whole-brain context query_profile_ids include unavailable profiles \"\n  3181\t            f\"{missing!r}.\"\n  3182\t        )\n  3183\t    return selected\n  3184\t\n  3185\t\n  3186\tdef _validate_query_profile_combination(query_profile_ids: Sequence[str]) -> None:\n  3187\t    profile_set = set(query_profile_ids)\n  3188\t    if len(profile_set) <= 1:\n  3189\t        return\n  3190\t    if ACTIVE_SUBSET_SHELL_QUERY_PROFILE_ID in profile_set:\n  3191\t        raise ValueError(\n  3192\t            \"Unsupported whole-brain-context query-profile combination: \"\n  3193\t            \"'active_subset_shell' must be requested alone.\"\n  3194\t        )\n  3195\t    if BIDIRECTIONAL_CONNECTIVITY_CONTEXT_QUERY_PROFILE_ID in profile_set and (\n  3196\t        \"upstream_connectivity_context\" in profile_set\n  3197\t        or DOWNSTREAM_CONNECTIVITY_CONTEXT_QUERY_PROFILE_ID in profile_set\n  3198\t    ):\n  3199\t        raise ValueError(\n  3200\t            \"Unsupported whole-brain-context query-profile combination: \"\n  3201\t            \"'bidirectional_connectivity_context' cannot be combined with directional \"\n  3202\t            \"connectivity profiles.\"\n  3203\t        )\n  3204\t    if profile_set & _REVIEW_ONLY_QUERY_PROFILE_IDS:\n  3205\t        raise ValueError(\n  3206\t            \"Unsupported whole-brain-context query-profile combination: review-focused \"\n  3207\t            \"profiles must be requested alone in v1.\"\n  3208\t        )\n  3209\t\n  3210\t\n  3211\tdef _build_manifest_reference(\n  3212\t    manifest_path: Path,\n  3213\t    manifest_payload: Mapping[str, Any],\n  3214\t) -> dict[str, Any]:\n  3215\t    return build_simulator_manifest_reference(\n  3216\t        experiment_id=_normalize_identifier(\n  3217\t            manifest_payload[\"experiment_id\"],\n  3218\t            field_name=\"manifest.experiment_id\",\n  3219\t        ),\n  3220\t        manifest_path=manifest_path,\n  3221\t        milestone=_normalize_identifier(\n  3222\t            manifest_payload[\"milestone\"],\n  3223\t            field_name=\"manifest.milestone\",\n  3224\t        ),\n  3225\t        manifest_id=_normalize_identifier(\n  3226\t            manifest_payload.get(\"experiment_id\"),\n  3227\t            field_name=\"manifest.experiment_id\",\n  3228\t        ),\n  3229\t        brief_version=_normalize_optional_identifier(\n  3230\t            manifest_payload.get(\"brief_version\"),\n  3231\t            field_name=\"manifest.brief_version\",\n  3232\t        ),\n  3233\t        hypothesis_version=_normalize_optional_identifier(\n  3234\t            manifest_payload.get(\"hypothesis_version\"),\n  3235\t            field_name=\"manifest.hypothesis_version\",\n  3236\t        ),\n  3237\t    )\n  3238\t\n  3239\t\n  3240\tdef _build_active_anchor_records(\n  3241\t    root_ids: Sequence[int],\n  3242\t    subset_manifest_payload: Mapping[str, Any] | None,\n  3243\t) -> list[dict[str, Any]]:\n  3244\t    if subset_manifest_payload is None:\n  3245\t        return [{\"root_id\": int(root_id)} for root_id in root_ids]\n  3246\t    neurons = subset_manifest_payload.get(\"neurons\")\n  3247\t    if not isinstance(neurons, Sequence) or isinstance(neurons, (str, bytes)):\n  3248\t        return [{\"root_id\": int(root_id)} for root_id in root_ids]\n  3249\t    records_by_root: dict[int, dict[str, Any]] = {}\n  3250\t    for item in neurons:\n  3251\t        if not isinstance(item, Mapping) or item.get(\"root_id\") is None:\n  3252\t            continue\n  3253\t        root_id = int(item[\"root_id\"])\n  3254\t        records_by_root[root_id] = {\n  3255\t            key: copy.deepcopy(value) for key, value in dict(item).items()\n  3256\t        }\n  3257\t    return [\n  3258\t        records_by_root.get(int(root_id), {\"root_id\": int(root_id)})\n  3259\t        for root_id in root_ids\n  3260\t    ]\n  3261\t\n  3262\t\n  3263\tdef _anchor_metadata_facet_values(\n  3264\t    anchor_record: Mapping[str, Any],\n  3265\t    *,\n  3266\t    enabled_metadata_facet_ids: set[str],\n  3267\t) -> dict[str, Any]:\n  3268\t    values: dict[str, Any] = {}\n  3269\t    if \"cell_class\" in enabled_metadata_facet_ids:\n  3270\t        values[\"cell_class\"] = (\n  3271\t            anchor_record.get(\"super_class\")\n  3272\t            or anchor_record.get(\"class\")\n  3273\t            or anchor_record.get(\"project_role\")\n  3274\t            or \"\"\n  3275\t        )\n  3276\t    if \"cell_type\" in enabled_metadata_facet_ids:\n  3277\t        values[\"cell_type\"] = (\n  3278\t            anchor_record.get(\"cell_type\")\n  3279\t            or anchor_record.get(\"resolved_type\")\n  3280\t            or anchor_record.get(\"primary_type\")\n  3281\t            or \"\"\n  3282\t        )\n  3283\t    if \"neuropil\" in enabled_metadata_facet_ids:\n  3284\t        values[\"neuropil\"] = anchor_record.get(\"neuropils\") or \"\"\n  3285\t    if \"side\" in enabled_metadata_facet_ids:\n  3286\t        values[\"side\"] = anchor_record.get(\"side\") or anchor_record.get(\"hemisphere\") or \"\"\n  3287\t    if \"nt_type\" in enabled_metadata_facet_ids:\n  3288\t        values[\"nt_type\"] = anchor_record.get(\"nt_type\") or \"\"\n  3289\t    if \"selection_boundary_status\" in enabled_metadata_facet_ids:\n  3290\t        values[\"selection_boundary_status\"] = \"active_selected\"\n  3291\t    if \"pathway_relevance_status\" in enabled_metadata_facet_ids:\n  3292\t        values[\"pathway_relevance_status\"] = \"active_selected\"\n  3293\t    return {\n  3294\t        key: value for key, value in values.items() if value not in {None, \"\"}\n  3295\t    }\n  3296\t\n  3297\t\n  3298\tdef _dashboard_records_for_reference_resolution(\n  3299\t    *,\n  3300\t    source_context: Mapping[str, Any],\n  3301\t    metadata_ref: Mapping[str, Any],\n  3302\t    payload_ref: Mapping[str, Any] | None,\n  3303\t    state_ref: Mapping[str, Any] | None,\n  3304\t    planned_artifact_paths: Mapping[str, str],\n  3305\t) -> tuple[dict[str, Any], dict[str, Any], dict[str, Any]]:\n  3306\t    if payload_ref is None or state_ref is None:\n  3307\t        raise ValueError(\n  3308\t            \"Whole-brain context planning requires dashboard metadata, payload, and state references.\"\n  3309\t        )\n  3310\t    dashboard_context = source_context.get(\"dashboard_context\")\n  3311\t    if (\n  3312\t        isinstance(dashboard_context, Mapping)\n  3313\t        and str(dashboard_context.get(\"origin\")) == \"planned\"\n  3314\t        and _reference_matches_planned_path(\n  3315\t            metadata_ref,\n  3316\t            role_id=DASHBOARD_SESSION_METADATA_ROLE_ID,\n  3317\t            planned_artifact_paths=planned_artifact_paths,\n  3318\t        )\n  3319\t        and _reference_matches_planned_path(\n  3320\t            payload_ref,\n  3321\t            role_id=DASHBOARD_SESSION_PAYLOAD_ROLE_ID,\n  3322\t            planned_artifact_paths=planned_artifact_paths,\n  3323\t        )\n  3324\t        and _reference_matches_planned_path(\n  3325\t            state_ref,\n  3326\t            role_id=DASHBOARD_SESSION_STATE_ROLE_ID,\n  3327\t            planned_artifact_paths=planned_artifact_paths,\n  3328\t        )\n  3329\t    ):\n  3330\t        return (\n  3331\t            _require_mapping(dashboard_context[\"metadata\"], field_name=\"dashboard_context.metadata\"),\n  3332\t            _require_mapping(dashboard_context[\"payload\"], field_name=\"dashboard_context.payload\"),\n  3333\t            _require_mapping(dashboard_context[\"state\"], field_name=\"dashboard_context.state\"),\n  3334\t        )\n  3335\t    metadata = _load_dashboard_metadata_reference(\n  3336\t        metadata_ref,\n  3337\t        planned_artifact_paths=planned_artifact_paths,\n  3338\t    )\n  3339\t    payload = _load_json_mapping(\n  3340\t        Path(str(payload_ref[\"path\"])).resolve(),\n  3341\t        field_name=\"dashboard_session_payload\",\n  3342\t    )\n  3343\t    state = _load_json_mapping(\n  3344\t        Path(str(state_ref[\"path\"])).resolve(),\n  3345\t        field_name=\"dashboard_session_state\",\n  3346\t    )\n  3347\t    if str(metadata[\"bundle_id\"]) != str(payload[\"bundle_reference\"][\"bundle_id\"]):\n  3348\t        raise ValueError(\"dashboard_session metadata and payload must reference the same bundle_id.\")\n  3349\t    if str(metadata[\"bundle_id\"]) != str(state[\"bundle_reference\"][\"bundle_id\"]):\n  3350\t        raise ValueError(\"dashboard_session metadata and state must reference the same bundle_id.\")\n  3351\t    return metadata, payload, state\n  3352\t\n  3353\t\n  3354\tdef _showcase_records_for_reference_resolution(\n  3355\t    *,\n  3356\t    source_context: Mapping[str, Any],\n  3357\t    metadata_ref: Mapping[str, Any],\n  3358\t    state_ref: Mapping[str, Any] | None,\n  3359\t    planned_artifact_paths: Mapping[str, str],\n  3360\t) -> tuple[dict[str, Any], dict[str, Any]]:\n  3361\t    if state_ref is None:\n  3362\t        raise ValueError(\n  3363\t            \"Whole-brain context planning requires showcase metadata and presentation-state references.\"\n  3364\t        )\n  3365\t    showcase_context = source_context.get(\"showcase_context\")\n  3366\t    if isinstance(showcase_context, Mapping):\n  3367\t        metadata = _require_mapping(showcase_context[\"metadata\"], field_name=\"showcase_context.metadata\")\n  3368\t        state = _require_mapping(showcase_context[\"state\"], field_name=\"showcase_context.state\")\n  3369\t        if (\n  3370\t            str(Path(metadata_ref[\"path\"]).resolve())\n  3371\t            == str(\n  3372\t                discover_showcase_session_bundle_paths(metadata)[SHOWCASE_METADATA_JSON_KEY].resolve()\n  3373\t            )\n  3374\t            and str(Path(state_ref[\"path\"]).resolve())\n  3375\t            == str(\n  3376\t                discover_showcase_session_bundle_paths(metadata)[\n  3377\t                    SHOWCASE_PRESENTATION_STATE_ARTIFACT_ID\n  3378\t                ].resolve()\n  3379\t            )\n  3380\t        ):\n  3381\t            return metadata, state\n  3382\t    metadata = _load_showcase_metadata_reference(\n  3383\t        metadata_ref,\n  3384\t        planned_artifact_paths=planned_artifact_paths,\n  3385\t    )\n  3386\t    state = _load_showcase_state_reference(\n  3387\t        state_ref,\n  3388\t        metadata=metadata,\n  3389\t        planned_artifact_paths=planned_artifact_paths,\n  3390\t    )\n  3391\t    return metadata, state\n  3392\t\n  3393\t\n  3394\tdef _reference_matches_planned_path(\n  3395\t    reference: Mapping[str, Any],\n  3396\t    *,\n  3397\t    role_id: str,\n  3398\t    planned_artifact_paths: Mapping[str, str],\n  3399\t) -> bool:\n  3400\t    planned_path = planned_artifact_paths.get(role_id)\n  3401\t    if planned_path is None:\n  3402\t        return False\n  3403\t    return str(Path(reference[\"path\"]).resolve()) == str(Path(planned_path).resolve())\n  3404\t\n  3405\t\n  3406\tdef _load_dashboard_metadata_reference(\n  3407\t    reference: Mapping[str, Any],\n  3408\t    *,\n  3409\t    planned_artifact_paths: Mapping[str, str],\n  3410\t) -> dict[str, Any]:\n  3411\t    path = Path(str(reference[\"path\"])).resolve()\n  3412\t    if not path.exists():\n  3413\t        planned_path = planned_artifact_paths.get(DASHBOARD_SESSION_METADATA_ROLE_ID)\n  3414\t        if planned_path is None or path != Path(planned_path).resolve():\n  3415\t            raise ValueError(f\"Dashboard session metadata is missing at {path}.\")\n  3416\t    return load_dashboard_session_metadata(path)\n  3417\t\n  3418\t\n  3419\tdef _load_dashboard_payload_reference(\n  3420\t    reference: Mapping[str, Any],\n  3421\t    *,\n  3422\t    metadata: Mapping[str, Any],\n  3423\t    planned_artifact_paths: Mapping[str, str],\n  3424\t) -> dict[str, Any]:\n  3425\t    path = Path(str(reference[\"path\"])).resolve()\n  3426\t    if not path.exists():\n  3427\t        planned_path = planned_artifact_paths.get(DASHBOARD_SESSION_PAYLOAD_ROLE_ID)\n  3428\t        if planned_path is None or path != Path(planned_path).resolve():\n  3429\t            raise ValueError(f\"Dashboard session payload is missing at {path}.\")\n  3430\t        return _require_mapping(\n  3431\t            _require_mapping(metadata, field_name=\"dashboard_session\").get(\"artifacts\", {}),\n  3432\t            field_name=\"dashboard_session.artifacts\",\n  3433\t        ) and _require_mapping(\n  3434\t            _load_planned_dashboard_payload(metadata, path),\n  3435\t            field_name=\"dashboard_session_payload\",\n  3436\t        )\n  3437\t    payload = _load_json_mapping(path, field_name=\"dashboard_session_payload\")\n  3438\t    if str(metadata[\"bundle_id\"]) != str(payload[\"bundle_reference\"][\"bundle_id\"]):\n  3439\t        raise ValueError(\"dashboard_session metadata and payload must reference the same bundle_id.\")\n  3440\t    return payload\n  3441\t\n  3442\t\n  3443\tdef _load_dashboard_state_reference(\n  3444\t    reference: Mapping[str, Any],\n  3445\t    *,\n  3446\t    metadata: Mapping[str, Any],\n  3447\t    planned_artifact_paths: Mapping[str, str],\n  3448\t) -> dict[str, Any]:\n  3449\t    path = Path(str(reference[\"path\"])).resolve()\n  3450\t    if not path.exists():\n  3451\t        planned_path = planned_artifact_paths.get(DASHBOARD_SESSION_STATE_ROLE_ID)\n  3452\t        if planned_path is None or path != Path(planned_path).resolve():\n  3453\t            raise ValueError(f\"Dashboard session state is missing at {path}.\")\n  3454\t        return _load_planned_dashboard_state(metadata, path)\n  3455\t    state = _load_json_mapping(path, field_name=\"dashboard_session_state\")\n  3456\t    if str(metadata[\"bundle_id\"]) != str(state[\"bundle_reference\"][\"bundle_id\"]):\n  3457\t        raise ValueError(\"dashboard_session metadata and state must reference the same bundle_id.\")\n  3458\t    return state\n  3459