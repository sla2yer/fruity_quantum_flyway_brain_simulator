lePaths(\n   143\t        stimulus_family=normalized_family,\n   144\t        stimulus_name=normalized_name,\n   145\t        parameter_hash=resolved_parameter_hash,\n   146\t        bundle_directory=bundle_directory,\n   147\t        metadata_json_path=bundle_directory / \"stimulus_bundle.json\",\n   148\t        frame_cache_path=bundle_directory / \"stimulus_frames.npz\",\n   149\t        preview_gif_path=bundle_directory / \"stimulus_preview.gif\",\n   150\t    )\n   151\t\n   152\t\n   153\tdef build_stimulus_alias_path(\n   154\t    *,\n   155\t    stimulus_family: str,\n   156\t    stimulus_name: str,\n   157\t    parameter_hash: str,\n   158\t    processed_stimulus_dir: str | Path = DEFAULT_PROCESSED_STIMULUS_DIR,\n   159\t) -> Path:\n   160\t    normalized_family = _normalize_identifier(stimulus_family, field_name=\"stimulus_family\")\n   161\t    normalized_name = _normalize_identifier(stimulus_name, field_name=\"stimulus_name\")\n   162\t    normalized_hash = _normalize_parameter_hash(parameter_hash)\n   163\t    contract_paths = build_stimulus_contract_paths(processed_stimulus_dir)\n   164\t    return (\n   165\t        contract_paths.alias_root_directory\n   166\t        / normalized_family\n   167\t        / normalized_name\n   168\t        / f\"{normalized_hash}.json\"\n   169\t    )\n   170\t\n   171\t\n   172\tdef build_stimulus_contract_manifest_metadata(\n   173\t    *,\n   174\t    processed_stimulus_dir: str | Path = DEFAULT_PROCESSED_STIMULUS_DIR,\n   175\t) -> dict[str, Any]:\n   176\t    contract_paths = build_stimulus_contract_paths(processed_stimulus_dir)\n   177\t    return {\n   178\t        \"version\": STIMULUS_BUNDLE_CONTRACT_VERSION,\n   179\t        \"design_note\": STIMULUS_BUNDLE_DESIGN_NOTE,\n   180\t        \"design_note_version\": STIMULUS_BUNDLE_DESIGN_NOTE_VERSION,\n   181\t        \"default_representation_family\": DEFAULT_REPRESENTATION_FAMILY,\n   182\t        \"supported_representation_families\": list(SUPPORTED_REPRESENTATION_FAMILIES),\n   183\t        \"default_time_unit\": DEFAULT_TIME_UNIT,\n   184\t        \"supported_sampling_modes\": list(SUPPORTED_SAMPLING_MODES),\n   185\t        \"default_rng_family\": DEFAULT_RNG_FAMILY,\n   186\t        \"bundle_root_directory\": str(contract_paths.bundle_root_directory),\n   187\t        \"alias_root_directory\": str(contract_paths.alias_root_directory),\n   188\t    }\n   189\t\n   190\t\n   191\tdef build_stimulus_parameter_hash(\n   192\t    *,\n   193\t    parameter_snapshot: Mapping[str, Any],\n   194\t    seed: int | str,\n   195\t    temporal_sampling: Mapping[str, Any],\n   196\t    spatial_frame: Mapping[str, Any],\n   197\t    luminance_convention: Mapping[str, Any] | None = None,\n   198\t    rng_family: str = DEFAULT_RNG_FAMILY,\n   199\t) -> str:\n   200\t    reproducibility_payload = {\n   201\t        \"parameter_snapshot\": _normalize_json_mapping(\n   202\t            parameter_snapshot,\n   203\t            field_name=\"parameter_snapshot\",\n   204\t        ),\n   205\t        \"determinism\": {\n   206\t            \"seed\": _normalize_seed(seed),\n   207\t            \"rng_family\": _normalize_nonempty_string(rng_family, field_name=\"rng_family\"),\n   208\t        },\n   209\t        \"temporal_sampling\": normalize_temporal_sampling(temporal_sampling),\n   210\t        \"spatial_frame\": normalize_spatial_frame(spatial_frame),\n   211\t        \"luminance_convention\": normalize_luminance_convention(luminance_convention),\n   212\t    }\n   213\t    serialized = json.dumps(\n   214\t        reproducibility_payload,\n   215\t        sort_keys=True,\n   216\t        separators=(\",\", \":\"),\n   217\t        ensure_ascii=True,\n   218\t    )\n   219\t    return hashlib.sha256(serialized.encode(\"utf-8\")).hexdigest()\n   220\t\n   221\t\n   222\tdef build_stimulus_bundle_metadata(\n   223\t    *,\n   224\t    stimulus_family: str,\n   225\t    stimulus_name: str,\n   226\t    parameter_snapshot: Mapping[str, Any],\n   227\t    seed: int | str,\n   228\t    temporal_sampling: Mapping[str, Any],\n   229\t    spatial_frame: Mapping[str, Any],\n   230\t    processed_stimulus_dir: str | Path = DEFAULT_PROCESSED_STIMULUS_DIR,\n   231\t    luminance_convention: Mapping[str, Any] | None = None,\n   232\t    representation_family: str = DEFAULT_REPRESENTATION_FAMILY,\n   233\t    frame_cache_status: str = ASSET_STATUS_MISSING,\n   234\t    preview_gif_status: str = ASSET_STATUS_MISSING,\n   235\t    compatibility_aliases: Sequence[Mapping[str, Any]] | None = None,\n   236\t    rng_family: str = DEFAULT_RNG_FAMILY,\n   237\t) -> dict[str, Any]:\n   238\t    normalized_representation_family = _normalize_representation_family(representation_family)\n   239\t    normalized_temporal_sampling = normalize_temporal_sampling(temporal_sampling)\n   240\t    normalized_spatial_frame = normalize_spatial_frame(spatial_frame)\n   241\t    normalized_luminance_convention = normalize_luminance_convention(luminance_convention)\n   242\t    normalized_parameter_snapshot = _normalize_json_mapping(\n   243\t        parameter_snapshot,\n   244\t        field_name=\"parameter_snapshot\",\n   245\t    )\n   246\t    normalized_seed = _normalize_seed(seed)\n   247\t    normalized_rng_family = _normalize_nonempty_string(rng_family, field_name=\"rng_family\")\n   248\t    parameter_hash = build_stimulus_parameter_hash(\n   249\t        parameter_snapshot=normalized_parameter_snapshot,\n   250\t        seed=normalized_seed,\n   251\t        temporal_sampling=normalized_temporal_sampling,\n   252\t        spatial_frame=normalized_spatial_frame,\n   253\t        luminance_convention=normalized_luminance_convention,\n   254\t        rng_family=normalized_rng_family,\n   255\t    )\n   256\t    bundle_paths = build_stimulus_bundle_paths(\n   257\t        stimulus_family=stimulus_family,\n   258\t        stimulus_name=stimulus_name,\n   259\t        processed_stimulus_dir=processed_stimulus_dir,\n   260\t        para