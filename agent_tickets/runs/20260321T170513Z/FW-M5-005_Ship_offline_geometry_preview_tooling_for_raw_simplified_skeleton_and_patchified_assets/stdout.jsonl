{"type":"item.completed","item":{"id":"item_59","type":"command_execution","command":"/bin/bash -lc \"nl -ba scripts/05_preview_geometry.py | sed -n '1,220p'\"","aggregated_output":"     1\t#!/usr/bin/env python3\n     2\tfrom __future__ import annotations\n     3\t\n     4\timport argparse\n     5\timport json\n     6\timport sys\n     7\tfrom pathlib import Path\n     8\t\n     9\tROOT = Path(__file__).resolve().parents[1]\n    10\tSRC = ROOT / \"src\"\n    11\tsys.path.insert(0, str(SRC))\n    12\t\n    13\tfrom flywire_wave.config import load_config\n    14\tfrom flywire_wave.geometry_preview import generate_geometry_preview_report\n    15\tfrom flywire_wave.io_utils import read_root_ids\n    16\t\n    17\t\n    18\tdef main() -> int:\n    19\t    parser = argparse.ArgumentParser(\n    20\t        description=\"Generate a static offline geometry preview from already-built local asset bundles.\"\n    21\t    )\n    22\t    parser.add_argument(\n    23\t        \"--config\",\n    24\t        required=True,\n    25\t        help=\"Path to the YAML config file. Relative paths inside config.paths resolve from the repository root.\",\n    26\t    )\n    27\t    parser.add_argument(\n    28\t        \"--root-id\",\n    29\t        action=\"append\",\n    30\t        type=int,\n    31\t        default=[],\n    32\t        help=\"Root ID to include. Repeat to preview multiple neurons.\",\n    33\t    )\n    34\t    parser.add_argument(\n    35\t        \"--root-ids-file\",\n    36\t        help=\"Optional path to a newline-delimited root-id file. Defaults to config.paths.selected_root_ids.\",\n    37\t    )\n    38\t    parser.add_argument(\n    39\t        \"--limit\",\n    40\t        type=int,\n    41\t        default=None,\n    42\t        help=\"Optional limit applied after reading the chosen root-id source.\",\n    43\t    )\n    44\t    args = parser.parse_args()\n    45\t\n    46\t    cfg = load_config(args.config)\n    47\t    paths = cfg[\"paths\"]\n    48\t\n    49\t    if args.root_id:\n    50\t        root_ids = list(args.root_id)\n    51\t    else:\n    52\t        root_id_source = args.root_ids_file or paths[\"selected_root_ids\"]\n    53\t        root_ids = read_root_ids(root_id_source)\n    54\t    if args.limit is not None:\n    55\t        root_ids = root_ids[: max(int(args.limit), 0)]\n    56\t    if not root_ids:\n    57\t        raise RuntimeError(\"No root IDs were resolved for preview generation.\")\n    58\t\n    59\t    summary = generate_geometry_preview_report(\n    60\t        root_ids=root_ids,\n    61\t        meshes_raw_dir=paths[\"meshes_raw_dir\"],\n    62\t        skeletons_raw_dir=paths[\"skeletons_raw_dir\"],\n    63\t        processed_mesh_dir=paths[\"processed_mesh_dir\"],\n    64\t        processed_graph_dir=paths[\"processed_graph_dir\"],\n    65\t        geometry_preview_dir=paths[\"geometry_preview_dir\"],\n    66\t    )\n    67\t    print(json.dumps(summary, indent=2))\n    68\t    return 0\n    69\t\n    70\t\n    71\tif __name__ == \"__main__\":\n    72\t    raise SystemExit(main())\n","exit_code":0,"status":"completed"}}
