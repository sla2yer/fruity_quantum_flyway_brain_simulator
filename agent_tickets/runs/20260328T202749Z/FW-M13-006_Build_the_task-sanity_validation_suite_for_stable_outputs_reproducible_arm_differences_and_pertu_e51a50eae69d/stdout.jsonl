ingContractPaths:\\\\n    62\\\\t    processed_coupling_dir: Path\\\\n    63\\\\t    local_synapse_registry_path: Path\\\\n    64\\\\t    root_asset_directory: Path\\\\n    65\\\\t    edge_bundle_directory: Path\\\\n    66\\\\t\\\\n    67\\\\t\\\\n    68\\\\t@dataclass(frozen=True)\\\\n    69\\\\tclass RootCouplingBundlePaths:\\\\n    70\\\\t    root_id: int\\\\n    71\\\\t    local_synapse_registry_path: Path\\\\n    72\\\\t    incoming_anchor_map_path: Path\\\\n    73\\\\t    outgoing_anchor_map_path: Path\\\\n    74\\\\t    coupling_index_path: Path\\\\n    75\\\\t\\\\n    76\\\\t    @property\\\\n    77\\\\t    def root_label(self) -> str:\\\\n    78\\\\t        return str(int(self.root_id))\\\\n    79\\\\t\\\\n    80\\\\t    def asset_paths(self) -> dict[str, Path]:\\\\n    81\\\\t        return {\\\\n    82\\\\t            LOCAL_SYNAPSE_REGISTRY_KEY: self.local_synapse_registry_path,\\\\n    83\\\\t            INCOMING_ANCHOR_MAP_KEY: self.incoming_anchor_map_path,\\\\n    84\\\\t            OUTGOING_ANCHOR_MAP_KEY: self.outgoing_anchor_map_path,\\\\n    85\\\\t            COUPLING_INDEX_KEY: self.coupling_index_path,\\\\n    86\\\\t        }\\\\n    87\\\\t\\\\n    88\\\\t\\\\n    89\\\\tdef build_coupling_contract_paths(processed_coupling_dir: str | Path) -> CouplingContractPaths:\\\\n    90\\\\t    coupling_dir = Path(processed_coupling_dir).resolve()\\\\n    91\\\\t    return CouplingContractPaths(\\\\n    92\\\\t        processed_coupling_dir=coupling_dir,\\\\n    93\\\\t        local_synapse_registry_path=coupling_dir / \\\\\\\"synapse_registry.csv\\\\\\\",\\\\n    94\\\\t        root_asset_directory=coupling_dir / \\\\\\\"roots\\\\\\\",\\\\n    95\\\\t        edge_bundle_directory=coupling_dir / \\\\\\\"edges\\\\\\\",\\\\n    96\\\\t    )\\\\n    97\\\\t\\\\n    98\\\\t\\\\n    99\\\\tdef build_root_coupling_bundle_paths(\\\\n   100\\\\t    root_id: int,\\\\n   101\\\\t    *,\\\\n   102\\\\t    processed_coupling_dir: str | Path,\\\\n   103\\\\t) -> RootCouplingBundlePaths:\\\\n   104\\\\t    root_label = str(int(root_id))\\\\n   105\\\\t    contract_paths = build_coupling_contract_paths(processed_coupling_dir)\\\\n   106\\\\t    return RootCouplingBundlePaths(\\\\n   107\\\\t        root_id=int(root_id),\\\\n   108\\\\t        local_synapse_registry_path=contract_paths.local_synapse_registry_path,\\\\n   109\\\\t        incoming_anchor_map_path=contract_paths.root_asset_directory / f\\\\\\\"{root_label}_incoming_anchor_map.npz\\\\\\\",\\\\n   110\\\\t        outgoing_anchor_map_path=contract_paths.root_asset_directory / f\\\\\\\"{root_label}_outgoing_anchor_map.npz\\\\\\\",\\\\n   111\\\\t        coupling_index_path=contract_paths.root_asset_directory / f\\\\\\\"{root_label}_coupling_index.json\\\\\\\",\\\\n   112\\\\t    )\\\\n   113\\\\t\\\\n   114\\\\t\\\\n   115\\\\tdef build_edge_coupling_bundle_path(\\\\n   116\\\\t    pre_root_id: int,\\\\n   117\\\\t    post_root_id: int,\\\\n   118\\\\t    *,\\\\n   119\\\\t    processed_coupling_dir: str | Path,\\\\n   120\\\\t) -> Path:\\\\n   121\\\\t    contract_paths = build_coupling_contract_paths(processed_coupling_dir)\\\\n   122\\\\t    return contract_paths.edge_bundle_directory / f\\\\\\\"{int(pre_root_id)}__to__{int(post_root_id)}_coupling.npz\\\\\\\"\\\\n   123\\\\t\\\\n   124\\\\t\\\\n   125\\\\tdef build_edge_coupling_bundle_reference(\\\\n   126\\\\t    *,\\\\n   127\\\\t    root_id: int,\\\\n   128\\\\t    pre_root_id: int,\\\\n   129\\\\t    post_root_id: int,\\\\n   130\\\\t    processed_coupling_dir: str | Path,\\\\n   131\\\\t    status: str = ASSET_STATUS_MISSING,\\\\n   132\\\\t) -> dict[str, Any]:\\\\n   133\\\\t    normalized_root_id = int(root_id)\\\\n   134\\\\t    normalized_pre_root_id = int(pre_root_id)\\\\n   135\\\\t    normalized_post_root_id = int(post_root_id)\\\\n   136\\\\t    if normalized_root_id == normalized_pre_root_id:\\\\n   137\\\\t        relation_to_root = \\\\\\\"outgoing\\\\\\\"\\\\n   138\\\\t        peer_root_id = normalized_post_root_id\\\\n   139\\\\t    elif normalized_root_id == normalized_post_root_id:\\\\n   140\\\\t        relation_to_root = \\\\\\\"incoming\\\\\\\"\\\\n   141\\\\t        peer_root_id = normalized_pre_root_id\\\\n   142\\\\t    else:\\\\n   143\\\\t        raise ValueError(\\\\n   144\\\\t            \\\\\\\"Root-local coupling bundle references must include edges where root_id \\\\\\\"\\\\n   145\\\\t            \\\\\\\"matches either pre_root_id or post_root_id.\\\\\\\"\\\\n   146\\\\t        )\\\\n   147\\\\t    return {\\\\n   148\\\\t        \\\\\\\"pre_root_id\\\\\\\": normalized_pre_root_id,\\\\n   149\\\\t        \\\\\\\"post_root_id\\\\\\\": normalized_post_root_id,\\\\n   150\\\\t        \\\\\\\"peer_root_id\\\\\\\": peer_root_id,\\\\n   151\\\\t        \\\\\\\"relation_to_root\\\\\\\": relation_to_root,\\\\n   152\\\\t        \\\\\\\"path\\\\\\\": str(\\\\n   153\\\\t            build_edge_coupling_bundle_path(\\\\n   154\\\\t                normalized_pre_root_id,\\\\n   155\\\\t                normalized_post_root_id,\\\\n   156\\\\t                processed_coupling_dir=processed_coupling_dir,\\\\n   157\\\\t            )\\\\n   158\\\\t        ),\\\\n   159\\\\t        \\\\\\\"status\\\\\\\": str(status),\\\\n   160\\\\t    }\\\\n   161\\\\t\\\\n   162\\\\t\\\\n   163\\\\tdef build_coupling_contract_manifest_metadata(\\\\n   164\\\\t    *,\\\\n   165\\\\t    processed_coupling_dir: str | Path | None = None,\\\\n   166\\\\t    coupling_bundle_metadata: Mapping[str, Any] | None = None,\\\\n   167\\\\t) -> dict[str, Any]:\\\\n   168\\\\t    local_synapse_registry_status = ASSET_STATUS_MISSING\\\\n   169\\\\t    resolved_processed_coupling_dir = processed_coupling_dir\\\\n   170\\\\t    if coupling_bundle_metadata is not None:\\\\n   171\\\\t        normalized_bundle = parse_coupling_bundle_metadata(coupling_bundle_metadata)\\\\n   172\\\\t        local_synapse_registry = dict(normalized_bundle[\\\\\\\"assets\\\\\\\"][LOCAL_SYNAPSE_REGISTRY_KEY])\