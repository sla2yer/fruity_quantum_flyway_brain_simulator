are one local synapse registry asset.\"\n        )\n    selected_root_ids = sorted(read_root_ids(baseline_roster_path))\n    return {\n        \"selected_root_ids_path\": str(baseline_roster_path),\n        \"selected_root_ids\": selected_root_ids,\n        \"selected_root_count\": len(selected_root_ids),\n        \"geometry_manifest_path\": str(geometry_manifest_path),\n        \"local_synapse_registry_path\": str(local_synapse_registry_path),\n    }\n\n\ndef _resolve_circuit_context(\n    *,\n    geometry_manifest_path: Path,\n    selected_root_ids: Sequence[int],\n    local_synapse_registry_path: Path,\n) -> dict[str, Any]:\n    _require_existing_path(geometry_manifest_path, field_name=\"geometry_manifest_path\")\n    _require_existing_path(local_synapse_registry_path, field_name=\"local_synapse_registry_path\")\n    manifest_records = load_geometry_manifest_records(geometry_manifest_path)\n    root_records: list[dict[str, Any]] = []\n    missing_roots = [\n        int(root_id)\n        for root_id in selected_root_ids\n        if str(int(root_id)) not in manifest_records\n    ]\n    if missing_roots:\n        raise ValueError(\n            \"geometry_manifest is missing selected roots required for the dashboard session: \"\n            f\"{missing_roots!r}.\"\n        )\n    for root_id in sorted(int(value) for value in selected_root_ids):\n        record = _require_mapping(\n            manifest_records[str(root_id)],\n            field_name=f\"geometry_manifest[{root_id}]\",\n        )\n        assets = _require_mapping(\n            record.get(\"assets\"),\n            field_name=f\"geometry_manifest[{root_id}].assets\",\n        )\n        simplified_mesh = _path_status_record(\n            _require_mapping(assets[SIMPLIFIED_MESH_KEY], field_name=f\"geometry_manifest[{root_id}].assets.simplified_mesh\")\n        )\n        raw_skeleton = _path_status_record(\n            _require_mapping(assets[RAW_SKELETON_KEY], field_name=f\"geometry_manifest[{root_id}].assets.raw_skeleton\")\n        )\n        surface_graph = _path_status_record(\n            _require_mapping(assets[SURFACE_GRAPH_KEY], field_name=f\"geometry_manifest[{root_id}].assets.surface_graph\")\n        )\n        patch_graph = _path_status_record(\n            _require_mapping(assets[PATCH_GRAPH_KEY], field_name=f\"geometry_manifest[{root_id}].assets.patch_graph\")\n        )\n        operator_paths = {\n            artifact_id: str(Path(path).resolve())\n            for artifact_id, path in discover_operator_bundle_paths(record).items()\n        }\n        edge_bundle_paths = [\n            {\n                \"pre_root_id\": int(item[\"pre_root_id\"]),\n                \"post_root_id\": int(item[\"post_root_id\"]),\n                \"peer_root_id\": int(item[\"peer_root_id\"]),\n                \"relation_to_root\": str(item[\"relation_to_root\"]),\n                \"path\": str(Path(item[\"path\"]).resolve()),\n                \"status\": str(item[\"status\"]),\n                \"exists\": Path(item[\"path\"]).resolve().exists(),\n            }\n            for item in discover_edge_coupling_bundle_paths(record)\n        ]\n        root_records.append(\n            {\n                \"root_id\": root_id,\n                \"cell_type\": str(record.get(\"cell_type\", \"\")),\n                \"project_role\": str(record.get(\"project_role\", \"\")),\n                \"geometry_assets\": {\n                    \"simplified_mesh\": simplified_mesh,\n                    \"raw_skeleton\": raw_skeleton,\n                    \"surface_graph\": surface_graph,\n                    \"patch_graph\": patch_graph,\n                },\n                \"operator_artifacts\": operator_paths,\n                \"edge_bundle_paths\": edge_bundle_paths,\n            }\n        )\n    return {\n        \"pane_id\": CIRCUIT_PANE_ID,\n        \"geometry_manifest_path\": str(geometry_manifest_path),\n        \"local_synapse_registry_path\": str(local_synapse_registry_path),\n        \"selected_root_ids\": [int(root_id) for root_id in selected_root_ids],\n        \"root_catalog\": root_records,\n    }\n\n\ndef _resolve_morphology_context(\n    *,\n    circuit_context: Mapping[str, Any],\n    wave_metadata: Mapping[str, Any],\n    selected_neuron_id: str | int | None,\n) -> dict[str, Any]:\n    mixed_index = wave_metadata.get(MIXED_MORPHOLOGY_INDEX_KEY)\n    mixed_root_map: dict[int, dict[str, Any]] = {}\n    if isinstance(mixed_index, Mapping):\n        for item in mixed_index.get(\"roots\", []):\n            if not isinstance(item, Mapping):\n                continue\n            mixed_root_map[int(item[\"root_id\"])] = copy.deepcopy(dict(item))\n\n    root_catalog: list[dict[str, Any]] = []\n    for root in circuit_context[\"root_catalog\"]:\n        root_id = int(root[\"root_id\"])\n        mixed_record = mixed_root_map.get(root_id, {})\n        morphology_class = mixed_record.get(\"morphology_class\")\n        if morphology_class is None:\n            if bool(root[\"geometry_assets\"][\"simplified_mesh\"][\"exists\"]):\n                morphology_class = SURFACE_NEURON_CLASS\n            elif bool(root[\"geometry_assets\"][\"raw_skeleton\"][\"exists\"]):\n                morphology_class = SKELETON_NEURON_CLASS\n        available_representations: list[str] = []\n        if bool(root[\"geometry_assets\"][\"simplified_mesh\"][\"exists\"]):\n            available_representations.append(\"surface_mesh\")\n        if bool(root[\"geometry_assets\"][\"raw_skeleton\"][\"exists\"]):\n            available_representations.append(\"skeleton\")\n        if morphology_class == POINT_NEURON_CLASS:\n            available_representations.append(\"point_fallback\")\n        root_catalog.append(\n            {\n                \"root_id\": root_id,\n                \"cell_type\": str(root[\"cell_type\"]),\n                \"project_role\": str(root[\"project_role\"]),\n                \"morphology_class\": morphology_class,\n                \"available_representations\": available_representations,\n                \"displayable\": bool(available_representations),\n                \"geometry_assets\": copy.deepcopy(dict(root[\"geometry_assets\"])),\n                \"mixed_morphology\": copy.deepcopy(dict(mixed_record)),\n            }\n        )\n\n    selected_root_ids = [int(item[\"root_id\"]) for item in root_catalog]\n    if selected_neuron_id is None:\n        resolved_selected_neuron_id = selected_root_ids[0]\n    else:\n        resolved_selected_neuron_id = int(selected_neuron_id)\n        if resolved_selected_neuron_id not in set(selected_root_ids):\n            raise ValueError(\n                \"selected_neuron_id must be present in the dashboard selected-root subset, \"\n                f\"got {resolved_selected_neuron_id!r}.\"\n            )\n    selected_root_record = next(\n        item for item in root_catalog if int(item[\"root_id\"]) == resolved_selected_neuron_id\n    )\n    if not bool(selected_root_record[\"displayable\"]):\n        raise ValueError(\n            \"Insufficient morphology metadata for requested selected_neuron_id \"\n            f\"{resolved_selected_neuron_id!r}; no surface mesh, skeleton, or explicit \"\n            \"point-neuron fallback is available.\"\n        )\n    return {\n        \"pane_id\": MORPHOLOGY_PANE_ID,\n        \"selected_neuron_id\": int(resolved_selected_neuron_id),\n        \"root_catalog\": root_catalog,\n        \"displayable_root_ids\": [\n            int(item[\"root_id\"]) for item in root_catalog if bool(item[\"displayable\"])\n        ],\n    }\n\n\n","exit_code":0,"status":"completed"}}
