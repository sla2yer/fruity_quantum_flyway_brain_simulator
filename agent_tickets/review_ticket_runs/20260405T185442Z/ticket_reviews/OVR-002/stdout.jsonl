ummary: Mapping[str, Any]) -> list[dict[str, Any]]:\n   271\t    failures: list[dict[str, Any]] = []\n   272\t    for field_name in (\"specialization_results\", \"review_results\"):\n   273\t        results = summary.get(field_name, [])\n   274\t        if not isinstance(results, Sequence):\n   275\t            continue\n   276\t        for raw_result in results:\n   277\t            if not isinstance(raw_result, Mapping):\n   278\t                continue\n   279\t            try:\n   280\t                return_code = int(raw_result.get(\"returncode\", -1))\n   281\t            except (TypeError, ValueError):\n   282\t                return_code = -1\n   283\t            if return_code == 0:\n   284\t                continue\n   285\t            diagnostic_paths = raw_result.get(\"diagnostic_paths\")\n   286\t            if not isinstance(diagnostic_paths, Sequence) or isinstance(\n   287\t                diagnostic_paths, str\n   288\t            ):\n   289\t                diagnostic_paths = collect_prompt_job_diagnostic_paths(raw_result)\n   290\t            failures.append(\n   291\t                {\n   292\t                    \"prompt_set\": str(raw_result.get(\"prompt_set\", \"\")).strip(),\n   293\t                    \"title\": str(raw_result.get(\"title\", \"\")).strip(),\n   294\t                    \"stage\": str(raw_result.get(\"stage\", \"\")).strip(),\n   295\t                    \"returncode\": return_code,\n   296\t                    \"diagnostic_paths\": [\n   297\t                        str(path).strip()\n   298\t                        for path in diagnostic_paths\n   299\t                        if str(path).strip()\n   300\t                    ],\n   301\t                }\n   302\t            )\n   303\t    return failures\n   304\t\n   305\t\n   306\tdef run_prompt_job(\n   307\t    job_name: str,\n   308\t    *,\n   309\t    prompt_text: str,\n   310\t    repo_root: str | Path,\n   311\t    runner: str,\n   312\t    output_dir: str | Path,\n   313\t    sandbox: str,\n   314\t    model: str | None = None,\n   315\t    extra_args: list[str] | None = None,\n   316\t    progress_callback: Callable[[str], None] | None = None,\n   317\t    heartbeat_seconds: float = 20.0,\n   318\t) -> dict[str, Any]:\n   319\t    repo_root = Path(repo_root)\n   320\t    output_dir = Path(output_dir)\n   321\t    prompt_path = output_dir / \"prompt.md\"\n   322\t    stdout_path = output_dir / \"stdout.jsonl\"\n   323\t    stderr_path = output_dir / \"stderr.log\"\n   324\t    last_message_path = output_dir / \"last_message.md\"\n   325\t\n   326\t    with tempfile.TemporaryDirectory(prefix=f\"flywire_wave_{job_name}_\") as staging_dir_str:\n   327\t        staging_dir = Path(staging_dir_str)\n   328\t        staging_prompt_path = staging_dir / \"prompt.md\"\n   329\t        staging_stdout_path = staging_dir / \"stdout.jsonl\"\n   330\t        staging_stderr_path = staging_dir / \"stderr.log\"\n   331\t        staging_last_message_path = staging_dir / \"last_message.md\"\n   332\t\n   333\t        staging_prompt_path.write_text(prompt_text, encoding=\"utf-8\")\n   334\t\n   335\t        cmd = [\n   336\t            runner,\n   337\t            \"exec\",\n   338\t            \"--json\",\n   339\t            \"--cd\",\n   340\t            str(repo_root),\n   341\t            \"--sandbox\",\n   342\t            sandbox,\n   343\t            \"--output-last-message\",\n   344\t            str(staging_last_message_path),\n   345\t        ]\n   346\t        if model:\n   347\t            cmd.extend([\"--model\", model])\n   348\t        if extra_args:\n   349\t            cmd.extend(extra_args)\n   350\t\n   351\t        with staging_stderr_path.open(\"w\", encoding=\"utf-8\") as stderr_file:\n   352\t            process = subprocess.Popen(\n   353\t                cmd,\n   354\t                stdin=subprocess.PIPE,\n   355\t                stdout=subprocess.PIPE,\n   356\t                stderr=stderr_file,\n   357\t        