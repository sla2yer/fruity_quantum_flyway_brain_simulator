.py\\\\n./flywire_codex/codex/main.py\\\\n./flywire_codex/codex/blueprints/base.py\\\\n./flywire_codex/codex/blueprints/app.py\\\\n./flywire_codex/README.md\\\\n./flywire_codex/tests/unit/test_search.py\\\\n./flywire_codex/tests/unit/test_formatting.py\\\\n./flywire_codex/tests/unit/test_graph_algos.py\\\\n./flywire_codex/tests/unit/test_number_compacter.py\\\\n./flywire_codex/tests/unit/test_parsing.py\\\\n./flywire_codex/tests/unit/test_connectivity.py\\\\n./flywire_codex/tests/unit/test_neuron_data_initializer.py\\\\n./flywire_codex/tests/unit/test_faq_qa_kb.py\\\\n./flywire_codex/tests/unit/test_neuron_data.py\\\\n./flywire_codex/tests/unit/test_neurotransmitters.py\\\\n./flywire_codex/tests/unit/test_heatmaps.py\\\\n./flywire_codex/tests/unit/test_catalog.py\\\\n./flywire_codex/tests/unit/__init__.py\\\\n./flywire_codex/tests/unit/test_stats_utils.py\\\\n./flywire_codex/tests/unit/test_motif_search.py\\\\n./flywire_codex/tests/unit/test_structured_search_filters.py\\\\n./flywire_codex/tests/unit/test_network_graph.py\\\\n./flywire_codex/tests/unit/test_pathway_vis.py\\\\n./flywire_codex/tests/unit/test_brain_regions.py\\\\n./flywire_codex/tests/__init__.py\\\\n./flywire_codex/tests/run_unit_tests_with_coverage.py\\\\n./flywire_codex/poetry.toml\\\\n./flywire_codex/pyproject.toml\\\\n./flywire_codex/LICENSE\\\\n\\\",\\\"exit_code\\\":0,\\\"status\\\":\\\"completed\\\"}}\\nagent_tickets/runs/20260322T023042Z/FW-M8B-004_Add_temporal_retinal_frame_generation_and_early-visual_channel_mapping_on_top_of_sampled_ommatidia/stdout.jsonl:31:{\\\"type\\\":\\\"item.completed\\\",\\\"item\\\":{\\\"id\\\":\\\"item_14\\\",\\\"type\\\":\\\"command_execution\\\",\\\"command\\\":\\\"/bin/bash -lc \\\\\\\"sed -n '1,260p' docs/retinal_bundle_design.md\\\\\\\"\\\",\\\"aggregated_output\\\":\\\"# Milestone 8B Retinal Input Bundle Contract And Ommatidial Sampling Choice\\\\n\\\\nThis note freezes the Milestone 8B handoff between world-facing visual sources\\\\nand fly-facing retinal input so later scene, simulator, and UI work can target\\\\none explicit bundle contract, one explicit meaning of a retinal frame, and one\\\\nexplicit set of coordinate and timing conventions.\\\\n\\\\n## Contract summary\\\\n\\\\nThe canonical Milestone 8B retinal contract is `retinal_input_bundle.v1`.\\\\n\\\\nThe bundle owns:\\\\n\\\\n- one canonical bundle ID built from upstream source identity plus the retinal\\\\n  sampling-spec hash\\\\n- one authoritative metadata file that records the retinal-contract version,\\\\n  design-note version, source identity, eye ordering, ommatidial ordering,\\\\n  frame timing, coordinate conventions, sampling-kernel settings, and signal\\\\n  conventions\\\\n- one optional sampled frame archive for deterministic local replay\\\\n\\\\nThe canonical layout is:\\\\n\\\\n- `config.paths.processed_retinal_dir/bundles/<source_kind>/<source_family>/<source_name>/<source_hash>/<retinal_spec_hash>/retinal_input_bundle.json`\\\\n- `config.paths.processed_retinal_dir/bundles/<source_kind>/<source_family>/<source_name>/<source_hash>/<retinal_spec_hash>/retinal_frames.npz`\\\\n\\\\n`retinal_input_bundle.v1` intentionally keeps the surface small. More sidecars\\\\nmay be added later, but those paths are the stable discovery surface for the\\\\nretinal recording itself.\\\\n\\\\n## Candidate abstraction families\\\\n\\\\n### Direct per-ommatidium irradiance\\\\n\\\\nDefinition:\\\\n\\\\n- each sampled frame stores one irradiance value per eye and per ommatidium\\\\n- later consumers can derive temporal filters, feature maps, or UI rasters from\\\\n  this detector-level representation\\\\n\\\\nAdvantages:\\\\n\\\\n- closest to the fly-facing sampling event the later simulator actually needs\\\\n- keeps bundle identity tied to stable detector ordering rather than a display\\\\n  raster convention\\\\n- easiest representation to compare across simulator, QA, and UI consumers\\\\n- avoids silently baking later feature-extraction assumptions into the contract\\\\n\\\\nCosts:\\\\n\\\\n- less convenient for human preview than an image-like raster\\\\n- later UIs need a detector-layout-aware rendering step\\\\n\\\\n### Eye-image raster intermediates\\\\n\\\\nDefinition:\\\\n\\\\n- first resample each eye into an image grid, then treat that raster as the\\\\n  retinal handoff\\\\n\\\\nAdvantages:\\\\n\\\\n- easy to display and debug visually\\\\n- fits commodity image tooling well\\\\n\\\\nCosts:\\\\n\\\\n- introduces one extra resampling layer before the simulator ever sees the\\\\n  input\\\\n- binds bundle identity to a raster layout that the fly does not physically\\\\n  observe\\\\n- makes detector indexing and acceptance kernels harder to audit\\\\n\\\\n### Higher-level retinotopic feature maps\\\\n\\\\nDefinition:\\\\n\\\\n- treat motion-energy channels, contrast filters, or other early visual feature\\\\n  maps as the primary retinal output\\\\n\\\\nAdvantages:\\\\n\\\\n- can align directly with some later model families\\\\n- compact for task-specific baselines\\\\n\\\\nCosts:\\\\n\\\\n- bakes model assumptions into the contract too early\\\\n- blocks fair comparisons between different simulator or front-end pipelines\\\\n- loses the detector-level input that later QA and ablation work needs\\\\n\\\\n## Decision\\\\n\\\\nThe default Milestone 8B abstraction is `direct_per_ommatidium_irradiance`.\\\\n\\\\n`retinal_input_bundle.v1` serializes only that family. Eye-image rasters and\\\\nhigher-level feature maps remain valid derived views or future-contract options,\\\\nbut they are not the authoritative handoff in this version.\\\\n\\\\nWhy this is the default:\\\\n\\\\n- Milestones 8C, 9, and 10 need one unambiguous detector-level definition of\\\\n  “the same retinal input”\\\\n- later simulators should share one source of truth before they add their own\\\\n  filtering or state abstractions\\\\n- UI code can always render detector values into a view, but it cannot recover\\\\n  omitted detector semantics from an arbitrary raster or feature stack\\\\n\\\\n## What one retinal frame means\\\\n\\\\nOne canonical retinal frame is a dense `time x eye x ommatidium` sample table\\\\nwith:\\\\n\\\\n- eye axis order fixed by the recorded `eye_order`, default `[left, right]`\\\\n- eye indexing fixed by `axis_index_matches_eye_order`\\\\n- ommatidial ordering fixed by `stable_eye_local_ommatidium_index`\\\\n- one shared `ommatidium_count_per_eye` recorded in the bundle metadata\\\\n- value semantics fixed to `per_ommatidium_linear_irradiance`\\\\n\\\\nMeaning:\\\\n\\\\n- frame `t` is the binocular detector snapshot for one sample-hold time bin\\\\n- later simulator and UI code may reshape or render the data, but they may not\\\\n  silently reorder the eye axis or ommatidial axis while still claiming they\\\\n  are consuming the same bundle\\\\n\\\\n## Coordinate conventions\\\\n\\\\nAll Cartesian frames are right-handed.\\\\n\\\\n### World frame\\\\n\\\\n- frame name: `world_cartesian`\\\\n- origin: `scene_defined_world_origin`\\\\n- axes: `+x forward`, `+y left`, `+z up`\\\\n\\\\n### Body frame\\\\n\\\\n- frame name: `fly_body`\\\\n- origin: `thorax_center`\\\\n- axes: `+x anterior`, `+y left`, `+z dorsal`\\\\n\\\\n### Head frame\\\\n\\\\n- frame name: `fly_head`\\\\n- origin: `head_center`\\\\n- axes: `+x anterior`, `+y left`, `+z dorsal`\\\\n- zero-pose alignment: aligned with the body frame\\\\n\\\\n### Eye frame\\\\n\\\\n- frame name: `compound_eye_local`\\\\n- origin: `eye_center`\\\\n- axes: `+z optical_axis_outward`, `+x dorsal`, `+y completes_right_handed_frame`\\\\n- positive azimuth is toward `+y`\\\\n- positive elevation is toward `+x`\\\\n\\\\nMeaning:\\\\n\\\\n- later geometry code may choose any internal transform implementation it wants\\\\n  as long as it lands on these same external frame semantics\\\\n- left and right eyes may have different rigid transforms from the head frame,\\\\n  but they must share the same local eye-axis naming and angular sign\\\\n  conventions\\\\n\\\\n## Timing and signal conventions\\\\n\\\\n### Temporal sampling\\\\n\\\\nMilestone 8B uses the same conservative timing convention as Milestone 8A:\\\\n\\\\n- time unit: milliseconds\\\\n- frame timing block records `time_origin_ms`, `dt_ms`, `duration_ms`, and\\\\n  `frame_count`\\\\n- sampling mode: `sample_hold`\\\\n\\\\nMeaning:\\\\n\\\\n- retinal frame `k` is authoritative for the half-open interval\\\\n  `[time_origin_ms + k * dt_ms, time_origin_ms + (k + 1) * dt_ms)`\\\\n- later simulators may integrate internally at finer timesteps, but they must\\\\n  preserve the same piecewise-constant bundle values at the retinal frame\\\\n  boundaries unless a later contract revision says otherwise\\\\n\\\\n### Signal convention\\\\n\\\\nMilestone 8B fixes one conservative detector-value convention:\\\\n\\\\n- encoding: `linear_irradiance_unit_interval`\\\\n- minimum value: `0.0`\\\\n- neutral value: `0.5`\\\\n- maximum value: `1.0`\\\\n- contrast semantics: `signed_delta_from_neutral_gray`\\\\n- positive polarity means `brighter_than_neutral`\\\\n\\\\nMeaning:\\\\n\\\\n- the detector values preserve the Milestone 8A linear luminance convention\\\\n  rather than introducing display gamma or simulator-specific normalization\\\\n- out-of-range sampling results must be clipped into `[0.0, 1.0]`, and that\\\\n  clipping is part of the contract\\\\n\\\\n## Sampling-kernel semantics\\\\n\\\\nThe default Milestone 8B sampling kernel is\\\\n`gaussian_acceptance_weighted_mean`.\\\\n\\\\nEvery bundle records:\\\\n\\\\n- kernel family\\\\n- acceptance angle in degrees\\\\n- support radius in degrees\\\\n- kernel normalization rule\\\\n- out-of-field policy and background fill value\\\\n\\\\nMeaning:\\\\n\\\\n- later samplers may optimize the implementation, but the realized detector\\\\n  values must remain equivalent to the recorded kernel settings\\\\n- out-of-field handling is never implicit; the background fill behavior is part\\\\n  of the reproducibility contract\\\\n\\\\n## Invariants later milestones must preserve\\\\n\\\\nLater scene, simulator, and UI milestones must preserve these invariants when\\\\nthey claim to reuse `retinal_input_bundle.v1`:\\\\n\\\\n- bundle identity is the tuple `(contract_version, source_kind, source_family,\\\\n  source_name, source_hash, retinal_spec_hash)`\\\\n- the authoritative source identity recorded in `source_reference` must not be\\\\n  replaced with an ad hoc file path or unnamed frame stack\\\\n- `direct_per_ommatidium_irradiance` remains the source-of-truth handoff even\\\\n  if a downstream consumer also builds rasters or feature maps\\\\n- eye ordering and ommatidial ordering are explicit contract fields, not\\\\n  consumer-defined guesses\\\\n- world, body, head, and eye frame semantics may not be mirrored or rotated\\\\n  silently between stages\\\\n- time stays in milliseconds with sample-hold semantics unless a later contract\\\\n  revision explicitly supersedes this one\\\\n- detector values stay in the recorded linear-irradiance convention; later\\\\n  contrast or adaptation transforms must be explicit derived steps\\\\n\\\\n\\\",\\\"exit_code\\\":0,\\\"status\\\":\\\"completed\\\"}}\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n./agent_tickets/runs/20260322T023042Z/FW-M8B-004_Add_temporal_retinal_frame_generation_and_early-visual_channel_mapping_on_top_of_sampled_ommatidia/stdout.jsonl:58:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_27\",\"type\":\"command_execution\",\"command\":\"/bin/bash -lc \\\"sed -n '1,220p' agent_tickets/runs/20260322T023042Z/FW-M8B-004_Add_temporal_retinal_frame_generation_and_early-visual_channel_mapping_on_top_of_sampled_ommatidia/prompt.md\\\"\",\"aggregated_output\":\"Work ticket FW-M8B-004: Add temporal retinal frame generation and early-visual channel mapping on top of sampled ommatidia.\\nRepository root: /home/jack/Documents/github/personal/fly_neural_simulation/flywire_wave_repo\\nPriority: high\\nSource: Milestone 8B roadmap 2026-03-21\\n\\nPlease implement the ticket end-to-end in this repository.\\nMake the code changes, run the relevant tests or validation commands, and finish with a concise summary of what changed and what you verified.\\n\\nProblem:\\nRaw per-ommatidium samples are not yet a full simulator-facing retinal representation. Milestone 8B also needs a defensible answer to how sampled detector values become time-indexed retinotopic input frames or early visual units that later simulator code can consume. Right now there is no canonical temporal bundling layer, no stable indexing for frame stacks, no place to record normalization or adaptation choices, and no shared mapping from ommatidial samples into the early-unit abstraction Grant defines.\\n\\nRequested Change:\\nBuild the temporal retinal-frame generation layer that turns sampled ommatidial values into deterministic time-indexed retinal bundles using the abstraction chosen in `FW-M8B-001`. Implement the default mapping from detector samples into the chosen simulator-facing retinal representation, record the metadata needed to explain that mapping, and keep the representation extensible enough that later milestones can add richer early-visual channels without breaking the default contract. The resulting bundle should be something later baseline and wave simulators can load directly instead of reverse-engineering raw detector samples.\\n\\nAcceptance Criteria:\\n- There is a canonical API that turns sampled ommatidial values into deterministic retinal frames or early-visual units with explicit temporal indexing and metadata.\\n- The resulting retinal bundle records the mapping from raw detector samples to the simulator-facing representation, including any normalization, aggregation, polarity, or channel semantics required to reproduce the output.\\n- Constant or repeated source input produces stable, reproducible retinal frame outputs rather than subtly drifting or shape-changing bundle structure.\\n- The bundle is discoverable through the contract and loadable through library helpers rather than relying on implicit script-local array conventions.\\n- Regression coverage validates temporal bundling, mapping semantics, and representative steady-state or motion-onset cases using local fixtures only.\\n\\nVerification:\\n- `make test`\\n- A focused unit or integration-style test that builds a small sampled detector sequence and asserts deterministic retinal-frame serialization plus early-unit mapping behavior\\n\\nNotes:\\nAssume `FW-M8B-001` through `FW-M8B-003` are already in place. The main deliverable is a stable simulator handoff: later code should be able to load \\\"retinal input\\\" as a named contract, not reconstruct it from scattered detector arrays. Before finishing this ticket, stage all changes made for it and create a non-amended commit that includes those changes.\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n./agent_tickets/runs/20260322T023042Z/FW-M8B-004_Add_temporal_retinal_frame_generation_and_early-visual_channel_mapping_on_top_of_sampled_ommatidia/stdout.jsonl:65:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_32\",\"type\":\"command_execution\",\"command\":\"/bin/bash -lc \\\"sed -n '360,620p' src/flywire_wave/stimulus_bundle.py\\\"\",\"aggregated_output\":\"    normalized_metadata = parse_stimulus_bundle_metadata(bundle_metadata)\\n    output_dir = (\\n        Path(normalized_metadata[\\\"assets\\\"][\\\"metadata_json\\\"][\\\"path\\\"]).resolve().parent / PREVIEW_DIR_NAME\\n    )\\n    frames_dir = output_dir / PREVIEW_FRAMES_DIR_NAME\\n    ensure_dir(frames_dir)\\n\\n    preview_indices = _normalize_preview_frame_indices(\\n        frame_count=int(render_result.frames.shape[0]),\\n        selected_frame_indices=selected_frame_indices,\\n        frame_times_ms=render_result.frame_times_ms,\\n        stimulus_spec=render_result.stimulus_spec,\\n    )\\n\\n    selected_frames: list[dict[str, Any]] = []\\n    for frame_index in preview_indices:\\n        frame_path = frames_dir / f\\\"frame-{frame_index:04d}.svg\\\"\\n        preview_frame = _downsample_frame_for_preview(\\n            render_result.frames[frame_index],\\n            max_dimension=PREVIEW_IMAGE_MAX_DIMENSION_PX,\\n        )\\n        frame_path.write_text(\\n            _render_frame_svg(preview_frame),\\n            encoding=\\\"utf-8\\\",\\n        )\\n        selected_frames.append(\\n            {\\n                \\\"frame_index\\\": frame_index,\\n                \\\"time_ms\\\": float(render_result.frame_times_ms[frame_index]),\\n                \\\"path\\\": str(frame_path.resolve()),\\n                \\\"mean_luminance\\\": float(np.mean(render_result.frames[frame_index])),\\n                \\\"min_luminance\\\": float(np.min(render_result.frames[frame_index])),\\n                \\\"max_luminance\\\": float(np.max(render_result.frames[frame_index])),\\n                \\\"preview_shape_y_x\\\": [\\n                    int(preview_frame.shape[0]),\\n                    int(preview_frame.shape[1]),\\n                ],\\n            }\\n        )\\n\\n    report_path = (output_dir / \\\"index.html\\\").resolve()\\n    summary_path = (output_dir / \\\"summary.json\\\").resolve()\\n    summary = {\\n        \\\"preview_version\\\": STIMULUS_PREVIEW_VERSION,\\n        \\\"bundle_id\\\": normalized_metadata[\\\"bundle_id\\\"],\\n        \\\"output_dir\\\": str(output_dir.resolve()),\\n        \\\"report_path\\\": str(report_path),\\n        \\\"summary_path\\\": str(summary_path),\\n        \\\"selected_frame_indices\\\": preview_indices,\\n        \\\"selected_frame_times_ms\\\": [\\n            float(render_result.frame_times_ms[index]) for index in preview_indices\\n        ],\\n        \\\"frame_count\\\": int(render_result.frames.shape[0]),\\n        \\\"frame_shape_y_x\\\": [\\n            int(render_result.frames.shape[1]),\\n            int(render_result.frames.shape[2]),\\n        ],\\n        \\\"selected_frames\\\": selected_frames,\\n    }\\n    report_path.write_text(\\n        _render_preview_html(\\n            bundle_metadata=normalized_metadata,\\n            render_result=render_result,\\n            summary=summary,\\n        ),\\n        encoding=\\\"utf-8\\\",\\n    )\\n    write_json(summary, summary_path)\\n    return summary\\n\\n\\ndef _build_recording_metadata(\\n    *,\\n    render_result: StimulusRenderResult,\\n    frame_cache_path: Path,\\n) -> dict[str, Any]:\\n    return {\\n        \\\"recording_version\\\": STIMULUS_RECORDING_VERSION,\\n        \\\"frame_cache_version\\\": STIMULUS_FRAME_CACHE_VERSION,\\n        \\\"frame_cache_path\\\": str(frame_cache_path.resolve()),\\n        \\\"frame_shape_t_y_x\\\": [\\n            int(render_result.frames.shape[0]),\\n            int(render_result.frames.shape[1]),\\n            int(render_result.frames.shape[2]),\\n        ],\\n        \\\"frame_dtype\\\": str(render_result.frames.dtype),\\n        \\\"render_metadata\\\": copy.deepcopy(render_result.render_metadata),\\n    }\\n\\n\\ndef _write_stimulus_frame_cache(\\n    *,\\n    render_result: StimulusRenderResult,\\n    frame_cache_path: str | Path,\\n) -> Path:\\n    arrays = {\\n        \\\"frame_times_ms\\\": np.asarray(render_result.frame_times_ms, dtype=np.float64),\\n        \\\"frames\\\": np.asarray(render_result.frames, dtype=np.float32),\\n        \\\"render_metadata_json\\\": np.asarray(\\n            json.dumps(\\n                render_result.render_metadata,\\n                sort_keys=True,\\n                separators=(\\\",\\\", \\\":\\\"),\\n                ensure_ascii=True,\\n            )\\n        ),\\n        \\\"x_coordinates_deg\\\": np.asarray(render_result.x_coordinates_deg, dtype=np.float64),\\n        \\\"y_coordinates_deg\\\": np.asarray(render_result.y_coordinates_deg, dtype=np.float64),\\n    }\\n    return _write_deterministic_npz(arrays, frame_cache_path)\\n\\n\\ndef _load_stimulus_frame_cache(\\n    frame_cache_path: str | Path,\\n) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray, dict[str, Any]]:\\n    cache_path = Path(frame_cache_path)\\n    with np.load(cache_path, allow_pickle=False) as payload:\\n        frames = np.asarray(payload[\\\"frames\\\"], dtype=np.float32)\\n        frame_times_ms = np.asarray(payload[\\\"frame_times_ms\\\"], dtype=np.float64)\\n        x_coordinates_deg = np.asarray(payload[\\\"x_coordinates_deg\\\"], dtype=np.float64)\\n        y_coordinates_deg = np.asarray(payload[\\\"y_coordinates_deg\\\"], dtype=np.float64)\\n        render_metadata = json.loads(str(payload[\\\"render_metadata_json\\\"].item()))\\n    return frames, frame_times_ms, x_coordinates_deg, y_coordinates_deg, render_metadata\\n\\n\\ndef _write_deterministic_npz(arrays: Mapping[str, np.ndarray], out_path: str | Path) -> Path:\\n    output_path = Path(out_path)\\n    output_path.parent.mkdir(parents=True, exist_ok=True)\\n    with output_path.open(\\\"wb\\\") as handle:\\n        with zipfile.ZipFile(handle, mode=\\\"w\\\", compression=zipfile.ZIP_STORED) as archive:\\n            for key in sorted(arrays):\\n                array_buffer = io.BytesIO()\\n                np.lib.format.write_array(\\n                    array_buffer,\\n                    np.asarray(arrays[key]),\\n                    allow_pickle=False,\\n                )\\n                info = zipfile.ZipInfo(f\\\"{key}.npy\\\", date_time=_FIXED_ZIP_DATETIME)\\n                info.compress_type = zipfile.ZIP_STORED\\n                info.create_system = 3\\n                info.external_attr = 0o600 << 16\\n                archive.writestr(info, array_buffer.getvalue())\\n    return output_path.resolve()\\n\\n\\ndef _render_preview_html(\\n    *,\\n    bundle_metadata: Mapping[str, Any],\\n    render_result: StimulusRenderResult,\\n    summary: Mapping[str, Any],\\n) -> str:\\n    selected_frame_cards = \\\"\\\\n\\\".join(\\n        _render_preview_frame_card(frame_record)\\n        for frame_record in summary[\\\"selected_frames\\\"]\\n    )\\n    temporal_sampling = bundle_metadata[\\\"temporal_sampling\\\"]\\n    spatial_frame = bundle_metadata[\\\"spatial_frame\\\"]\\n    determinism = bundle_metadata[\\\"determinism\\\"]\\n    return f\\\"\\\"\\\"<!doctype html>\\n<html lang=\\\"en\\\">\\n<head>\\n  <meta charset=\\\"utf-8\\\">\\n  <title>Offline Stimulus Preview</title>\\n  <style>\\n    body {{\\n      font-family: sans-serif;\\n      margin: 2rem;\\n      background: #f8fafc;\\n      color: #0f172a;\\n    }}\\n    main {{\\n      max-width: 1040px;\\n      margin: 0 auto;\\n    }}\\n    h1, h2 {{\\n      margin-bottom: 0.5rem;\\n    }}\\n    .meta {{\\n      display: grid;\\n      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));\\n      gap: 0.75rem;\\n      margin: 1.5rem 0;\\n    }}\\n    .card {{\\n      background: white;\\n      border: 1px solid #cbd5e1;\\n      border-radius: 12px;\\n      padding: 1rem;\\n      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06);\\n    }}\\n    .frames {{\\n      display: grid;\\n      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));\\n      gap: 1rem;\\n      margin-top: 1rem;\\n    }}\\n    img {{\\n      width: 100%;\\n      image-rendering: pixelated;\\n      border: 1px solid #cbd5e1;\\n      border-radius: 8px;\\n      background: #e2e8f0;\\n    }}\\n    code {{\\n      font-family: monospace;\\n      font-size: 0.95em;\\n    }}\\n    dl {{\\n      margin: 0;\\n    }}\\n    dt {{\\n      font-weight: 700;\\n      margin-top: 0.4rem;\\n    }}\\n    dd {{\\n      margin: 0.1rem 0 0;\\n    }}\\n  </style>\\n</head>\\n<body>\\n  <main>\\n    <h1>Offline Stimulus Preview</h1>\\n    <p><code>{html.escape(bundle_metadata[\\\"bundle_id\\\"])}</code></p>\\n    <div class=\\\"meta\\\">\\n      <section class=\\\"card\\\">\\n        <h2>Identity</h2>\\n        <dl>\\n          <dt>Family</dt>\\n          <dd>{html.escape(str(bundle_metadata[\\\"stimulus_family\\\"]))}</dd>\\n          <dt>Name</dt>\\n          <dd>{html.escape(str(bundle_metadata[\\\"stimulus_name\\\"]))}</dd>\\n          <dt>Parameter hash</dt>\\n          <dd><code>{html.escape(str(bundle_metadata[\\\"parameter_hash\\\"]))}</code></dd>\\n        </dl>\\n      </section>\\n      <section class=\\\"card\\\">\\n        <h2>Timing</h2>\\n        <dl>\\n          <dt>Frame count</dt>\\n          <dd>{int(temporal_sampling[\\\"frame_count\\\"])}</dd>\\n          <dt>dt</dt>\\n          <dd>{float(temporal_sampling[\\\"dt_ms\\\"]):.6f} ms</dd>\\n          <dt>Duration</dt>\\n          <dd>{float(temporal_sampling[\\\"duration_ms\\\"]):.6f} ms</dd>\\n        </dl>\\n      </section>\\n      <section class=\\\"card\\\">\\n        <h2>Spatial frame</h2>\\n        <dl>\\n          <dt>Resolution</dt>\\n          <dd>{int(spatial_frame[\\\"width_px\\\"])} x {int(spatial_frame[\\\"height_px\\\"])}</dd>\\n          <dt>Extent</dt>\\n          <dd>{float(spatial_frame[\\\"width_deg\\\"]):.3f} x {float(spatial_frame[\\\"height_deg\\\"]):.3f} deg</dd>\\n          <dt>Frame name</dt>\\n          <dd>{html.escape(str(spatial_frame[\\\"frame_name\\\"]))}</dd>\\n        </dl>\\n      </section>\\n      <section class=\\\"card\\\">\\n        <h2>Determinism</h2>\\n        <dl>\\n          <dt>Seed</dt>\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n./agent_tickets/runs/20260322T023042Z/FW-M8B-004_Add_temporal_retinal_frame_generation_and_early-visual_channel_mapping_on_top_of_sampled_ommatidia/stdout.jsonl:68:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_34\",\"type\":\"agent_message\",\"text\":\"Plan for the implementation:\\n\\n1. Add a library-owned retinal bundle workflow module on top of `retinal_sampling` that:\\n   - records deterministic frame archives\\n   - exposes a load/replay helper\\n   - carries a formal early-visual mapping block instead of script-local conventions\\n\\n2. Extend the retinal contract metadata so the bundle explicitly describes:\\n   - the simulator-facing unit/channel layout\\n   - the default identity mapping from sampled ommatidia to early-visual units\\n   - normalization, aggregation, polarity, and channel semantics\\n\\n3. Add regression tests for:\\n   - deterministic serialization and loading of a recorded retinal bundle\\n   - stable repeated-input behavior\\n   - a motion-onset case where the mapped early-visual values change only because the source changed, not because bundle structure drifted\\n\\n4. Run the requested verification, then stage and commit only the ticket-related changes.\"}}\n./agent_tickets/runs/20260322T023042Z/FW-M8B-004_Add_temporal_retinal_frame_generation_and_early-visual_channel_mapping_on_top_of_sampled_ommatidia/stdout.jsonl:69:{\"type\":\"item.started\",\"item\":{\"id\":\"item_35\",\"type\":\"todo_list\",\"items\":[{\"text\":\"Design the retinal bundle metadata and default early-visual mapping on top of the existing retinal contract/sampling APIs\",\"completed\":true},{\"text\":\"Implement the retinal bundle workflow and contract extensions in library code\",\"completed\":false},{\"text\":\"Add focused regression tests for deterministic serialization, loading, and mapping behavior\",\"completed\":false},{\"text\":\"Run verification commands, stage ticket changes, and create a non-amended commit\",\"completed\":false}]}}\n./agent_tickets/runs/20260322T023042Z/FW-M8B-004_Add_temporal_retinal_frame_generation_and_early-visual_channel_mapping_on_top_of_sampled_ommatidia/stdout.jsonl:98:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_52\",\"type\":\"agent_message\",\"text\":\"The new workflow module is in place. I’m wiring it into the package exports and tightening the contract tests now, then I’ll add the focused bundle regression that exercises deterministic archive writing and the identity early-visual mapping.\"}}\n./agent_tickets/runs/20260322T023042Z/FW-M8B-004_Add_temporal_retinal_frame_generation_and_early-visual_channel_mapping_on_top_of_sampled_ommatidia/stdout.jsonl:101:{\"type\":\"item.completed\",\