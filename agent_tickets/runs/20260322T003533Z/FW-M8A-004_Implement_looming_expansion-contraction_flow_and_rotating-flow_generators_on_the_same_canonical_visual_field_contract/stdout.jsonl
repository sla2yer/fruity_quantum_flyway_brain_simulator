{"type":"item.started","item":{"id":"item_49","type":"command_execution","command":"/bin/bash -lc \"PYTHONPATH=src ./.venv/bin/python - <<'PY'\nfrom math import cos, sin, radians\nfrom flywire_wave.stimulus_generators import synthesize_stimulus\n\nfor omega in [30.0, 40.0, 50.0, 70.0]:\n    for cycles in [1, 2, 3, 4]:\n        stim_overrides = {\n            'background_level': 0.5,\n            'contrast': 0.25,\n            'polarity': 'positive',\n            'onset_ms': 0.0,\n            'offset_ms': 1250.0,\n            'angular_velocity_deg_per_s': omega,\n            'angular_cycle_count': cycles,\n            'phase_deg': 20.0,\n            'waveform': 'sine',\n            'inner_radius_deg': 2.0,\n            'outer_radius_deg': 12.0,\n        }\n        values = {}\n        for name in ['clockwise_rotation', 'counterclockwise_rotation']:\n            stim = {'stimulus': {'stimulus_family': 'rotating_flow', 'stimulus_name': name, 'temporal_sampling': {'dt_ms': 250.0, 'duration_ms': 1250.0}, 'stimulus_overrides': stim_overrides}}\n            result = synthesize_stimulus(stim)\n            current = result.sample_field(time_ms=1000.0, azimuth_deg=6.0, elevation_deg=0.0)\n            angle = omega\n            plus = result.sample_field(time_ms=0.0, azimuth_deg=6.0*cos(radians(angle)), elevation_deg=6.0*sin(radians(angle)))\n            minus = result.sample_field(time_ms=0.0, azimuth_deg=6.0*cos(radians(-angle)), elevation_deg=6.0*sin(radians(-angle)))\n            values[name] = (current, plus, minus)\n        c = values['clockwise_rotation']\n        cc = values['counterclockwise_rotation']\n        if abs(c[1]-c[2]) > 1e-4:\n            print('omega', omega, 'cycles', cycles, 'clockwise', c, 'counter', cc)\n            raise SystemExit\nprint('none')\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
