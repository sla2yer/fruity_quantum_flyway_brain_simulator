\\\\\\\\\\\\n]\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nDEFAULT_SIGN_REPRESENTATION = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"categorical_sign_with_signed_weight\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\nDEFAULT_DELAY_REPRESENTATION = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"nonnegative_delay_ms_per_synapse_or_delay_bin\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\nDEFAULT_AGGREGATION_RULE = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sum_over_synapses_preserving_sign_and_delay_bins\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\nDEFAULT_MISSING_GEOMETRY_POLICY = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"fallback_or_blocked_with_explicit_reason\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nCOUPLING_ASSEMBLY_CONFIG_VERSION = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"coupling_assembly.v1\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\nCOUPLING_DELAY_MODEL_CONFIG_VERSION = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"coupling_delay_model.v1\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nSEPARABLE_RANK_ONE_CLOUD_KERNEL = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"separable_rank_one_cloud\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\nPOINT_IMPULSE_KERNEL = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"point_impulse\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\nSUPPORTED_COUPLING_KERNEL_FAMILIES = (\\\\\\\\\\\\\\\\n    SEPARABLE_RANK_ONE_CLOUD_KERNEL,\\\\\\\\\\\\\\\\n    POINT_IMPULSE_KERNEL,\\\\\\\\\\\\\\\\n)\\\\\\\\\\\\\\\\nDEFAULT_COUPLING_KERNEL_FAMILY = SEPARABLE_RANK_ONE_CLOUD_KERNEL\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nWEIGHT_SIGN_ONLY_REPRESENTATION = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"weight_sign_only\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\nSUPPORTED_SIGN_REPRESENTATIONS = (\\\\\\\\\\\\\\\\n    DEFAULT_SIGN_REPRESENTATION,\\\\\\\\\\\\\\\\n    WEIGHT_SIGN_ONLY_REPRESENTATION,\\\\\\\\\\\\\\\\n)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nCONSTANT_ZERO_DELAY_MODEL = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"constant_zero_ms\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\nEUCLIDEAN_ANCHOR_DISTANCE_DELAY_MODEL = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"euclidean_anchor_distance_over_velocity\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\nSUPPORTED_DELAY_MODELS = (\\\\\\\\\\\\\\\\n    CONSTANT_ZERO_DELAY_MODEL,\\\\\\\\\\\\\\\\n    EUCLIDEAN_ANCHOR_DISTANCE_DELAY_MODEL,\\\\\\\\\\\\\\\\n)\\\\\\\\\\\\\\\\nDEFAULT_DELAY_MODEL = CONSTANT_ZERO_DELAY_MODEL\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nCOLLAPSE_DELAY_WITH_WEIGHTED_MEAN_AGGREGATION = (\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sum_over_synapses_preserving_sign_with_weighted_mean_delay\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n)\\\\\\\\\\\\\\\\nSUPPORTED_AGGREGATION_RULES = (\\\\\\\\\\\\\\\\n    DEFAULT_AGGREGATION_RULE,\\\\\\\\\\\\\\\\n    COLLAPSE_DELAY_WITH_WEIGHTED_MEAN_AGGREGATION,\\\\\\\\\\\\\\\\n)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nSUM_TO_ONE_PER_COMPONENT_NORMALIZATION = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sum_to_one_per_component\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\nNO_CLOUD_NORMALIZATION = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"none\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\nSUPPORTED_CLOUD_NORMALIZATIONS = (\\\\\\\\\\\\\\\\n    SUM_TO_ONE_PER_COMPONENT_NORMALIZATION,\\\\\\\\\\\\\\\\n    NO_CLOUD_NORMALIZATION,\\\\\\\\\\\\\\\\n)\\\\\\\\\\\\\\\\nDEFAULT_SOURCE_CLOUD_NORMALIZATION = SUM_TO_ONE_PER_COMPONENT_NORMALIZATION\\\\\\\\\\\\\\\\nDEFAULT_TARGET_CLOUD_NORMALIZATION = SUM_TO_ONE_PER_COMPONENT_NORMALIZATION\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nLOCAL_SYNAPSE_REGISTRY_KEY = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"local_synapse_registry\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\nINCOMING_ANCHOR_MAP_KEY = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"incoming_anchor_map\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\nOUTGOING_ANCHOR_MAP_KEY = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"outgoing_anchor_map\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\nCOUPLING_INDEX_KEY = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"coupling_index\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nREQUIRED_COUPLING_ASSET_KEYS = (\\\\\\\\\\\\\\\\n    LOCAL_SYNAPSE_REGISTRY_KEY,\\\\\\\\\\\\\\\\n    INCOMING_ANCHOR_MAP_KEY,\\\\\\\\\\\\\\\\n    OUTGOING_ANCHOR_MAP_KEY,\\\\\\\\\\\\\\\\n    COUPLING_INDEX_KEY,\\\\\\\\\\\\\\\\n)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n@dataclass(frozen=True)\\\\\\\\\\\\\\\\nclass CouplingContractPaths:\\\\\\\\\\\\\\\\n    processed_coupling_dir: Path\\\\\\\\\\\\\\\\n    local_synapse_registry_path: Path\\\\\\\\\\\\\\\\n    root_asset_directory: Path\\\\\\\\\\\\\\\\n    edge_bundle_directory: Path\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n@dataclass(frozen=True)\\\\\\\\\\\\\\\\nclass RootCouplingBundlePaths:\\\\\\\\\\\\\\\\n    root_id: int\\\\\\\\\\\\\\\\n    local_synapse_registry_path: Path\\\\\\\\\\\\\\\\n    incoming_anchor_map_path: Path\\\\\\\\\\\\\\\\n    outgoing_anchor_map_path: Path\\\\\\\\\\\\\\\\n    coupling_index_path: Path\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    @property\\\\\\\\\\\\\\\\n    def root_label(self) -> str:\\\\\\\\\\\\\\\\n        return str(int(self.root_id))\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    def asset_paths(self) -> dict[str, Path]:\\\\\\\\\\\\\\\\n        return {\\\\\\\\\\\\\\\\n            LOCAL_SYNAPSE_REGISTRY_KEY: self.local_synapse_registry_path,\\\\\\\\\\\\\\\\n            INCOMING_ANCHOR_MAP_KEY: self.incoming_anchor_map_path,\\\\\\\\\\\\\\\\n            OUTGOING_ANCHOR_MAP_KEY: self.outgoing_anchor_map_path,\\\\\\\\\\\\\\\\n            COUPLING_INDEX_KEY: self.coupling_index_path,\\\\\\\\\\\\\\\\n        }\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef build_coupling_contract_paths(processed_coupling_dir: str | Path) -> CouplingContractPaths:\\\\\\\\\\\\\\\\n    coupling_dir = Path(processed_coupling_dir).resolve()\\\\\\\\\\\\\\\\n    return CouplingContractPaths(\\\\\\\\\\\\\\\\n        processed_coupling_dir=coupling_dir,\\\\\\\\\\\\\\\\n        local_synapse_registry_path=coupling_dir / \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"synapse_registry.csv\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        root_asset_directory=coupling_dir / \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"roots\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        edge_bundle_directory=coupling_dir / \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"edges\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n    )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef build_root_coupling_bundle_paths(\\\\\\\\\\\\\\\\n    root_id: int,\\\\\\\\\\\\\\\\n    *,\\\\\\\\\\\\\\\\n    processed_coupling_dir: str | Path,\\\\\\\\\\\\\\\\n) -> RootCouplingBundlePaths:\\\\\\\\\\\\\\\\n    root_label = str(int(root_id))\\\\\\\\\\\\\\\\n    contract_paths = build_coupling_contract_paths(processed_coupling_dir)\\\\\\\\\\\\\\\\n    return RootCouplingBundlePaths(\\\\\\\\\\\\\\\\n        root_id=int(root_id),\\\\\\\\\\\\\\\\n        local_synapse_registry_path=contract_paths.local_synapse_registry_path,\\\\\\\\\\\\\\\\n        incoming_anchor_map_path=contract_paths.root_asset_directory / f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"{root_label}_incoming_anchor_map.npz\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        outgoing_anchor_map_path=contract_paths.root_asset_directory / f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"{root_label}_outgoing_anchor_map.npz\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        coupling_index_path=contract_paths.root_asset_directory / f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"{root_label}_coupling_index.json\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n    )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef build_edge_coupling_bundle_path(\\\\\\\\\\\\\\\\n    pre_root_id: int,\\\\\\\\\\\\\\\\n    post_root_id: int,\\\\\\\\\\\\\\\\n    *,\\\\\\\\\\\\\\\\n    processed_coupling_dir: str | Path,\\\\\\\\\\\\\\\\n) -> Path:\\\\\\\\\\\\\\\\n    contract_paths = build_coupling_contract_paths(processed_coupling_dir)\\\\\\\\\\\\\\\\n    return contract_paths.edge_bundle_directory / f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"{int(pre_root_id)}__to__{int(post_root_id)}_coupling.npz\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef build_edge_coupling_bundle_reference(\\\\\\\\\\\\\\\\n    *,\\\\\\\\\\\\\\\\n    root_id: int,\\\\\\\\\\\\\\\\n    pre_root_id: int,\\\\\\\\\\\\\\\\n    post_root_id: int,\\\\\\\\\\\\\\\\n    processed_coupling_dir: str | Path,\\\\\\\\\\\\\\\\n    status: str = ASSET_STATUS_MISSING,\\\\\\\\\\\\\\\\n) -> dict[str, Any]:\\\\\\\\\\\\\\\\n    normalized_root_id = int(root_id)\\\\\\\\\\\\\\\\n    normalized_pre_root_id = int(pre_root_id)\\\\\\\\\\\\\\\\n    normalized_post_root_id = int(post_root_id)\\\\\\\\\\\\\\\\n    if normalized_root_id == normalized_pre_root_id:\\\\\\\\\\\\\\\\n        relation_to_root = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"outgoing\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        peer_root_id = normalized_post_root_id\\\\\\\\\\\\\\\\n    elif normalized_root_id == normalized_post_root_id:\\\\\\\\\\\\\\\\n        relation_to_root = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"incoming\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        peer_root_id = normalized_pre_root_id\\\\\\\\\\\\\\\\n    else:\\\\\\\\\\\\\\\\n        raise ValueError(\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Root-local coupling bundle references must include edges where root_id \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"matches either pre_root_id or post_root_id.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n    return {\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"pre_root_id\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": normalized_pre_root_id,\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"post_root_id\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": normalized_post_root_id,\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"peer_root_id\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": peer_root_id,\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"relation_to_root\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": relation_to_root,\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"path\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": str(\\\\\\\\\\\\\\\\n            build_edge_coupling_bundle_path(\\\\\\\\\\\\\\\\n                normalized_pre_root_id,\\\\\\\\\\\\\\\\n                normalized_post_root_id,\\\\\\\\\\\\\\\\n                processed_coupling_dir=processed_coupling_dir,\\\\\\\\\\\\\\\\n            )\\\\\\\\\\\\\\\\n        ),\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"status\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": str(status),\\\\\\\\\\\\\\\\n    }\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef build_coupling_contract_manifest_metadata(\\\\\\\\\\\\\\\\n    *,\\\\\\\\\\\\\\\\n    processed_coupling_dir: str | Path | None = None,\\\\\\\\\\\\\\\\n    coupling_bundle_metadata: Mapping[str, Any] | None = None,\\\\\\\\\\\\\\\\n) -> dict[str, Any]:\\\\\\\\\\\\\\\\n    local_synapse_registry_status = ASSET_STATUS_MISSING\\\\\\\\\\\\\\\\n    resolved_processed_coupling_dir = processed_coupling_dir\\\\\\\\\\\\\\\\n    if coupling_bundle_metadata is not None:\\\\\\\\\\\\\\\\n        normalized_bundle = parse_coupling_bundle_metadata(coupling_bundle_metadata)\\\\\\\\\\\\\\\\n        local_synapse_registry = dict(normalized_bundle[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"assets\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"][LOCAL_SYNAPSE_REGISTRY_KEY])\\\\\\\\\\\\\\\\n        resolved_processed_coupling_dir = Path(local_synapse_registry[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"path\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"]).resolve().parent\\\\\\\\\\\\\\\\n        local_synapse_registry_status = str(local_synapse_registry[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"status\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"])\\\\\\\\\\\\\\\\n    if resolved_processed_coupling_dir is None:\\\\\\\\\\\\\\\\n        raise ValueError(\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"processed_coupling_dir must be provided when coupling_bundle_metadata is unavailable.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    contract_paths = build_coupling_contract_paths(resolved_processed_coupling_dir)\\\\\\\\\\\\\\\\n    