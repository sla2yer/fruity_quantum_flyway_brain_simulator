\\\\\\\\\\\\\\\\n    *,\\\\\\\\\\\\\\\\n    processed_coupling_dir: str | Path,\\\\\\\\\\\\\\\\n) -> RootCouplingBundlePaths:\\\\\\\\\\\\\\\\n    root_label = str(int(root_id))\\\\\\\\\\\\\\\\n    contract_paths = build_coupling_contract_paths(processed_coupling_dir)\\\\\\\\\\\\\\\\n    return RootCouplingBundlePaths(\\\\\\\\\\\\\\\\n        root_id=int(root_id),\\\\\\\\\\\\\\\\n        local_synapse_registry_path=contract_paths.local_synapse_registry_path,\\\\\\\\\\\\\\\\n        incoming_anchor_map_path=contract_paths.root_asset_directory / f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"{root_label}_incoming_anchor_map.npz\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        outgoing_anchor_map_path=contract_paths.root_asset_directory / f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"{root_label}_outgoing_anchor_map.npz\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        coupling_index_path=contract_paths.root_asset_directory / f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"{root_label}_coupling_index.json\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n    )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef build_edge_coupling_bundle_path(\\\\\\\\\\\\\\\\n    pre_root_id: int,\\\\\\\\\\\\\\\\n    post_root_id: int,\\\\\\\\\\\\\\\\n    *,\\\\\\\\\\\\\\\\n    processed_coupling_dir: str | Path,\\\\\\\\\\\\\\\\n) -> Path:\\\\\\\\\\\\\\\\n    contract_paths = build_coupling_contract_paths(processed_coupling_dir)\\\\\\\\\\\\\\\\n    return contract_paths.edge_bundle_directory / f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"{int(pre_root_id)}__to__{int(post_root_id)}_coupling.npz\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef build_edge_coupling_bundle_reference(\\\\\\\\\\\\\\\\n    *,\\\\\\\\\\\\\\\\n    root_id: int,\\\\\\\\\\\\\\\\n    pre_root_id: int,\\\\\\\\\\\\\\\\n    post_root_id: int,\\\\\\\\\\\\\\\\n    processed_coupling_dir: str | Path,\\\\\\\\\\\\\\\\n    status: str = ASSET_STATUS_MISSING,\\\\\\\\\\\\\\\\n) -> dict[str, Any]:\\\\\\\\\\\\\\\\n    normalized_