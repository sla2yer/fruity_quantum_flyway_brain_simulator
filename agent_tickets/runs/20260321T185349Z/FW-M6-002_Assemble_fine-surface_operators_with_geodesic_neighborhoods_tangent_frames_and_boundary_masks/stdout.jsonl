 283\t                    ),\n   284\t                    \"conserves_constant_field\": restriction_available,\n   285\t                },\n   286\t                \"coarse_to_fine_prolongation\": {\n   287\t                    \"available\": restriction_available,\n   288\t                    \"path\": str(bundle_paths.transfer_operator_path),\n   289\t                    \"normalization\": str(\n   290\t                        meshing_config_snapshot.get(\"transfer_prolongation_mode\", FALLBACK_TRANSFER_PROLONGATION)\n   291\t                    ),\n   292\t                    \"partition_of_unity\": restriction_available,\n   293\t                },\n   294\t                \"fine_operator_available\": fine_operator_available,\n   295\t                \"coarse_operator_available\": coarse_operator_available,\n   296\t            },\n   297\t            \"assets\": {\n   298\t                FINE_OPERATOR_KEY: fine_operator_asset,\n   299\t                COARSE_OPERATOR_KEY: coarse_operator_asset,\n   300\t                TRANSFER_OPERATORS_KEY: {\n   301\t                    \"path\": str(bundle_paths.transfer_operator_path),\n   302\t                    \"status\": operator_asset_statuses[TRANSFER_OPERATORS_KEY],\n   303\t                },\n   304\t                OPERATOR_METADATA_KEY: {\n   305\t                    \"path\": str(bundle_paths.operator_metadata_path),\n   306\t                    \"status\": operator_asset_statuses[OPERATOR_METADATA_KEY],\n   307\t                },\n   308\t            },\n   309\t        }\n   310\t        for extra_field in (\n   311\t            \"weighting_scheme\",\n   312\t            \"operator_matrix_role\",\n   313\t            \"stiffness_matrix_role\",\n   314\t            \"mass_matrix_role\",\n   315\t            \"orientation_convention\",\n   316\t            \"matrix_properties\",\n   317\t            \"supporting_geometry\",\n   318\t            \"counts\",\n   319\t        ):\n   320\t            if extra_fi