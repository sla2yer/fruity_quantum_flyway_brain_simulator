88\t\n  1389\t\n  1390\tdef _condition_groups_from_plan(\n  1391\t    analysis_plan: Mapping[str, Any],\n  1392\t) -> dict[str, list[dict[str, Any]]]:\n  1393\t    groups: dict[str, list[dict[str, Any]]] = {}\n  1394\t    for item in analysis_plan[\"condition_catalog\"]:\n  1395\t        parameter_name = _normalize_identifier(\n  1396\t            item[\"parameter_name\"],\n  1397\t            field_name=\"analysis_plan.condition_catalog.parameter_name\",\n  1398\t        )\n  1399\t        groups.setdefault(parameter_name, []).append(copy.deepcopy(dict(item)))\n  1400\t    for values in groups.values():\n  1401\t        values.sort(key=lambda item: str(item[\"condition_id\"]))\n  1402\t    return dict(sorted(groups.items()))\n  1403\t\n  1404\t\n  1405\tdef _plan_requires_condition_labels(analysis_plan: Mapping[str, Any]) -> bool:\n  1406\t    for metric_definition in analysis_plan[\"active_metric_definitions\"]:\n  1407\t        if str(metric_definition[\"metric_class\"]) == WAVE_ONLY_DIAGNOSTIC_CLASS:\n  1408\t            continue\n  1409\t        return True\n  1410\t    return False\n  1411\t\n  1412\t\n  1413\tdef _expected_condition_signatures(\n  1414\t    condition_groups: Mapping[str, Sequence[Mapping[str, Any]]],\n  1415\t) -> list[dict[str, Any]]:\n  1416\t    if not condition_groups:\n  1417\t        return [{\"condition_ids\": [], \"condition_signature\": \"unlabeled\"}]\n  1418\t    grouped_condition_ids = [\n  1419\t        [str(item[\"condition_id\"]) for item in group]\n  1420\t        for _, group in sorted(condition_groups.items())\n  1421\t    ]\n  1422\t    signatures = []\n  1423\t    for combo in itertools.product(*grouped_condition_ids):\n  1424\t        condition_ids = sorted(str(item) for item in combo)\n  1425\t        signatures.append(\n  1426\t            {\n  1427\t                \"condition_ids\": condition_ids,\n  1428\t                \"condition_signature\": _condition_signature(condition_ids),\n  1429\t            }\n  1430\t        )\n  1431\t    signatures.sort(key=lambda item: str(item[\"condition_signature\"]))\n  1432\t    return signatures\n  1433\t\n  1434\t\n  1435\tdef _infer_bundle_conditions(\n  1436\t    *,\n  1437\t    bundle_metadata: Mapping[str, Any],\n  1438\t    condition_groups: Mapping[str, Sequence[Mapping[str, Any]]],\n  1439\t    requires_condition_labels: bool,\n  1440\t) -> dict[str, Any]:\n  1441\t    stimulus_asset = _find_input_asset(bundle_metadata, artifact_type=\"stimulus_bundle\")\n  1442\t    if stimulus_asset is None:\n  1443\t        if requires_condition_labels:\n  1444\t            raise ValueError(\n  1445\t                f\"Discovered bundle {bundle_metadata['bundle_id']!r} is missing its selected \"\n  1446\t                \"stimulus bundle metadata, so the workflow cannot infer analysis condition labels.\"\n  1447\t            )\n  1448\t        return {\n  1449\t            \"condition_ids\": [],\n  1450\t            \"stimulus_family\": None,\n  1451\t            \"stimulus_name\": None,\n  1452\t            \"parameter_snapshot\": None,\n  1453\t        }\n  1454\t    stimulus_metadata = load_stimulus_bundle_metadata(Path(stimulus_asset[\"path\"]))\n  1455\t    parameter_snapshot = copy.deepcopy(dict(stimulus_metadata[\"parameter_snapshot\"]))\n  1456\t    condition_ids: list[str] = []\n  1457\t    for parameter_name, candidates in sorted(condition_groups.items()):\n  1458\t        if parameter_name not in parameter_snapshot:\n  1459\t            raise ValueError(\n  1460\t                f\"Stimulus bundle {stimulus_metadata['bundle_id']!r} for simulator bundle \"\n  1461\t                f\"{bundle_metadata['bundle_id']!r} is missing parameter {parameter_name!r} \"\n  1462\t                \"required by the normalized analysis condition catalog.\"\n  1463\t            )\n  1464\t        observed_value = parameter_snapshot[parameter_name]\n  1465\t        matched_condition_ids = [\n  1466\t            str(item[\"condition_id\"])\n  1467\t            for item in candidates\n  1468\t            if _condition_value_matches(\n  1469\t                observed_value=observed_value,\n  1470\t                expected_value=item[\"value\"],\n  1471\t            )\n  1472\t        ]\n  1473\t        if len(matched_condition_ids) != 1:\n  1474\t            raise ValueError(\n  1475\t                f\"Stimulus bundle {stimulus_metadata['bundle_id']!r} for simulator bundle \"\n  1476\t                f\"{bundle_metadata['bundle_id']!r} matched condition ids \"\n  1477\t                f\"{matched_condition_ids!r} for parameter {parameter_name!r}; expected exactly one.\"\n  1478\t            )\n  1479\t        condition_ids.append(matched_condition_ids[0])\n  1480\t    return {\n  1481\t        \"condition_ids\": sorted(condition_ids),\n  1482\t        \"stimulus_family\": str(stimulus_metadata[\"stimulus_family\"]),\n  1483\t        \"stimulus_name\": str(stimulus_metadata[\"stimulus_name\"]),\n  1484\t        \"parameter_snapshot\": parameter_snapshot,\n  1485\t    }\n  1486\t\n  1487\t\n  1488\tdef _condition_value_matches(*, observed_value: Any, expected_value: Any) -> bool:\n  1489\t    if isinstance(expected_value, str):\n  1490\t        return _normalize_identifier(\n  1491\t            observed_value,\n  1492\t            field_name=\"stimulus.parameter_snapshot.value\",\n  1493\t        ) == _normalize_identifier(\n  1494\t            expected_value,\n  1495\t            field_name=\"analysis_plan.condition_catalog.value\",\n  1496\t        )\n  1497\t    observed_float = _normalize_float(\n  1498\t        observed_value,\n  1499\t        field_name=\"stimulus.parameter_snapshot.value\",\n  1500\t    )\n  1501\t    expected_float = _normalize_float(\n  1502\t        expected_value,\n  1503\t        field_name=\"analysis_plan.condition_catalog.value\",\n  1504\t    )\n  1505\t    return math.isclose(\n  1506\t        float(observed_float),\n  1507\t        float(expected_float),\n  1508\t        rel_tol=0.0,\n  1509\t        abs_tol=_CONDITION_VALUE_TOLERANCE,\n  1510\t    )\n  1511\t\n  1512\t\n  1513\tdef _find_input_asset(\n  1514\t    bundle_metadata: Mapping[str, Any],\n  1515\t    *,\n  1516\t    artifact_type: str,\n  1517\t) -> dict[str, Any] | None:\n  1518\t    normalized_artifact_type = _normalize_nonempty_string(\n  1519\t        artifact_type,\n  1520\t        field_name=\"artifact_type\",\n  1521\t    )\n  1522\t    for item in bundle_metadata[\"selected_assets\"]:\n  1523\t        if (\n  1524\t            str(item[\"asset_role\"]) == \"input_bundle\"\n  1525\t            and str(item[\"artifact_type\"]) == normalized_artifact_type\n  1526\t        ):\n  1527\t            return copy.deepcopy(dict(item))\n  1528\t    return None\n  1529\t\n  1530\t\n  1531\tdef _validate_bundle_coverage(\n  1532\t    *,\n  1533\t    bundle_inventory: Sequence[Mapping[str, Any]],\n  1534\t    arm_ids: Sequence[str],\n  1535\t    expected_seeds_by_arm_id: Mapping[str, Sequence[int]],\n  1536\t    expected_condition_signatures: Sequence[Mapping[str, Any]],\n  1537\t    requires_condition_labels: bool,\n  1538\t) -> None:\n  1539\t    expected_condition_keys = [\n  1540\t        tuple(item[\"condition_ids\"]) for item in expected_condition_signatures\n  1541\t    ]\n  1542\t    inventory_by_arm_seed: dict[tuple[str, int], set[tuple[str, ...]]] = {}\n  1543\t    for item in bundle_inventory:\n  1544\t        key = (str(item[\"arm_id\"]), int(item[\"seed\"]))\n  1545\t        inventory_by_arm_seed.setdefault(key, set()).add(tuple(item[\"condition_ids\"]))\n  1546\t    for arm_id in arm_ids:\n  1547\t        expected_seeds = expected_seeds_by_arm_id.get(arm_id, [])\n  1548\t        for seed in expected_seeds:\n  1549\t            seen_conditions = inventory_by_arm_seed.get((arm_id, int(seed)), set())\n  1550\t            if requires_condition_labels:\n  1551\t                missing_conditions = [\n  1552\t                    list(condition_ids)\n  1553\t                    for condition_ids in expected_condition_keys\n  1554\t                    if condition_ids not in seen_conditions\n  1555\t                ]\n  1556\t                if missing_conditions:\n  1557\t                    raise ValueError(\n  1558\t                        f\"Experiment bundle set is missing required condition coverage for \"\n  1559\t                        f\"arm_id {arm_id!r}, seed {seed!r}: {missing_conditions!r}.\"\n  1560\t                    )\n  1561\t            elif not seen_conditions:\n  1562\t                raise ValueError(\n  1563\t                    f\"Experiment bundle set is missing any bundle coverage for arm_id {arm_id!r}, \"\n  1564\t                    f\"seed {seed!r}.\"\n  1565\t                )\n  1566\t\n  1567\t\n  1568\tdef _subset_analysis_plan(\n  1569\t    analysis_plan: Mapping[str, Any],\n  1570\t    *,\n  1571\t    metric_ids: Sequence[str],\n  1572\t) -> dict[str, Any]:\n  1573\t    active_metric_ids = {\n  1574\t        _normalize_identifier(metric_id, field_name=\"metric_ids\")\n  1575\t        for metric_id in metric_ids\n  1576\t    }\n  1577\t    return {\n  1578\t        \"plan_version\": str(analysis_plan[\"plan_version\"]),\n  1579\t        \"condition_catalog\": copy.deepcopy(list(analysis_plan[\"condition_catalog\"])),\n  1580\t        \"condition_pair_catalog\": copy.deepcopy(list(analysis_plan[\"condition_pair_catalog\"])),\n  1581\t        \"analysis_window_catalog\": copy.deepcopy(list(analysis_plan[\"analysis_window_catalog\"])),\n  1582\t        \"metric_recipe_catalog\": [\n  1583\t            copy.deepcopy(dict(item))\n  1584\t            for item in analysis_plan[\"metric_recipe_catalog\"]\n  1585\t            if str(item[\"metric_id\"]) in active_metric_ids\n  1586\t            and item[\"active_readout_ids\"]\n  1587\t        ],\n  1588\t    }\n  1589\t\n  1590\t\n  1591\tdef _wave_analysis_windows(analysis_plan: Mapping[str, Any]) -> list[dict[str, Any]] | None:\n  1592\t    windows_by_id = {\n  1593\t        str(item[\"window_id\"]): copy.deepcopy(dict(item))\n  1594\t        for item in analysis_plan[\"analysis_window_catalog\"]\n  1595\t    }\n  1596\t    requested_window_ids = sorted(\n  1597\t        {\n  1598\t            str(item[\"window_id\"])\n  1599\t            for item in analysis_plan[\"metric_recipe_catalog\"]\n  1600\t            if str(item[\"metric_id\"]) in set(SUPPORTED_WAVE_STRUCTURE_METRIC_IDS)\n  1601\t        }\n  1602\t    )\n  1603\t    if not requested_window_ids:\n  1604\t        return None\n  1605\t    return [windows_by_id[window_id] for window_id in requested_window_ids]\n  1606\t\n  1607\t\n  1608\tdef _comparable_metric_ids(analysis_plan: Mapping[str, Any]) -> set[str]:\n  1609\t    comparable: set[str] = set()\n  1610\t    for item in analysis_plan[\"active_metric_definitions\"]:\n  1611\t        if str(item[\"metric_class\"]) == WAVE_ONLY_DIAGNOSTIC_CLASS:\n  1612\t            continue\n  1613\t        comparable.add(str(item[\"metric_id\"]))\n  1614\t    return comparable\n  1615\t\n  1616\t\n  1617\tdef _combined_metric_rows(\n  1618\t    *,\n  1619\t    shared_result: Mapping[str, Any],\n  1620\t    task_result: Mapping[str, Any],\n  1621\t    wave_result: Mapping[str, Any],\n  1622\t) -> list[dict[str, Any]]:\n  1623\t    combined: list[dict[str, Any]] = []\n  1624\t    for source_name, result in (\n  1625\t        (\"shared_readout_analysis\", shared_result),\n  1626\t        (\"task_decoder_analysis\", task_result),\n  1627\t        (\"wave_diagnostic_analysis\", wave_result),\n  1628\t    ):\n  1629\t        for item in result.get(\"metric_rows\", []):\n  1630\t            row = copy.deepcopy(dict(item))\n  1631\t            row[\"analysis_source\"] = source_name\n  1632\t            combined.append(row)\n  1633\t    return combined\n  1634\t\n  1635\t\n  1636\tdef _combined_group_catalog(analysis_plan: Mapping[str, Any]) -> list[dict[str, Any]]:\n  1637\t    records = [\n  1638\t        copy.deepcopy(dict(item)) for item in analysis_plan[\"arm_pair_catalog\"]\n  1639\t    ] + [\n  1640\t        copy.deepcopy(dict(item)) for item in analysis_plan[\"comparison_group_catalog\"]\n  1641\t    ]\n  1642\t    records.sort(key=lambda item: str(item[\"group_id\"]))\n  1643\t    return records\n  1644\t\n  1645\t\n  1646\tdef _expected_seeds_by_group_id(\n  1647\t    *,\n  1648\t    analysis_plan: Mapping[str, Any],\n  1649\t    bundle_set: Mapping[str, Any],\n  1650\t) -> dict[str, list[int]]:\n  1651\t    seeds_by_arm_id = {\n  1652\t        str(arm_id): [int(seed) for seed in seeds]\n  1653\t        for arm_id, seeds in bundle_set[\"expected_seeds_by_arm_id\"].items()\n  1654\t    }\n  1655\t    seeds_by_group_id: dict[str, list[int]] = {}\n  1656\t    for item in analysis_plan[\"arm_pair_catalog\"]:\n  1657\t        baseline_arm_id = str(item[\"baseline_arm_id\"])\n  1658\t        surface_wave_arm_id = str(item[\"surface_wave_arm_id\"])\n  1659\t        baseline_seeds = seeds_by_arm_id.get(baseline_arm_id, [])\n  1660\t        surface_wave_seeds = seeds_by_arm_id.get(surface_wave_arm_id, [])\n  1661\t        if baseline_seeds != surface_wave_seeds:\n  1662\t            raise ValueError(\n  1663\t                f\"Matched arm-pair group {item['group_id']!r} has incompatible seed coverage: \"\n  1664\t                f\"{baseline_arm_id!r} -> {baseline_seeds!r}, \"\n  1665\t                f\"{surface_wave_arm_id!r} -> {surface_wave_seeds!r}.\"\n  1666\t            )\n  1667\t        seeds_by_group_id[str(item[\"group_id\"])] = list(baseline_seeds)\n  1668\t    groups_by_id = {\n  1669\t        str(item[\"group_id\"]): item for item in analysis_plan[\"comparison_group_catalog\"]\n  1670\t    }\n  1671\t    changed = True\n  1672\t    while changed:\n  1673\t        changed = False\n  1674\t        for group_id, group in groups_by_id.items():\n  1675\t            if group_id in seeds_by_group_id:\n  1676\t                continue\n  1677\t            component_group_ids = [\n  1678\t                str(component_group_id)\n  1679\t                for component_group_id in group.get(\"component_group_ids\", [])\n  1680\t            ]\n  1681\t            if not component_group_ids:\n  1682\t                seeds_by_group_id[group_id] = []\n  1683\t                changed = True\n  1684\t                continue\n  1685\t            if any(component_group_id not in seeds_by_group_id for component_group_id in component_group_ids):\n  1686\t                continue\n  1687\t            component_seeds = [tuple(seeds_by_group_id[component_group_id]) for component_group_id in component_group_ids]\n  1688\t            if len(set(component_seeds)) != 1:\n  1689\t                raise ValueError(\n  1690\t                    f\"Derived comparison group {group_id!r} has incompatible seed coverage across \"\n  1691\t                    f\"component groups {component_group_ids!r}.\"\n  1692\t                )\n  1693\t            seeds_by_group_id[group_id] = list(component_seeds[0])\n  1694\t            changed = True\n  1695\t    missing_group_ids = sorted(\n  1696\t        set(groups_by_id) - set(seeds_by_group_id)\n  1697\t    )\n  1698\t    if missing_group_ids:\n  1699\t        raise ValueError(\n  1700\t            f\"Could not resolve expected seed coverage for derived comparison groups \"\n  1701\t            f\"{missing_group_ids!r}.\"\n  1702\t        )\n  1703\t    return seeds_by_group_id\n  1704\t\n  1705\t\n  1706\tdef _index_metric_rows_by_arm_seed_key(\n  1707\t    *,\n  1708\t    metric_rows: Sequence[Mapping[str, Any]],\n  1709\t    comparable_metric_ids: set[str],\n  1710\t) -> dict[tuple[str, int], dict[tuple[Any, ...], dict[str, Any]]]:\n  1711\t    index: dict[tuple[str, int], dict[tuple[Any, ...], dict[str, Any]]] = {}\n  1712\t    for item in metric_rows:\n  1713\t        metric_id = str(item[\"metric_id\"])\n  1714\t        if metric_id not in comparable_metric_ids:\n  1715\t            continue\n  1716\t        arm_id = str(item[\"arm_id\"])\n  1717\t        seed = int(item[\"seed\"])\n  1718\t        key = _metric_row_identity(item)\n  1719\t        index.setdefault((arm_id, seed), {})\n  1720\t        if key in index[(arm_id, seed)]:\n  1721\t            raise ValueError(\n  1722\t                f\"Experiment comparison analysis found duplicate metric coverage for arm_id \"\n  1723\t                f\"{arm_id!r}, seed {seed!r}, and metric identity {key!r}.\"\n  1724\t            )\n  1725\t        index[(arm_id, seed)][key] = copy.deepcopy(dict(item))\n  1726\t    return index\n  1727\t\n  1728\t\n  1729\tdef _build_matched_pair_detail_rows(\n  1730\t    *,\n  1731\t    analysis_plan: Mapping[str, Any],\n  1732\t    expected_seeds_by_group_id: Mapping[str, Sequence[int]],\n  1733\t    metric_rows_by_arm_seed_key: Mapping[tuple[str, int], Mapping[tuple[Any, ...], Mapping[str, Any]]],\n  1734\t) -> list[dict[str, Any]]:\n  1735\t    rows: list[dict[str, Any]] = []\n  1736\t    for group in analysis_plan[\"arm_pair_catalog\"]:\n  1737\t        group_id = str(group[\"group_id\"])\n  1738\t        baseline_arm_id = str(group[\"baseline_arm_id\"])\n  1739\t        surface_wave_arm_id = str(group[\"surface_wave_arm_id\"])\n  1740\t        for seed in expected_seeds_by_group_id[group_id]:\n  1741\t            baseline_rows = metric_rows_by_arm_seed_key.get((baseline_arm_id, int(seed)))\n  1742\t            surface_wave_rows = metric_rows_by_arm_seed_key.get((surface_wave_arm_id, int(seed)))\n  1743\t            if not baseline_rows:\n  1744\t                raise ValueError(\n  1745\t                    f\"Comparison group {group_id!r} is missing baseline metric rows for \"\n  1746\t                    f\"arm_id {baseline_arm_id!r} seed {seed!r}.\"\n  1747\t                )\n  1748\t            if not surface_wave_rows:\n  1749\t                raise ValueError(\n  1750\t                    f\"Comparison group {group_id!r} is missing surface-wave metric rows for \"\n  1751\t                    f\"arm_id {surface_wave_arm_id!r} seed {seed!r}.\"\n  1752\t                )\n  1753\t            baseline_keys = set(baseline_rows)\n  1754\t            surface_wave_keys = set(surface_wave_rows)\n  1755\t            if baseline_keys != surface_wave_keys:\n  1756\t                raise ValueError(\n  1757\t                    f\"Comparison group {group_id!r} has incompatible metric/readout coverage \"\n  1758\t                    f\"between arm_id {baseline_arm_id!r} and arm_id {surface_wave_arm_id!r} \"\n  1759\t                    f\"for seed {seed!r}.\"\n  1760\t                )\n  1761\t            for metric_key in sorted(baseline_keys):\n  1762\t                baseline_row = baseline_rows[metric_key]\n  1763\t                surface_wave_row = surface_wave_rows[metric_key]\n  1764\t                if str(baseline_row[\"units\"]) != str(surface_wave_row[\"units\"]):\n  1765\t                    raise ValueError(\n  1766\t                        f\"Comparison group {group_id!r} metric {baseline_row['metric_id']!r} has \"\n  1767\t                        \"incompatible units between matched arms.\"\n  1768\t                    )\n  1769\t                rows.append(\n  1770\t                    {\n  1771\t                        \"group_id\": group_id,\n  1772\t                        \"group_kind\": str(group[\"group_kind\"]),\n  1773\t                        \"comparison_semantics\": str(group[\"comparison_semantics\"]),\n  1774\t                        \"metric_id\": str(baseline_row[\"metric_id\"]),\n  1775\t                        \"readout_id\": str(baseline_row[\"readout_id\"]),\n  1776\t                        \"window_id\": str(baseline_row[\"window_id\"]),\n  1777\t                        \"statistic\": str(baseline_row[\"statistic\"]),\n  1778\t                        \"condition_pair_id\": baseline_row.get(\"condition_pair_id\"),\n  1779\t                        \"pairing_key\": baseline_row.get(\"pairing_key\"),\n  1780\t                        \"condition_signature\": baseline_row.get(\"condition_signature\"),\n  1781\t                        \"decoder_id\": baseline_row.get(\"decoder_id\"),\n  1782\t                        \"root_id\": baseline_row.get(\"root_id\"),\n  1783\t                        \"units\": str(baseline_row[\"units\"]),\n  1784\t                        \"seed\": int(seed),\n  1785\t                        \"baseline_family\": str(group[\"baseline_family\"]),\n  1786\t                        \"topology_condition\": str(group[\"topology_condition\"]),\n  1787\t                        \"value\": _rounded_float(\n  1788\t                            float(surface_wave_row[\"value\"]) - float(baseline_row[\"value\"])\n  1789\t                        ),\n  1790\t                        \"component_values\": {\n  1791\t                            \"baseline\": _rounded_float(float(baseline_row[\"value\"])),\n  1792\t                            \"surface_wave\": _rounded_float(float(surface_wave_row[\"value\"])),\n  1793\t                        },\n  1794\t                        \"component_group_ids\": [],\n  1795\t                    }\n  1796\t                )\n  1797\t    return rows\n  1798\t\n  1799\t\n  1800\tdef _build_derived_detail_rows(\n  1801\t    *,\n  1802\t    analysis_plan: Mapping[str, Any],\n  1803\t    detail_rows_by_group_id: Mapping[str, Sequence[Mapping[str, Any]]],\n  1804\t    expected_seeds_by_group_id: Mapping[str, Sequence[int]],\n  1805\t) -> list[dict[str, Any]]:\n  1806\t    rows: list[dict[str, Any]] = []\n  1807\t    for group in analysis_plan[\"comparison_group_catalog\"]:\n  1808\t        group_id = str(group[\"group_id\"])\n  1809\t        component_group_ids = [str(item) for item in group[\"component_group_ids\"]]\n  1810\t        component_indices = {\n  1811\t            component_group_id: _index_detail_rows_by_seed_and_identity(\n  1812\t                detail_rows_by_group_id.get(component_group_id, [])\n  1813\t            )\n  1814\t            for component_group_id in component_group_ids\n  1815\t        }\n  1816\t        for seed in expected_seeds_by_group_id[group_id]:\n  1817\t            missing_component_groups = [\n  1818\t                component_group_id\n  1819\t                for component_group_id, index in component_indices.items()\n  1820\t                if int(seed) not in index\n  1821\t            ]\n  1822\t            if missing_component_groups:\n  1823\t                raise ValueError(\n  1824\t                    f\"Derived comparison group {group_id!r} is missing component coverage for \"\n  1825\t                    f\"seed {seed!r}: {missing_component_groups!r}.\"\n  1826\t                )\n  1827\t            reference_keys = set(component_indices[component_group_ids[0]][int(seed)])\n  1828\t            for component_group_id in component_group_ids[1:]:\n  1829\t                if set(component_indices[component_group_id][int(seed)]) != reference_keys:\n  1830\t                    raise ValueError(\n  1831\t                        f\"Derived comparison group {group_id!r} has incompatible detail-row \"\n  1832\t                        f\"coverage across component groups {component_group_ids!r} for seed {seed!r}.\"\n  1833\t                    )\n  1834\t            for detail_key in sorted(reference_keys):\n  1835\t                component_rows = {\n  1836\t                    component_group_id: component_indices[component_group_id][int(seed)][detail_key]\n  1837\t                    for component_group_id in component_group_ids\n  1838\t                }\n  1839\t                first_row = component_rows[component_group_ids[0]]\n  1840\t                if str(group[\"group_kind\"]) == \"geometry_ablation\":\n  1841\t                    intact_row = component_rows[component_group_ids[0]]\n  1842\t                    shuffled_row = component_rows[component_group_ids[1]]\n  1843\t                    rows.append(\n  1844\t                        _derived_detail_row(\n  1845\t                            group=group,\n  1846\t                            seed=int(seed),\n  1847\t                            template_row=first_row,\n  1848\t                            value=_rounded_float(\n  1849\t                                float(intact_row[\"value\"]) - float(shuffled_row[\"value\"])\n  1850\t                            ),\n  1851\t                            component_values={\n  1852\t                                \"intact\": _rounded_float(float(intact_row[\"value\"])),\n  1853\t                                \"shuffled\": _rounded_float(float(shuffled_row[\"value\"])),\n  1854\t                            },\n  1855\t                            component_group_ids=component_group_ids,\n  1856\t                        )\n  1857\t                    )\n  1858\t                elif str(group[\"group_kind\"]) == \"baseline_strength_challenge\":\n  1859\t                    p0_row = component_rows[component_group_ids[0]]\n  1860\t                    p1_row = component_rows[component_group_ids[1]]\n  1861\t                    rows.append(\n  1862\t                        _derived_detail_row(\n  1863\t                            group=group,\n  1864\t                            seed=int(seed),\n  1865\t                            template_row=first_row,\n  1866\t                            value=_rounded_float(float(p1_row[\"value\"])),\n  1867\t                            component_values={\n  1868\t                                \"p0_reference\": _rounded_float(float(p0_row[\"value\"])),\n  1869\t                                \"p1_challenge\": _rounded_float(float(p1_row[\"value\"])),\n  1870\t                                \"delta_from_reference\": _rounded_float(\n  1871\t                                    float(p1_row[\"value\"]) - float(p0_row[\"value\"])\n  1872\t                                ),\n  1873\t                            },\n  1874\t                            component_group_ids=component_group_ids,\n  1875\t                        )\n  1876\t                    )\n  1877\t                else:\n  1878\t                    raise ValueError(\n  1879\t                        f\"Unsupported derived comparison group_kind {group['group_kind']!r}.\"\n  1880\t                    )\n  1881\t    return rows\n  1882\t\n  1883\t\n  1884\tdef _index_detail_rows_by_seed_and_identity(\n  1885\t    rows: Sequence[Mapping[str, Any]],\n  1886\t) -> dict[int, dict[tuple[Any, ...], dict[str, Any]]]:\n  1887\t    index: dict[int, dict[tuple[Any, ...], dict[str, Any]]] = {}\n  1888\t    for item in rows:\n  1889\t        seed = int(item[\"seed\"])\n  1890\t        detail_key = _comparison_detail_identity(item)\n  1891\t        index.setdefault(seed, {})\n  1892\t        if detail_key in index[seed]:\n  1893\t            raise ValueError(\n  1894\t                f\"Derived comparison construction found duplicate detail coverage for seed \"\n  1895\t                f\"{seed!r} and identity {detail_key!r}.\"\n  1896\t            )\n  1897\t        index[seed][detail_key] = copy.deepcopy(dict(item))\n  1898\t    return index\n  1899\t\n  1900\t\n  1901\tdef _derived_detail_row(\n  1902\t    *,\n  1903\t    group: Mapping[str, Any],\n  1904\t    seed: int,\n  1905\t    template_row: Mapping[str, Any],\n  1906\t    value: float,\n  1907\t    component_values: Mapping[str, float],\n  1908\t    component_group_ids: Sequence[str],\n  1909\t) -> dict[str, Any]:\n  1910\t    return {\n  1911\t        \"group_id\": str(group[\"group_id\"]),\n  1912\t        \"group_kind\": str(group[\"group_kind\"]),\n  1913\t        \"comparison_semantics\": str(group[\"comparison_semantics\"]),\n  1914\t        \"metric_id\": str(template_row[\"metric_id\"]),\n  1915\t        \"readout_id\": str(template_row[\"readout_id\"]),\n  1916\t        \"window_id\": str(template_row[\"window_id\"]),\n  1917\t        \"statistic\": str(template_row[\"statistic\"]),\n  1918\t        \"condition_pair_id\": template_row.get(\"condition_pair_id\"),\n  1919\t        \"pairing_key\": template_row.get(\"pairing_key\"),\n  1920\t        \"condition_signature\": template_row.get(\"condition_signature\"),\n  1921\t        \"decoder_id\": template_row.get(\"decoder_id\"),\n  1922\t        \"root_id\": template_row.get(\"root_id\"),\n  1923\t        \"units\": str(template_row[\"units\"]),\n  1924\t        \"seed\": int(seed),\n  1925\t        \"baseline_family\": group.get(\"baseline_family\"),\n  1926\t        \"topology_condition\": group.get(\"topology_condition\"),\n  1927\t        \"value\": value,\n  1928\t        \"component_values\": copy.deepcopy(dict(component_values)),\n  1929\t        \"component_group_ids\": list(component_group_ids),\n  1930\t    }\n  1931\t\n  1932\t\n  1933\tdef _build_group_metric_seed_rows(\n  1934\t    comparison_detail_rows: Sequence[Mapping[str, Any]],\n  1935\t) -> list[dict[str, Any]]:\n  1936\t    grouped: dict[tuple[str, str, int], list[dict[str, Any]]] = {}\n  1937\t    for item in comparison_detail_rows:\n  1938\t        key = (str(item[\"group_id\"]), str(item[\"metric_id\"]), int(item[\"seed\"]))\n  1939\t        grouped.setdefault(key, []).append(copy.deepcopy(dict(item)))\n  1940\t    rows: list[dict[str, Any]] = []\n  1941\t    for (group_id, metric_id, seed), items in grouped.items():\n  1942\t        template = items[0]\n  1943\t        values = np.asarray([float(item[\"value\"]) for item in items], dtype=np.float64)\n  1944\t        component_names = sorted(\n  1945\t            {\n  1946\t                str(component_name)\n  1947\t                for item in items\n  1948\t                for component_name in item.get(\"component_values\", {})\n  1949\t            }\n  1950\t        )\n  1951\t        component_values = {\n  1952\t            component_name: _rounded_float(\n  1953\t                float(\n  1954\t                    np.mean(\n  1955\t                        [\n  1956\t                            float(item[\"component_values\"][component_name])\n  1957\t                            for item in items\n  1958\t                            if component_name in item.get(\"component_values\", {})\n  1959\t                        ],\n  1960\t                        dtype=np.float64,\n  1961\t                    )\n  1962\t                )\n  1963\t            )\n  1964\t            for component_name in component_names\n  1965\t        }\n  1966\t        rows.append(\n  1967\t            {\n  1968\t                \"group_id\": group_id,\n  1969\t                \"group_kind\": str(template[\"group_kind\"]),\n  1970\t                \"comparison_semantics\": str(template[\"comparison_semantics\"]),\n  1971\t                \"metric_id\": metric_id,\n  1972\t                \"readout_id\": str(template[\"readout_id\"]),\n  1973\t                \"window_id\": str(template[\"window_id\"]),\n  1974\t                \"statistic\": str(template[\"statistic\"]),\n  1975\t                \"units\": str(template[\"units\"]),\n  1976\t                \"seed\": int(seed),\n  1977\t                \"baseline_family\": template.get(\"baseline_family\"),\n  1978\t                \"topology_condition\": template.get(\"topology_condition\"),\n  1979\t                \"value\": _rounded_float(float(np.mean(values, dtype=np.float64))),\n  1980\t                \"component_values\": component_values,\n  1981\t                \"source_detail_count\": len(items),\n  1982\t                \"source_condition_signatures\": sorted(\n  1983\t                    {\n  1984\t                        str(item[\"condition_signature\"])\n  1985\t                        for item in items\n  1986\t                        if item.get(\"condition_signature\") is not None\n  1987\t                    }\n  1988\t                ),\n  1989\t                \"source_pairing_keys\": sorted(\n  1990\t                    {\n  1991\t                        str(item[\"pairing_key\"])\n  1992\t                        for item in items\n  1993\t                        if item.get(\"pairing_key\") is not None\n  1994\t                    }\n  1995\t                ),\n  1996\t                \"source_component_group_ids\": list(template.get(\"component_group_ids\", [])),\n  1997\t            }\n  1998\t        )\n  1999\t    return rows\n  2000\t\n  2001\t\n  2002\tdef _build_group_metric_rollups(\n  2003\t    *,\n  2004\t    group_metric_seed_rows: Sequence[Mapping[str, Any]],\n  2005\t    expected_seeds_by_group_id: Mapping[str, Sequence[int]],\n  2006\t    analysis_plan: Mapping[str, Any],\n  2007\t) -> list[dict[str, Any]]:\n  2008\t    rule_by_id = {\n  2009\t        str(item[\"rule_id\"]): copy.deepcopy(dict(item))\n  2010\t        for item in analysis_plan[\"seed_aggregation_rules\"]\n  2011\t    }\n  2012\t    grouped: dict[tuple[str, str], list[dict[str, Any]]] = {}\n  2013\t    for item in group_metric_seed_rows:\n  2014\t        grouped.setdefault(\n  2015\t            (str(item[\"group_id\"]), str(item[\"metric_id\"])),\n  2016\t            [],\n  2017\t        ).append(copy.deepcopy(dict(item)))\n  2018\t    rows: list[dict[str, Any]] = []\n  2019\t    for (group_id, metric_id), items in grouped.items():\n  2020\t        items.sort(key=lambda item: int(item[\"seed\"]))\n  2021\t        expected_seeds = [int(seed) for seed in expected_seeds_by_group_id[group_id]]\n  2022\t        if [int(item[\"seed\"]) for item in items] != expected_seeds:\n  2023\t            raise ValueError(\n  2024\t                f\"Experiment comparison aggregation requires complete seed coverage for \"\n  2025\t                f\"group_id {group_id!r} metric_id {metric_id!r}; expected {expected_seeds!r}, \"\n  2026\t                f\"got {[int(item['seed']) for item in items]!r}.\"\n  2027\t            )\n  2028\t        values = np.asarray([float(item[\"value\"]) for item in items], dtype=np.float64)\n  2029\t        component_names = sorted(\n  2030\t            {\n  2031\t                str(component_name)\n  2032\t                for item in items\n  2033\t                for component_name in item.get(\"component_values\", {})\n  2034\t            }\n  2035\t        )\n  2036\t        component_stats = {\n  2037\t            component_name: _summary_statistics(\n  2038\t                np.asarray(\n  2039\t                    [float(item[\"component_values\"][component_name]) for item in items],\n  2040\t                    dtype=np.float64,\n  2041\t                )\n  2042\t            )\n  2043\t            for component_name in component_names\n  2044\t        }\n  2045\t        signs = [_value_sign(float(item[\"value\"])) for item in items]\n  2046\t        sign_consistency = len({sign for sign in signs if sign != \"zero\"}) <= 1\n  2047\t        aggregation_rule_id = (\n  2048\t            MANIFEST_SEED_SWEEP_ROLLUP_RULE_ID\n  2049\t            if len(expected_seeds) > 1\n  2050\t            else PER_RUN_SINGLE_SEED_RULE_ID\n  2051\t        )\n  2052\t        if aggregation_rule_id not in rule_by_id:\n  2053\t            raise ValueError(\n  2054\t                f\"Missing seed aggregation rule {aggregation_rule_id!r} required for \"\n  2055\t                f\"group_id {group_id!r}.\"\n  2056\t            )\n  2057\t        template = items[0]\n  2058\t        rows.append(\n  2059\t            {\n  2060\t                \"group_id\": group_id,\n  2061\t                \"group_kind\": str(template[\"group_kind\"]),\n  2062\t                \"comparison_semantics\": str(template[\"comparison_semantics\"]),\n  2063\t                \"metric_id\": metric_id,\n  2064\t                \"readout_id\": str(template[\"readout_id\"]),\n  2065\t                \"window_id\": str(template[\"window_id\"]),\n  2066\t                \"statistic\": str(template[\"statistic\"]),\n  2067\t                \"units\": str(template[\"units\"]),\n  2068\t                \"seed_aggregation_rule_id\": aggregation_rule_id,\n  2069\t                \"seed_count\": len(expected_seeds),\n  2070\t                \"seeds\": expected_seeds,\n  2071\t                \"baseline_family\": template.get(\"baseline_family\"),\n  2072\t                \"topology_condition\": template.get(\"topology_condition\"),\n  2073\t                \"summary_statistics\": _summary_statistics(values),\n  2074\t                \"component_statistics\": component_stats,\n  2075\t                \"sign_consistency\": bool(sign_consistency),\n  2076\t                \"effect_direction\": _value_sign(float(np.mean(values, dtype=np.float64))),\n  2077\t            }\n  2078\t        )\n  2079\t    return rows\n  2080\t\n  2081\t\n  2082\tdef _summary_statistics(values: np.ndarray) -> dict[str, float]:\n  2083\t    if values.ndim != 1 or values.size < 1:\n  2084\t        raise ValueError(\"summary statistics require a non-empty 1D array.\")\n  2085\t    return {\n  2086\t        \"mean\": _rounded_float(float(np.mean(values, dtype=np.float64))),\n  2087\t        \"median\": _rounded_float(float(np.median(values))),\n  2088\t        \"min\": _rounded_float(float(np.min(values))),\n  2089\t        \"max\": _rounded_float(float(np.max(values))),\n  2090\t        \"std\": _rounded_float(float(np.std(values, dtype=np.float64))),\n  2091\t    }\n  2092\t\n  2093\t\n  2094\tdef _build_wave_metric_seed_rows(\n  2095\t    metric_rows: Sequence[Mapping[str, Any]],\n  2096\t) -> list[dict[str, Any]]:\n  2097\t    grouped: dict[tuple[str, str, int], list[dict[str, Any]]] = {}\n  2098\t    for item in metric_rows:\n  2099\t        key = (str(item[\"arm_id\"]), str(item[\"metric_id\"]), int(item[\"seed\"]))\n  2100\t        grouped.setdefault(key, []).append(copy.deepcopy(dict(item)))\n  2101\t    rows: list[dict[str, Any]] = []\n  2102\t    for (arm_id, metric_id, seed), items in grouped.items():\n  2103\t        values = np.asarray([float(item[\"value\"]) for item in items], dtype=np.float64)\n  2104\t        rows.append(\n  2105\t            {\n  2106\t                \"arm_id\": arm_id,\n  2107\t                \"metric_id\": metric_id,\n  2108\t                \"seed\": int(seed),\n  2109\t                \"value\": _rounded_float(float(np.mean(values, dtype=np.float64))),\n  2110\t                \"units\": str(items[0][\"units\"]),\n  2111\t                \"source_row_count\": len(items),\n  2112\t            }\n  2113\t        )\n  2114\t    return rows\n  2115\t\n  2116\t\n  2117\tdef _build_wave_metric_rollups(\n  2118\t    wave_metric_seed_rows: Sequence[Mapping[str, Any]],\n  2119\t) -> list[dict[str, Any]]:\n  2120\t    grouped: dict[tuple[str, str], list[dict[str, Any]]] = {}\n  2121\t    for item in wave_metric_seed_rows:\n  2122\t        grouped.setdefault((str(item[\"arm_id\"]), str(item[\"metric_id\"])), []).append(\n  2123\t            copy.deepcopy(dict(item))\n  2124\t        )\n  2125\t    rows: list[dict[str, Any]] = []\n  2126\t    for (arm_id, metric_id), items in grouped.items():\n  2127\t        items.sort(key=lambda item: int(item[\"seed\"]))\n  2128\t        values = np.asarray([float(item[\"value\"]) for item in items], dtype=np.float64)\n  2129\t        rows.append(\n  2130\t            {\n  2131\t                \"arm_id\": arm_id,\n  2132\t                \"metric_id\": metric_id,\n  2133\t                \"seed_count\": len(items),\n  2134\t                \"seeds\": [int(item[\"seed\"]) for item in items],\n  2135\t                \"units\": str(items[0][\"units\"]),\n  2136\t                \"summary_statistics\": _summary_statistics(values),\n  2137\t            }\n  2138\t        )\n  2139\t    return rows\n  2140\t\n  2141\t\n  2142\tdef _evaluate_null_tests(\n  2143\t    *,\n  2144\t    analysis_plan: Mapping[str, Any],\n  2145\t    group_metric_seed_rows: Sequence[Mapping[str, Any]],\n  2146\t    group_metric_rollups: Sequence[Mapping[str, Any]],\n  2147\t    shared_result: Mapping[str, Any],\n  2148\t    task_result: Mapping[str, Any],\n  2149\t    wave_result: Mapping[str, Any],\n  2150\t) -> list[dict[str, Any]]:\n  2151\t    seed_rows_by_group_metric: dict[tuple[str, str], list[dict[str, Any]]] = {}\n  2152\t    for item in group_metric_seed_rows:\n  2153\t        seed_rows_by_group_metric.setdefault(\n  2154\t            (str(item[\"group_id\"]), str(item[\"metric_id\"])),\n  2155\t            [],\n  2156\t        ).append(copy.deepcopy(dict(item)))\n  2157\t    rollups_by_group_metric = {\n  2158\t        (str(item[\"group_id\"]), str(item[\"metric_id\"])): copy.deepcopy(dict(item))\n  2159\t        for item in group_metric_rollups\n  2160\t    }\n  2161\t    shared_metric_rows = [copy.deepcopy(dict(item)) for item in shared_result.get(\"metric_rows\", [])]\n  2162\t    task_metric_rows = [copy.deepcopy(dict(item)) for item in task_result.get(\"metric_rows\", [])]\n  2163\t    wave_diagnostic_summaries = [\n  2164\t        copy.deepcopy(dict(item)) for item in wave_result.get(\"diagnostic_summaries\", [])\n  2165\t    ]\n  2166\t\n  2167\t    results: list[dict[str, Any]] = []\n  2168\t    for declaration in analysis_plan[\"null_test_declarations\"]:\n  2169\t        null_test_id = str(declaration[\"null_test_id\"])\n  2170\t        if null_test_id == \"geometry_shuffle_collapse\":\n  2171\t            results.append(\n  2172\t                _evaluate_geometry_shuffle_collapse(\n  2173\t                    declaration=declaration,\n  2174\t                    rollups_by_group_metric=rollups_by_group_metric,\n  2175\t                )\n  2176\t            )\n  2177\t        elif null_test_id == \"stronger_baseline_survival\":\n  2178\t            results.append(\n  2179\t                _evaluate_stronger_baseline_survival(\n  2180\t                    declaration=declaration,\n  2181\t                    rollups_by_group_metric=rollups_by_group_metric,\n  2182\t                )\n  2183\t            )\n  2184\t        elif null_test_id == \"seed_stability\":\n  2185\t            results.append(\n  2186\t                _evaluate_seed_stability(\n  2187\t                    declaration=declaration,\n  2188\t                    seed_rows_by_group_metric=seed_rows_by_group_metric,\n  2189\t                )\n  2190\t            )\n  2191\t        elif null_test_id == \"polarity_label_swap\":\n  2192\t            results.append(\n  2193\t                _evaluate_polarity_label_swap(\n  2194\t                    declaration=declaration,\n  2195\t                    shared_metric_rows=shared_metric_rows,\n  2196\t                )\n  2197\t            )\n  2198\t        elif null_test_id == \"direction_label_swap\":\n  2199\t            results.append(\n  2200\t                _evaluate_direction_label_swap(\n  2201\t                    declaration=declaration,\n  2202\t                    task_metric_rows=task_metric_rows,\n  2203\t                )\n  2204\t            )\n  2205\t        elif null_test_id == \"wave_artifact_presence_guard\":\n  2206\t            results.append(\n  2207\t                _evaluate_wave_artifact_presence_guard(\n  2208\t                    declaration=declaration,\n  2209\t                    wave_diagnostic_summaries=wave_diagnostic_summaries,\n  2210\t                )\n  2211\t            )\n  2212\t        else:\n  2213\t            raise ValueError(f\"Unsupported null_test_id {null_test_id!r}.\")\n  2214\t    return results\n  2215\t\n  2216\t\n  2217\tdef _evaluate_geometry_shuffle_collapse(\n  2218\t    *,\n  2219\t    declaration: Mapping[str, Any],\n  2220\t    rollups_by_group_metric: Mapping[tuple[str, str], Mapping[str, Any]],\n  2221\t) -> dict[str, Any]:\n  2222\t    metric_outcomes: list[dict[str, Any]] = []\n  2223\t    for group_id in declaration[\"comparison_group_ids\"]:\n  2224\t        for metric_id in declaration[\"required_metric_ids\"]:\n  2225\t            rollup = rollups_by_group_metric.get((str(group_id), str(metric_id)))\n  2226\t            if rollup is None:\n  2227\t                metric_outcomes.append(\n  2228\t                    {\n  2229\t                        \"group_id\": str(group_id),\n  2230\t                        \"metric_id\": str(metric_id),\n  2231\t                        \"status\": \"unavailable\",\n  2232\t                        \"reason\": \"missing_group_metric_rollup\",\n  2233\t                    }\n  2234\t                )\n  2235\t                continue\n  2236\t            intact_mean = rollup[\"component_statistics\"].get(\"intact\", {}).get(\"mean\")\n  2237\t            shuffled_mean = rollup[\"component_statistics\"].get(\"shuffled\", {}).get(\"mean\")\n  2238\t            if intact_mean is None or shuffled_mean is None:\n  2239\t                metric_outcomes.append(\n  2240\t                    {\n  2241\t                        \"group_id\": str(group_id),\n  2242\t                        \"metric_id\": str(metric_id),\n  2243\t                        \"status\": \"unavailable\",\n  2244\t                        \"reason\": \"missing_component_statistics\",\n  2245\t                    }\n  2246\t                )\n  2247\t                continue\n  2248\t            passed = abs(float(intact_mean)) > abs(float(shuffled_mean)) + _EFFECT_ABS_TOLERANCE\n  2249\t            metric_outcomes.append(\n  2250\t                {\n  2251\t                    \"group_id\": str(group_id),\n  2252\t                    \"metric_id\": str(metric_id),\n  2253\t                    \"status\": \"pass\" if passed else \"fail\",\n  2254\t                    \"intact_mean\": intact_mean,\n  2255\t                    \"shuffled_mean\": shuffled_mean,\n  2256\t                    \"geometry_gap_mean\": rollup[\"summary_statistics\"][\"mean\"],\n  2257\t                }\n  2258\t            )\n  2259\t    return _null_test_result(\n  2260\t        declaration=declaration,\n  2261\t        metric_outcomes=metric_outcomes,\n  2262\t    )\n  2263\t\n  2264\t\n  2265\tdef _evaluate_stronger_baseline_survival(\n  2266\t    *,\n  2267\t    declaration: Mapping[str, Any],\n  2268\t    rollups_by_group_metric: Mapping[tuple[str, str], Mapping[str, Any]],\n  2269\t) -> dict[str, Any]:\n  2270\t    metric_outcomes: list[dict[str, Any]] = []\n  2271\t    for group_id in declaration[\"comparison_group_ids\"]:\n  2272\t        for metric_id in declaration[\"required_metric_ids\"]:\n  2273\t            rollup = rollups_by_group_metric.get((str(group_id), str(metric_id)))\n  2274\t            if rollup is None:\n  2275\t                metric_outcomes.append(\n  2276\t                    {\n  2277\t                        \"group_id\": str(group_id),\n  2278\t                        \"metric_id\": str(metric_id),\n  2279\t                        \"status\": \"unavailable\",\n  2280\t                        \"reason\": \"missing_group_metric_rollup\",\n  2281\t                    }\n  2282\t                )\n  2283\t                continue\n  2284\t            p0_mean = rollup[\"component_statistics\"].get(\"p0_reference\", {}).get(\"mean\")\n  2285\t            p1_mean = rollup[\"component_statistics\"].get(\"p1_challenge\", {}).get(\"mean\")\n  2286\t            if p0_mean is None or p1_mean is None:\n  2287\t                metric_outcomes.append(\n  2288\t                    {\n  2289\t                        \"group_id\": str(group_id),\n  2290\t                        \"metric_id\": str(metric_id),\n  2291\t                        \"status\": \"unavailable\",\n  2292\t                        \"reason\": \"missing_component_statistics\",\n  2293\t                    }\n  2294\t                )\n  2295\t                continue\n  2296\t            both_collapsed = (\n  2297\t                abs(float(p0_mean)) <= _EFFECT_ABS_TOLERANCE\n  2298\t                and abs(float(p1_mean)) <= _EFFECT_ABS_TOLERANCE\n  2299\t            )\n  2300\t            same_sign = _same_effect_direction(float(p0_mean), float(p1_mean))\n  2301\t            survives = both_collapsed or (\n  2302\t                abs(float(p1_mean)) > _EFFECT_ABS_TOLERANCE and same_sign\n  2303\t            )\n  2304\t            metric_outcomes.append(\n  2305\t                {\n  2306\t                    \"group_id\": str(group_id),\n  2307\t                    \"metric_id\": str(metric_id),\n  2308\t                    \"status\": \"pass\" if survives else \"fail\",\n  2309\t                    \"p0_reference_mean\": p0_mean,\n  2310\t                    \"p1_challenge_mean\": p1_mean,\n  2311\t                    \"delta_from_reference_mean\": rollup[\"component_statistics\"][\"delta_from_reference\"][\"mean\"],\n  2312\t                    \"both_collapsed\": bool(both_collapsed),\n  2313\t                }\n  2314\t            )\n  2315\t    return _null_test_result(\n  2316\t        declaration=declaration,\n  2317\t        metric_outcomes=metric_outcomes,\n  2318\t    )\n  2319\t\n  2320\t\n  2321\tdef _evaluate_seed_stability(\n  2322\t    *,\n  2323\t    declaration: Mapping[str, Any],\n  2324\t    seed_rows_by_group_metric: Mapping[tuple[str, str], Sequence[Mapping[str, Any]]],\n  2325\t) -> dict[str, Any]:\n  2326\t    metric_outcomes: list[dict[str, Any]] = []\n  2327\t    for group_id in declaration[\"comparison_group_ids\"]:\n  2328\t        for metric_id in declaration[\"required_metric_ids\"]:\n  2329\t            seed_rows = list(seed_rows_by_group_metric.get((str(group_id), str(metric_id)), []))\n  2330\t            if not seed_rows:\n  2331\t                metric_outcomes.append(\n  2332\t                    {\n  2333\t                        \"group_id\": str(group_id),\n  2334\t                        \"metric_id\": str(metric_id),\n  2335\t                        \"status\": \"unavailable\",\n  2336\t                        \"reason\": \"missing_seed_rows\",\n  2337\t                    }\n  2338\t                )\n  2339\t                continue\n  2340\t            nonzero_signs = {\n  2341\t                _value_sign(float(item[\"value\"])) for item in seed_rows if _value_sign(float(item[\"value\"])) != \"zero\"\n  2342\t            }\n  2343\t            consistent = bool(nonzero_signs) and len(nonzero_signs) == 1\n  2344\t            metric_outcomes.append(\n  2345\t                {\n  2346\t                    \"group_id\": str(group_id),\n  2347\t                    \"metric_id\": str(metric_id),\n  2348\t                    \"status\": \"pass\" if consistent else \"fail\",\n  2349\t                    \"seed_values\": [\n  2350\t                        {\n  2351\t                            \"seed\": int(item[\"seed\"]),\n  2352\t                            \"value\": item[\"value\"],\n  2353\t                        }\n  2354\t                        for item in seed_rows\n  2355\t                    ],\n  2356\t                }\n  2357\t            )\n  2358\t    return _null_test_result(\n  2359\t        declaration=declaration,\n  2360\t        metric_outcomes=metric_outcomes,\n  2361\t    )\n  2362\t\n  2363\t\n  2364\tdef _evaluate_polarity_label_swap(\n  2365\t    *,\n  2366\t    declaration: Mapping[str, Any],\n  2367\t    shared_metric_rows: Sequence[Mapping[str, Any]],\n  2368\t) -> dict[str, Any]:\n  2369\t    relevant_rows = [\n  2370\t        copy.deepcopy(dict(item))\n  2371\t        for item in shared_metric_rows\n  2372\t        if str(item[\"metric_id\"]) == \"on_off_selectivity_index\"\n  2373\t    ]\n  2374\t    status = \"pass\" if relevant_rows else \"unavailable\"\n  2375\t    metric_outcomes = [\n  2376\t        {\n  2377\t            \"group_id\": None,\n  2378\t            \"metric_id\": \"on_off_selectivity_index\",\n  2379\t            \"status\": status,\n  2380\t            \"observed_row_count\": len(relevant_rows),\n  2381\t        }\n  2382\t    ]\n  2383\t    return _null_test_result(declaration=declaration, metric_outcomes=metric_outcomes)\n  2384\t\n  2385\t\n  2386\tdef _evaluate_direction_label_swap(\n  2387\t    *,\n  2388\t    declaration: Mapping[str, Any],\n  2389\t    task_metric_rows: Sequence[Mapping[str, Any]],\n  2390\t) -> dict[str, Any]:\n  2391\t    relevant_rows = [\n  2392\t        copy.deepcopy(dict(item))\n  2393\t        for item in task_metric_rows\n  2394\t        if str(item[\"metric_id\"]) in set(declaration[\"required_metric_ids\"])\n  2395\t    ]\n  2396\t    status = \"pass\" if relevant_rows else \"unavailable\"\n  2397\t    metric_outcomes = [\n  2398\t        {\n  2399\t            \"group_id\": None,\n  2400\t            \"metric_id\": metric_id,\n  2401\t            \"status\": status,\n  2402\t            \"observed_row_count\": len(\n  2403\t                [item for item in relevant_rows if str(item[\"metric_id\"]) == str(metric_id)]\n  2404\t            ),\n  2405\t        }\n  2406\t        for metric_id in declaration[\"required_metric_ids\"]\n  2407\t    ]\n  2408\t    return _null_test_result(declaration=declaration, metric_outcomes=metric_outcomes)\n  2409\t\n  2410\t\n  2411\tdef _evaluate_wave_artifact_presence_guard(\n  2412\t    *,\n  2413\t    declaration: Mapping[str, Any],\n  2414\t    wave_diagnostic_summaries: Sequence[Mapping[str, Any]],\n  2415\t) -> dict[str, Any]:\n  2416\t    unavailable_count = sum(\n  2417\t        1 for item in wave_diagnostic_summaries if str(item[\"status\"]) != \"ok\"\n  2418\t    )\n  2419\t    metric_outcomes = [\n  2420\t        {\n  2421\t            \"group_id\": None,\n  2422\t            \"metric_id\": metric_id,\n  2423\t            \"status\": \"pass\",\n  2424\t            \"unavailable_summary_count\": unavailable_count,\n  2425\t        }\n  2426\t        for metric_id in declaration[\"required_metric_ids\"]\n  2427\t    ]\n  2428\t    return _null_test_result(declaration=declaration, metric_outcomes=metric_outcomes)\n  2429\t\n  2430\t\n  2431\tdef _null_test_result(\n  2432\t    *,\n  2433\t    declaration: Mapping[str, Any],\n  2434\t    metric_outcomes: Sequence[Mapping[str, Any]],\n  2435\t) -> dict[str, Any]:\n  2436\t    statuses = [str(item[\"status\"]) for item in metric_outcomes]\n  2437\t    if statuses and all(status == \"pass\