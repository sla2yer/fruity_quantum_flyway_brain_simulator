p.csr_matrix\n    55\t    patch_lap: sp.csr_matrix\n    56\t\n    57\t\n    58\tdef _optional_imports() -> tuple[Any, Any]:\n    59\t    try:\n    60\t        from fafbseg import flywire  # type: ignore\n    61\t    except Exception as exc:  # pragma: no cover\n    62\t        raise RuntimeError(\n    63\t            \"fafbseg is required for FlyWire mesh access. Install requirements.txt first.\"\n    64\t        ) from exc\n    65\t\n    66\t    try:\n    67\t        import navis  # type: ignore\n    68\t    except Exception as exc:  # pragma: no cover\n    69\t        raise RuntimeError(\n    70\t            \"navis is required for exporting skeletons. Install requirements.txt first.\"\n    71\t        ) from exc\n    72\t\n    73\t    return flywire, navis\n    74\t\n    75\t\n    76\tdef _faces_to_adjacency(faces: np.ndarray, n_vertices: int) -> sp.csr_matrix:\n    77\t    edges = set()\n    78\t    for tri in faces:\n    79\t        a, b, c = (int(tri[0]), int(tri[1]), int(tri[2]))\n    80\t        edges.add(tuple(sorted((a, b))))\n    81\t        edges.add(tuple(sorted((b, c))))\n    82\t        edges.add(tuple(sorted((a, c))))\n    83\t\n    84\t    if not edges:\n    85\t        raise ValueError(\"No edges could be built from faces.\")\n    86\t\n    87\t    rows = []\n    88\t    cols = []\n    89\t    for i, j in sorted(edges):\n    90\t        rows.extend([i, j])\n    91\t        cols.extend([j, i])\n    92\t\n    93\t    data = np.ones(len(rows), dtype=np.float32)\n    94\t    adj = sp.csr_matrix((data, (rows, cols)), shape=(n_vertices, n_vertices))\n    95\t    adj.eliminate_zeros()\n    96\t    adj.sort_indices()\n    97\t    return adj\n    98\t\n    99\t\n   100\tdef _uniform_laplacian(adj: sp.csr_matrix) -> sp.csr_matrix:\n   101\t    deg = np.asarray(adj.sum(axis=1)).ravel()\n   102\t    d = sp.diags(deg)\n   103\t    return d - adj\n   104\t\n   105\t\n   106\tdef _serialize_sparse_matrix(matrix: sp.csr_matrix) -> dict[str, np.ndarray]:\n   107\t    matrix = matrix.tocsr().astype(np.float32)\n   108\t    matrix.sort_indices()\n   109\t    return {\n   110\t        \"data\": matrix.data.astype(np.float32, copy=False),\n   111\t        \"indices\": matrix.indices.astype(np.int32, copy=False),\n   112\t        \"indptr\": matrix.indptr.astype(np.int32, copy=False),\n   113\t        \"shape\": np.asarray(matrix.shape, dtype=np.int32),\n   114\t    }\n   115\t\n   116\t\n   117\tdef _collect_patch_vertices(\n   118\t    adj: sp.csr_matrix,\n   119\t    *,\n   120\t    seed: int,\n   121\t    unassigned: np.ndarray,\n   122\t    patch_hops: int,\n   123\t    cap: int,\n   124\t) -> np.ndarray:\n   125\t    queue: deque[tuple[int, int]] = deque([(int(seed), 0)])\n   126\t    visited = {int(seed)}\n   127\t    patch_vertices: list[int] = []\n   128\t\n   129\t    while queue and len(patch_vertices) < cap:\n   130\t        vertex, distance = queue.popleft()\n   131\t        if not bool(unassigned[vertex]):\n   132\t            continue\n   133\t\n   134\t        patch_vertices.append(vertex)\n   135\t        if distance >= patch_hops:\n   136\t            continue\n   137\t\n   138\t        start = int(adj.indptr[vertex])\n   139\t        end = int(adj.indptr[vertex + 1])\n   140\t        for neighbor in adj.indices[start:end]:\n   141\t            neighbor_idx = int(neighbor)\n   142\t            if neighbor_idx in visited or not bool(unassigned[neighbor_idx]):\n   143\t                continue\n   144\t            visited.add(neighbor_idx)\n   145\t            queue.append((neighbor_idx, distance + 1))\n   146\t\n   147\t    return np.asarray(patch_vertices, dtype=np.int32)\n   148\t\n   149\t\n   150\tdef _build_patch_membership_arrays(patches: list[np.ndarray]) -> tuple[np.ndarray, np.ndarray]:\n   151\t    member_vertex_indptr = np.zeros(len(patches) + 1, dtype=np.int32)\n   152\t    if not patches:\n   153\t        return np.empty(0, dtype=np.int32), member_vertex_indptr\n   154\t\n   155\t    counts = np.asarray([int(patch.size) for patch in patches], dtype=np.int32)\n   156\t    member_vertex_indptr[1:] = np.cumsum(counts, dtype=np.int32)\n   157\t    member_vertex_indices = np.concatenate(patches).astype(np.int32, copy=False)\n   158\t    return member_vertex_indices, member_vertex_indptr\n   159\t\n   160\t\n   161\tdef _build_patch_adjacency(\n   162\t    adj: sp.csr_matrix,\n   163\t    surface_to_patch: np.ndarray,\n   164\t    *,\n   165\t    patch_count: int,\n   166\t) -> sp.csr_matrix:\n   167\t    if patch_count <= 0:\n   168\t        return sp.csr_matrix((0, 0), dtype=np.float32)\n   169\t\n   170\t    upper_edges = sp.triu(adj, k=1).tocoo()\n   171\t    edge_weights: dict[tuple[int, int], float] = {}\n   172\t    for row, col, weight in zip(upper_edges.row, upper_edges.col, upper_edges.data):\n   173\t        patch_u = int(surface_to_patch[int(row)])\n   174\t        patch_v = int(surface_to_patch[int(col)])\n   175\t        if patch_u == patch_v:\n   176\t            continue\n   177\t        if patch_u > patch_v:\n   178\t            patch_u, patch_v = patch_v, patch_u\n   179\t        edge_weights[(patch_u, patch_v)] = edge_weights.get((patch_u, patch_v), 0.0) + float(weight)\n   180\t\n   181\t    if not edge_weights:\n   182\t        return sp.csr_matrix((patch_count, patch_count), dtype=np.float32)\n   183\t\n   184\t    rows: list[int] = []\n   185\t    cols: list[int] = []\n   186\t    data: list[float] = []\n   187\t    for (patch_u, patch_v), weight in sorted(edge_weights.items()):\n   188\t        rows.extend([patch_u, patch_v])\n   189\t        cols.extend([patch_v, patch_u])\n   190\t        data.extend([weight, weight])\n   191\t\n   192\t    patch_adj = sp.csr_matrix(\n   193\t        (np.asarray(data, dtype=np.float32), (rows, cols)),\n   194\t        shape=(patch_count, patch_count),\n   195\t    )\n   196\t    patch_adj.eliminate_zeros()\n   197\t    patch_adj.sort_indices()\n   198\t    return patch_adj\n   199\t\n   200\t\n   201\tdef _partition_surface_into_patches(\n   202\t    adj: sp.csr_matrix,\n   203\t    vertices: np.ndarray,\n   204\t    *,\n   205\t    patch_hops: int,\n   206\t    patch_vertex_cap: int,\n   207\t) -> PatchDecomposition:\n   208\t    n_vertices = int(adj.shape[0])\n   209\t    if patch_hops < 0:\n   210\t        raise ValueError(\"patch_hops must be non-negative.\")\n   211\t    if patch_vertex_cap <= 0:\n   212\t        raise ValueError(\"patch_vertex_cap must be positive.\")\n   213\t    if n_vertices != int(vertices.shape[0]):\n   214\t        raise ValueError(\"Surface graph vertex count does not match vertex coordinates.\")\n   215\t\n   216\t    unassigned = np.ones(n_vertices, dtype=bool)\n   217\t    surface_to_patch = np.full(n_vertices, -1, dtype=np.int32)\n   218\t    patches: list[np.ndarray] = []\n   219\t    patch_seed_vertices: list[int] = []\n   220\t    patch_centroids: list[np.ndarray] = []\n","exit_code":0,"status":"completed"}}
