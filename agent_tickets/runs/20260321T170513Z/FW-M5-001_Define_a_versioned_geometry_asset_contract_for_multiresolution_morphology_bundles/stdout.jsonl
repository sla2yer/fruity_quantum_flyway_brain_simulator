paths\"]\n    50\t    meshing = cfg[\"meshing\"]\n    51\t    dataset = cfg[\"dataset\"].get(\"flywire_dataset\", \"public\")\n    52\t    materialization_version = cfg[\"dataset\"].get(\"materialization_version\")\n    53\t    registry_path = paths.get(\"neuron_registry_csv\", \"data/interim/registry/neuron_registry.csv\")\n    54\t\n    55\t    root_ids = read_root_ids(paths[\"selected_root_ids\"])\n    56\t    if not root_ids:\n    57\t        raise RuntimeError(\"No root IDs found. Run scripts/01_select_subset.py first.\")\n    58\t\n    59\t    registry_df = load_neuron_registry(registry_path)\n    60\t    validate_selected_root_ids(root_ids, registry_df, registry_path)\n    61\t\n    62\t    registry = registry_df.set_index(\"root_id\", drop=False)\n    63\t    manifest_records: dict[int, dict[str, object]] = {}\n    64\t    fetch_skeletons = bool(meshing.get(\"fetch_skeletons\", True))\n    65\t    for root_id in tqdm(root_ids, desc=\"Building wave assets\"):\n    66\t        bundle_paths = build_geometry_bundle_paths(\n    67\t            root_id,\n    68\t            meshes_raw_dir=paths[\"meshes_raw_dir\"],\n    69\t            skeletons_raw_dir=paths[\"skeletons_raw_dir\"],\n    70\t            processed_mesh_dir=paths[\"processed_mesh_dir\"],\n    71\t            processed_graph_dir=paths[\"processed_graph_dir\"],\n    72\t        )\n    73\t        if not bundle_paths.raw_mesh_path.exists():\n    74\t            raise FileNotFoundError(f\"Missing raw mesh for root_id={root_id}: {bundle_paths.raw_mesh_path}\")\n    75\t\n    76\t        registry_metadata: dict[str, object] = {}\n    77\t        if int(root_id) in registry.index:\n    78\t            row = registry.loc[int(root_id)]\n    79\t            if isinstance(row, pd.DataFrame):\n    80\t                row = row.iloc[0]\n    81\t            registry_metadata = {\n    82\t                key: _json_safe(value)\n    83\t                for key, value in row.to_dict().items()\n    84\t              