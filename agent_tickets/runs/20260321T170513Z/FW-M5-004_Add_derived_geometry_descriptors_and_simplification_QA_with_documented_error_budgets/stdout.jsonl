tch_decomposition.surface_to_patch.size),\n        \"patch_membership_index_count\": int(patch_decomposition.member_vertex_indices.size),\n        \"patch_hops\": int(patch_hops),\n        \"patch_vertex_cap\": int(patch_vertex_cap),\n        \"patch_generation_method\": \"deterministic_bfs_partition\",\n        \"simplify_target_faces\": int(simplify_target_faces),\n        \"raw_mesh_face_count\": original_face_count,\n        \"surface_area\": float(mesh.area),\n        \"volume\": float(mesh.volume),\n        \"bounds_min\": vertices.min(axis=0).tolist(),\n        \"bounds_max\": vertices.max(axis=0).tolist(),\n        \"raw_mesh_path\": str(bundle_paths.raw_mesh_path),\n        \"raw_skeleton_path\": str(bundle_paths.raw_skeleton_path),\n        \"processed_mesh_path\": str(bundle_paths.simplified_mesh_path),\n        \"surface_graph_path\": str(bundle_paths.surface_graph_path),\n        \"patch_graph_path\": str(bundle_paths.patch_graph_path),\n        \"registry_metadata\": registry_metadata or {},\n    }\n    write_json(descriptor_payload, bundle_paths.descriptor_sidecar_path)\n\n    qa_payload = {\n        \"root_id\": int(root_id),\n        \"raw_mesh_available\": bundle_paths.raw_mesh_path.exists(),\n        \"raw_skeleton_available\": bundle_paths.raw_skeleton_path.exists(),\n        \"simplified_mesh_available\": bundle_paths.simplified_mesh_path.exists(),\n        \"surface_graph_available\": bundle_paths.surface_graph_path.exists(),\n        \"patch_graph_available\": bundle_paths.patch_graph_path.exists(),\n        \"descriptor_sidecar_available\": bundle_paths.descriptor_sidecar_path.exists(),\n        \"is_watertight\": bool(mesh.is_watertight),\n        \"vertex_count_matches_surface_graph\": int(vertices.shape[0]) == int(adj.shape[0]),\n        \"patch_count\": int(patch_decomposition.patch_sizes.size),\n        \"patch_is_nonempty\": bool(patch_decomposition.patch_sizes.size),\n        \"surface_to_patch_length_matches_vertex_count\": int(patch_