ormalize_identifier(state[\"id\"], field_name=\"output_bundle.ui_states.id\"),\n  3216\t                \"path\": str(_resolve_project_path(state[\"path\"], project_root)),\n  3217\t            }\n  3218\t        )\n  3219\t    return {\n  3220\t        \"metrics_json\": str(_resolve_project_path(output_bundle[\"metrics_json\"], project_root)),\n  3221\t        \"summary_table_csv\": str(\n  3222\t            _resolve_project_path(output_bundle[\"summary_table_csv\"], project_root)\n  3223\t        ),\n  3224\t        \"plots\": plots,\n  3225\t        \"ui_states\": ui_states,\n  3226\t    }\n  3227\t\n  3228\t\n  3229\tdef _resolve_arm_seed_handling(\n  3230\t    *,\n  3231\t    arm: Mapping[str, Any],\n  3232\t    arm_index: int,\n  3233\t    manifest_random_seed: int,\n  3234\t    seed_sweep: list[int],\n  3235\t) -> dict[str, Any]:\n  3236\t    arm_seed = arm.get(\"random_seed\")\n  3237\t    if arm_seed is None:\n  3238\t        default_seed = int(manifest_random_seed)\n  3239\t        seed_source = \"manifest.random_seed\"\n  3240\t    else:\n  3241\t        default_seed = int(arm_seed)\n  3242\t        seed_source = f\"comparison_arms[{arm_index}].random_seed\"\n  3243\t    return {\n  3244\t        \"default_seed\": default_seed,\n  3245\t        \"default_seed_source\": seed_source,\n  3246\t        \"manifest_random_seed\": int(manifest_random_seed),\n  3247\t        \"seed_sweep\": list(seed_sweep),\n  3248\t        \"seed_sweep_ordering\": DEFAULT_SEED_SWEEP_ORDERING,\n  3249\t    }\n  3250\t\n  3251\t\n  3252\tdef _build_model_configuration(\n  3253\t    *,\n  3254\t    arm_reference: Mapping[str, Any],\n  3255\t    arm_payload: Mapping[str, Any],\n  3256\t    runtime_config: Mapping[str, Any],\n  3257\t    circuit_assets: Mapping[str, Any],\n  3258\t    topology_condition: str,\n  3259\t) -> dict[str, Any]:\n  3260\t    model_mode = str(arm_reference[\"model_mode\"])\n  3261\t    baseline_family = arm_reference.get(\"baseline_family\")\n  3262\t    if model_mode == BASELINE_MODEL_MODE:\n  3263\t        assert isinstance(baseline_family, str)\n  3264\t        return {\n  3265\t            \"model_mode\": model_mode,\n  3266\t            \"baseline_family\": baseline_family,\n  3267\t            \"baseline_parameters\": copy.deepcopy(\n  3268\t                runtime_config[\"baseline_families\"][baseline_family]\n  3269\t            ),\n  3270\t        }\n  3271\t    surface_wave_model = copy.deepcopy(runtime_config[\"surface_wave_model\"])\n  3272\t    return {\n  3273\t        \"model_mode\": model_mode,\n  3274\t        \"baseline_family\": None,\n  3275\t        \"baseline_parameters\": None,\n  3276\t        \"surface_wave_model\": surface_wave_model,\n  3277\t        \"surface_wave_reference\": build_surface_wave_model_reference(surface_wave_model),\n  3278\t        \"surface_wave_execution_plan\": _build_surface_wave_execution_plan(\n  3279\t            arm_reference=arm_reference,\n  3280\t            arm_payload=arm_payload,\n  3281\t            point_neuron_model_spec=runtime_config[\"baseline_families\"][P0_BASELINE_FAMILY],\n  3282\t            topology_condition=topology_condition,\n  3283\t            runtime_timebase=runtime_config[\"timebase\"],\n  3284\t            circuit_assets=circuit_assets,\n  3285\t            surface_wave_model=surface_wave_model,\n  3286\t            mixed_fidelity_config=runtime_config[\"mixed_fidelity\"],\n  3287\t        ),\n  3288\t    }\n  3289\t\n  3290\t\n  3291\tdef _build_selected_assets(\n  3292\t    *,\n  3293\t    selection_reference: Mapping[str, Any],\n  3294\t    input_reference: Mapping[str, Any],\n  3295\t    circuit_assets: Mapping[str, Any],\n  3296\t    arm_reference: Mapping[str, Any],\n  3297\t    model_configuration: Mapping[str, Any],\n  3298\t    config_path: Path,\n  3299\t) -> list[dict[str, Any]]:\n  3300\t    selected_input_reference = input_reference[\"selected_input_reference\"]\n  3301\t    selected_input_kind = str(input_reference[\"selected_input_kind\"])\n  3302\t    selected_assets = [\n  3303\t        build_selected_asset_reference(\n  3304\t            asset_role=SELECTED_ROOT_IDS_ASSET_ROLE,\n  3305\t            artifact_type=\"root_id_roster\",\n  3306\t            path=selection_reference[\"selected_root_ids_path\"],\n  3307\t            contract_version=None,\n  3308\t            artifact_id=f\"root_id_roster:{selection_reference['selected_root_ids_hash']}\",\n  3309\t            bundle_id=None,\n  3310\t        ),\n  3311\t        build_selected_asset_reference(\n  3312\t            asset_role=INPUT_BUNDLE_ASSET_ROLE,\n  3313\t            artifact_type=selected_input_kind,\n  3314\t            path=input_reference[\"selected_input_metadata_path\"],\n  3315\t            contract_version=selected_input_reference[\"contract_version\"],\n  3316\t            artifact_id=selected_input_reference[\"bundle_id\"],\n  3317\t            bundle_id=selected_input_reference[\"bundle_id\"],\n  3318\t        ),\n  3319\t        build_selected_asset_reference(\n  3320\t            asset_role=GEOMETRY_MANIFEST_ASSET_ROLE,\n  3321\t            artifact_type=\"geometry_bundle_manifest\",\n  3322\t            path=circuit_assets[\"geometry_manifest_path\"],\n  3323\t            contract_version=circuit_assets[\"geometry_contract_version\"],\n  3324\t            artifact_id=f\"geometry_manifest:{circuit_assets['circuit_asset_hash']}\",\n  3325\t            bundle_id=None,\n  3326\t        ),\n  3327\t        build_selected_asset_reference(\n  3328\t            asset_role=COUPLING_REGISTRY_ASSET_ROLE,\n  3329\t            artifact_type=\"synapse_registry_csv\",\n  3330\t            path=circuit_assets[\"local_synapse_registry_path\"],\n  3331\t            contract_version=circuit_assets[\"coupling_contract_version\"],\n  3332\t            artifact_id=f\"coupling_synapse_registry:{circuit_assets['circuit_asset_hash']}\",\n  3333\t            bundle_id=None,\n  3334\t        ),\n  3335\t        _build_model_configuration_asset_reference(\n  3336\t            arm_reference=arm_reference,\n  3337\t            model_configuration=model_configuration,\n  3338\t            config_path=config_path,\n  3339\t        ),\n  3340\t    ]\n  3341\t    if str(arm_reference[\"model_mode\"]) == SURFACE_WAVE_MODEL_MODE:\n  3342\t        selected_assets.append(\n  3343\t            build_selected_asset_reference(\n  3344\t                asset_role=SURFACE_WAVE_OPERATOR_INVENTORY_ASSET_ROLE,\n  3345\t                artifact_type=\"surface_wave_operator_inventory\",\n  3346\t                path=circuit_assets[\"geometry_manifest_path\"],\n  3347\t                contract_version=circuit_assets[\"operator_contract_version\"],\n  3348\t                artifact_id=(\n  3349\t                    f\"surface_wave_operator_inventory:{circuit_assets['operator_asset_hash']}\"\n  3350\t                ),\n  3351\t                bundle_id=None,\n  3352\t            )\n  3353\t        )\n  3354\t    return selected_assets\n  3355\t\n  3356\t\n  3357\tdef _build_model_configuration_asset_reference(\n  3358\t    *,\n  3359\t    arm_reference: Mapping[str, Any],\n  3360\t    model_configuration: Mapping[str, Any],\n  3361\t    config_path: Path,\n  3362\t) -> dict[str, Any]:\n  3363\t    model_mode = str(arm_reference[\"model_mode\"])\n  3364\t    if model_mode == BASELINE_MODEL_MODE:\n  3365\t        artifact_type = \"baseline_model_configuration\"\n  3366\t        artifact_payload = {\n  3367\t            \"model_mode\": model_mode,\n  3368\t            \"baseline_family\": arm_reference[\"baseline_family\"],\n  3369\t            \"baseline_parameters\": model_configuration[\"baseline_parameters\"],\n  3370\t        }\n  3371\t    else:\n  3372\t        artifact_type = \"surface_wave_model_configuration\"\n  3373\t        surface_wave_execution_plan = _require_mapping(\n  3374\t            model_configuration.get(\"surface_wave_execution_plan\"),\n  3375\t            field_name=\"model_configuration.surface_wave_execution_plan\",\n  3376\t        )\n  3377\t        artifact_payload = {\n  3378\t            \"model_mode\": model_mode,\n  3379\t            \"surface_wave_reference\": model_configuration[\"surface_wave_reference\"],\n  3380\t            \"surface_wave_model\": model_configuration[\"surface_wave_model\"],\n  3381\t            \"topology_condition\": surface_wave_execution_plan[\"topology_condition\"],\n  3382\t            \"resolution\": copy.deepcopy(surface_wave_execution_plan[\"resolution\"]),\n  3383\t            \"hybrid_morphology\": copy.deepcopy(\n  3384\t                surface_wave_execution_plan[\"hybrid_morphology\"]\n  3385\t            ),\n  3386\t            \"mixed_fidelity\": copy.deepcopy(\n  3387\t                surface_wave_execution_plan[\"mixed_fidelity\"]\n  3388\t            ),\n  3389\t        }\n  3390\t        if isinstance(model_configuration.get(\"ablation_transform\"), Mapping):\n  3391\t            artifact_payload[\"ablation_transform\"] = copy.deepcopy(\n  3392\t                dict(\n  3393\t                    _require_mapping(\n  3394\t                        model_configuration.get(\"ablation_transform\"),\n  3395\t                        field_name=\"model_configuration.ablation_transform\",\n  3396\t                    )\n  3397\t                )\n  3398\t            )\n  3399\t    return build_selected_asset_reference(\n  3400\t        asset_role=MODEL_CONFIGURATION_ASSET_ROLE,\n  3401\t        artifact_type=artifact_type,\n  3402\t        path=config_path,\n  3403\t        contract_version=SIMULATION_RUNTIME_CONFIG_VERSION,\n  3404\t        artifact_id=f\"{artifact_type}:{_stable_hash(artifact_payload)}\",\n  3405\t        bundle_id=None,\n  3406\t    )\n  3407\t\n  3408\t\n  3409\tdef _build_surface_wave_execution_plan(\n  3410\t    *,\n  3411\t    arm_reference: Mapping[str, Any],\n  3412\t    arm_payload: Mapping[str, Any] | None = None,\n  3413\t    point_neuron_model_spec: Mapping[str, Any],\n  3414\t   