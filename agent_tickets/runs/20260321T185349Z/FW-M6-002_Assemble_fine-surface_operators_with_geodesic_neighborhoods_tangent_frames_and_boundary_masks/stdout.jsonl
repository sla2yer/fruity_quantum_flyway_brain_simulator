    COARSE_OPERATOR_KEY: self.coarse_operator_path,\n   104\t            TRANSFER_OPERATORS_KEY: self.transfer_operator_path,\n   105\t            OPERATOR_METADATA_KEY: self.operator_metadata_path,\n   106\t        }\n   107\t\n   108\t\n   109\tdef build_geometry_bundle_paths(\n   110\t    root_id: int,\n   111\t    *,\n   112\t    meshes_raw_dir: str | Path,\n   113\t    skeletons_raw_dir: str | Path,\n   114\t    processed_mesh_dir: str | Path,\n   115\t    processed_graph_dir: str | Path,\n   116\t) -> GeometryBundlePaths:\n   117\t    root_label = str(int(root_id))\n   118\t    raw_mesh_dir = Path(meshes_raw_dir).resolve()\n   119\t    raw_skeleton_dir = Path(skeletons_raw_dir).resolve()\n   120\t    mesh_dir = Path(processed_mesh_dir).resolve()\n   121\t    graph_dir = Path(processed_graph_dir).resolve()\n   122\t    return GeometryBundlePaths(\n   123\t        root_id=int(root_id),\n   124\t        raw_mesh_path=raw_mesh_dir / f\"{root_label}.ply\",\n   125\t        raw_skeleton_path=raw_skeleton_dir / f\"{root_label}.swc\",\n   126\t        simplified_mesh_path=mesh_dir / f\"{root_label}.ply\",\n   127\t        surface_graph_path=graph_dir / f\"{root_label}_graph.npz\",\n   128\t        fine_operator_path=graph_dir / f\"{root_label}_fine_operator.npz\",\n   129\t        patch_graph_path=graph_dir / f\"{root_label}_patch_graph.npz\",\n   130\t        descriptor_sidecar_path=graph_dir / f\"{root_label}_descriptors.json\",\n   131\t        qa_sidecar_path=graph_dir / f\"{root_label}_qa.json\",\n   132\t        transfer_operator_path=graph_dir / f\"{root_label}_transfer_operators.npz\",\n   133\t        operator_metadata_path=graph_dir / f\"{root_label}_operator_metadata.json\",\n   134\t        legacy_meta_json_path=graph_dir / f\"{root_label}_meta.json\",\n   135\t    )\n   136\t\n   137\t\n   138\tdef default_asset_statuses(*, fetch_skeletons: bool) -> dict[str, str]:\n   139\t    return {\n   140\t        RAW_MESH_KEY: ASSET_STATUS_MISSING,\n   141\t       