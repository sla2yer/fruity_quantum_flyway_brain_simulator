d the declared filter set.\\\\\\\"\\\\n   344\\\\t        )\\\\n   345\\\\t    else:\\\\n   346\\\\t        if (\\\\n   347\\\\t            resolved_reduction_controls[\\\\\\\"allowed_cell_classes\\\\\\\"]\\\\n   348\\\\t            and node_metadata_df is None\\\\n   349\\\\t        ):\\\\n   350\\\\t            raise WholeBrainContextQueryError(\\\\n   351\\\\t                \\\\\\\"Whole-brain context query execution requires a local node metadata registry \\\\\\\"\\\\n   352\\\\t                \\\\\\\"to apply allowed_cell_classes filters.\\\\\\\"\\\\n   353\\\\t            )\\\\n   354\\\\t        adjacency = _build_adjacency(aggregated_edges)\\\\n   355\\\\t        traversal = _build_traversal_registry(\\\\n   356\\\\t            active_root_ids=active_root_ids,\\\\n   357\\\\t            active_root_set=active_root_set,\\\\n   358\\\\t            adjacency=adjacency,\\\\n   359\\\\t            query_family=query_family,\\\\n   360\\\\t            reduction_controls=resolved_reduction_controls,\\\\n   361\\\\t            metadata_by_root=metadata_by_root,\\\\n   362\\\\t        )\\\\n   363\\\\t        directional_membership = traversal[\\\\\\\"directional_membership\\\\\\\"]\\\\n   364\\\\t        selected_context_root_ids, selected_candidate_records, selected_required_edge_keys = (\\\\n   365\\\\t            _select_context_candidates(\\\\n   366\\\\t                traversal_registry=traversal[\\\\\\\"candidate_registry\\\\\\\"],\\\\n   367\\\\t                active_internal_edges=active_internal_edges,\\\\n   368\\\\t                reduction_controls=resolved_reduction_controls,\\\\n   369\\\\t                active_root_set=active_root_set,\\\\n   370\\\\t            )\\\\n   371\\\\t        )\\\\n   372\\\\t        selected_biological_edges = _select_biological_edges(\\\\n   373\\\\t            aggregated_edges=aggregated_edges,\\\\n   374\\\\t            active_root_set=active_root_set,\\\\n   375\\\\t            selected_context_root_ids=selected_c