\n  3785\t        operator_asset = None\n  3786\t        skeleton_runtime_asset = None\n  3787\t        if morphology_class == SURFACE_NEURON_CLASS:\n  3788\t            operator_asset = _resolve_surface_wave_operator_asset(\n  3789\t                arm_id=arm_id,\n  3790\t                root_mapping=root_mapping,\n  3791\t                anisotropy_mode=anisotropy_mode,\n  3792\t                branching_mode=branching_mode,\n  3793\t                hybrid_morphology=hybrid_record,\n  3794\t            )\n  3795\t            coupling_asset = _resolve_surface_wave_coupling_asset(\n  3796\t                arm_id=arm_id,\n  3797\t                root_mapping=root_mapping,\n  3798\t                hybrid_morphology=hybrid_record,\n  3799\t            )\n  3800\t            surface_operator_assets.append(copy.deepcopy(operator_asset))\n  3801\t            surface_coupling_assets.append(copy.deepcopy(coupling_asset))\n  3802\t            realized_anchor_mode = SURFACE_PATCH_CLOUD_MODE\n  3803\t        elif morphology_class == SKELETON_NEURON_CLASS:\n  3804\t            coupling_asset = _resolve_skeleton_neuron_coupling_asset(\n  3805\t                arm_id=arm_id,\n  3806\t                root_mapping=root_mapping,\n  3807\t                hybrid_morphology=hybrid_record,\n  3808\t            )\n  3809\t            skeleton_runtime_asset = _resolve_skeleton_runtime_asset(\n  3810\t                arm_id=arm_id,\n  3811\t                root_mapping=root_mapping,\n  3812\t                hybrid_morphology=hybrid_record,\n  3813\t            )\n  3814\t            skeleton_runtime_assets.append(\n  3815\t                {\n  3816\t                    **copy.deepcopy(skeleton_runtime_asset),\n  3817\t                    \"hybrid_morphology\": copy.deepcopy(hybrid_record),\n  3818\t                    \"selected_edge_bundle_paths\": copy.deepcopy(\n  3819\t                        coupling_asset[\"selected_edge_bundle_paths\"]\n  3820\t                    ),\n  3821\t                }\n  3822\t            )\n  3823\t            realized_anchor_mode = SKELETON_SEGMENT_CLOUD_MODE\n  3824\t        else:\n  3825\t            coupling_asset = _resolve_point_neuron_coupling_asset(\n  3826\t                arm_id=arm_id,\n  3827\t                root_mapping=root_mapping,\n  3828\t                hybrid_morphology=hybrid_record,\n  3829\t            )\n  3830\t            realized_anchor_mode = POINT_NEURON_LUMPED_MODE\n  3831\t        policy_evaluation = evaluate_mixed_fidelity_policy(\n  3832\t            root_id=root_id,\n  3833\t            cell_type=str(root_mapping.get(\"cell_type\", \"\")),\n  3834\t            realized_morphology_class=morphology_class,\n  3835\t            assignment_policy=assignment_policy,\n  3836\t            descriptor_payload=_load_mixed_fidelity_descriptor_payload(root_mapping),\n  3837\t            arm_id=arm_id,\n  3838\t            topology_condition=(\n  3839\t                None\n  3840\t                if arm_payload.get(\"topology_condition\") is None\n  3841\t                else str(arm_payload[\"topology_condition\"])\n  3842\t            ),\n  3843\t            morphology_condition=(\n  3844\t                None\n  3845\t                if arm_payload.get(\"morphology_condition\") is None\n  3846\t                else str(arm_payload[\"morphology_condition\"])\n  3847\t            ),\n  3848\t            arm_tags=_optional_string_sequence(arm_payload.get(\"tags\")),\n  3849\t        )\n  3850\t        policy_evaluations.append(copy.deepcopy(policy_evaluation))\n  3851\t\n  3852\t        per_root_assignments.append(\n  3853\t            {\n  3854\t                \"root_id\": root_id,\n  3855\t                \"cell_type\": str(root_mapping.get(\"cell_type\", \"\")),\n  3856\t                \"source_project_role\": str(root_mapping.get(\"project_role\", \"\")),\n  3857\t                \"canonical_project_role\": str(hybrid_record[\"canonical_project_role\"]),\n  3858\t                \"registry_default_morphology_class\": registry_default_class_by_root[root_id],\n  3859\t                \"realized_morphology_class\": morphology_class,\n  3860\t                \"assignment_provenance\": _build_assignment_provenance(\n  3861\t                    registry_default_morphology_class=registry_default_class_by_root[\n  3862\t                        root_id\n  3863\t                    ],\n  3864\t                    arm_default_morphology_class=arm_fidelity_assignment[\n  3865\t                        \"default_morphology_class\"\n  3866\t                    ],\n  3867\t                    arm_root_override_morphology_class=arm_fidelity_assignment[\n  3868\t                        \"root_overrides_by_root\"\n  3869\t                    ].get(root_id),\n  3870\t                    assignment_policy=assignment_policy,\n  3871\t                    policy_evaluation=policy_evaluation,\n  3872\t                    resolved_from=resolved_source_by_root[root_id],\n  3873\t                ),\n  3874\t                \"approximation_route\": _build_approximation_route(\n  3875\t                    registry_default_morphology_class=registry_default_class_by_root[\n  3876\t                        root_id\n  3877\t                    ],\n  3878\t                    realized_morphology_class=morphology_class,\n  3879\t                    policy_evaluation=policy_evaluation,\n  3880\t                ),\n  3881\t                \"policy_evaluation\": policy_evaluation,\n  3882\t                \"state_resolution\": copy.deepcopy(\n  3883\t                    hybrid_record[\"realized_state_space\"]\n  3884\t                ),\n  3885\t                \"readout_surface\": copy.deepcopy(hybrid_record[\"readout_surface\"]),\n  3886\t                \"coupling_resolution\": {\n  3887\t                    **copy.deepcopy(hybrid_record[\"coupling_anchor_resolution\"]),\n  3888\t                    \"realized_anchor_mode\": realized_anchor_mode,\n  3889\t                    \"topology_family\": str(coupling_asset[\"topology_family\"]),\n  3890\t                    \"fallback_hierarchy\": copy.deepcopy(\n  3891\t                        coupling_asset[\"fallback_hierarchy\"]\n  3892\t                    ),\n  3893\t                },\n  3894\t                \"required_local_assets\": required_local_assets,\n  3895\t                \"optional_local_assets\": optional_local_assets,\n  3896\t                \"surface_operator_asset\": (\n  3897\t                    None if operator_asset is None else copy.deepcopy(operator_asset)\n  3898\t                ),\n  3899\t                \"skeleton_runtime_asset\": (\n  3900\t                    None\n  3901\t                    if skeleton_runtime_asset is None\n  3902\t                    else copy.deepcopy(skeleton_runtime_asset)\n  3903\t                ),\n  3904\t                \"coupling_asset\": copy.deepcopy(coupling_asset),\n  3905\t            }\n  3906\t        )\n  3907\t    policy_hook = build_mixed_fidelity_policy_hook_summary(\n  3908\t        assignment_policy=assignment_policy,\n  3909\t        policy_evaluations=policy_evaluations,\n  3910\t    )\n  3911\t\n  3912\t    return {\n  3913\t        \"hybrid_morphology\": hybrid_morphology,\n  3914\t        \"mixed_fidelity\": {\n  3915\t            \"plan_version\": MIXED_FIDELITY_PLAN_VERSION,\n  3916\t            \"assignment_ordering\": normalized_config[\"assignment_ordering\"],\n  3917\t            \"assignment_policy\": copy.deepcopy(assignment_policy),\n  3918\t            \"policy_hook\": policy_hook,\n  3919\t            \"point_neuron_model_spec\": copy.deepcopy(\n  3920\t                _require_mapping(\n  3921\t                    point_neuron_model_spec,\n  3922\t                    field_name=\"simulation.baseline_families.P0\",\n  3923\t                )\n  3924\t            ),\n  3925\t            \"arm_overrides\": {\n  3926\t                \"default_morphology_class\": arm_fidelity_assignment[\n  3927\t                    \"default_morphology_class\"\n  3928\t                ],\n  3929\t                \"root_overrides\": copy.deepcopy(\n  3930\t                    arm_fidelity_assignment[\"root_overrides\"]\n  3931\t                ),\n  3932\t            },\n  3933\t            \"resolved_class_counts\": {\n  3934\t                class_name: int(class_counts[class_name])\n  3935\t                for class_name in HYBRID_MORPHOLOGY_PROMOTION_ORDER\n  3936\t                if class_counts[class_name] > 0\n  3937\t            },\n  3938\t            \"per_root_assignments\": per_root_assignments,\n  3939\t        },\n  3940\t        \"selected_root_operator_assets\": surface_operator_assets,\n  3941\t        \"selected_root_coupling_assets\": surface_coupling_assets,\n  3942\t        \"selected_root_skeleton_assets\": skeleton_runtime_assets,\n  3943\t    }\n  3944\t\n  3945\t\n  3946\tdef _load_mixed_fidelity_descriptor_payload(\n  3947\t    root_mapping: Mapping[str, Any],\n  3948\t) -> dict[str, Any] | None:\n  3949\t    descriptor_sidecar_path = root_mapping.get(\"descriptor_sidecar_path\")\n  3950\t    if descriptor_sidecar_path is None:\n  3951\t        return None\n  3952\t    descriptor_path = Path(str(descriptor_sidecar_path)).resolve()\n  3953\t    if not descriptor_path.exists():\n  3954\t        return None\n  3955\t    descriptor_payload = load_json(descriptor_path)\n  3956\t    return copy.deepcopy(descriptor_payload)\n  3957\t\n  3958\t\n  3959\tdef _build_assignment_provenance(\n  3960\t    *,\n  3961\t    registry_default_morphology_class: str,\n  3962\t    arm_default_morphology_class: str | None,\n  3963\t    arm_root_override_morphology_class: str | None,\n  3964\t    assignment_policy: Mapping[str, Any],\n  3965\t    policy_evaluation: Mapping[str, Any],\n  3966\t    resolved_from: str,\n  3967\t) -> dict[str, Any]:\n  3968\t    return {\n  3969\t        \"default_source\": str(assignment_policy[\"default_source\"]),\n  3970\t        \"registry_default_morphology_class\": registry_default_morphology_class,\n  3971\t        \"arm_default_morphology_class\": arm_default_morphology_class,\n  3972\t        \"arm_root_override_morphology_class\": arm_root_override_morphology_class,\n  3973\t        \"promotion_mode\": str(assignment_policy[\"promotion_mode\"]),\n  3974\t        \"demotion_mode\": str(assignment_policy[\"demotion_mode\"]),\n  3975\t        \"policy_applied\": False,\n  3976\t        \"policy_evaluated\": True,\n  3977\t        \"policy_recommended_morphology_class\": str(\n  3978\t            policy_evaluation[\"recommended_morphology_class\"]\n  3979\t        ),\n  3980\t        \"policy_recommendation_relation\": str(\n  3981\t            policy_evaluation[\"recommended_relation_to_realized\"]\n  3982\t        ),\n  3983\t        \"resolved_from\": resolved_from,\n  3984\t    }\n  3985\t\n  3986\t\n  3987\tdef _build_approximation_route(\n  3988\t    *,\n  3989\t    registry_default_morphology_class: str,\n  3990\t    realized_morphology_class: str,\n  3991\t    policy_evaluation: Mapping[str, Any],\n  3992\t) -> dict[str, Any]:\n  3993\t    rank_delta = (\n  3994\t        _morphology_class_rank(realized_morphology_class)\n  3995\t        - _morphology_class_rank(registry_default_morphology_class)\n  3996\t    )\n  3997\t    if rank_delta == 0:\n  3998\t        relation = \"same_as_registry_default\"\n  3999\t    elif rank_delta > 0:\n  4000\t        relation = \"promoted_from_registry_default\"\n  4001\t    else:\n  4002\t        relation = \"demoted_from_registry_default\"\n  4003\t    return {\n  4004\t        \"route_id\": (\n  4005\t            f\"{registry_default_morphology_class}_to_\"\n  4006\t            f\"{realized_morphology_class}\"\n  4007\t        ),\n  4008\t        \"registry_default_morphology_class\": registry_default_morphology_class,\n  4009\t        \"realized_morphology_class\": realized_morphology_class,\n  4010\t        \"relation_to_registry_default\": relation,\n  4011\t        \"promotion_rank_delta\": rank_delta,\n  4012\t        \"policy_action\": str(policy_evaluation[\"recommended_relation_to_realized\"]),\n  4013\t        \"policy_recommended_morphology_class\": str(\n  4014\t            policy_evaluation[\"recommended_morphology_class\"]\n  4015\t        ),\n  4016\t    }\n  4017\t\n  4018\t\n  4019\tdef _morphology_class_rank(value: str) -> int:\n  4020\t    return HYBRID_MORPHOLOGY_PROMOTION_ORDER.index(value)\n  4021\t\n  4022\t\n  4023\tdef _build_local_asset_reference_map(\n  4024\t    *,\n  4025\t    root_mapping: Mapping[str, Any],\n  4026\t    asset_keys: Sequence[Any],\n  4027\t) -> dict[str, Any]:\n  4028\t    return {\n  4029\t        str(asset_key): copy.deepcopy(\n  4030\t            _resolve_local_asset_reference(\n  4031\t                root_mapping=root_mapping,\n  4032\t                asset_key=str(asset_key),\n  4033\t            )\n  4034\t        )\n  4035\t        for asset_key in asset_keys\n  4036\t    }\n  4037\t\n  4038\t\n  4039\tdef _resolve_local_asset_reference(\n  4040\t    *,\n  4041\t    root_mapping: Mapping[str, Any],\n  4042\t    asset_key: str,\n  4043\t) -> Any:\n  4044\t    geometry_asset_records = _require_mapping(\n  4045\t        root_mapping.get(\"geometry_asset_records\"),\n  4046\t        field_name=\"selected_root_asset.geometry_asset_records\",\n  4047\t    )\n  4048\t    operator_asset_records = _require_mapping(\n  4049\t        root_mapping.get(\"operator_asset_records\"),\n  4050\t        field_name=\"selected_root_asset.operator_asset_records\",\n  4051\t    )\n  4052\t    coupling_asset_records = _require_mapping(\n  4053\t        root_mapping.get(\"coupling_asset_records\"),\n  4054\t        field_name=\"selected_root_asset.coupling_asset_records\",\n  4055\t    )\n  4056\t    if asset_key == \"raw_mesh\":\n  4057\t        return _require_mapping(\n  4058\t            geometry_asset_records[RAW_MESH_KEY],\n  4059\t            field_name=\"selected_root_asset.raw_mesh\",\n  4060\t        )\n  4061\t    if asset_key == \"raw_swc_skeleton\":\n  4062\t        return _require_mapping(\n  4063\t            geometry_asset_records[RAW_SKELETON_KEY],\n  4064\t            field_name=\"selected_root_asset.raw_skeleton\",\n  4065\t        )\n  4066\t    if asset_key == SKELETON_RUNTIME_ASSET_KEY:\n  4067\t        return _resolve_skeleton_runtime_asset_reference(\n  4068\t            root_mapping=root_mapping,\n  4069\t        )\n  4070\t    if asset_key == \"processed_surface_mesh\":\n  4071\t        return _require_mapping(\n  4072\t            geometry_asset_records[SIMPLIFIED_MESH_KEY],\n  4073\t            field_name=\"selected_root_asset.processed_surface_mesh\",\n  4074\t        )\n  4075\t    if asset_key == \"geometry_descriptors\":\n  4076\t        return _require_mapping(\n  4077\t            geometry_asset_records[DESCRIPTOR_SIDECAR_KEY],\n  4078\t            field_name=\"selected_root_asset.geometry_descriptors\",\n  4079\t        )\n  4080\t    if asset_key == \"geometry_qa\":\n  4081\t        return _require_mapping(\n  4082\t            geometry_asset_records[QA_SIDECAR_KEY],\n  4083\t            field_name=\"selected_root_asset.geometry_qa\",\n  4084\t        )\n  4085\t    if asset_key == \"fine_surface_operator\":\n  4086\t        return _require_mapping(\n  4087\t            operator_asset_records[FINE_OPERATOR_KEY],\n  4088\t            field_name=\"selected_root_asset.fine_surface_operator\",\n  4089\t        )\n  4090\t    if asset_key == \"coarse_patch_operator\":\n  4091\t        return _require_mapping(\n  4092\t            operator_asset_records[COARSE_OPERATOR_KEY],\n  4093\t            field_name=\"selected_root_asset.coarse_patch_operator\",\n  4094\t        )\n  4095\t    if asset_key == \"surface_transfer_operators\":\n  4096\t        return _require_mapping(\n  4097\t            operator_asset_records[TRANSFER_OPERATORS_KEY],\n  4098\t            field_name=\"selected_root_asset.surface_transfer_operators\",\n  4099\t        )\n  4100\t    if asset_key == \"surface_operator_metadata\":\n  4101\t        return _require_mapping(\n  4102\t            operator_asset_records[OPERATOR_METADATA_KEY],\n  4103\t            field_name=\"selected_root_asset.surface_operator_metadata\",\n  4104\t        )\n  4105\t    if asset_key == \"root_local_synapse_registry\":\n  4106\t        return _require_mapping(\n  4107\t            coupling_asset_records[LOCAL_SYNAPSE_REGISTRY_KEY],\n  4108\t            field_name=\"selected_root_asset.root_local_synapse_registry\",\n  4109\t        )\n  4110\t    if asset_key == \"incoming_anchor_map\":\n  4111\t        return _require_mapping(\n  4112\t            coupling_asset_records[INCOMING_ANCHOR_MAP_KEY],\n  4113\t            field_name=\"selected_root_asset.incoming_anchor_map\",\n  4114\t        )\n  4115\t    if asset_key == \"outgoing_anchor_map\":\n  4116\t        return _require_mapping(\n  4117\t            coupling_asset_records[OUTGOING_ANCHOR_MAP_KEY],\n  4118\t            field_name=\"selected_root_asset.outgoing_anchor_map\",\n  4119\t        )\n  4120\t    if asset_key == \"root_coupling_index\":\n  4121\t        return _require_mapping(\n  4122\t            coupling_asset_records[COUPLING_INDEX_KEY],\n  4123\t            field_name=\"selected_root_asset.root_coupling_index\",\n  4124\t        )\n  4125\t    if asset_key == \"selected_edge_coupling_bundles\":\n  4126\t        return [\n  4127\t            copy.deepcopy(item)\n  4128\t            for item in _selected_peer_edge_bundles(root_mapping)\n  4129\t        ]\n  4130\t    raise ValueError(f\"Unsupported local asset key {asset_key!r}.\")\n  4131\t\n  4132\t\n  4133\tdef _validate_required_local_assets(\n  4134\t    *,\n  4135\t    arm_id: str,\n  4136\t    root_id: int,\n  4137\t    morphology_class: str,\n  4138\t    asset_references: Mapping[str, Any],\n  4139\t) -> None:\n  4140\t    for asset_key, asset_reference in asset_references.items():\n  4141\t        if asset_key == \"selected_edge_coupling_bundles\":\n  4142\t            missing_paths = [\n  4143\t                str(item[\"path\"])\n  4144\t                for item in _require_sequence(\n  4145\t                    asset_reference,\n  4146\t                    field_name=(\n  4147\t                        f\"surface_wave arm {arm_id!r} required \"\n  4148\t                        f\"selected_edge_coupling_bundles\"\n  4149\t                    ),\n  4150\t                )\n  4151\t                if str(item[\"status\"]) != ASSET_STATUS_READY or not bool(item[\"exists\"])\n  4152\t            ]\n  4153\t            if missing_paths:\n  4154\t                raise ValueError(\n  4155\t                    f\"surface_wave arm {arm_id!r} requested morphology_class \"\n  4156\t                    f\"{morphology_class!r} for root {root_id}, but selected edge \"\n  4157\t                    f\"coupling bundles are unavailable at {missing_paths!r}.\"\n  4158\t                )\n  4159\t            continue\n  4160\t        asset_record = _require_mapping(\n  4161\t            asset_reference,\n  4162\t            field_name=(\n  4163\t                f\"surface_wave arm {arm_id!r} required local asset {asset_key!r}\"\n  4164\t            ),\n  4165\t        )\n  4166\t        if str(asset_record[\"status\"]) != ASSET_STATUS_READY or not bool(\n  4167\t            asset_record[\"exists\"]\n  4168\t        ):\n  4169\t            raise ValueError(\n  4170\t                f\"surface_wave arm {arm_id!r} requested morphology_class \"\n  4171\t                f\"{morphology_class!r} for root {root_id}, but required local asset \"\n  4172\t                f\"{asset_key!r} is unavailable at {asset_record['path']} with status \"\n  4173\t                f\"{asset_record['status']!r}.\"\n  4174\t            )\n  4175\t\n  4176\t\n  4177\tdef _selected_peer_edge_bundles(\n  4178\t    root_mapping: Mapping[str, Any],\n  4179\t) -> list[dict[str, Any]]:\n  4180\t    return [\n  4181\t        copy.deepcopy(_require_mapping(item, field_name=\"edge_bundle_paths\"))\n  4182\t        for item in _require_sequence(\n  4183\t            root_mapping.get(\"edge_bundle_paths\"),\n  4184\t            field_name=\"selected_root_asset.edge_bundle_paths\",\n  4185\t        )\n  4186\t        if bool(_require_mapping(item, field_name=\"edge_bundle_paths\").get(\"selected_peer\"))\n  4187\t    ]\n  4188\t\n  4189\t\n  4190\tdef _resolve_surface_wave_operator_asset(\n  4191\t    *,\n  4192\t    arm_id: str,\n  4193\t    root_mapping: Mapping[str, Any],\n  4194\t    anisotropy_mode: str,\n  4195\t    branching_mode: str,\n  4196\t    hybrid_morphology: Mapping[str, Any],\n  4197\t) -> dict[str, Any]:\n  4198\t    root_id = int(root_mapping[\"root_id\"])\n  4199\t    operator_bundle = _require_mapping(\n  4200\t        root_mapping.get(\"operator_bundle\"),\n  4201\t        field_name=f\"circuit_assets.selected_root_assets[{root_id}].operator_bundle\",\n  4202\t    )\n  4203\t    operator_status = _normalize_nonempty_string(\n  4204\t        root_mapping.get(\"operator_bundle_status\", operator_bundle.get(\"status\")),\n  4205\t        field_name=f\"circuit_assets.selected_root_assets[{root_id}].operator_bundle_status\",\n  4206\t    )\n  4207\t    if operator_status != ASSET_STATUS_READY:\n  4208\t        raise ValueError(\n  4209\t            f\"surface_wave arm {arm_id!r} requires ready operator bundles for \"\n  4210\t            f\"selected root {root_id}, found status {operator_status!r}.\"\n  4211\t        )\n  4212\t    operator_asset_records = _require_mapping(\n  4213\t        root_mapping.get(\"operator_asset_records\"),\n  4214\t        field_name=f\"circuit_assets.selected_root_assets[{root_id}].operator_asset_records\",\n  4215\t    )\n  4216\t    missing_operator_paths = [\n  4217\t        asset_key\n  4218\t        for asset_key in (\n  4219\t            FINE_OPERATOR_KEY,\n  4220\t            COARSE_OPERATOR_KEY,\n  4221\t            TRANSFER_OPERATORS_KEY,\n  4222\t            OPERATOR_METADATA_KEY,\n  4223\t        )\n  4224\t        if not bool(\n  4225\t            _require_mapping(\n  4226\t                operator_asset_records.get(asset_key),\n  4227\t                field_name=(\n  4228\t                    f\"circuit_assets.selected_root_assets[{root_id}].\"\n  4229\t                    f\"operator_asset_records.{asset_key}\"\n  4230\t                ),\n  4231\t            ).get(\"exists\")\n  4232\t        )\n  4233\t    ]\n  4234\t    if missing_operator_paths:\n  4235\t        raise ValueError(\n  4236\t            f\"surface_wave arm {arm_id!r} is missing local operator assets \"\n  4237\t            f\"{missing_operator_paths!r} for selected root {root_id}.\"\n  4238\t        )\n  4239\t\n  4240\t    metadata_path = Path(\n  4241\t        str(\n  4242\t            _require_mapping(\n  4243\t                operator_asset_records[OPERATOR_METADATA_KEY],\n  4244\t                field_name=f\"operator_asset_records[{root_id}].operator_metadata\",\n  4245\t            )[\"path\"]\n  4246\t        )\n  4247\t    ).resolve()\n  4248\t    loaded_operator_metadata = load_operator_bundle_metadata(metadata_path)\n  4249\t    if loaded_operator_metadata != dict(operator_bundle):\n  4250\t        raise ValueError(\n  4251\t            f\"surface_wave arm {arm_id!r} found operator metadata drift for root \"\n  4252\t            f\"{root_id}: manifest record does not match {metadata_path}.\"\n  4253\t        )\n  4254\t\n  4255\t    normalization = _normalize_nonempty_string(\n  4256\t        operator_bundle.get(\"normalization\"),\n  4257\t        field_name=f\"operator_bundle[{root_id}].normalization\",\n  4258\t    )\n  4259\t    if normalization != \"mass_normalized\":\n  4260\t        raise ValueError(\n  4261\t            f\"surface_wave arm {arm_id!r} requires mass_normalized operators, but \"\n  4262\t            f\"root {root_id} exposes normalization {normalization!r}.\"\n  4263\t        )\n  4264\t    transfer_operators = _require_mapping(\n  4265\t        operator_bundle.get(\"transfer_operators\"),\n  4266\t        field_name=f\"operator_bundle[{root_id}].transfer_operators\",\n  4267\t    )\n  4268\t    surface_membership = _require_mapping(\n  4269\t        transfer_operators.get(\"surface_to_patch_membership\"),\n  4270\t        field_name=(\n  4271\t            f\"operator_bundle[{root_id}].transfer_operators.surface_to_patch_membership\"\n  4272\t        ),\n  4273\t    )\n  4274\t    fine_to_coarse = _require_mapping(\n  4275\t        transfer_operators.get(\"fine_to_coarse_restriction\"),\n  4276\t        field_name=(\n  4277\t            f\"operator_bundle[{root_id}].transfer_operators.fine_to_coarse_restriction\"\n  4278\t        ),\n  4279\t    )\n  4280\t    if not bool(surface_membership.get(\"available\")) or not bool(\n  4281\t        fine_to_coarse.get(\"available\")\n  4282\t    ):\n  4283\t        raise ValueError(\n  4284\t            f\"surface_wave arm {arm_id!r} requires surface-to-patch transfer \"\n  4285\t            f\"operators for root {root_id}, but the operator bundle does not \"\n  4286\t            \"expose them as available.\"\n  4287\t        )\n  4288\t\n  4289\t    anisotropy_model = _normalize_nonempty_string(\n  4290\t        operator_bundle.get(\"anisotropy_model\"),\n  4291\t        field_name=f\"operator_bundle[{root_id}].anisotropy_model\",\n  4292\t    )\n  4293\t    if anisotropy_mode == \"operator_embedded\" and anisotropy_model == \"isotropic\":\n  4294\t        raise ValueError(\n  4295\t            f\"surface_wave arm {arm_id!r} requested anisotropy.mode \"\n  4296\t            \"'operator_embedded' but root \"\n  4297\t            f\"{root_id} operator bundle only exposes anisotropy_model 'isotropic'.\"\n  4298\t        )\n  4299\t\n  4300\t    descriptor_sidecar = _require_mapping(\n  4301\t        _resolve_local_asset_reference(\n  4302\t            root_mapping=root_mapping,\n  4303\t            asset_key=\"geometry_descriptors\",\n  4304\t        ),\n  4305\t        field_name=f\"surface_wave arm {arm_id!r} geometry_descriptors\",\n  4306\t    )\n  4307\t    descriptor_sidecar_path = Path(str(descriptor_sidecar[\"path\"])).resolve()\n  4308\t    if branching_mode != \"disabled\" and not descriptor_sidecar_path.exists():\n  4309\t        raise ValueError(\n  4310\t            f\"surface_wave arm {arm_id!r} requested branching.mode {branching_mode!r} \"\n  4311\t            f\"but root {root_id} is missing geometry descriptors at \"\n  4312\t            f\"{descriptor_sidecar_path}.\"\n  4313\t        )\n  4314\t\n  4315\t    spectral_radius = _estimate_surface_wave_operator_spectral_radius(\n  4316\t        operator_path=Path(\n  4317\t            str(\n  4318\t                _require_mapping(\n  4319\t                    operator_asset_records[FINE_OPERATOR_KEY],\n  4320\t                    field_name=f\"operator_asset_records[{root_id}].fine_operator\",\n  4321\t                )[\"path\"]\n  4322\t            )\n  4323\t        ).resolve(),\n  4324\t        arm_id=arm_id,\n  4325\t        root_id=root_id,\n  4326\t    )\n  4327\t    return {\n  4328\t        \"root_id\": root_id,\n  4329\t        \"hybrid_morphology\": copy.deepcopy(hybrid_morphology),\n  4330\t        \"operator_bundle_status\": operator_status,\n  4331\t        \"preferred_discretization_family\": str(\n  4332\t            operator_bundle[\"preferred_discretization_family\"]\n  4333\t        ),\n  4334\t        \"discretization_family\": str(operator_bundle[\"discretization_family\"]),\n  4335\t        \"mass_treatment\": str(operator_bundle[\"mass_treatment\"]),\n  4336\t        \"normalization\": normalization,\n  4337\t        \"boundary_condition_mode\": str(operator_bundle[\"boundary_condition_mode\"]),\n  4338\t        \"anisotropy_model\": anisotropy_model,\n  4339\t        \"fallback_policy\": copy.deepcopy(operator_bundle[\"fallback_policy\"]),\n  4340\t        \"fine_operator_path\": str(\n  4341\t            Path(str(operator_asset_records[FINE_OPERATOR_KEY][\"path\"])).resolve()\n  4342\t        ),\n  4343\t        \"coarse_operator_path\": str(\n  4344\t            Path(str(operator_asset_records[COARSE_OPERATOR_KEY][\"path\"])).resolve()\n  4345\t        ),\n  4346\t        \"transfer_operator_path\": str(\n  4347\t            Path(str(operator_asset_records[TRANSFER_OPERATORS_KEY][\"path\"])).resolve()\n  4348\t        ),\n  4349\t        \"operator_metadata_path\": str(metadata_path),\n  4350\t        \"descriptor_sidecar_path\": str(descriptor_sidecar_path),\n  4351\t        \"surface_to_patch_membership_available\": True,\n  4352\t        \"fine_to_coarse_restriction_available\": True,\n  4353\t        \"coarse_to_fine_prolongation_available\": bool(\n  4354\t            _require_mapping(\n  4355\t                transfer_operators.get(\"coarse_to_fine_prolongation\"),\n  4356\t                field_name=(\n  4357\t                    \"operator_bundle\"\n  4358\t                    f\"[{root_id}].transfer_operators.coarse_to_fine_prolongation\"\n  4359\t                ),\n  4360\t            ).get(\"available\")\n  4361\t        ),\n  4362\t        \"normalized_state_transfer_available\": bool(\n  4363\t            _require_mapping(\n  4364\t                transfer_operators.get(\"normalized_state_transfer\"),\n  4365\t                field_name=(\n  4366\t                    \"operator_bundle\"\n  4367\t                    f\"[{root_id}].transfer_operators.normalized_state_transfer\"\n  4368\t                ),\n  4369\t            ).get(\"available\")\n  4370\t        ),\n  4371\t        \"spectral_radius\": spectral_radius,\n  4372\t    }\n  4373\t\n  4374\t\n  4375\tdef _resolve_skeleton_runtime_asset_reference(\n  4376\t    *,\n  4377\t    root_mapping: Mapping[str, Any],\n  4378\t) -> dict[str, Any]:\n  4379\t    geometry_asset_records = _require_mapping(\n  4380\t        root_mapping.get(\"geometry_asset_records\"),\n  4381\t        field_name=\"selected_root_asset.geometry_asset_records\",\n  4382\t    )\n  4383\t    raw_skeleton_record = _require_mapping(\n  4384\t        geometry_asset_records[RAW_SKELETON_KEY],\n  4385\t        field_name=\"selected_root_asset.raw_skeleton\",\n  4386\t    )\n  4387\t    root_id = int(root_mapping[\"root_id\"])\n  4388\t    processed_graph_dir = Path(\n  4389\t        str(\n  4390\t            _require_mapping(\n  4391\t                geometry_asset_records[DESCRIPTOR_SIDECAR_KEY],\n  4392\t                field_name=\"selected_root_asset.geometry_descriptors\",\n  4393\t            )[\"path\"]\n  4394\t        )\n  4395\t    ).resolve().parent\n  4396\t    if str(raw_skeleton_record[\"status\"]) != ASSET_STATUS_READY or not bool(\n  4397\t        raw_skeleton_record[\"exists\"]\n  4398\t    ):\n  4399\t        paths = build_skeleton_runtime_asset_paths(\n  4400\t            root_id,\n  4401\t            processed_graph_dir=processed_graph_dir,\n  4402\t        )\n  4403\t        return {\n  4404\t            \"root_id\": root_id,\n  4405\t            \"contract_version\": None,\n  4406\t            \"approximation_family\": None,\n  4407\t            \"graph_operator_family\": None,\n  4408\t            \"state_layout\": None,\n  4409\t            \"projection_surface\": None,\n  4410\t            \"projection_layout\": None,\n  4411\t            \"source_injection_strategy\": None,\n  4412\t            \"raw_skeleton_path\": str(Path(str(raw_skeleton_record[\"path\"])).resolve()),\n  4413\t            \"data_path\": str(paths.data_path),\n  4414\t            \"metadata_path\": str(paths.metadata_path),\n  4415\t            \"path\": str(paths.metadata_path),\n  4416\t            \"status\": str(raw_skeleton_record[\"status\"]),\n  4417\t            \"exists\": bool(paths.metadata_path.exists()),\n  4418\t            \"asset_hash\": None,\n  4419\t            \"node_count\": 0,\n  4420\t            \"edge_count\": 0,\n  4421\t            \"branch_point_count\": 0,\n  4422\t            \"leaf_count\": 0,\n  4423\t            \"readout_semantics\": {},\n  4424\t            \"operator\": {},\n  4425\t        }\n  4426\t    return build_skeleton_runtime_asset_record(\n  4427\t        root_id=root_id,\n  4428\t        raw_skeleton_path=raw_skeleton_record[\"path\"],\n  4429\t        processed_graph_dir=processed_graph_dir,\n  4430\t    )\n  4431\t\n  4432\t\n  4433\tdef _resolve_root_coupling_asset_record(\n  4434\t    *,\n  4435\t    arm_id: str,\n  4436\t    root_mapping: Mapping[str, Any],\n  4437\t    hybrid_morphology: Mapping[str, Any],\n  4438\t) -> dict[str, Any]:\n  4439\t    root_id = int(root_mapping[\"root_id\"])\n  4440\t    coupling_bundle = _require_mapping(\n  4441\t        root_mapping.get(\"coupling_bundle\"),\n  4442\t        field_name=f\"circuit_assets.selected_root_assets[{root_id}].coupling_bundle\",\n  4443\t    )\n  4444\t    topology_family = _normalize_nonempty_string(\n  4445\t        coupling_bundle.get(\"topology_family\"),\n  4446\t        field_name=f\"coupling_bundle[{root_id}].topology_family\",\n  4447\t    )\n  4448\t    fallback_hierarchy = [\n  4449\t        _normalize_nonempty_string(\n  4450\t            item,\n  4451\t            field_name=f\"coupling_bundle[{root_id}].fallback_hierarchy[{index}]\",\n  4452\t        )\n  4453\t        for index, item in enumerate(\n  4454\t            _require_sequence(\n  4455\t                coupling_bundle.get(\"fallback_hierarchy\"),\n  4456\t                field_name=f\"coupling_bundle[{root_id}].fallback_hierarchy\",\n  4457\t            )\n  4458\t        )\n  4459\t    ]\n  4460\t    selected_edge_bundle_paths = _selected_peer_edge_bundles(root_mapping)\n  4461\t    blocked_selected_edges = [\n  4462\t        str(edge_bundle[\"path\"])\n  4463\t        for edge_bundle in selected_edge_bundle_paths\n  4464\t        if str(edge_bundle[\"status\"]) != ASSET_STATUS_READY or not bool(edge_bundle[\"exists\"])\n  4465\t    ]\n  4466\t    if blocked_selec