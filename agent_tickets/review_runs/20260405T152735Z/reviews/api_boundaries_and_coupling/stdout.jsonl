_payload(\n    47\t        manifest=manifest,\n    48\t        schema=schema,\n    49\t        design_lock=design_lock,\n    50\t        manifest_path=manifest_path,\n    51\t        processed_stimulus_dir=processed_stimulus_dir,\n    52\t    )\n    53\t\n    54\t\n    55\tdef validate_manifest_payload(\n    56\t    manifest: dict[str, Any],\n    57\t    schema: dict[str, Any],\n    58\t    design_lock: dict[str, Any],\n    59\t    manifest_path: str | Path | None = None,\n    60\t    *,\n    61\t    processed_stimulus_dir: str | Path | None = None,\n    62\t) -> dict[str, Any]:\n    63\t    validator = Draft202012Validator(schema)\n    64\t    errors = sorted(validator.iter_errors(manifest), key=lambda err: list(err.absolute_path))\n    65\t    if errors:\n    66\t        details = \"; \".join(f\"{'/'.join(str(part) for part in err.absolute_path) or '<root>'}: {err.message}\" for err in errors)\n    67\t        raise ValueError(f\"Schema validation failed for {manifest_path or 'manifest'}: {details}\")\n    68\t\n    69\t    metadata = design_lock.get(\"metadata\", {})\n    70\t    if manifest[\"milestone\"] != metadata.get(\"milestone_id\"):\n    71\t        raise ValueError(\"Manifest milestone does not match the Milestone 1 design-lock metadata.\")\n    72\t    if manifest[\"brief_version\"] != metadata.get(\"brief_version\"):\n    73\t        raise ValueError(\"Manifest brief_version does not match the locked brief version.\")\n    74\t    if manifest[\"hypothesis_version\"] != metadata.get(\"hypothesis_version\"):\n    75\t        raise ValueError(\"Manifest hypothesis_version does not match the locked hypothesis version.\")\n    76\t\n    77\t    criteria_catalog = {item[\"id\"]: item for item in design_lock.get(\"success_criteria\", [])}\n    78\t    unknown_criteria = sorted(set(manifest[\"success_criteria_ids\"]) - set(criteria_catalog))\n    79\t    if unknown_criteria:\n    80\t        raise ValueError(f\"Manifest references unknown success criteria IDs: {unknown_criteria}\")\n    81\t\n    82\t    required_output_catalog = {item[\"id\"]: item for item in design_lock.get(\"must_show_outputs\", [])}\n    83\t    unknown_outputs = sorted(set(manifest[\"must_show_outputs\"]) - set(required_output_catalog))\n    84\t    if unknown_outputs:\n    85\t        raise ValueError(f\"Manifest references unknown must-show outputs: {unknown_outputs}\")\n    86\t\n    87\t    declared_outputs = {\n    88\t        *(item[\"id\"] for item in manifest[\"output_bundle\"][\"plots\"]),\n    89\t        *(item[\"id\"] for item in manifest[\"output_bundle\"][\"ui_states\"]),\n    90\t    }\n    91\t    missing_outputs = sorted(set(manifest[\"must_show_outputs\"]) - declared_outputs)\n    92\t    if missing_outputs:\n    93\t        raise ValueError(f\"Manifest must_show_outputs are missing from output_bundle: {missing_outputs}\")\n    94\t\n    95\t    arm_ids = {arm[\"arm_id\"] for arm in manifest[\"comparison_arms\"]}\n    96\t    if len(arm_ids) != len(manifest[\"comparison_arms\"]):\n    97\t        raise ValueError(\"Manifest comparison_arms contain duplicate arm_id values.\")\n    98\t\n    99\t    has_p1 = any(arm[\"baseline_family\"] == \"P1\" for arm in manifest[\"comparison_arms\"])\n   100\t    if \"m1_survives_stronger_baseline\" in manifest[\"success_criteria_ids\"] and not has_p1:\n   101\t        raise ValueError(\"Manifest claims survival against P1 but defines no P1 comparison arm.\")\n   102\t\n   103\t    try:\n   104\t        _validate_manifest_stimulus_declaration(manifest)\n   105\t        resolved_stimulus = resolve_manifest_stimulus(manifest)\n   106\t    except ValueError as exc:\n   107\t        raise ValueError(f\"Manifest stimulus is invalid: {exc}\") from exc\n   108\t\n   109\t    resolved_processed_stimulus_dir = _resolve_processed_stimulus_dir(processed_stimulus_dir)\n   110\t    stimulus_contract = resolved_stimulus.build_contract_metadata(\n   111\t        processed_stimulus_dir=resolved_processed_stimulus_dir\n   112\t    )\n   113\t    stimulus_bundle = resolved_stimulus.build_bundle_metadata(\n   114\t        processed_stimulus_dir=resolved_processed_stimulus_dir\n   115\t    )\n   116\t    stimulus_bundle_reference = resolved_stimulus.build_bundle_reference(\n   117\t        processed_stimulus_dir=resolved_processed_stimulus_dir\n   118\t    )\n   119\t    stimulus_bundle_metadata_path = resolved_stimulus.resolve_bundle_metadata_path(\n   120\t        processed_stimulus_dir=resolved_processed_stimulus_dir\n   121\t    )\n   122\t\n   123\t    return {\n   124\t        \"experiment_id\": manifest[\"experiment_id\"],\n   125\t        \"milestone\": manifest[\"milestone\"],\n   126\t        \"brief_version\": manifest[\"brief_version\"],\n   127\t        \"success_criteria_count\": len(manifest[\"success_criteria_ids\"]),\n   128\t        \"comparison_arm_count\": len(manifest[\"comparison_arms\"]),\n   129\t        \"must_show_output_count\": len(manifest[\"must_show_outputs\"]),\n   130\t        \"resolved_stimulus_family\": resolved_stimulus.stimulus_family,\n   131\t        \"resolved_stimulus_name\": resolved_stimulus.stimulus_name,\n   132\t        \"resolved_stimulus_parameter_hash\": resolved_stimulus.stimulus_spec[\"parameter_hash\"],\n   133\t        \"stimulus_contract_version\": stimulus_bundle_reference[\"contract_version\"],\n   134\t        \"stimulus_bundle_id\": stimulus_bundle_reference[\"bundle_id\"],\n   135\t        \"stimulus_bundle_metadata_path\": stimulus_bundle_metadata_path,\n   136\t        \"resolved_stimulus\": resolved_stimulus.stimulus_spec,\n   137\t        \"stimulus_registry_entry\": resolved_stimulus.registry_entry,\n   138\t        \"stimulus_contract\": stimulus_contract,\n   139\t        \"stimulus_bundle\": stimulus_bundle,\n   140\t        \"stimulus_bundle_reference\": stimulus_bundle_reference,\n   141\t    }\n   142\t\n   143\t\n   144\tdef resolve_manifest_stimulus(manifest: Mapping[str, Any]) -> ResolvedStimulusSpec:\n   145\t    if not isinstance(manifest, Mapping):\n   146\t        raise ValueError(\"manifest must be a mapping.\")\n   147\t    return resolve_stimulus_spec(manifest)\n   148\t\n   149\t\n   150\tdef resolve_manifest_retinal_geometry(manifest: Mapping[str, Any]) -> ResolvedRetinalGeometry:\n   151\t    if not isinstance(manifest, Mapping):\n   152\t        raise ValueError(\"manifest must be a mapping.\")\n   153\t    return resolve_retinal_geometry_spec(manifest)\n   154\t\n   155\t\n   156\tdef _resolve_processed_stimulus_dir(processed_stimulus_dir: str | Path | None) -> Path:\n   157\t    if processed_stimulus_dir is not None:\n   158\t        return Path(processed_stimulus_dir).resolve()\n   159\t    return (REPO_ROOT / DEFAULT_PROCESSED_STIMULUS_DIR).resolve()\n   160\t\n   161\t\n   162\tdef _validate_manifest_stimulus_declaration(manifest: Mapping[str, Any]) -> None:\n   163\t    nested_stimulus = manifest.get(\"stimulus\")\n   164\t    if nested_stimulus is None:\n   165\t        return\n   166\t    if not isinstance(nested_stimulus, Mapping):\n   167\t        raise ValueError(\"stimulus must be a mapping when provided.\")\n   168\t\n   169\t    nested_has_family = nested_stimulus.get(\"stimulus_family\") is not None\n   170\t    nested_has_name = nested_stimulus.get(\"stimulus_name\") is not None\n   171\t    if nested_has_family != nested_has_name:\n   172\t        raise ValueError(\n   173\t            \"stimulus.stimulus_family and stimulus.stimulus_name must either both be provided \"\n   174\t            \"or both be omitted.\"\n   175\t        )\n   176\t\n   177\t    top_level_seed = manifest.get(\"random_seed\")\n   178\t    determinism = nested_stimulus.get(\"determinism\")\n   179\t    if isinstance(determinism, Mapping) and determinism.get(\"seed\") is not None and top_level_seed is not None:\n   180\t        if int(determinism[\"seed\"]) != int(top_level_seed):\n   181\t            raise ValueError(\"stimulus.determinism.seed must match the top-level random_seed.\")\n   182\t\n   183\t    if nested_has_family and nested_has_name:\n   184\t        top_level_reference = resolve_stimulus_spec(\n   185\t            stimulus_family=manifest.get(\"stimulus_family\"),\n   186\t            stimulus_name=manifest.get(\"stimulus_name\"),\n   187\t        )\n   188\t        nested_reference = resolve_stimulus_spec(stimulus=nested_stimulus)\n   189\t        if (\n   190\t            top_level_reference.stimulus_family != nested_reference.stimulus_family\n   191\t            or top_level_reference.stimulus_name != nested_reference.stimulus_name\n   192\t        ):\n   193\t            raise ValueError(\n   194\t                \"stimulus.stimulus_family/stimulus_name must resolve to the same canonical \"\n   195\t                \"stimulus as the top-level stimulus_family/stimulus_name fields.\"\n   196\t            )\n","exit_code":0,"status":"completed"}}
