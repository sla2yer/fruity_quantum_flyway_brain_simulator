       return {\n    56\t            RAW_MESH_KEY: self.raw_mesh_path,\n    57\t            RAW_SKELETON_KEY: self.raw_skeleton_path,\n    58\t            SIMPLIFIED_MESH_KEY: self.simplified_mesh_path,\n    59\t            SURFACE_GRAPH_KEY: self.surface_graph_path,\n    60\t            PATCH_GRAPH_KEY: self.patch_graph_path,\n    61\t            DESCRIPTOR_SIDECAR_KEY: self.descriptor_sidecar_path,\n    62\t            QA_SIDECAR_KEY: self.qa_sidecar_path,\n    63\t        }\n    64\t\n    65\t\n    66\tdef build_geometry_bundle_paths(\n    67\t    root_id: int,\n    68\t    *,\n    69\t    meshes_raw_dir: str | Path,\n    70\t    skeletons_raw_dir: str | Path,\n    71\t    processed_mesh_dir: str | Path,\n    72\t    processed_graph_dir: str | Path,\n    73\t) -> GeometryBundlePaths:\n    74\t    root_label = str(int(root_id))\n    75\t    raw_mesh_dir = Path(meshes_raw_dir).resolve()\n    76\t    raw_skeleton_dir = Path(skeletons_raw_dir).resolve()\n    77\t    mesh_dir = Path(processed_mesh_dir).resolve()\n    78\t    graph_dir = Path(processed_graph_dir).resolve()\n    79\t    return GeometryBundlePaths(\n    80\t        root_id=int(root_id),\n    81\t        raw_mesh_path=raw_mesh_dir / f\"{root_label}.ply\",\n    82\t        raw_skeleton_path=raw_skeleton_dir / f\"{root_label}.swc\",\n    83\t        simplified_mesh_path=mesh_dir / f\"{root_label}.ply\",\n    84\t        surface_graph_path=graph_dir / f\"{root_label}_graph.npz\",\n    85\t        patch_graph_path=graph_dir / f\"{root_label}_patch_graph.npz\",\n    86\t        descriptor_sidecar_path=graph_dir / f\"{root_label}_descriptors.json\",\n    87\t        qa_sidecar_path=graph_dir / f\"{root_label}_qa.json\",\n    88\t        legacy_meta_json_path=graph_dir / f\"{root_label}_meta.json\",\n    89\t    )\n    90\t\n    91\t\n    92\tdef default_asset_statuses(*, fetch_skeletons: bool) -> dict[str, str]:\n    93\t    return {\n    94\t        RAW_MESH_KEY: ASSET_STATUS_MISSING,\n    95\t        RAW_SKEL