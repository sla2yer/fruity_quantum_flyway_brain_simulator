    50\\t            if not _is_transient_http_error(exc) or attempt >= attempts:\\n    51\\t                raise\\n    52\\t            wait_seconds = 2 ** (attempt - 1)\\n    53\\t            status = _http_status(exc)\\n    54\\t            url = _http_url(exc) or \\\"<unknown>\\\"\\n    55\\t            print(\\n    56\\t                f\\\"{label}: transient HTTP {status} from {url}; \\\"\\n    57\\t                f\\\"retrying in {wait_seconds}s ({attempt}/{attempts}).\\\"\\n    58\\t            )\\n    59\\t            time.sleep(wait_seconds)\\n    60\\t        except (requests.ConnectionError, requests.Timeout) as exc:\\n    61\\t            last_exc = exc\\n    62\\t            if attempt >= attempts:\\n    63\\t                raise\\n    64\\t            wait_seconds = 2 ** (attempt - 1)\\n    65\\t            print(\\n    66\\t                f\\\"{label}: transient network error ({exc}); \\\"\\n    67\\t                f\\\"retrying in {wait_seconds}s ({attempt}/{attempts}).\\\"\\n    68\\t            )\\n    69\\t            time.sleep(wait_seconds)\\n    70\\t\\n    71\\t    if last_exc is not None:\\n    72\\t        raise last_exc\\n    73\\t    raise RuntimeError(f\\\"{label} failed before making a request.\\\")\\n    74\\t\\n    75\\t\\n    76\\tdef _format_exception(exc: BaseException) -> str:\\n    77\\t    detail = str(exc).strip()\\n    78\\t    if detail:\\n    79\\t        return f\\\"{type(exc).__name__}: {detail}\\\"\\n    80\\t    return type(exc).__name__\\n    81\\t\\n    82\\t\\n    83\\tdef _print_next_step(message: str) -> None:\\n    84\\t    print(f\\\"Next step: {message}\\\")\\n    85\\t\\n    86\\t\\n    87\\tdef _resolved_config_path(cfg: dict[str, Any], fallback: str) -> Path:\\n    88\\t    config_path = get_config_path(cfg)\\n    89\\t    if config_path is not None:\\n    90\\t        return config_path.resolve()\\n    91\\t    return Path(fallback).expanduser().resolve()\\n    92\\t\\n    93\\t\\n    94\\tdef _fail_miss