utated[\"work_item_id\"]))\n   231\t        mutated_artifact_references.append(mutated)\n   232\t\n   233\t    if reverse:\n   234\t        mutated_cells.reverse()\n   235\t        mutated_work_items.reverse()\n   236\t        mutated_upstream_references.reverse()\n   237\t        mutated_artifact_references.reverse()\n   238\t\n   239\t    return {\n   240\t        \"suite_cells\": mutated_cells,\n   241\t        \"work_items\": mutated_work_items,\n   242\t        \"upstream_references\": mutated_upstream_references,\n   243\t        \"artifact_references\": mutated_artifact_references,\n   244\t    }\n   245\t\n   246\t\n   247\tclass ExperimentSuiteContractTest(unittest.TestCase):\n   248\t    def test_default_contract_exposes_milestone15_taxonomy(self) -> None:\n   249\t        metadata = build_experiment_suite_contract_metadata()\n   250\t\n   251\t        self.assertEqual(metadata[\"contract_version\"], EXPERIMENT_SUITE_CONTRACT_VERSION)\n   252\t        self.assertEqual(metadata[\"design_note\"], EXPERIMENT_SUITE_DESIGN_NOTE)\n   253\t        self.assertEqual(\n   254\t            [item[\"dimension_id\"] for item in discover_experiment_suite_dimensions(metadata)],\n   255\t            list(SUPPORTED_DIMENSION_IDS),\n   256\t        )\n   257\t        self.assertEqual(\n   258\t            [\n   259\t                item[\"ablation_family_id\"]\n   260\t                for item in discover_experiment_suite_ablation_families(\n   261\t                    metadata,\n   262\t                    required_only=True,\n   263\t                )\n   264\t            ],\n   265\t            list(SUPPORTED_ABLATION_FAMILY_IDS),\n   266\t        )\n   267\t        self.assertEqual(\n   268\t            get_experiment_suite_dimension_definition(\n   269\t                \"Motion Speed\",\n   270\t                record=metadata,\n   271\t            )[\"dimension_id\"],\n   272\t            MOTION_SPEED_DIMENSION_ID,\n   273\t        )\n   274\t        self.assertEqual(\n   275\t            get_experiment_suite_ablation_family_definition(\n   276\t                \"No Waves\",\n   277\t                record=metadata,\n   278\t            )[\"ablation_family_id\"],\n   279\t            NO_WAVES_ABLATION_FAMILY_ID,\n   280\t        )\n   281\t        self.assertEqual(\n   282\t            [\n   283\t                item[\"artifact_role_id\"]\n   284\t                for item in discover_experiment_suite_artifact_roles(\n   285\t                    metadata,\n   286\t                    artifact_scope=\"Downstream Bundle\",\n   287\t                )\n   288\t            ],\n   289\t            [\n   290\t                SIMULATOR_RESULT_BUNDLE_ROLE_ID,\n   291\t                EXPERIMENT_ANALYSIS_BUNDLE_ROLE_ID,\n   292\t                VALIDATION_BUNDLE_ROLE_ID,\n   293\t                DASHBOARD_SESSION_ROLE_ID,\n   294\t            ],\n   295\t        )\n   296\t\n   297\t        with tempfile.TemporaryDirectory(dir=ROOT) as tmp_dir_str:\n   298\t            metadata_path = Path(tmp_dir_str) / \"experiment_suite_contract.json\"\n   299\t            written_path = write_experiment_suite_contract_metadata(metadata, metadata_path)\n   300\t            self.assertEqual(load_experiment_suite_contract_metadata(written_path), metadata)\n   301\t\n   302\t    def test_fixture_contract_serializes_deterministically_and_discovers_taxonomy(self) -> None:\n   303\t        default_metadata = build_experiment_suite_contract_metadata()\n   304\t        fixture_a = _mutate_contract_fixture(default_metadata, reverse=False)\n   305\t        fixture_b = _mutate_contract_fixture(default_metadata, reverse=True)\n   306\t\n   307\t        metadata_a = build_experiment_suite_contract_metadata(**fixture_a)\n   308\t        metadata_b = build_experiment_suite_contract_metadata(**fixture_b)\n   309\t\n   310\t        self.assertEqual(metadata_a, metadata_b)\n   311\t        self.assertEqual(\n   312\t            [\n   313\t                item[\"dimension_id\"]\n   314\t                for item in discover_experiment_suite_dimensions(metadata_a)\n   315\t            ],\n   316\t            list(SUPPORTED_DIMENSION_IDS),\n   317\t        )\n   318\t        self.assertEqual(\n   319\t            [\n   320\t                item[\"ablation_family_id\"]\n   321\t                for item in discover_experiment_suite_ablation_families(metadata_a)\n   322\t            ],\n   323\t            list(SUPPORTED_ABLATION_FAMILY_IDS),\n   324\t        )\n   325\t\n   326\t    def test_fixture_suite_metadata_serializes_deterministically_and_discovers_cells(self) -> None:\n   327\t        contract_metadata = build_experiment_suite_contract_metadata()\n   328\t        with tempfile.TemporaryDirectory(dir=ROOT) as tmp_dir_str:\n   329\t            temp_root = Path(tmp_dir_str)\n   330\t\n   331\t            upstream_references = [\n   332\t                build_experiment_suite_artifact_reference(\n   333\t                    artifact_role_id=\"Simulation Plan\",\n   334\t                    source_kind=\"Simulation Plan\",\n   335\t                    path=temp_root / \"plans/motion_demo/simulation_plan.json\",\n   336\t                    contract_version=SIMULATION_PLAN_VERSION,\n   337\t                    artifact_id=\"simulation_plan\",\n   338\t                    format=\"json_simulation_plan.v1\",\n   339\t                    artifact_scope=\"contract_metadata\",\n   340\t                ),\n   341\t                build_experiment_suite_artifact_reference(\n   342\t                    artifact_role_id=\"Experiment Manifest Input\",\n   343\t                    source_kind=\"Experiment Manifest\",\n   344\t                    path=temp_root / \"manifests/motion_demo.yaml\",\n   345\t                    artifact_id=\"motion_demo_manifest\",\n   346\t                    format=\"yaml_experiment_manifest.v1\",\n   347\t                    artifact_scope=\"source_manifest\",\n   348\t                ),\n   349\t                bui