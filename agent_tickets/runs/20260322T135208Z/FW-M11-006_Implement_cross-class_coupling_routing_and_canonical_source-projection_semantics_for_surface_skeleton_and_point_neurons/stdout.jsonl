\n   564\t            root_ids=self.root_ids,\n   565\t            states_by_root=states_by_root,\n   566\t            patch_state_by_root={\n   567\t                int(root_id): np.asarray(\n   568\t                    self.coupling_projection_history_by_root[int(root_id)][history_index],\n   569\t                    dtype=np.float64,\n   570\t                )\n   571\t                for root_id in self.root_ids\n   572\t            },\n   573\t        )\n   574\t\n   575\t    def export_readout_values(\n   576\t        self,\n   577\t        *,\n   578\t        summary: Mapping[str, Any],\n   579\t        readout_catalog: Sequence[SimulationReadoutDefinition],\n   580\t    ) -> np.ndarray:\n   581\t        return _surface_wave_readout_values(\n   582\t            summary=summary,\n   583\t            readout_catalog=readout_catalog,\n   584\t        )\n   585\t\n   586\t    def export_readout_trace_values(\n   587\t        self,\n   588\t        *,\n   589\t        readout_catalog: Sequence[SimulationReadoutDefinition],\n   590\t        sample_count: int,\n   591\t    ) -> np.ndarray:\n   592\t        normalized_sample_count = int(sample_count)\n   593\t        if len(self.shared_readout_history) < normalized_sample_count:\n   594\t            raise ValueError(\n   595\t                \"surface-wave shared_readout_history is shorter than the declared sample_count.\"\n   596\t            )\n   597\t        values = np.empty(\n   598\t            (normalized_sample_count, len(readout_catalog)),\n   599\t            dtype=np.float64,\n   600\t        )\n   601\t        for sample_index in range(normalized_sample_count):\n   602\t            values[sample_index, :] = self.export_readout_values(\n   603\t                summary=self.shared_readout_history[sample_index],\n   604\t                readout_catalog=readout_catalog,\n   605\t            )\n   606\t        return values\n   607\t\n   608\t    def export_dynamic_state_vector(\n   609\t        self,\n   610\t        *,\n   611\t        summary: Mapping[str, Any],\n   612\t    ) -> np.ndarray:\n   613\t        return _surface_wave_dynamic_state_vector(\n   614\t            summary=summary,\n   615\t            root_ids=self.root_ids,\n   616\t        )\n   617\t\n   618\t    def export_projection_trace_payload(self) -> dict[str, np.ndarray]:\n   619\t        history_length = len(\n   620\t            self.coupling_projection_history_by_root[int(self.root_ids[0])]\n   621\t        )\n   622\t        payload: dict[str, np.ndarray] = {\n   623\t            \"substep_time_ms\": (\n   624\t                np.arange(history_length, dtype=np.float64)\n   625\t                * float(self.resolved.integration_timestep_ms)\n   626\t                + float(self.resolved.timebase.time_origin_ms)\n   627\t            ),\n   628\t            \"root_ids\": np.asarray(self.root_ids, dtype=np.int64),\n   629\t        }\n   630\t        for root_id in self.root_ids:\n   631\t            payload[f\"root_{int(root_id)}_patch_activation\"] = np.asarray(\n   632\t                self.coupling_projection_history_by_root[int(root_id)],\n   633\t                dtype=np.float64,\n   634\t            )\n   635\t        return payload\n   636\t\n   637\t\n   638\tclass _SingleRootSkeletonGraphRuntime:\n   639\t    def __init__(\n   640\t        self,\n   641\t        *,\n   642\t        asset: SkeletonRuntimeAsset,\n   643\t        integration_timestep_ms: float,\n   644\t        internal_substep_count: int,\n   645\t        wave_speed_sq_scale: float,\n   646\t        restoring_strength_per_ms2: float,\n   647\t        gamma_per_ms: float,\n   648\t    ) -> None:\n   649\t        self.asset = asset\n   650\t        self.integration_timestep_ms = float(integration_timestep_ms)\n   651\t        self.internal_substep_count = int(internal_substep_count)\n   652\t        self.wave_speed_sq_scale = float(wave_speed_sq_scale)\n   653\t        self.restoring_strength_per_ms2 = float(restoring_strength_per_ms2)\n   654\t        self.gamma_per_ms = float(gamma_per_ms)\n   655\t        self._pending_source_value = 0.0\n   656\t        self._current_state: SkeletonGraphState | None = None\n   657\t        self._initial_state_mapping: dict[str, Any] | None = None\n   658\t        self._projection_history: list[np.ndarray] = []\n   659\t\n   660\t    @property\n   661\t    def root_id(self) -> int:\n   662\t        return int(self.asset.root_id)\n   663\t\n   664\t    @property\n   665\t    def current_state(self) -> SkeletonGraphState:\n   666\t        if self._current_state is None:\n   667\t            raise ValueError(\"Skeleton runtime root has not been initialized.\")\n   668\t        return self._current_state\n   669\t\n   670\t    @property\n   671\t    def projection_history(self) -> np.ndarray:\n   672\t        return np.asarray(self._projection_history, dtype=np.float64)\n   673\t\n   674\t    @property\n   675\t    def initial_state_mapping(self) -> dict[str, Any]:\n   676\t        if self._initial_state_mapping is None:\n   677\t            raise ValueError(\"Skeleton runtime root has not been initialized.\")\n   678\t        return copy.deepcopy(self._initial_state_mapping)\n   679\t\n   680\t    def initialize_zero(self) -> None:\n   681\t        state = SkeletonGraphState.zeros(self.asset.node_count)\n   682\t        self.initialize_state(state)\n   683\t\n   684\t    def initialize_state(self, state: Any) -> None:\n   685\t        normalized_state = self._normalize_state(state)\n   686\t        self._current_state = normalized_state\n   687\t        self._pending_source_value = 0.0\n   688\t        self._projection_history = [\n   689\t            np.asarray(normalized_state.activation, dtype=np.float64).copy()\n   690\t        ]\n   691\t        self._initial_state_mapping = normalized_state.as_mapping(\n   692\t            node_ids=self.asset.node_ids,\n   693\t            node_coordinates=self.asset.node_coordinates,\n   694\t            projection_weights=self.asset.readout_weights,\n   695\t        )\n   696\t\n   697\t    def inject_source(self, value: float | None) -> None:\n   698\t        self._pending_source_value = 0.0 if value is None else float(value)\n   699\t\n   700\t    def step_shared(self) -> None:\n   701\t        state = self.current_state.copy()\n   702\t        source_value = float(self._pending_source_value)\n   703\t        source_vector = np.full(self.asset.node_count, source_value, dtype=np.float64)\n   704\t        operator = self.asset.graph_operator\n   705\t        for _ in range(self.internal_substep_count):\n   706\t            acceleration = (\n   707\t                -self.wave_speed_sq_scale\n   708\t                * np.asarray(operator @ state.activation, dtype=np.float64)\n   709\t                - self.restoring_strength_per_ms2 * np.asarray(state.activation, dtype=np.float64)\n   710\t                - self.gamma_per_ms * np.asarray(state.velocity, dtype=np.float64)\n   711\t                + source_vector\n   712\t            )\n   713\t            updated_velocity = (\n   714\t                np.asarray(state.velocity, dtype=np.float64)\n   715\t                + self.integration_timestep_ms * acceleration\n   716\t            )\n   717\t            updated_activation = (\n   718\t                np.asarray(state.activation, dtype=np.float64)\n   719\t                + self.integration_timestep_ms * updated_velocity\n   720\t            )\n   721\t            state = SkeletonGraphState(\n   722\t                resolution=SKELETON_GRAPH_STATE_RESOLUTION,\n   723\t                activation=updated_activation,\n   724\t                velocity=updated_velocity,\n   725\t            )\n   726\t        self._current_state = state\n   727\t        self._pending_source_value = 0.0\n   728\t        self._projection_history.append(\n   729\t            np.asarray(self.current_state.activation, dtype=np.float64).copy()\n   730\t        )\n   731\t\n   732\t    def export_state_mapping(self) -> dict[str, Any]:\n   733\t        return self.current_state.as_mapping(\n   734\t            node_ids=self.asset.node_ids,\n   735\t            node_coordinates=self.asset.node_coordinates,\n   736\t            projection_weights=self.asset.readout_weights,\n   737\t        )\n   738\t\n   739\t    def runtime_metadata(self) -> dict[str, Any]:\n   740\t        metadata = load_skeleton_runtime_asset_metadata(\n   741\t            self.asset.metadata[\"metadata_path\"]\n   742\t        )\n   743\t        return {\n   744\t            \"root_id\": self.root_id,\n   745\t            \"morphology_class\": SKELETON_NEURON_CLASS,\n   746\t            \"state_layout\": str(metadata[\"state_layout\"]),\n   747\t            \"projection_surface\": str(metadata[\"projection_surface\"]),\n   748\t            \"projection_layout\": str(metadata[\"projection_layout\"]),\n   749\t            \"node_count\": int(metadata[\"counts\"][\"node_count\"]),\n   750\t            \"edge_count\": int(metadata[\"counts\"][\"edge_count\"]),\n   751\t            \"asset_hash\": str(metadata[\"asset_hash\"]),\n   752\t            \"asset_contract_version\": str(metadata[\"contract_version\"]),\n   753\t            \"approximation_family\": str(metadata[\"approximation_family\"]),\n   754\t            \"graph_operator_family\": str(metadata[\"graph_operator_family\"]),\n   755\t            \"source_injection_strategy\": str(metadata[\"source_injection_strategy\"]),\n   756\t            \"spectral_radius\": float(metadata[\"operator\"][\"spectral_radius\"]),\n   757\t            \"integration_timestep_ms\": float(self.integration_timestep_ms),\n   758\t            \"internal_substep_count\": int(self.internal_substep_count),\n   759\t        }\n   760\t\n   761\t    def summary_fragment(self) -> dict[str, Any]:\n   762\t        state = self.current_state\n   763\t        weights = np.asarray(self.asset.readout_weights, dtype=np.float64)\n   764\t        return {\n   765\t            \"mean_activation\": float(np.dot(weights, state.activation)),\n   766\t            \"mean_velocity\": float(np.dot(weights, state.velocity)),\n   767\t            \"projection\": np.asarray(state.activation, dtype=np.float64).copy(),\n   768\t        }\n   769\t\n   770\t    def _normalize_state(self, value: Any) -> SkeletonGraphState:\n   771\t        if isinstance(value, SkeletonGraphState):\n   772\t            normalized = value.copy()\n   773\t        elif isinstance(value, Mapping):\n   774\t            normalized = SkeletonGraphState(\n   775\t                resolution=str(value.get(\"resolution\", SKELETON_GRAPH_STATE_RESOLUTION)),\n   776\t                activation=np.asarray(value[\"activation\"], dtype=np.float64),\n   777\t                velocity=np.asarray(value[\"velocity\"], dtype=np.float64),\n   778\t            )\n   779\t        else:\n   780\t            raise ValueError(\n   781\t                \"Skeleton runtime initialization requires SkeletonGraphState or a \"\n   782\t                \"mapping with activation and velocity arrays.\"\n   783\t            )\n   784\t        if normalized.activation.shape[0] != self.asset.node_count:\n   785\t            raise ValueError(\n   786\t                \"Skeleton runtime initialization state does not match the asset node \"\n   787\t                f\"count for root {self.root_id}: got {normalized.activation.shape[0]} \"\n   788\t                f\"and expected {self.asset.node_count}.\"\n   789\t            )\n   790\t        return normalized\n   791\t\n   792\t\n   793\tclass _SingleRootPointNeuronRuntime:\n   794\t    def __init__(\n   795\t        self,\n   796\t        *,\n   797\t        root_id: int,\n   798\t        model_spec: Mapping[str, Any],\n   799\t        integration_timestep_ms: float,\n   800\t    ) -> None:\n   801\t        spec = BaselineFamilySpec.from_mapping(model_spec)\n   802\t        if spec.family != \"P0\":\n   803\t            raise ValueError(\n   804\t                \"Point-neuron placeholders currently support only the canonical \"\n   805\t                \"P0 baseline family.\"\n   806\t            )\n   807\t        parameters = spec.parameters\n   808\t        assert isinstance(parameters, P0BaselineParameters)\n   809\t        self.root_id = int(root_id)\n   810\t        self.spec = spec\n   811\t        self.parameters = parameters\n   812\t        self.integration_timestep_ms = float(integration_timestep_ms)\n   813\t        self._pending_source_value = 0.0\n   814\t        self._current_state: PointNeuronState | None = None\n   815\t        self._initial_state_mapping: dict[str, Any] | None = None\n   816\t        self._projection_history: list[np.ndarray] = []\n   817\t\n   818\t    @property\n   819\t    def current_state(self) -> PointNeuronState:\n   820\t        if self._current_state is None:\n   821\t            raise ValueError(\"Point runtime root has not been initialized.\")\n   822\t        return self._current_state\n   823\t\n   824\t    @property\n   825\t    def projection_history(self) -> np.ndarray:\n   826\t        return np.asarray(self._projection_history, dtype=np.float64)\n   827\t\n   828\t    @property\n   829\t    def initial_state_mapping(self) -> dict[str, Any]:\n   830\t        if self._initial_state_mapping is None:\n   831\t            raise ValueError(\"Point runtime root has not been initialized.\")\n   832\t        return copy.deepcopy(self._initial_state_mapping)\n   833\t\n   834\t    def initialize_zero(self) -> None:\n   835\t        self.initialize_state(PointNeuronState.zeros())\n   836\t\n   837\t    def initialize_state(self, state: Any) -> None:\n   838\t        normalized_state = self._normalize_state(state)\n   839\t        self._current_state = normalized_state\n   840\t        self._pending_source_value = 0.0\n   841\t        self._projection_history = [\n   842\t            np.asarray(normalized_state.activation, dtype=np.float64).copy()\n   843\t        ]\n   844\t        self._initial_state_mapping = normalized_state.as_mapping()\n   845\t\n   846\t    def inject_source(self, value: float | None) -> None:\n   847\t        self._pending_source_value = 0.0 if value is None else float(value)\n   848\t\n   849\t    def step_shared(self) -> None:\n   850\t        state = self.current_state.copy()\n   851\t        source_value = float(self._pending_source_value)\n   852\t        activation = float(state.activation[0])\n   853\t        tau_ms = float(self.parameters.membrane_time_constant_ms)\n   854\t        resting_potential = float(self.parameters.resting_potential)\n   855\t        input_gain = float(self.parameters.input_gain)\n   856\t        delta = (\n   857\t            (-(activation - resting_potential) + input_gain * source_value)\n   858\t            / tau_ms\n   859\t        )\n   860\t        updated_activation = activation + self.integration_timestep_ms * delta\n   861\t        self._current_state = PointNeuronState(\n   862\t            resolution=POINT_NEURON_STATE_RESOLUTION,\n   863\t            activation=np.asarray([updated_activation], dtype=np.float64),\n   864\t            velocity=np.asarray([delta], dtype=np.float64),\n   865\t        )\n   866\t        self._pending_source_value = 0.0\n   867\t        self._projection_history.append(\n   868\t            np.asarray(self.current_state.activation, dtype=np.float64).copy()\n   869\t        )\n   870\t\n   871\t    def export_state_mapping(self) -> dict[str, Any]:\n   872\t        return self.current_state.as_mapping()\n   873\t\n   874\t    def runtime_metadata(self) -> dict[str, Any]:\n   875\t        return {\n   876\t            \"root_id\": self.root_id,\n   877\t            \"morphology_class\": POINT_NEURON_CLASS,\n   878\t            \"state_layout\": str(self.spec.state_layout),\n   879\t            \"projection_surface\": \"root_state_scalar\",\n   880\t            \"projection_layout\": \"single_value_projection\",\n   881\t            \"node_count\