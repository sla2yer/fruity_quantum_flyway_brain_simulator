\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"member_vertex_indptr\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": patch_decomposition.member_vertex_indptr,\\\\\\\\\\\\\\\\n    }\\\\\\\\\\\\\\\\n    patch_graph_payload.update(\\\\\\\\\\\\\\\\n        {\\\\\\\\\\\\\\\\n            f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"adj_{key}\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": value\\\\\\\\\\\\\\\\n            for key, value in _serialize_sparse_matrix(patch_decomposition.patch_adj).items()\\\\\\\\\\\\\\\\n        }\\\\\\\\\\\\\\\\n    )\\\\\\\\\\\\\\\\n    patch_graph_payload.update(\\\\\\\\\\\\\\\\n        {\\\\\\\\\\\\\\\\n            f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"lap_{key}\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": value\\\\\\\\\\\\\\\\n            for key, value in _serialize_sparse_matrix(patch_decomposition.patch_lap).items()\\\\\\\\\\\\\\\\n        }\\\\\\\\\\\\\\\\n    )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    mesh.export(bundle_paths.simplified_mesh_path)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    np.savez_compressed(bundle_paths.surface_graph_path, **surface_graph_payload)\\\\\\\\\\\\\\\\n    np.savez_compressed(bundle_paths.patch_graph_path, **patch_graph_payload)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    simplified_mesh_summary = describe_mesh(mesh, adj=adj)\\\\\\\\\\\\\\\\n    coarse_summary = describe_patch_decomposition(\\\\\\\\\\\\\\\\n        surface_vertex_count=int(vertices.shape[0]),\\\\\\\\\\\\\\\\n        surface_extent=np.asarray(simplified_mesh_summary[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"extent\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"], dtype=np.float64),\\\\\\\\\\\\\\\\n        surface_component_count=int(simplified_mesh_summary[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"component_count\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"]),\\\\\\\\\\\\\\\\n        patch_sizes=patch_decomposition.patch_sizes,\\\\\\\\\\\\\\\\n        patch_centroids=patch_decomposition.patch_centroids,\\\\\\\\\\\\\\\\n        surface_to_patch=patch_decomposition.surface_to_patch,\\\\\\\\\\\\\\\\n        member_vertex_indices=patch_decomposition.member_vertex_in