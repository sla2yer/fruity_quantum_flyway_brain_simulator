  3456\t            f\"surface_wave arm {arm_id!r} solver.family drifted from the normalized \"\n  3457\t            \"surface_wave model metadata.\"\n  3458\t        )\n  3459\t    shared_timebase_mode = _normalize_nonempty_string(\n  3460\t        solver.get(\"shared_timebase_mode\"),\n  3461\t        field_name=\"surface_wave_model.parameter_bundle.solver.shared_timebase_mode\",\n  3462\t    )\n  3463\t    if shared_timebase_mode not in SUPPORTED_SURFACE_WAVE_SHARED_TIMEBASE_MODES:\n  3464\t        raise ValueError(\n  3465\t            f\"surface_wave arm {arm_id!r} only supports solver.shared_timebase_mode \"\n  3466\t            f\"{list(SUPPORTED_SURFACE_WAVE_SHARED_TIMEBASE_MODES)!r}, got \"\n  3467\t            f\"{shared_timebase_mode!r}.\"\n  3468\t        )\n  3469\t    stability_policy = _normalize_nonempty_string(\n  3470\t        solver.get(\"stability_policy\"),\n  3471\t        field_name=\"surface_wave_model.parameter_bundle.solver.stability_policy\",\n  3472\t    )\n  3473\t    if stability_policy not in SUPPORTED_SURFACE_WAVE_STABILITY_POLICIES:\n  3474\t        raise ValueError(\n  3475\t            f\"surface_wave arm {arm_id!r} only supports solver.stability_policy \"\n  3476\t            f\"{list(SUPPORTED_SURFACE_WAVE_STABILITY_POLICIES)!r}, got \"\n  3477\t            f\"{stability_policy!r}.\"\n  3478\t        )\n  3479\t    cfl_safety_factor = _normalize_positive_float(\n  3480\t        solver.get(\"cfl_safety_factor\"),\n  3481\t        field_name=\"surface_wave_model.parameter_bundle.solver.cfl_safety_factor\",\n  3482\t    )\n  3483\t\n  3484\t    operator_family = _normalize_identifier(\n  3485\t        propagation.get(\"operator_family\"),\n  3486\t        field_name=\"surface_wave_model.parameter_bundle.propagation.operator_family\",\n  3487\t    )\n  3488\t    if operator_family not in SUPPORTED_SURFACE_WAVE_OPERATOR_FAMILIES:\n  3489\t        raise ValueError(\n  3490\t            f\"surface_wave arm {arm_id!r} only supports propa