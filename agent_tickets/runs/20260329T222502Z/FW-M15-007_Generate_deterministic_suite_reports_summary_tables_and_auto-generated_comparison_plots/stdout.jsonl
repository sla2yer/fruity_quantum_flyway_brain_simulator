ntegration verification pass and publish a readiness report' \\\n    78\t\t\t'milestone13-readiness Run the Milestone 13 validation-ladder integration verification pass and publish a readiness report' \\\n    79\t\t\t'milestone14-readiness Run the Milestone 14 dashboard integration verification pass and publish a readiness report' \\\n    80\t\t\t'validate-manifest  Validate the example manifest against schema/design lock' \\\n    81\t\t\t'all                Run verify -> registry -> select -> meshes -> assets'\n    82\t\n    83\tbootstrap:\n    84\t\ttest -x .venv/bin/python || python3 -m venv .venv\n    85\t\t./.venv/bin/python -m pip install --upgrade pip\n    86\t\t./.venv/bin/python -m pip install -e .\n    87\t\n    88\tverify:\n    89\t\t$(PYTHON) scripts/00_verify_access.py --config $(CONFIG)\n    90\t\n    91\tregistry:\n    92\t\t$(PYTHON) scripts/build_registry.py --config $(CONFIG)\n    93\t\n    94\tselect:\n    95\t\t$(PYTHON) scripts/01_select_subset.py --config $(CONFIG)\n    96\t\n    97\tmeshes:\n    98\t\t$(PYTHON) scripts/02_fetch_meshes.py --config $(CONFIG)\n    99\t\n   100\tassets:\n   101\t\t$(PYTHON) scripts/03_build_wave_assets.py --config $(CONFIG)\n   102\t\n   103\tpreview:\n   104\t\t$(PYTHON) scripts/05_preview_geometry.py --config $(CONFIG)\n   105\t\n   106\tcoupling-inspect:\n   107\t\t$(PYTHON) scripts/08_coupling_inspection.py --config $(CONFIG) $(COUPLING_INSPECT_ARGS)\n   108\t\n   109\toperator-qa:\n   110\t\t$(PYTHON) scripts/06_operator_qa.py --config $(CONFIG)\n   111\t\n   112\tsimulate:\n   113\t\t$(PYTHON) scripts/run_simulation.py --config $(CONFIG) --manifest $(MANIFEST) --schema $(SCHEMA) --design-lock $(DESIGN_LOCK) $(SIMULATE_ARGS)\n   114\t\n   115\tsuite-run:\n   116\t\t$(PYTHON) scripts/31_run_experiment_suite.py --config $(CONFIG) --schema $(SCHEMA) --design-lock $(DESIGN_LOCK) $(SUITE_RUN_ARGS)\n   117\t\n   118\tsuite-report:\n   119\t\t$(PYTHON) scripts/33_suite_report.py $(SUITE_REPORT_ARGS)\n   120\t\n","ex