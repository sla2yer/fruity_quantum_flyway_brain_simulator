t)\n   106\t\n   107\t    def test_verify_fails_when_secret_sync_raises_runtime_error(self) -> None:\n   108\t        with tempfile.TemporaryDirectory(dir=ROOT) as tmp_dir_str:\n   109\t            tmp_dir = Path(tmp_dir_str)\n   110\t            config_path = _write_verify_config(tmp_dir, fetch_skeletons=False)\n   111\t            stub_dir = _write_verify_stubs(tmp_dir, include_fafbseg=True, include_cloudvolume=True)\n   112\t\n   113\t            result = _run_verify(\n   114\t                config_path,\n   115\t                stub_dir,\n   116\t                env_overrides={\n   117\t                    \"FLYWIRE_TOKEN\": \"secret-token\",\n   118\t                    \"VERIFY_STUB_SECRET_MODE\": \"error\",\n   119\t                },\n   120\t                expect_success=False,\n   121\t            )\n   122\t\n   123\t            self.assertNotEqual(result.returncode, 0)\n   124\t            combined_output = result.stdout + result.stderr\n   125\t            self.assertIn(\"FlyWire token sync failed\", combined_output)\n   126\t            self.assertIn(\"secret-store access\", combined_output)\n   127\t\n   128\t    def test_verify_rejects_invalid_skeleton_config(self) -> None:\n   129\t        with tempfile.TemporaryDirectory(dir=ROOT) as tmp_dir_str:\n   130\t            tmp_dir = Path(tmp_dir_str)\n   131\t            config_path = _write_verify_config(\n   132\t                tmp_dir,\n   133\t                fetch_skeletons=False,\n   134\t                require_skeletons=True,\n   135\t            )\n   136\t            stub_dir = _write_verify_stubs(tmp_dir)\n   137\t\n   138\t            result = _run_verify(config_path, stub_dir, expect_success=False)\n   139\t\n   140\t            self.assertNotEqual(result.returncode, 0)\n   141\t            combined_output = result.stdout + result.stderr\n   142\t            self.assertIn(\"meshing.require_skeletons\", combined_output)\n   143\t            self.assertIn(\"meshing.fetch_skeletons\", combined_output)\n   144\t\n   145\t    def test_verify_succeeds_when_mesh_prerequisites_are_present(self) -> None:\n   146\t        with tempfile.TemporaryDirectory(dir=ROOT) as tmp_dir_str:\n   147\t            tmp_dir = Path(tmp_dir_str)\n   148\t            config_path = _write_verify_config(tmp_dir, fetch_skeletons=True)\n   149\t            stub_dir = _write_verify_stubs(\n   150\t                tmp_dir,\n   151\t                include_fafbseg=True,\n   152\t                include_navis=True,\n   153\t                include_cloudvolume=True,\n   154\t            )\n   155\t\n   156\t            result = _run_verify(config_path, stub_dir)\n   157\t\n   158\t            self.assertEqual(result.returncode, 0)\n   159\t            combined_output = result.stdout + result.stderr\n   160\t            self.assertIn(\"Info service auth: OK\", combined_output)\n   161\t            self.assertIn(\"fafbseg setup: OK\", combined_output)\n   162\t            self.assertIn(\"navis setup: OK\", combined_output)\n   163\t            self.assertIn(\"Mesh preflight looks good.\", combined_output)\n   164\t\n   165\t\n   166\tdef _run_verify(\n   167\t    config_path: Path,\n   168\t    stub_dir: Path,\n   169\t    *,\n   170\t    env_overrides: dict[str, str] | None = None,\n   171\t    extra_args: list[str] | None = None,\n   172\t    expect_success: bool = True,\n   173\t) -> subprocess.CompletedProcess[str]:\n   174\t    env = os.environ.copy()\n   175\t    env[\"FLYWIRE_TOKEN\"] = \"\"\n   176\t    env[\"VERIFY_STUB_INFO_MODE\"] = \"ok\"\n   177\t    env[\"VERIFY_STUB_CAVE_INIT_MODE\"] = \"ok\"\n   178\t    env[\"VERIFY_STUB_SECRET_MODE\"] = \"\"\n   179\t    env[\"VERIFY_STUB_CREDENTIAL_MODE\"] = \"\"\n   180\t    existing_pythonpath = env.get(\"PYTHONPATH\", \"\")\n   181\t    env[\"PYTHONPATH\"] = (\n   182\t        str(stub_dir)\n   183\t        if not existing_pythonpath\n   184\t        else os.pathsep.join([str(stub_dir), existing_pythonpath])\n   185\t    )\n   186\t    if env_overrides:\n   187\t        env.update(env_overrides)\n   188\t\n   189\t    args = [\n   190\t        sys.executable,\n   191\t        str(ROOT / \"scripts\" / \"00_verify_access.py\"),\n   192\t        \"--config\",\n   193\t        str(config_path),\n   194\t    ]\n   195\t    if extra_args:\n   196\t        args.extend(extra_args)\n   197\t\n   198\t    result = subprocess.run(\n   199\t        args,\n   200\t        cwd=ROOT,\n   201\t        env=env,\n   202\t        capture_output=True,\n   203\t        text=True,\n   204\t        check=False,\n   205\t    )\n   206\t    if expect_success and result.returncode != 0:\n   207\t        raise AssertionError(\n   208\t            \"verify script failed unexpectedly\\n\"\n   209\t            f\"stdout:\\n{result.stdout}\\n\"\n   210\t            f\"stderr:\\n{result.stderr}\"\n   211\t        )\n   212\t    return result\n   213\t\n   214\t\n   215\tdef _write_verify_config(\n   216\t    fixture_dir: Path,\n   217\t    *,\n   218\t    fetch_skeletons: bool,\n   219\t    require_skeletons: bool = False,\n   220\t) -> Path:\n   221\t    config_path = fixture_dir / \"verify_config.yaml\"\n   222\t    config_path.write_text(\n   223\t        textwrap.dedent(\n   224\t            f\"\"\"\n   225\t            dataset:\n   226\t              datastack_name: flywire_fafb_public\n   227\t              materialization_version: 783\n   228\t              flywire_dataset: public\n   229\t\n   230\t            meshing:\n   231\t              fetch_skeletons: {\"true\" if fetch_skeletons else \"false\"}\n   232\t              require_skeletons: {\"true\" if require_skeletons else \"false\"}\n   233\t            \"\"\"\n   234\t        ).strip()\n   235\t        + \"\\n\",\n   236\t        encoding=\"utf-8\",\n   237\t    )\n   238\t    return config_path.resolve()\n   239\t\n   240\t\n   241\tdef _write_verify_stubs(\n   242\t    fixture_dir: Path,\n   243\t    *,\n   244\t    include_fafbseg: bool = False,\n   245\t    include_navis: bool = False,\n   246\t    include_cloudvolume: bool = False,\n   247\t) -> Path:\n   248\t    stub_dir = fixture_dir / \"stubs\"\n   249\t    stub_dir.mkdir(parents=True, exist_ok=True)\n   250\t\n   251\t    (stub_dir / \"requests.py\").write_text(\n   252\t        textwrap.dedent(\n   253\t            \"\"\"\n   254\t            class _Response:\n   255\t                def __init__(self, status_code: int, url: str) -> None:\n   256\t                    self.status_code = status_code\n   257\t                    self.url = url\n   258\t\n   259\t\n   260\t            class HTTPError(Exception):\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_59","type":"command_execution","command":"/bin/bash -lc \"nl -ba scripts/00_verify_access.py | sed -n '1,260p'\"","aggregated_output":"     1\t#!/usr/bin/env python3\n     2\tfrom __future__ import annotations\n     3\t\n     4\timport argparse\n     5\timport importlib\n     6\timport os\n     7\timport sys\n     8\timport time\n     9\tfrom pathlib import Path\n    10\tfrom typing import Any, Callable\n    11\t\n    12\tfrom dotenv import load_dotenv\n    13\t\n    14\tROOT = Path(__file__).resolve().parents[1]\n    15\tSRC = ROOT / \"src\"\n    16\tsys.path.insert(0, str(SRC))\n    17\t\n    18\tfrom flywire_wave.auth import ensure_flywire_secret\n    19\tfrom flywire_wave.config import get_config_path, load_config\n    20\t\n    21\t\n    22\tdef _http_status(exc: BaseException) -> int | None:\n    23\t    response = getattr(exc, \"response\", None)\n    24\t    return getattr(response, \"status_code\", None)\n    25\t\n    26\t\n    27\tdef _http_url(exc: BaseException) -> str | None:\n    28\t    response = getattr(exc, \"response\", None)\n    29\t    return getattr(response, \"url\", None)\n    30\t\n    31\t\n    32\tdef _is_transient_http_error(exc: BaseException) -> bool:\n    33\t    status = _http_status(exc)\n    34\t    return status in {429, 502, 503, 504}\n    35\t\n    36\t\n    37\tdef _call_with_retries(label: str, func: Callable[[], Any], attempts: int = 3) -> Any:\n    38\t    try:\n    39\t        import requests\n    40\t    except Exception as exc:\n    41\t        raise RuntimeError(\"requests is required for retry handling.\") from exc\n    42\t\n    43\t    last_exc: BaseException | None = None\n    44\t\n    45\t    for attempt in range(1, attempts + 1):\n    46\t        try:\n    47\t            return func()\n    48\t        except requests.HTTPError as exc:\n    49\t            last_exc = exc\n    50\t            if not _is_transient_http_error(exc) or attempt >= attempts:\n    51\t                raise\n    52\t            wait_seconds = 2 ** (attempt - 1)\n    53\t            status = _http_status(exc)\n    54\t            url = _http_url(exc) or \"<unknown>\"\n    55\t            print(\n    56\t                f\"{label}: transient HTTP {status} from {url}; \"\n    57\t                f\"retrying in {wait_seconds}s ({attempt}/{attempts}).\"\n    58\t            )\n    59\t            time.sleep(wait_seconds)\n    60\t        except (requests.ConnectionError, requests.Timeout) as exc:\n    61\t            last_exc = exc\n    62\t            if attempt >= attempts:\n    63\t                raise\n    64\t            wait_seconds = 2 ** (attempt - 1)\n    65\t            print(\n    66\t                f\"{label}: transient network error ({exc}); \"\n    67\t                f\"retrying in {wait_seconds}s ({attempt}/{attempts}).\"\n    68\t            )\n    69\t            time.sleep(wait_seconds)\n    70\t\n    71\t    if last_exc is not None:\n    72\t        raise last_exc\n    73\t    raise RuntimeError(f\"{label} failed before making a request.\")\n    74\t\n    75\t\n    76\tdef _format_exception(exc: BaseException) -> str:\n    77\t    detail = str(exc).strip()\n    78\t    if detail:\n    79\t        return f\"{type(exc).__name__}: {detail}\"\n    80\t    return type(exc).__name__\n    81\t\n    82\t\n    83\tdef _print_next_step(message: str) -> None:\n    84\t    print(f\"Next step: {message}\")\n    85\t\n    86\t\n    87\tdef _resolved_config_path(cfg: dict[str, Any], fallback: str) -> Path:\n    88\t    config_path = get_config_path(cfg)\n    89\t    if config_path is not None:\n    90\t        return config_path.resolve()\n    91\t    return Path(fallback).expanduser().resolve()\n    92\t\n    93\t\n    94\tdef _fail_missing_dependency(message: str) -> int:\n    95\t    print(message)\n    96\t    _print_next_step(\"run `make bootstrap` in this repo, then rerun `make verify`.\")\n    97\t    return 1\n    98\t\n    99\t\n   100\tdef _handle_http_failure(*, label: str, datastack: str, config_path: Path, exc: BaseException) -> int:\n   101\t    status = _http_status(exc)\n   102\t    url = _http_url(exc) or \"<unknown>\"\n   103\t    if status in {400, 404}:\n   104\t        print(f\"{label} failed for datastack '{datastack}': HTTP {status} from {url}\")\n   105\t        _print_next_step(f\"check `dataset.datastack_name` in {config_path} and retry.\")\n   106\t        return 1\n   107\t    if status in {401, 403}:\n   108\t        print(f\"{label} auth failed for datastack '{datastack}': HTTP {status} from {url}\")\n   109\t        _print_next_step(\"refresh `FLYWIRE_TOKEN` or your local caveclient token, then rerun `make verify`.\")\n   110\t        return 1\n   111\t    if _is_transient_http_error(exc):\n   112\t        print(f\"{label} is temporarily unavailable for datastack '{datastack}': HTTP {status} from {url}\")\n   113\t        _print_next_step(\"retry after the FlyWire service recovers or verify network reachability.\")\n   114\t        return 1\n   115\t    print(f\"{label} failed for datastack '{datastack}': HTTP {status} from {url}\")\n   116\t    _print_next_step(f\"confirm the FlyWire service is reachable and recheck {config_path}.\")\n   117\t    return 1\n   118\t\n   119\t\n   120\tdef _handle_network_failure(*, label: str, datastack: str, exc: BaseException) -> int:\n   121\t    print(f\"{label} hit a network error for datastack '{datastack}': {exc}\")\n   122\t    _print_next_step(\"verify FlyWire network reachability and rerun `make verify`.\")\n   123\t    return 1\n   124\t\n   125\t\n   126\tdef _handle_unexpected_service_failure(*, label: str, datastack: str, config_path: Path, exc: BaseException) -> int:\n   127\t    print(f\"{label} failed for datastack '{datastack}': {_format_exception(exc)}\")\n   128\t    _print_next_step(f\"check the FlyWire config in {config_path} and rerun `make verify`.\")\n   129\t    return 1\n   130\t\n   131\t\n   132\tdef _check_materialize_access(*, client: Any, version: int, datastack: str) -> int:\n   133\t    try:\n   134\t        import requests\n   135\t    except Exception:\n   136\t        return _fail_missing_dependency(\n   137\t            \"requests is required for the optional materialize probe.\"\n   138\t        )\n   139\t\n   140\t    try:\n   141\t        versions = _call_with_retries(\"Materialize version lookup\", client.materialize.get_versions)\n   142\t        tables = _call_with_retries(\"Materialize table lookup\", client.materialize.get_tables)\n   143\t    except requests.HTTPError as exc:\n   144\t        status = _http_status(exc)\n   145\t        url = _http_url(exc) or \"<unknown>\"\n   146\t        if _is_transient_http_error(exc):\n   147\t            print(\n   148\t                \"Materialize access is temporarily unavailable \"\n   149\t                f\"for datastack '{datastack}': HTTP {status} from {url}\"\n   150\t            )\n   151\t            _print_next_step(\"retry after the FlyWire materialize service recovers.\")\n   152\t            return 1\n   153\t        print(f\"Materialize access failed for datastack '{datastack}': HTTP {status} from {url}\")\n   154\t        _print_next_step(\"confirm the configured materialization service is reachable and retry.\")\n   155\t        return 1\n   156\t    except (requests.ConnectionError, requests.Timeout) as exc:\n   157\t        print(f\"Materialize access hit a network error for datastack '{datastack}': {exc}\")\n   158\t        _print_next_step(\"verify FlyWire network reachability and rerun `make verify`.\")\n   159\t        return 1\n   160\t    except Exception as exc:\n   161\t        print(f\"Materialize access failed for datastack '{datastack}': {_format_exception(exc)}\")\n   162\t        _print_next_step(\"confirm the configured materialization service is reachable and retry.\")\n   163\t        return 1\n   164\t\n   165\t    print(f\"Requested version: {version}\")\n   166\t    print(f\"Materialization versions visible: {versions}\")\n   167\t    print(f\"Tables: {tables}\")\n   168\t    print(\"Materialize access: OK\")\n   169\t\n   170\t    if int(version) not in [int(v) for v in versions]:\n   171\t        print(f\"Requested materialization version {version} is not visible in this environment.\")\n   172\t        _print_next_step(\"set `dataset.materialization_version` to a visible version and rerun `make verify`.\")\n   173\t        return 1\n   174\t    return 0\n   175\t\n   176\t\n   177\tdef _check_mesh_prerequisites(\n   178\t    *,\n   179\t    flywire_dataset: str,\n   180\t    fetch_skeletons: bool,\n   181\t    token: str,\n   182\t    config_path: Path,\n   183\t) -> int:\n   184\t    if token:\n   185\t        try:\n   186\t            token_sync = ensure_flywire_secret(token)\n   187\t        except Exception as exc:\n   188\t            detail = _format_exception(exc)\n   189\t            print(f\"FlyWire token sync failed for `.env` `FLYWIRE_TOKEN`: {detail}\")\n   190\t            detail_lower = detail.lower()\n   191\t            if \"cloudvolume\" in detail_lower:\n   192\t                _print_next_step(\n   193\t                    \"install `cloudvolume` in the active environment, or run `make bootstrap`, then rerun `make verify`.\"\n   194\t                )\n   195\t            elif \"fafbseg\" in detail_lower:\n   196\t                _print_next_step(\n   197\t                    \"install `fafbseg` in the active environment, or run `make bootstrap`, then rerun `make verify`.\"\n   198\t                )\n   199\t            else:\n   200\t                _print_next_step(\n   201\t                    \"check `.env` `FLYWIRE_TOKEN` and local CAVE/cloudvolume secret-store access, then rerun `make verify`.\"\n   202\t                )\n   203\t            return 1\n   204\t\n   205\t        if token_sync == \"updated\":\n   206\t            print(\"FlyWire token sync: updated local secret storage\")\n   207\t        elif token_sync == \"already-configured\":\n   208\t            print(\"FlyWire token sync: already configured\")\n   209\t        else:\n   210\t            print(\"FlyWire token sync: skipped (no `.env` token)\")\n   211\t\n   212\t    try:\n   213\t        flywire = importlib.import_module(\"fafbseg.flywire\")\n   214\t    except Exception:\n   215\t        return _fail_missing_dependency(\n   216\t            \"fafbseg is required for FlyWire mesh access before `make meshes` can run.\"\n   217\t        )\n   218\t\n   219\t    try:\n   220\t        flywire.set_default_dataset(flywire_dataset)\n   221\t    except Exception as exc:\n   222\t        print(f\"FlyWire dataset setup failed for dataset '{flywire_dataset}': {_format_exception(exc)}\")\n   223\t        _print_next_step(\n   224\t            f\"set `dataset.flywire_dataset` to a fafbseg-supported value in {config_path} and rerun `make verify`.\"\n   225\t        )\n   226\t        return 1\n   227\t    print(\"fafbseg setup: OK\")\n   228\t\n   229\t    if fetch_skeletons:\n   230\t        try:\n   231\t            importlib.import_module(\"navis\")\n   232\t        except Exception:\n   233\t            print(\"navis is required because `meshing.fetch_skeletons` is enabled.\")\n   234\t            _print_next_step(\n   235\t                f\"install `navis`, or set `meshing.fetch_skeletons: false` in {config_path}, before running `make meshes`.\"\n   236\t            )\n   237\t            return 1\n   238\t        print(\"navis setup: OK\")\n   239\t    else:\n   240\t        print(\"navis setup: skipped (`meshing.fetch_skeletons` is false)\")\n   241\t\n   242\t    return 0\n   243\t\n   244\t\n   245\tdef main() -> int:\n   246\t    parser = argparse.ArgumentParser(\n   247\t        description=\"Verify the active FlyWire/CAVE mesh preflight for FAFB public.\"\n   248\t    )\n   249\t    parser.add_argument(\"--config\", required=True)\n   250\t    parser.add_argument(\n   251\t        \"--require-materialize\",\n  