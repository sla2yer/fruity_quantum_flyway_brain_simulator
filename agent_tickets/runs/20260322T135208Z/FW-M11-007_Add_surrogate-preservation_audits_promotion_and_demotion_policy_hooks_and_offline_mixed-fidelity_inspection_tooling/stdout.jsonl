rmalized = _normalize_reference_root(spec)\n   466\t            root_id = int(normalized[\"root_id\"])\n   467\t            if root_id not in assignment_by_root:\n   468\t                raise ValueError(\n   469\t                    f\"Mixed-fidelity inspection requested unknown root_id {root_id!r}.\"\n   470\t                )\n   471\t            _validate_reference_root_higher_fidelity(\n   472\t                assignment=assignment_by_root[root_id],\n   473\t                reference_morphology_class=str(\n   474\t                    normalized[\"reference_morphology_class\"]\n   475\t                ),\n   476\t            )\n   477\t            resolved[root_id] = {\n   478\t                \"root_id\": root_id,\n   479\t                \"reference_morphology_class\": str(\n   480\t                    normalized[\"reference_morphology_class\"]\n   481\t                ),\n   482\t                \"reference_source\": \"explicit_reference_root\",\n   483\t            }\n   484\t    if not resolved:\n   485\t        for assignment in mixed_fidelity_plan[\"per_root_assignments\"]:\n   486\t            policy_evaluation = dict(assignment.get(\"policy_evaluation\", {}))\n   487\t            reference_class = policy_evaluation.get(\"recommended_morphology_class\")\n   488\t            if reference_class is None:\n   489\t                continue\n   490\t            if _morphology_class_rank(str(reference_class)) <= _morphology_class_rank(\n   491\t                str(assignment[\"realized_morphology_class\"])\n   492\t            ):\n   493\t                continue\n   494\t            root_id = int(assignment[\"root_id\"])\n   495\t            resolved[root_id] = {\n   496\t                \"root_id\": root_id,\n   497\t                \"reference_morphology_class\": str(reference_class),\n   498\t                \"reference_source\": \"policy_recommendation\",\n   499\t            }\n   500\t    if not resolved:\n   501\t        for assignment in mixed_fidelity