ted_analysis_bundle_id,\n   743\t        }:\n   744\t            continue\n   745\t        target_arm_ids = {\n   746\t            str(arm_id)\n   747\t            for arm_id in metadata[\"validation_plan_reference\"].get(\"target_arm_ids\", [])\n   748\t        }\n   749\t        baseline_arm_id, wave_arm_id = selected_arm_ids\n   750\t        if target_arm_ids and (\n   751\t            (baseline_arm_id is not None and baseline_arm_id not in target_arm_ids)\n   752\t            or (wave_arm_id is not None and wave_arm_id not in target_arm_ids)\n   753\t        ):\n   754\t            continue\n   755\t        filtered.append(metadata)\n   756\t    if not filtered:\n   757\t        raise ValueError(\n   758\t            \"Dashboard session planning could not find a validation_bundle aligned with \"\n   759\t            f\"analysis bundle {expected_analysis_bundle_id!r}.\"\n   760\t        )\n","exit_code":0,"status":"completed"}}
