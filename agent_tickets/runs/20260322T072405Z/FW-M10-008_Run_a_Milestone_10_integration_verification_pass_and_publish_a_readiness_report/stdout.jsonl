\\\\\\\\\"], \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"operator_bundle.v1\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n                self.assertEqual(\\\\\\\\\\\\\\\\n                    manifest[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"101\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"][\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"operator_bundle\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"][\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"transfer_operators\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"][\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"coarse_to_fine_prolongation\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"][\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"path\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"],\\\\\\\\\\\\\\\\n                    str(transfer_operator_path.resolve()),\\\\\\\\\\\\\\\\n                )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    def test_build_wave_assets_rejects_selected_root_ids_missing_from_registry(self) -> None:\\\\\\\\\\\\\\\\n        with tempfile.TemporaryDirectory(dir=ROOT) as fixture_dir_str:\\\\\\\\\\\\\\\\n            fixture_dir = Path(fixture_dir_str)\\\\\\\\\\\\\\\\n            fixture_rel = fixture_dir.relative_to(ROOT)\\\\\\\\\\\\\\\\n            with tempfile.TemporaryDirectory() as outside_dir_str:\\\\\\\\\\\\\\\\n                outside_dir = Path(outside_dir_str)\\\\\\\\\\\\\\\\n                config_path = _write_pipeline_fixture(fixture_dir, fixture_rel)\\\\\\\\\\\\\\\\n                stub_dir = _write_stub_dependencies(fixture_dir)\\\\\\\\\\\\\\\\n                env = os.environ.copy()\\\\\\\\\\\\\\\\n                env[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"FLYWIRE_TOKEN\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n                existing_pythonpath = env.get(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"PYTHONPATH\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n                env[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"PYTHONPATH\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] = (\\\\\\\\\\\\\\\\n                    str(stub_dir)\\\\\\\\\\\\\\\\