_paths.surface_graph_path, **surface_graph_payload)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    np.savez_compressed(bundle_paths.patch_graph_path, **patch_graph_payload)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    simplified_mesh_summary = describe_mesh(mesh, adj=adj)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    coarse_summary = describe_patch_decomposition(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        surface_vertex_count=int(vertices.shape[0]),\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        surface_extent=np.asarray(simplified_mesh_summary[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"extent\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"], dtype=np.float64),\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        surface_component_count=int(simplified_mesh_summary[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"component_count\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"]),\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        patch_sizes=patch_decomposition.patch_sizes,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        patch_centroids=patch_decomposition.patch_centroids,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        surface_to_patch=patch_decomposition.surface_to_patch,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        member_vertex_indices=patch_decomposition.member_vertex_indices,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        patch_adj=patch_decomposition.patch_adj,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    )\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    skeleton_summary = describe_skeleton(bundle_paths.raw_skeleton_path)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    descriptor_payload = build_descriptor_payload(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        root_id=root_id,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        raw_mesh_summary=raw_mesh_summary,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        simplified_mesh_summary=simplified_mesh_summary,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        coarse_summary=coarse_summary,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        skeleton_summary=skeleton_summary,\\\\\\\\\\