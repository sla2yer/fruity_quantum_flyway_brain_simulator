        (processed_coupling_dir / \\\"synapse_registry.csv\\\").resolve(),\\n   151\\t        )\\n   152\\t        self.assertEqual(\\n   153\\t            discovered_paths[INCOMING_ANCHOR_MAP_KEY],\\n   154\\t            (processed_coupling_dir / \\\"roots/101_incoming_anchor_map.npz\\\").resolve(),\\n   155\\t        )\\n   156\\t        self.assertEqual(\\n   157\\t            discovered_paths[OUTGOING_ANCHOR_MAP_KEY],\\n   158\\t            (processed_coupling_dir / \\\"roots/101_outgoing_anchor_map.npz\\\").resolve(),\\n   159\\t        )\\n   160\\t        self.assertEqual(\\n   161\\t            discovered_paths[COUPLING_INDEX_KEY],\\n   162\\t            (processed_coupling_dir / \\\"roots/101_coupling_index.json\\\").resolve(),\\n   163\\t        )\\n   164\\t\\n   165\\t        discovered_edge_bundles = discover_edge_coupling_bundle_paths(manifest[\\\"101\\\"])\\n   166\\t        self.assertEqual(\\n   167\\t            [\\n   168\\t                (item[\\\"pre_root_id\\\"], item[\\\"post_root_id\\\"], item[\\\"relation_to_root\\\"], item[\\\"path\\\"])\\n   169\\t                for item in discovered_edge_bundles\\n   170\\t            ],\\n   171\\t            [\\n   172\\t                (\\n   173\\t                    101,\\n   174\\t                    303,\\n   175\\t                    \\\"outgoing\\\",\\n   176\\t                    (processed_coupling_dir / \\\"edges/101__to__303_coupling.npz\\\").resolve(),\\n   177\\t                ),\\n   178\\t                (\\n   179\\t                    202,\\n   180\\t                    101,\\n   181\\t                    \\\"incoming\\\",\\n   182\\t                    (processed_coupling_dir / \\\"edges/202__to__101_coupling.npz\\\").resolve(),\\n   183\\t                ),\\n   184\\t            ],\\n   185\\t        )\\n   186\\t\\n   187\\t        operator_paths = discover_operator_bundle_paths(manifest[\\\"101\\\"])\\n   188\\t        self.assertEqual(\\n   189\\t            operator_paths[TRA