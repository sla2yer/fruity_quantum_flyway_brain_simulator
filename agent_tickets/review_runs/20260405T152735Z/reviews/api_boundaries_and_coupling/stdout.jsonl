oard_session(plan)\n   202\t    if args.open:\n   203\t        packaged[\"browser_opened\"] = bool(webbrowser.open(packaged[\"app_shell_file_url\"], new=2))\n   204\t    else:\n   205\t        packaged[\"browser_opened\"] = False\n   206\t    return packaged\n   207\t\n   208\t\n   209\tdef _open_packaged_dashboard(\n   210\t    metadata_path: Path,\n   211\t    *,\n   212\t    open_browser: bool = True,\n   213\t) -> dict[str, object]:\n   214\t    metadata = load_dashboard_session_metadata(metadata_path)\n   215\t    bundle_paths = discover_dashboard_session_bundle_paths(metadata)\n   216\t    app_shell_path = bundle_paths[APP_SHELL_INDEX_ARTIFACT_ID].resolve()\n   217\t    file_url = app_shell_path.as_uri()\n   218\t    return {\n   219\t        \"metadata_path\": str(metadata_path.resolve()),\n   220\t        \"app_shell_path\": str(app_shell_path),\n   221\t        \"app_shell_file_url\": file_url,\n   222\t        \"browser_opened\": bool(webbrowser.open(file_url, new=2)) if open_browser else False,\n   223\t    }\n   224\t\n   225\t\n   226\tdef _export_dashboard(args: argparse.Namespace) -> dict[str, object]:\n   227\t    export_kwargs = {\n   228\t        \"dashboard_session_metadata_path\": Path(args.dashboard_session_metadata),\n   229\t        \"export_target_id\": args.export_target_id,\n   230\t        \"pane_id\": args.pane_id,\n   231\t        \"sample_index\": args.sample_index,\n   232\t        \"selected_neuron_id\": args.selected_neuron_id,\n   233\t        \"selected_readout_id\": args.selected_readout_id,\n   234\t        \"active_overlay_id\": args.active_overlay_id,\n   235\t        \"comparison_mode\": args.comparison_mode,\n   236\t        \"active_arm_id\": args.active_arm_id,\n   237\t    }\n   238\t    return execute_dashboard_export(\n   239\t        **{key: value for key, value in export_kwargs.items() if value is not None}\n   240\t    )\n   241\t\n   242\t\n   243\tif __name__ == \"__main__\":\n   244\t    raise SystemExit(main())\n"