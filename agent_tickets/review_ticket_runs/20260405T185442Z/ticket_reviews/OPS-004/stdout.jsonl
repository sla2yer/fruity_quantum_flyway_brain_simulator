eturncode']})\"\n   592\t            progress_callback(f\"[specialization:{prompt_set.slug}] finished: {status_text}\")\n   593\t        return result\n   594\t\n   595\t    specialization_results = _run_parallel_stage(\n   596\t        selected_prompt_sets,\n   597\t        stage=\"specialization\",\n   598\t        max_workers=worker_count,\n   599\t        worker=run_specialization,\n   600\t        progress_callback=progress_callback,\n   601\t    )\n   602\t\n   603\t    successful_specializations = [\n   604\t        result for result in specialization_results if result.get(\"returncode\") == 0\n   605\t    ]\n   606\t    specialization_failures = [\n   607\t        result for result in specialization_results if result.get(\"returncode\") != 0\n   608\t    ]\n   609\t\n   610\t    review_results: list[dict[str, Any]] = []\n   611\t    if successful_specializations and (continue_on_error or not specialization_failures):\n   612\t        specialization_by_slug = {\n   613\t            result[\"prompt_set\"]: result for result in successful_specializations\n   614\t        }\n   615\t\n   616\t        def run_review(prompt_set: ReviewPromptSet) -> dict[str, Any]:\n   617\t            specialization_result = specialization_by_slug[prompt_set.slug]\n   618\t            stage_output_dir = output_dir / \"reviews\" / prompt_set.slug\n   619\t            specialized_prompt_path = Path(specialization_result[\"specialized_prompt_path\"])\n   620\t            specialized_prompt_text = specialized_prompt_path.read_text(encoding=\"utf-8\")\n   621\t\n   622\t            if progress_callback is not None:\n   623\t                progress_callback(f\"[review:{prompt_set.slug}] starting\")\n   624\t\n   625\t            result = job_runner(\n   626\t                f\"review_{prompt_set.slug}\",\n   627\t                prompt_text=build_review_execution_prompt(\n   628\t                    prompt_set,\n   629\t                    repo_root=repo_root,\n   630\t                