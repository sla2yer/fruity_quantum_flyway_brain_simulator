atus\"] != ASSET_STATUS_READY:\n  3050\t            raise ValueError(\n  3051\t                f\"Selected root {root_id} has coupling_bundle status \"\n  3052\t                f\"{coupling_bundle['status']!r}, expected 'ready'.\"\n  3053\t            )\n  3054\t        bundle_paths = discover_coupling_bundle_paths(record)\n  3055\t        coupling_asset_records = {\n  3056\t            asset_key: _asset_record_reference(\n  3057\t                {\n  3058\t                    \"path\": str(Path(asset_path).resolve()),\n  3059\t                    \"status\": str(coupling_bundle[\"assets\"][asset_key][\"status\"]),\n  3060\t                },\n  3061\t                field_name=(\n  3062\t                    f\"geometry_manifest[{root_id}].coupling_bundle.assets.{asset_key}\"\n  3063\t                ),\n  3064\t            )\n  3065\t            for asset_key, asset_path in bundle_paths.items()\n  3066\t        }\n  3067\t        missing_required_assets = [\n  3068\t            asset_key\n  3069\t            for asset_key, asset_record in coupling_asset_records.items()\n  3070\t            if not bool(asset_record[\"exists\"])\n  3071\t        ]\n  3072\t        if missing_required_assets:\n  3073\t            raise ValueError(\n  3074\t                f\"Selected root {root_id} is missing local coupling assets \"\n  3075\t                f\"{missing_required_assets!r} under {geometry_manifest_path}.\"\n  3076\t            )\n  3077\t        edge_bundles = discover_edge_coupling_bundle_paths(record)\n  3078\t        edge_bundle_records = [\n  3079\t            {\n  3080\t                \"pre_root_id\": int(edge_bundle[\"pre_root_id\"]),\n  3081\t                \"post_root_id\": int(edge_bundle[\"post_root_id\"]),\n  3082\t                \"peer_root_id\": int(edge_bundle[\"peer_root_id\"]),\n  3083\t                \"relation_to_root\": str(edge_bundle[\"relation_to_root\"]),\n  3084\t                \"path\": str(Path(edge_bundle[\"path\"]).resolve()),\n  3085\t                \"status\": str(edge_bundle[\"status\"]),\n  3086\t                \"exists\": Path(edge_bundle[\"path\"]).exists(),\n  3087\t                \"selected_peer\": int(edge_bundle[\"peer_root_id\"]) in selected_root_set,\n  3088\t            }\n  3089\t            for edge_bundle in edge_bundles\n  3090\t        ]\n  3091\t        missing_edge_paths = [\n  3092\t            str(edge_bundle[\"path\"])\n  3093\t            for edge_bundle in edge_bundle_records\n  3094\t            if str(edge_bundle[\"status\"]) == ASSET_STATUS_READY\n  3095\t            and not bool(edge_bundle[\"exists\"])\n  3096\t        ]\n  3097\t        if missing_edge_paths:\n  3098\t            raise ValueError(\n  3099\t                f\"Selected root {root_id} is missing ready edge coupling bundles \"\n  3100\t                f\"{missing_edge_paths!r}.\"\n  3101\t            )\n  3102\t        per_root_assets.append(\n  3103\t            {\n  3104\t                \"root_id\": root_id,\n  3105\t                \"cell_type\": str(record.get(\"cell_type\", \"\")),\n  3106\t                \"project_role\": str(record.get(\"project_role\", \"\")),\n  3107\t                \"geometry_asset_records\": geometry_asset_records,\n  3108\t                \"operator_bundle_status\": str(operator_bundle[\"status\"]),\n  3109\t                \"operator_asset_records\": operator_asset_records,\n  3110\t                \"required_operator_assets\": {\n  3111\t                    asset_key: str(operator_asset_records[asset_key][\"path\"])\n  3112\t                    for asset_key in operator_asset_records\n  3113\t                },\n  3114\t                \"descriptor_sidecar_path\": str(\n  3115\t                    Path(str(record.get(\"descriptor_sidecar_path\", \"\"))).resolve()\n  3116\t                ),\n  3117\t                \"qa_sidecar_path\": str(\n  3118\t                    Path(str(record.get(\"qa_sidecar_path\", \"\"))).resolve()\n  3119\t                ),\n  3120\t    