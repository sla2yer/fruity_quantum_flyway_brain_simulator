  108\t    sanitized = mesh.copy()\n   109\t    faces = np.asarray(sanitized.faces, dtype=np.int64)\n   110\t    original_face_count = int(faces.shape[0])\n   111\t    original_vertex_count = int(np.asarray(sanitized.vertices).shape[0])\n   112\t    cleanup = {\n   113\t        \"original_face_count\": original_face_count,\n   114\t        \"sanitized_face_count\": original_face_count,\n   115\t        \"removed_face_count\": 0,\n   116\t        \"removed_invalid_index_face_count\": 0,\n   117\t        \"removed_repeated_vertex_face_count\": 0,\n   118\t        \"removed_zero_area_face_count\": 0,\n   119\t        \"removed_duplicate_face_count\": 0,\n   120\t        \"original_vertex_count\": original_vertex_count,\n   121\t        \"sanitized_vertex_count\": original_vertex_count,\n   122\t    }\n   123\t    if faces.ndim != 2 or faces.shape[0] == 0 or faces.shape[1] != 3:\n   124\t        return sanitized, cleanup\n   125\t\n   126\t    vertex_count = original_vertex_count\n   127\t    valid_index_mask = np.all((faces >= 0) & (faces < vertex_count), axis=1)\n   128\t    repeated_vertex_mask = valid_index_mask & (\n   129\t        (faces[:, 0] == faces[:, 1]) | (faces[:, 1] == faces[:, 2]) | (faces[:, 0] == faces[:, 2])\n   130\t    )\n   131\t    area_candidate_mask = valid_index_mask & ~repeated_vertex_mask\n   132\t    positive_area_mask = np.zeros(faces.shape[0], dtype=bool)\n   133\t    if np.any(area_candidate_mask):\n   134\t        area_faces = faces[area_candidate_mask]\n   135\t        vertices = np.asarray(sanitized.vertices, dtype=np.float64)\n   136\t        areas = np.linalg.norm(\n   137\t            np.cross(\n   138\t                vertices[area_faces[:, 1]] - vertices[area_faces[:, 0]],\n   139\t                vertices[area_faces[:, 2]] - vertices[area_faces[:, 0]],\n   140\t            ),\n   141\t            axis=1,\n   142\t        ) / 2.0\n   143\t        positive_area_mask[area_candidate_mask] = areas > _MESH_FACE_AREA_EPSILON\n   144\t   