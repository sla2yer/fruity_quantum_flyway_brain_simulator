lies.P1.delay_handling.max_supported_delay_steps\",\n  2651\t        )\n  2652\t    return defaults\n  2653\t\n  2654\t\n  2655\tdef _normalize_arm_fidelity_assignment(\n  2656\t    payload: Any,\n  2657\t    *,\n  2658\t    field_name: str,\n  2659\t) -> dict[str, Any]:\n  2660\t    if payload is None:\n  2661\t        return {\n  2662\t            \"default_morphology_class\": None,\n  2663\t            \"root_overrides\": [],\n  2664\t            \"root_overrides_by_root\": {},\n  2665\t        }\n  2666\t    if not isinstance(payload, Mapping):\n  2667\t        raise ValueError(f\"{field_name} must be a mapping when provided.\")\n  2668\t\n  2669\t    raw_payload = dict(payload)\n  2670\t    unknown_keys = sorted(set(raw_payload) - ALLOWED_ARM_FIDELITY_ASSIGNMENT_KEYS)\n  2671\t    if unknown_keys:\n  2672\t        raise ValueError(\n  2673\t            f\"{field_name} contains unsupported keys: {unknown_keys!r}.\"\n  2674\t        )\n  2675\t\n  2676\t    default_morphology_class = None\n  2677\t    if raw_payload.get(\"default_morphology_class\") is not None:\n  2678\t        default_morphology_class = normalize_hybrid_morphology_class(\n  2679\t            raw_payload[\"default_morphology_class\"],\n  2680\t            field_name=f\"{field_name}.default_morphology_class\",\n  2681\t        )\n  2682\t\n  2683\t    root_overrides_payload = raw_payload.get(\"root_overrides\", ())\n  2684\t    if root_overrides_payload is None:\n  2685\t        root_overrides_payload = ()\n  2686\t    root_overrides: list[dict[str, Any]] = []\n  2687\t    root_overrides_by_root: dict[int, str] = {}\n  2688\t    for index, item in enumerate(\n  2689\t        _require_sequence(\n  2690\t            root_overrides_payload,\n  2691\t            field_name=f\"{field_name}.root_overrides\",\n  2692\t        )\n  2693\t    ):\n  2694\t        override = _require_mapping(\n  2695\t            item,\n  2696\t            field_name=f\"{field_name}.root_overrides[{index}]\",\n  2697\t        )\n  2698\t        override_unknown_keys = sorted(\n  2699\t            set(override) - ALLOWED_ARM_FIDELITY_OVERRIDE_KEYS\n  2700\t        )\n  2701\t        if override_unknown_keys:\n  2702\t            raise ValueError(\n  2703\t                f\"{field_name}.root_overrides[{index}] contains unsupported keys: \"\n  2704\t                f\"{override_unknown_keys!r}.\"\n  2705\t            )\n  2706\t        if \"root_id\" not in override:\n  2707\t            raise ValueError(\n  2708\t                f\"{field_name}.root_overrides[{index}] requires root_id.\"\n  2709\t            )\n  2710\t        if \"morphology_class\" not in override:\n  2711\t            raise ValueError(\n  2712\t                f\"{field_name}.root_overrides[{index}] requires morphology_class.\"\n  2713\t            )\n  2714\t        root_id = int(override[\"root_id\"])\n  2715\t        if root_id in root_overrides_by_root:\n  2716\t            raise ValueError(\n  2717\t                f\"{field_name}.root_overrides contains duplicate root_id {root_id}.\"\n  2718\t            )\n  2719\t        morphology_class = normalize_hybrid_morphology_class(\n  2720\t            override[\"morphology_class\"],\n  2721\t            field_name=f\"{field_name}.root_overrides[{index}].morphology_class\",\n  2722\t        )\n  2723\t        root_overrides_by_root[root_id] = morphology_class\n  2724\t        root_overrides.append(\n  2725\t            {\n  2726\t                \"root_id\": root_id,\n  2727\t                \"morphology_class\": morphology_class,\n  2728\t            }\n  2729\t        )\n  2730\t    root_overrides.sort(key=lambda item: int(item[\"root_id\"]))\n  2731\t    return {\n  2732\t        \"default_morphology_class\": default_morphology_class,\n  2733\t        \"root_overrides\": root_overrides,\n  2734\t        \"root_overrides_by_root\": root_overrides_by_root,\n  2735\t    }\n  2736\t\n  2737\t\n  2738\tdef _resolve_selection_reference(\n  2739\t    *,\n  2740\t    manifest: Mapping[str, Any],\n  2741\t    cfg: Mapping[str, Any],\n  2742\t) -> dict[str, Any]:\n  2743\t    selected_root_ids_path = Path(cfg[\"paths\"][\"selected_root_ids\"]).resolve()\n  2744\t    if not selected_root_ids_path.exists():\n  2745\t        raise ValueError(\n  2746\t            f\"Selected-root roster is missing at {selected_root_ids_path}.\"\n  2747\t        )\n  2748\t    root_ids = read_root_ids(selected_root_ids_path)\n  2749\t    if not root_ids:\n  2750\t        raise ValueError(\n  2751\t            f\"Selected-root roster at {selected_root_ids_path} is empty.\"\n  2752\t        )\n  2753\t    normalized_root_ids = sorted(int(root_id) for root_id in root_ids)\n  2754\t    if len(set(normalized_root_ids)) != len(normalized_root_ids):\n  2755\t        raise ValueError(\n  2756\t            f\"Selected-root roster at {selected_root_ids_path} contains duplicate root IDs.\"\n  2757\t        )\n  2758\t\n  2759\t    subset_name = manifest.get(\"subset_name\")\n  2760\t    circuit_name = manifest.get(\"circuit_name\")\n  2761\t    selection_cfg = dict(cfg.get(\"selection\", {}))\n  2762\t    active_preset = selection_cfg.get(\"active_preset\")\n  2763\t    if subset_name is not None and active_preset is not None:\n  2764\t        normalized_subset_name = _normalize_identifier(\n  2765\t            subset_name,\n  2766\t            field_name=\"manifest.subset_name\",\n  2767\t        )\n  2768\t        normalized_active_preset = _normalize_identifier(\n  2769\t            active_preset,\n  2770\t            field_name=\"config.selection.active_preset\",\n  2771\t        )\n  2772\t        if normalized_subset_name != normalized_active_preset:\n  2773\t            raise ValueError(\n  2774\t                \"Manifest subset_name and config selection.active_preset disagree: \"\n  2775\t                f\"{normalized_subset_name!r} != {normalized_active_preset!r}.\"\n  2776\t            )\n  2777\t\n  2778\t    subset_manifest_reference = _resolve_subset_manifest_reference(\n  2779\t        subset_name=subset_name,\n  2780\t        subset_output_dir=Path(cfg[\"paths\"][\"subset_output_dir\"]).resolve(),\n  2781\t        expected_root_ids=normalized_root_ids,\n  2782\t    )\n  2783\t    root_id_roster_hash = _stable_hash(normalized_root_ids)\n  2784\t\n  2785\t    return {\n  2786\t        \"identity_kind\": \"subset\" if subset_name is not None else \"circuit\",\n  2787\t        \"subset_name\": (\n  2788\t            _normalize_identifier(subset_name, field_name=\"manifest.subset_name\")\n  2789\t            if subset_name is not None\n  2790\t            else None\n  2791\t        ),\n  2792\t        \"circuit_name\": (\n  2793\t            _normalize_identifier(circuit_name, field_name=\"manifest.circuit_name\")\n  2794\t            if circuit_name is not None\n  2795\t            else None\n  2796\t        ),\n  2797\t        \"selection_preset\": (\n  2798\t            _normalize_identifier(active_preset, field_name=\"config.selection.active_preset\")\n  2799\t            if active_preset is not None\n  2800\t            else None\n  2801\t        ),\n  2802\t        \"selected_root_ids_path\": str(selected_root_ids_path),\n  2803\t        \"selected_root_ids\": normalized_root_ids,\n  2804\t        \"selected_root_count\": len(normalized_root_ids),\n  2805\t        \"selected_root_ids_hash\": root_id_roster_hash,\n  2806\t        \"subset_manifest_reference\": subset_manifest_reference,\n  2807\t    }\n  2808\t\n  2809\t\n  2810\tdef _resolve_subset_manifest_reference(\n  2811\t    *,\n  2812\t    subset_name: Any,\n  2813\t    subset_output_dir: Path,\n  2814\t    expected_root_ids: list[int],\n  2815\t) -> dict[str, Any] | None:\n  2816\t    if subset_name is None:\n  2817\t        return None\n  2818\t    normalized_subset_name = _normalize_identifier(\n  2819\t        subset_name,\n  2820\t        field_name=\"manifest.subset_name\",\n  2821\t    )\n  2822\t    safe_subset_name = re.sub(r\"[^0-9A-Za-z._-]+\", \"_\", normalized_subset_name).strip(\"_\") or \"default\"\n  2823\t    subset_manifest_path = (subset_output_dir / safe_subset_name / SUBSET_MANIFEST_FILENAME).resolve()\n  2824\t    if not subset_manifest_path.exists():\n  2825\t        return None\n  2826\t    subset_manifest = load_json(subset_manifest_path)\n  2827\t    manifest_root_ids = subset_manifest.get(\"root_ids\")\n  2828\t    if not isinstance(manifest_root_ids, list):\n  2829\t        raise ValueError(\n  2830\t            f\"Subset manifest at {subset_manifest_path} is missing the root_ids list.\"\n  2831\t        )\n  2832\t    normalized_manifest_root_ids = sorted(int(root_id) for root_id in manifest_root_ids)\n  2833\t    if normalized_manifest_root_ids != expected_root_ids:\n  2834\t        raise ValueError(\n  2835\t            \"Subset manifest root_ids do not match the selected-root roster: \"\n  2836\t            f\"{subset_manifest_path}.\"\n  2837\t        )\n  2838\t    return {\n  2839\t        \"subset_manifest_path\": str(subset_manifest_path),\n  2840\t        \"subset_manifest_version\": str(subset_manifest.get(\"subset_manifest_version\", \"\")),\n  2841\t        \"root_id_count\": len(normalized_manifest_root_ids),\n  2842\t    }\n  2843\t\n  2844\t\n  2845\tdef _resolve_input_reference(\n  2846\t    *,\n  2847\t    manifest_path: Path,\n  2848\t    manifest_payload: Mapping[str, Any],\n  2849\t    manifest_summary: Mapping[str, Any],\n  2850\t    runtime_config: Mapping[str, Any],\n  2851\t    schema_path: Path,\n  2852\t    design_lock_path: Path,\n  2853\t    processed_stimulus_dir: Path,\n  2854\t    processed_retinal_dir: Path,\n  2855\t) -> dict[str, Any]:\n  2856\t    source_kind = str(runtime_config[\"input\"][\"source_kind\"])\n  2857\t    require_recorded_bundle = bool(runtime_config[\"input\"][\"require_recorded_bundle\"])\n  2858\t    stimulus_metadata_path = Path(\n  2859\t        str(manifest_summary[\"stimulus_bundle_metadata_path\"])\n  2860\t    ).resolve()\n  2861\t    stimulus_bundle_exists = stimulus_metadata_path.exists()\n  2862\t    predicted_stimulus_reference = build_stimulus_bundle_reference(\n  2863\t        manifest_summary[\"stimulus_bundle\"]\n  2864\t    )\n  2865\t    recorded_stimulus_reference = None\n  2866\t    if stimulus_bundle_exists:\n  2867\t        recorded_stimulus_reference = build_stimulus_bundle_reference(\n  2868\t            load_stimulus_bundle_metadata(stimulus_metadata_path)\n  2869\t        )\n  2870\t        if recorded_stimulus_reference != predicted_stimulus_reference:\n  2871\t            raise ValueError(\n  2872\t                \"Recorded stimulus bundle metadata does not match the manifest-resolved \"\n  2873\t                f\"bundle reference at {stimulus_metadata_path}.\"\n  2874\t            )\n  2875\t\n  2876\t    input_reference: dict[str, Any] = {\n  2877\t        \"source_kind\": source_kind,\n  2878\t        \"require_recorded_bundle\": require_recorded_bundle,\n  2879\t        \"stimulus_bundle_reference\": (\n  2880\t            recorded_stimulus_reference\n  2881\t            if recorded_stimulus_reference is not None\n  2882\t            else predicted_stimulus_reference\n  2883\t        ),\n  2884\t        \"stimulus_bundle_metadata_path\": str(stimulus_metadata_path),\n  2885\t        \"stimulus_bundle_metadata_exists\": stimulus_bundle_exists,\n  2886\t    }\n  2887\t\n  2888\t    if source_kind == STIMULUS_BUNDLE_INPUT_SOURCE:\n  2889\t        if require_recorded_bundle and not stimulus_bundle_exists:\n  2890\t            raise ValueError(\n  2891\t                \"simulation.input.source_kind='stimulus_bundle' requires a recorded local \"\n  2892\t                f\"bundle, but {stimulus_metadata_path} does not exist.\"\n  2893\t            )\n  2894\t        selected_reference = (\n  2895\t            recorded_stimulus_reference\n  2896\t            if recorded_stimulus_reference is not None\n  2897\t            else predicted_stimulus_reference\n  2898\t        )\n  2899\t        input_reference.update(\n  2900\t            {\n  2901\t                \"selected_input_kind\": STIMULUS_BUNDLE_INPUT_SOURCE,\n  2902\t                \"selected_input_reference\": copy.deepcopy(selected_reference),\n  2903\t                \"selected_input_metadata_path\": str(stimulus_metadata_path),\n  2904\t                \"selected_input_metadata_exists\": stimulus_bundle_exists,\n  2905\t                \"resolution_source\": (\n  2906\t                    \"recorded_local_bundle\"\n  2907\t                    if stimulus_bundle_exists\n  2908\t                    else \"predicted_manifest_bundle\"\n  2909\t                ),\n  2910\t            }\n  2911\t        )\n  2912\t        return input_reference\n  2913\t\n  2914\t    retinal_config_path = runtime_config[\"input\"][\"retinal_config_path\"]\n  2915\t    assert retinal_config_path is not None\n  2916\t    resolved_retinal_input = resolve_retinal_bundle_input(\n  2917\t        manifest_path=manifest_path,\n  2918\t        retinal_config_path=retinal_config_path,\n  2919\t        schema_path=schema_path,\n  2920\t        design_lock_path=design_lock_path,\n  2921\t        processed_stimulus_dir=processed_stimulus_dir,\n  2922\t        processed_retinal_dir=processed_retinal_dir,\n  2923\t    )\n  2924\t    retinal_metadata_path = resolved_retinal_input.retinal_bundle_metadata_path.resolve()\n  2925\t    if not retinal_metadata_path.exists():\n  2926\t        raise ValueError(\n  2927\t            \"simulation.input.source_kind='retinal_bundle' requires a recorded local \"\n  2928\t            f\"bundle, but {retinal_metadata_path} does not exist.\"\n  2929\t        )\n  2930\t    retinal_bundle_reference = build_retinal_bundle_reference(\n  2931\t        load_retinal_bundle_metadata(retinal_metadata_path)\n  2932\t    )\n  2933\t    input_reference.update(\n  2934\t        {\n  2935\t            \"retinal_bundle_reference\": retinal_bundle_reference,\n  2936\t            \"retinal_bundle_metadata_path\": str(retinal_metadata_path),\n  2937\t            \"retinal_bundle_metadata_exists\": True,\n  2938\t            \"retinal_config_path\": str(Path(retinal_config_path).resolve()),\n  2939\t            \"selected_input_kind\": RETINAL_BUNDLE_INPUT_SOURCE,\n  2940\t            \"selected_input_reference\": copy.deepcopy(retinal_bundle_reference),\n  2941\t            \"selected_input_metadata_path\": str(retinal_metadata_path),\n  2942\t            \"selected_input_metadata_exists\": True,\n  2943\t            \"resolution_source\": \"recorded_local_bundle\",\n  2944\t            \"source_lineage\": copy.deepcopy(resolved_retinal_input.source_lineage),\n  2945\t        }\n  2946\t    )\n  2947\t    return input_reference\n  2948\t\n  2949\t\n  2950\tdef _resolve_circuit_assets(\n  2951\t    *,\n  2952\t    manifest: Mapping[str, Any],\n  2953\t    cfg: Mapping[str, Any],\n  2954\t    selection_reference: Mapping[str, Any],\n  2955\t) -> dict[str, Any]:\n  2956\t    geometry_manifest_path = Path(cfg[\"paths\"][\"manifest_json\"]).resolve()\n  2957\t    if not geometry_manifest_path.exists():\n  2958\t        raise ValueError(f\"Geometry manifest is missing at {geometry_manifest_path}.\")\n  2959\t    geometry_manifest_payload = load_geometry_manifest(geometry_manifest_path)\n  2960\t    geometry_manifest_records = load_geometry_manifest_records(geometry_manifest_path)\n  2961\t    if not geometry_manifest_records:\n  2962\t        raise ValueError(\n  2963\t            f\"Geometry manifest at {geometry_manifest_path} does not contain any root records.\"\n  2964\t        )\n  2965\t\n  2966\t    selected_root_ids = [int(root_id) for root_id in selection_reference[\"selected_root_ids\"]]\n  2967\t    missing_roots = [\n  2968\t        root_id\n  2969\t        for root_id in selected_root_ids\n  2970\t        if str(root_id) not in geometry_manifest_records\n  2971\t    ]\n  2972\t    if missing_roots:\n  2973\t        raise ValueError(\n  2974\t            \"Geometry manifest is missing selected roots required by the manifest plan: \"\n  2975\t            f\"{missing_roots!r}.\"\n  2976\t        )\n  2977\t\n  2978\t    coupling_contract = geometry_manifest_payload.get(\"_coupling_contract\")\n  2979\t    if not isinstance(coupling_contract, Mapping):\n  2980\t        raise ValueError(\n  2981\t            f\"Geometry manifest at {geometry_manifest_path} is missing _coupling_contract metadata.\"\n  2982\t        )\n  2983\t    local_synapse_registry = coupling_contract.get(\"local_synapse_registry\")\n  2984\t    if not isinstance(local_synapse_registry, Mapping):\n  2985\t        raise ValueError(\n  2986\t            f\"Geometry manifest at {geometry_manifest_path} is missing coupling local_synapse_registry metadata.\"\n  2987\t        )\n  2988\t    local_synapse_registry_path = Path(\n  2989\t        _normalize_nonempty_string(\n  2990\t            local_synapse_registry.get(\"path\"),\n  2991\t            field_name=\"_coupling_contract.local_synapse_registry.path\",\n  2992\t        )\n  2993\t    ).resolve()\n  2994\t    local_synapse_registry_status = _normalize_nonempty_string(\n  2995\t        local_synapse_registry.get(\"status\"),\n  2996\t        field_name=\"_coupling_contract.local_synapse_registry.status\",\n  2997\t    )\n  2998\t    if local_synapse_registry_status != ASSET_STATUS_READY:\n  2999\t        raise ValueError(\n  3000\t            \"Geometry manifest coupling local_synapse_registry is not ready: \"\n  3001\t            f\"{local_synapse_registry_status!r}.\"\n  3002\t        )\n  3003\t    if not local_synapse_registry_path.exists():\n  3004\t        raise ValueError(\n  3005\t            \"Geometry manifest coupling local_synapse_registry path does not exist: \"\n  3006\t            f\"{local_synapse_registry_path}.\"\n  3007\t        )\n  3008\t\n  3009\t    per_root_assets = []\n  3010\t    selected_root_set = set(selected_root_ids)\n  3011\t    for root_id in selected_ro