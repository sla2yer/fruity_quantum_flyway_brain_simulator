{"type":"item.completed","item":{"id":"item_23","type":"command_execution","command":"/bin/bash -lc \"sed -n '620,1400p' src/flywire_wave/dashboard_assets/dashboard_shell.js\"","aggregated_output":"    const validation = analysis.validation || {};\n    const overlayOptions = getOverlayOptions(model, state);\n    const unavailable = overlayOptions.filter(function onlyUnavailable(item) {\n      return item.availability !== \"available\";\n    });\n    body.innerHTML = [\n      paneBand(\n        \"Linked state\",\n        \"\",\n        pillRow([\n          statePill(\"Comparison\", comparisonModeName(model, state.comparison_mode)),\n          statePill(\"Overlay\", overlayName(model, state.active_overlay_id)),\n          statePill(\"Hover\", hoveredNeuronLabel(model, state)),\n        ]) +\n          '<pre class=\"state-json\">' +\n          escapeHtml(JSON.stringify(state, null, 2)) +\n          \"</pre>\"\n      ),\n      paneBand(\n        \"Analysis bridges\",\n        \"\",\n        summaryList([\n          [\"Phase maps\", String(analysis.phase_map_reference_count || 0)],\n          [\"Wave cards\", String(analysis.wave_diagnostic_card_count || 0)],\n          [\"Validation status\", String(validation.overall_status || \"unknown\")],\n          [\"Open findings\", String(validation.open_finding_count || 0)],\n        ]) +\n          linkRow(model.links)\n      ),\n      paneBand(\n        \"Overlay catalog\",\n        \"\",\n        chipList(\n          overlayOptions.map(function map(item) {\n            return {\n              label:\n                String(item.display_name) +\n                (item.availability === \"available\" ? \"\" : \" | \" + String(item.reason || \"unavailable\")),\n              tone: item.availability === \"available\" ? \"good\" : \"warn\",\n            };\n          })\n        ) +\n          (unavailable.length > 0\n            ? paragraph(\n                \"Overlay availability is recalculated inside the shell when comparison m