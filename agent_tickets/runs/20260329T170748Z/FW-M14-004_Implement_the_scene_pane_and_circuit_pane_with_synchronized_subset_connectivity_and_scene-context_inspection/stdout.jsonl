deg, rgba(0, 0, 0, 0.65), transparent 92%);\n}\n\n.app-shell {\n  position: relative;\n  max-width: 1480px;\n  margin: 0 auto;\n  padding: 28px 20px 40px;\n}\n\n.shell-hero,\n.toolbar-card,\n.dashboard-pane,\n.shell-footer {\n  position: relative;\n  border: 1px solid var(--border);\n  border-radius: var(--radius-xl);\n  background: var(--card);\n  box-shadow: var(--shadow);\n  backdrop-filter: blur(18px);\n}\n\n.shell-hero {\n  display: grid;\n  gap: 22px;\n  padding: 28px;\n  overflow: hidden;\n}\n\n.shell-hero::after {\n  content: \"\";\n  position: absolute;\n  inset: 0;\n  background: linear-gradient(120deg, rgba(215, 238, 236, 0.68), transparent 40%, rgba(199, 154, 89, 0.14) 100%);\n  pointer-events: none;\n}\n\n.hero-copy,\n.hero-facts {\n  position: relative;\n  z-index: 1;\n}\n\n.eyebrow,\n.section-kicker,\n.control-label,\n.fact-label {\n  font-size: 0.78rem;\n  font-weight: 700;\n  letter-spacing: 0.12em;\n  text-transform: uppercase;\n  color: var(--muted);\n}\n\n.shell-hero h1 {\n  margin: 0.35rem 0 0.65rem;\n  max-width: 16ch;\n  font-family: var(--serif);\n  font-size: clamp(2.2rem, 4vw, 3.6rem);\n  line-height: 0.98;\n}\n\n.hero-text,\n.pane-description,\n.footer-note,\n.time-readout {\n  margin: 0;\n  color: var(--muted);\n  line-height: 1.55;\n}\n\n.hero-facts {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));\n  gap: 14px;\n}\n\n.fact-card {\n  padding: 14px 16px;\n  border-radius: var(--radius-md);\n  background: rgba(255, 255, 255, 0.72);\n  border: 1px solid rgba(18, 69, 89, 0.1);\n}\n\n.fact-value {\n  display: block;\n  margin-top: 6px;\n  font-size: 0.98rem;\n  word-break: break-word;\n}\n\n.toolbar-card {\n  margin-top: 20px;\n  padding: 24px;\n}\n\n.toolbar-header {\n  display: flex;\n  justify-content: space-between;\n  gap: 16px;\n  align-items: start;\n  margin-bottom: 18px;\n}\n\n.toolbar-header h2,\n.pane-header h2 {\n  margin: 0.25rem 0 0;\n  font-family: var(--serif);\n  font-size: 1.35rem;\n}\n\n.manifest-link {\n  align-self: center;\n  white-space: nowrap;\n}\n\n.toolbar-grid {\n  display: grid;\n  grid-template-columns: repeat(6, minmax(0, 1fr));\n  gap: 14px;\n  align-items: end;\n}\n\n.control-cluster {\n  display: grid;\n  gap: 8px;\n}\n\n.control-cluster select,\n.time-slider,\n.playback-button,\n.segment-button {\n  width: 100%;\n  border-radius: 14px;\n  border: 1px solid rgba(18, 69, 89, 0.16);\n  background: var(--card-strong);\n  color: var(--ink);\n  font: inherit;\n}\n\n.control-cluster select {\n  padding: 11px 12px;\n}\n\n.segmented-controls {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 8px;\n}\n\n.segment-button,\n.playback-button {\n  padding: 11px 12px;\n  cursor: pointer;\n  transition:\n    transform 180ms ease,\n    background-color 180ms ease,\n    border-color 180ms ease,\n    box-shadow 180ms ease;\n}\n\n.segment-button:hover,\n.playback-button:hover {\n  transform: translateY(-1px);\n  border-color: rgba(10, 92, 99, 0.28);\n}\n\n.segment-button.is-active,\n.playback-button.is-active {\n  background: linear-gradient(135deg, var(--accent), var(--accent-strong));\n  color: white;\n  border-color: transparent;\n  box-shadow: 0 10px 28px rgba(10, 92, 99, 0.22);\n}\n\n.playback-cluster {\n  grid-column: span 2;\n}\n\n.playback-controls {\n  display: grid;\n  grid-template-columns: repeat(4, minmax(0, 1fr));\n  gap: 8px;\n}\n\n.time-slider {\n  appearance: none;\n  height: 0.8rem;\n  padding: 0;\n  background: linear-gradient(90deg, rgba(10, 92, 99, 0.14), rgba(199, 154, 89, 0.28));\n}\n\n.time-slider::-webkit-slider-thumb {\n  appearance: none;\n  width: 18px;\n  height: 18px;\n  border-radius: 999px;\n  background: var(--accent-strong);\n  border: 2px solid #fff;\n}\n\n.dashboard-grid {\n  display: grid;\n  grid-template-columns: 1.2fr 1fr 1.1fr;\n  gap: 18px;\n  margin-top: 20px;\n}\n\n.dashboard-pane {\n  min-height: 230px;\n  padding: 20px;\n  animation: pane-rise 480ms ease both;\n}\n\n.dashboard-pane