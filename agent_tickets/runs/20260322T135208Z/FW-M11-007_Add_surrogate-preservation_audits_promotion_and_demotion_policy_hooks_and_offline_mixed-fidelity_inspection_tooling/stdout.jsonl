y descriptors at \"\nsrc/flywire_wave/simulation_planning.py:2602:            f\"{descriptor_sidecar_path}.\"\nsrc/flywire_wave/simulation_planning.py:2640:        \"descriptor_sidecar_path\": str(descriptor_sidecar_path),\nsrc/flywire_wave/simulation_planning.py:2682:                field_name=\"selected_root_asset.geometry_descriptors\",\nsrc/flywire_wave/mesh_pipeline.py:37:    build_descriptor_payload,\nsrc/flywire_wave/mesh_pipeline.py:769:    descriptor_payload = build_descriptor_payload(\nsrc/flywire_wave/mesh_pipeline.py:786:    write_json(descriptor_payload, bundle_paths.descriptor_sidecar_path)\nsrc/flywire_wave/mesh_pipeline.py:801:        descriptor_payload,\nsrc/flywire_wave/mesh_pipeline.py:812:            **descriptor_payload,\nsrc/flywire_wave/mesh_pipeline.py:813:            \"descriptor_sidecar_path\": str(bundle_paths.descriptor_sidecar_path),\nsrc/flywire_wave/mesh_pipeline.py:823:        \"n_vertices\": int(descriptor_payload[\"n_vertices\"]),\nsrc/flywire_wave/mesh_pipeline.py:824:        \"n_faces\": int(descriptor_payload[\"n_faces\"]),\nsrc/flywire_wave/mesh_pipeline.py:825:        \"surface_graph_edge_count\": int(descriptor_payload[\"surface_graph_edge_count\"]),\nsrc/flywire_wave/mesh_pipeline.py:826:        \"patch_count\": int(descriptor_payload[\"patch_count\"]),\nsrc/flywire_wave/mesh_pipeline.py:827:        \"patch_graph_vertex_count\": int(descriptor_payload[\"patch_graph_vertex_count\"]),\nsrc/flywire_wave/mesh_pipeline.py:828:        \"patch_graph_edge_count\": int(descriptor_payload[\"patch_graph_edge_count\"]),\nsrc/flywire_wave/mesh_pipeline.py:829:        \"surface_to_patch_count\": int(descriptor_payload[\"surface_to_patch_count\"]),\nsrc/flywire_wave/mesh_pipeline.py:881:        \"descriptor_payload\": descriptor_payload,\nsrc/flywire_wave/coupling_inspection.py:1047:    descriptor_payload = _load_json_if_exists(bundle_paths.descriptor_sidecar_path)\nsrc/flywire_wave/coupling_inspection.py:1048:    registry_metadata = dict(d