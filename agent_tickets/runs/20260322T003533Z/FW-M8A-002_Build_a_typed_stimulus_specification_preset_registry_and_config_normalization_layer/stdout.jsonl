 - arm_id: surface_wave_intact\n    model_mode: surface_wave\n    baseline_family: null\n    topology_condition: intact\n    morphology_condition: intact_synapse_landing_geometry\n    random_seed: 11\n    notes: Surface-wave condition with distributed morphology-bound state on T4/T5 only.\n    tags:\n      - surface_wave\n      - intact\n  - arm_id: baseline_p0_shuffled\n    model_mode: baseline\n    baseline_family: P0\n    topology_condition: shuffled\n    morphology_condition: shuffled_synapse_landing_geometry\n    random_seed: 11\n    notes: Canonical point baseline under the same shuffled topology perturbation used for the surface-wave ablation.\n    tags:\n      - canonical_baseline\n      - shuffled\n  - arm_id: surface_wave_shuffled\n    model_mode: surface_wave\n    baseline_family: null\n    topology_condition: shuffled\n    morphology_condition: shuffled_synapse_landing_geometry\n    random_seed: 11\n    notes: Surface-wave condition with synapse landing geometry shuffled to test geometry dependence.\n    tags:\n      - surface_wave\n      - shuffled\n  - arm_id: baseline_p1_intact\n    model_mode: baseline\n    baseline_family: P1\n    topology_condition: intact\n    morphology_condition: intact_synapse_landing_geometry\n    random_seed: 11\n    notes: Stronger reduced baseline with explicit integration current or delay structure under intact topology.\n    tags:\n      - stronger_baseline\n      - intact\n  - arm_id: baseline_p1_shuffled\n    model_mode: baseline\n    baseline_family: P1\n    topology_condition: shuffled\n    morphology_condition: shuffled_synapse_landing_geometry\n    random_seed: 11\n    notes: Stronger reduced baseline under shuffled topology for the same comparison family.\n    tags:\n      - stronger_baseline\n      - shuffled\noutput_bundle:\n  metrics_json: outputs/milestone_1/milestone_1_demo_motion_patch/metrics/summary_metrics.json\n  summary_table_csv: outputs/milestone_1/milestone_1_demo_motion_patch/metrics/per_condition_summary.csv\n  plots:\n    - id: shared_output_trace_overlay\n      path: outputs/milestone_1/milestone_1_demo_motion_patch/plots/shared_output_trace_overlay.png\n    - id: null_direction_suppression_comparison\n      path: outputs/milestone_1/milestone_1_demo_motion_patch/plots/null_direction_suppression_comparison.png\n    - id: latency_shift_comparison\n      path: outputs/milestone_1/milestone_1_demo_motion_patch/plots/latency_shift_comparison.png\n    - id: topology_ablation_comparison\n      path: outputs/milestone_1/milestone_1_demo_motion_patch/plots/topology_ablation_comparison.png\n    - id: baseline_challenge_comparison\n      path: outputs/milestone_1/milestone_1_demo_motion_patch/plots/baseline_challenge_comparison.png\n  ui_states:\n    - id: stimulus_overview\n      path: outputs/milestone_1/milestone_1_demo_motion_patch/ui/stimulus_overview.json\n    - id: surface_vs_baseline_split_view\n      path: outputs/milestone_1/milestone_1_demo_motion_patch/ui/surface_vs_baseline_split_view.json\n    - id: milestone_decision_panel\n      path: outputs/milestone_1/milestone_1_demo_motion_patch/ui/milestone_decision_panel.json\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_15","type":"command_execution","command":"/bin/bash -lc \"sed -n '1,260p' schemas/milestone_1_experiment_manifest.schema.json\"","aggregated_output":"{\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n  \"$id\": \"https://example.local/schemas/milestone_1_experiment_manifest.schema.json\",\n  \"title\": \"Milestone 1 Experiment Manifest\",\n  \"type\": \"object\",\n  \"additionalProperties\": false,\n  \"required\": [\n    \"experiment_id\",\n    \"milestone\",\n    \"brief_version\",\n    \"hypothesis_version\",\n    \"model_scope\",\n    \"stimulus_family\",\n    \"stimulus_name\",\n    \"primary_metric\",\n    \"companion_metrics\",\n    \"success_criteria_ids\",\n    \"must_show_outputs\",\n    \"random_seed\",\n    \"comparison_arms\",\n    \"output_bundle\"\n  ],\n  \"properties\": {\n    \"experiment_id\": {\n      \"type\": \"string\",\n      \"minLength\": 1\n    },\n    \"milestone\": {\n      \"const\": \"milestone_1\"\n    },\n    \"brief_version\": {\n      \"type\": \"string\",\n      \"pattern\": \"^\\\\d+\\\\.\\\\d+\\\\.\\\\d+$\"\n    },\n    \"hypothesis_version\": {\n      \"type\": \"string\",\n      \"pattern\": \"^\\\\d+\\\\.\\\\d+\\\\.\\\\d+$\"\n    },\n    \"subset_name\": {\n      \"type\": \"string\",\n      \"minLength\": 1\n    },\n    \"circuit_name\": {\n      \"type\": \"string\",\n      \"minLength\": 1\n    },\n    \"model_scope\": {\n      \"type\": \"string\",\n      \"minLength\": 1\n    },\n    \"stimulus_family\": {\n      \"type\": \"string\",\n      \"minLength\": 1\n    },\n    \"stimulus_name\": {\n      \"type\": \"string\",\n      \"minLength\": 1\n    },\n    \"primary_metric\": {\n      \"type\": \"string\",\n      \"minLength\": 1\n    },\n    \"companion_metrics\": {\n      \"type\": \"array\",\n      \"minItems\": 1,\n      \"uniqueItems\": true,\n      \"items\": {\n        \"type\": \"string\",\n        \"minLength\": 1\n      }\n    },\n    \"success_criteria_ids\": {\n      \"type\": \"array\",\n      \"minItems\": 3,\n      \"uniqueItems\": true,\n      \"items\": {\n        \"type\": \"string\",\n        \"pattern\": \"^m1_[a-z0-9_]+$\"\n      }\n    },\n    \"must_show_outputs\": {\n      \"type\": \"array\",\n      \"minItems\": 4,\n      \"uniqueItems\": true,\n      \"items\": {\n        \"type\": \"string\",\n        \"enum\": [\n          \"stimulus_overview\",\n          \"surface_vs_baseline_split_view\",\n          \"shared_output_trace_overlay\",\n          \"null_direction_suppression_comparison\",\n          \"latency_shift_comparison\",\n          \"topology_ablation_comparison\",\n          \"baseline_challenge_comparison\",\n          \"milestone_decision_panel\"\n        ]\n      }\n    },\n    \"random_seed\": {\n      \"type\": \"integer\"\n    },\n    \"seed_sweep\": {\n      \"type\": \"array\",\n      \"minItems\": 1,\n      \"uniqueItems\": true,\n      \"items\": {\n        \"type\": \"integer\"\n      }\n    },\n    \"notes\": {\n      \"type\": \"string\"\n    },\n    \"tags\": {\n      \"type\": \"array\",\n      \"uniqueItems\": true,\n      \"items\": {\n        \"type\": \"string\",\n        \"minLength\": 1\n      }\n    },\n    \"comparison_arms\": {\n      \"type\": \"array\",\n      \"minItems\": 4,\n      \"items\": {\n        \"$ref\": \"#/$defs/comparisonArm\"\n      }\n    },\n    \"output_bundle\": {\n      \"$ref\": \"#/$defs/outputBundle\"\n    }\n  },\n  \"anyOf\": [\n    {\n      \"required\": [\n        \"subset_name\"\n      ]\n    },\n    {\n      \"required\": [\n        \"circuit_name\"\n      ]\n    }\n  ],\n  \"allOf\": [\n    {\n      \"properties\": {\n        \"comparison_arms\": {\n          \"contains\": {\n            \"properties\": {\n              \"model_mode\": {\n                \"const\": \"baseline\"\n              }\n            },\n            \"required\": [\n              \"model_mode\"\n            ]\n          }\n        }\n      }\n    },\n    {\n      \"properties\": {\n        \"comparison_arms\": {\n          \"contains\": {\n            \"properties\": {\n              \"model_mode\": {\n                \"const\": \"surface_wave\"\n              }\n            },\n            \"required\": [\n              \"model_mode\"\n            ]\n          }\n        }\n      }\n    },\n    {\n      \"properties\": {\n        \"comparison_arms\": {\n          \"contains\": {\n            \"properties\": {\n              \"topology_condition\": {\n                \"const\": \"intact\"\n              }\n            },\n            \"required\": [\n              \"topology_condition\"\n            ]\n          }\n        }\n      }\n    },\n    {\n      \"properties\": {\n        \"comparison_arms\": {\n          \"contains\": {\n            \"properties\": {\n              \"topology_condition\": {\n                \"const\": \"shuffled\"\n              }\n            },\n            \"required\": [\n              \"topology_condition\"\n            ]\n          }\n        }\n      }\n    }\n  ],\n  \"$defs\": {\n    \"comparisonArm\": {\n      \"type\": \"object\",\n      \"additionalProperties\": false,\n      \"required\": [\n        \"arm_id\",\n        \"model_mode\",\n        \"baseline_family\",\n        \"topology_condition\",\n        \"morphology_condition\",\n        \"notes\"\n      ],\n      \"properties\": {\n        \"arm_id\": {\n          \"type\": \"string\",\n          \"minLength\": 1\n        },\n        \"model_mode\": {\n          \"type\": \"string\",\n          \"enum\": [\n            \"baseline\",\n            \"surface_wave\"\n          ]\n        },\n        \"baseline_family\": {\n          \"type\": [\n            \"string\",\n            \"null\"\n          ],\n          \"enum\": [\n            \"P0\",\n            \"P1\",\n            null\n          ]\n        },\n        \"topology_condition\": {\n          \"type\": \"string\",\n          \"enum\": [\n            \"intact\",\n            \"shuffled\"\n          ]\n        },\n        \"morphology_condition\": {\n          \"type\": \"string\",\n          \"minLength\": 1\n        },\n        \"random_seed\": {\n          \"type\": \"integer\"\n        },\n        \"notes\": {\n          \"type\": \"string\",\n","exit_code":0,"status":"completed"}}
{"type":"item.started","item":{"id":"item_16","type":"command_execution","command":"/bin/bash -lc 'rg -n \"moving bars|drifting gratings|looming|rotating flow|translated edge|flashes|preset|alias\" docs src tests config manifests agent_tickets/milestone_8a_canonical_stimulus_library_tickets.md'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
{"type":"item.completed","item":{"id":"item_16","type":"command_execution","command":"/bin/bash -lc 'rg -n \"moving bars|drifting gratings|looming|rotating flow|translated edge|flashes|preset|alias\" docs src tests config manifests agent_tickets/milestone_8a_canonical_stimulus_library_tickets.md'","aggregated_output":"agent_tickets/milestone_8a_canonical_stimulus_library_tickets.md:20:Define a first-class canonical stimulus bundle contract in library code and document the design choices behind it. Centralize bundle naming, metadata, and discovery so later tooling can resolve a stimulus without hardcoded filenames, and add a markdown design note that compares the viable representation families before choosing the default. The design note should be decisive: choose the default between pure procedural regeneration, fully cached frame bundles, and a hybrid descriptor-plus-cache model; define the canonical spatial coordinate frame and temporal units; specify luminance or contrast conventions; and state how deterministic seeding, parameter hashing, and compatibility aliases must work.\nagent_tickets/milestone_8a_canonical_stimulus_library_tickets.md:36:## FW-M8A-002 - Build a typed stimulus specification, preset registry, and config normalization layer\nagent_tickets/milestone_8a_canonical_stimulus_library_tickets.md:43:Even with a bundle contract, the repo still has no stable way to ask for a standard stimulus from config. A caller would have to pass untyped dictionaries, duplicate defaults, and guess family-specific parameter names. That would make `stimulus_family` and `stimulus_name` little more than labels instead of a reproducible input contract, and it would make later experiment orchestration fragile whenever a family adds a new parameter or compatibility alias.\nagent_tickets/milestone_8a_canonical_stimulus_library_tickets.md:46:Implement the library-owned stimulus specification layer that resolves config or manifest inputs into normalized, typed stimulus specs. The API should accept a family identifier, named preset, and optional overrides, then return a normalized spec with explicit defaults, units, duration, frame timing, spatial extent, and deterministic seed behavior. Keep the implementation YAML-friendly and manifest-friendly, reserve stable family identifiers for every Milestone 8A family, and preserve compatibility with the existing `moving_edge` naming used by the Milestone 1 example manifest.\nagent_tickets/milestone_8a_canonical_stimulus_library_tickets.md:51:- Named presets and aliases are discoverable through library code and stable enough for manifests, config examples, and later UI tooling to reference directly.\nagent_tickets/milestone_8a_canonical_stimulus_library_tickets.md:53:- Regression coverage validates normalization, alias handling, parameter overrides, and clear failure modes using fixture configs only.\nagent_tickets/milestone_8a_canonical_stimulus_library_tickets.md:69:The roadmap explicitly calls for flashes, moving bars, drifting gratings, and translated edge patterns, yet the repo has no canonical generator implementation for any of them. The existing Milestone 1 manifest names a moving-edge stimulus, but there is no shared generation layer that defines how onset timing, polarity, aperture, speed, spatial frequency, contrast, or phase should map into actual frames. Without this, every downstream consumer will end up reinterpreting the same stimulus differently.\nagent_tickets/milestone_8a_canonical_stimulus_library_tickets.md:72:Implement the first wave of canonical lab-stimulus generators using the normalized spec and contract established in `FW-M8A-001` and `FW-M8A-002`. Add generator implementations for flashes, moving bars, translated edge patterns, and drifting gratings, along with the family-specific metadata needed to replay or inspect them later. Make the rendering semantics explicit for background intensity, polarity, onset and offset timing, direction, velocity, aperture or mask handling, grating phase, spatial frequency, contrast, and edge sharpness. Preserve a stable compatibility path for the current `moving_edge` naming.\nagent_tickets/milestone_8a_canonical_stimulus_library_tickets.md:75:- Flashes, moving bars, translated edge patterns, and drifting gratings can each be instantiated through the canonical registry and sampled into deterministic frame outputs or equivalent replayable field evaluators.\nagent_tickets/milestone_8a_canonical_stimulus_library_tickets.md:78:- Existing `moving_edge` references continue to work through a compatibility alias or a documented migration shim that keeps current Milestone 1 assets valid.\nagent_tickets/milestone_8a_canonical_stimulus_library_tickets.md:88:## FW-M8A-004 - Implement looming, expansion-contraction flow, and rotating-flow generators on the same canonical visual field contract\nagent_tickets/milestone_8a_canonical_stimulus_library_tickets.md:95:Milestone 8A also calls for looming stimuli plus expansion, contraction, and rotating flow, but those families are more sensitive to coordinate choices than simple translated patterns. If they are bolted on later without the same field contract, later retinal sampling and scene tooling will have to guess how centers of motion, angular velocity, radial speed, clipping, and polarity should behave. That would undermine the point of having a canonical stimulus library.\nagent_tickets/milestone_8a_canonical_stimulus_library_tickets.md:98:Implement the canonical generator families for looming, expansion or contraction flow, and rotating flow using the same normalized field and timing conventions as the simpler generators. The implementation should support explicit motion centers, radial or angular velocity parameters, polarity, apertures or masks, looming size-growth semantics, and the metadata needed to distinguish inward versus outward or clockwise versus counterclockwise motion. Keep the resulting outputs deterministic, inspectable, and ready for later retinal sampling without hidden coordinate transforms.\nagent_tickets/milestone_8a_canonical_stimulus_library_tickets.md:101:- Looming, expansion or contraction flow, and rotating flow are each instantiable through the canonical registry and produce deterministic replayable outputs using the shared coordinate contract.\nagent_tickets/milestone_8a_canonical_stimulus_library_tickets.md:128:- Validation errors are clear when a manifest references an unknown family, an unknown preset, or invalid family-specific parameters.\nconfig/milestone_7_verification.yaml:33:  active_preset: milestone7_cached_subset\nconfig/milestone_7_verification.yaml:36:  presets:\nconfig/local.yaml:19:  active_preset: motion_minimal\nconfig/local.yaml:22:  presets:\ntests/test_selection.py:19:    def test_active_preset_writes_manifest_stats_preview_and_root_id_alias(self) -> None:\ntests/test_selection.py:35:            self.assertEqual(summary[\"active_preset\"], \"motion_medium\")\ntests/test_selection.py:36:            self.assertEqual(len(summary[\"generated_presets\"]), 1)\ntests/test_selection.py:38:            generated = summary[\"generated_presets\"][0]\ntests/test_selection.py:39:            self.assertEqual(generated[\"preset_name\"], \"motion_medium\")\ntests/test_selection.py:46:            self.assertEqual(manifest[\"preset_name\"], \"motion_medium\")\ntests/test_selection.py:60:    def test_generate_all_presets_respects_inheritance_and_relation_append(self) -> None:\ntests/test_selection.py:80:            preset_counts = {\ntests/test_selection.py:81:                item[\"preset_name\"]: item[\"root_id_count\"]\ntests/test_selection.py:82:                for item in summary[\"generated_presets\"]\ntests/test_selection.py:85:                preset_counts,\ntests/test_selection.py:95:                for item in summary[\"generated_presets\"]\ntests/test_selection.py:96:                if item[\"preset_name\"] == \"motion_dense\"\ntests/test_selection.py:100:                for item i