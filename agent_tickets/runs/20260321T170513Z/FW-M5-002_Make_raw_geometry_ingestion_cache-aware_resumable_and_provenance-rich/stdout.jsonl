\t            bundle_paths = _bundle_paths(Path(tmp_dir_str))\n   148\t\n   149\t            outputs = fetch_mesh_and_optional_skeleton(\n   150\t                root_id=101,\n   151\t                bundle_paths=bundle_paths,\n   152\t                flywire_dataset=\"public\",\n   153\t                fetch_skeletons=True,\n   154\t                set_default_dataset=lambda _dataset: None,\n   155\t                mesh_fetcher=lambda _root_id: _MeshNeuron(),\n   156\t                skeleton_fetcher=_failing_skeleton_fetcher,\n   157\t                skeleton_writer=lambda _skeleton, path: _write_valid_swc(Path(path)),\n   158\t            )\n   159\t\n   160\t            self.assertEqual(outputs[\"asset_statuses\"][RAW_MESH_KEY], ASSET_STATUS_READY)\n   161\t            self.assertEqual(outputs[\"asset_statuses\"][RAW_SKELETON_KEY], ASSET_STATUS_MISSING)\n   162\t            self.assertEqual(outputs[\"raw_asset_provenance\"][RAW_SKELETON_KEY][\"fetch_status\"], FETCH_STATUS_FAILED)\n   163\t            self.assertEqual(outputs[\"raw_asset_provenance\"][RAW_SKELETON_KEY][\"cache_before\"][\"state\"], \"missing\")\n   164\t            self.assertIn(\"skeleton endpoint unavailable\", outputs[\"raw_asset_provenance\"][RAW_SKELETON_KEY][\"error\"])\n   165\t\n   166\t    def test_required_skeleton_failure_raises_with_provenance(self) -> None:\n   167\t        with tempfile.TemporaryDirectory(dir=ROOT) as tmp_dir_str:\n   168\t            bundle_paths = _bundle_paths(Path(tmp_dir_str))\n   169\t\n   170\t            with self.assertRaises(RawAssetFetchError) as exc_info:\n   171\t                fetch_mesh_and_optional_skeleton(\n   172\t                    root_id=101,\n   173\t                    bundle_paths=bundle_paths,\n   174\t                    flywire_dataset=\"public\",\n   175\t                    fetch_skeletons=True,\n   176\t                    require_skeletons=True,\n   177\t                    set_default_dataset=lambda _dataset: None,\n   178\t      