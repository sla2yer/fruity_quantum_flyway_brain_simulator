  mesh.export(processed_mesh_path)\\nsrc/flywire_wave/mesh_pipeline.py:180:            \\\"processed_mesh_path\\\": str(processed_mesh_path),\\nsrc/flywire_wave/mesh_pipeline.py:181:            \\\"processed_graph_path\\\": str(graph_path),\\nsrc/flywire_wave/mesh_pipeline.py:184:        meta_json_path,\\nsrc/flywire_wave/mesh_pipeline.py:188:        \\\"processed_mesh_path\\\": str(processed_mesh_path),\\nsrc/flywire_wave/mesh_pipeline.py:189:        \\\"processed_graph_path\\\": str(graph_path),\\nsrc/flywire_wave/mesh_pipeline.py:190:        \\\"meta_json_path\\\": str(meta_json_path),\\nsrc/flywire_wave/config.py:18:    \\\"meshes_raw_dir\\\": Path(\\\"data/interim/meshes_raw\\\"),\\nsrc/flywire_wave/config.py:20:    \\\"processed_mesh_dir\\\": Path(\\\"data/processed/meshes\\\"),\\nsrc/flywire_wave/config.py:21:    \\\"processed_graph_dir\\\": Path(\\\"data/processed/graphs\\\"),\\nsrc/flywire_wave/config.py:22:    \\\"manifest_json\\\": Path(\\\"data/processed/asset_manifest.json\\\"),\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n./agent_tickets/runs/20260321T170513Z/FW-M5-001_Define_a_versioned_geometry_asset_contract_for_multiresolution_morphology_bundles/stdout.jsonl:43:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_22\",\"type\":\"command_execution\",\"command\":\"/bin/bash -lc \\\"sed -n '1,320p' src/flywire_wave/mesh_pipeline.py\\\"\",\"aggregated_output\":\"from __future__ import annotations\\n\\nfrom dataclasses import dataclass\\nfrom pathlib import Path\\nfrom typing import Any\\n\\nimport numpy as np\\nimport scipy.sparse as sp\\nfrom scipy.sparse.csgraph import shortest_path\\nimport trimesh\\n\\nfrom .geometry_contract import (\\n    ASSET_STATUS_MISSING,\\n    ASSET_STATUS_READY,\\n    GeometryBundlePaths,\\n    PATCH_GRAPH_KEY,\\n    QA_SIDECAR_KEY,\\n    RAW_MESH_KEY,\\n    RAW_SKELETON_KEY,\\n    SIMPLIFIED_MESH_KEY,\\n    SURFACE_GRAPH_KEY,\\n    DESCRIPTOR_SIDECAR_KEY,\\n)\\nfrom .io_utils import ensure_dir, write_json\\n\\n\\n@dataclass\\nclass MeshAssetPaths:\\n    raw_mesh_path: Path\\n    raw_skeleton_path: Path | None\\n    processed_mesh_path: Path\\n    processed_graph_path: Path\\n    meta_json_path: Path\\n\\n\\ndef _optional_imports() -> tuple[Any, Any]:\\n    try:\\n        from fafbseg import flywire  # type: ignore\\n    except Exception as exc:  # pragma: no cover\\n        raise RuntimeError(\\n            \\\"fafbseg is required for FlyWire mesh access. Install requirements.txt first.\\\"\\n        ) from exc\\n\\n    try:\\n        import navis  # type: ignore\\n    except Exception as exc:  # pragma: no cover\\n        raise RuntimeError(\\n            \\\"navis is required for exporting skeletons. Install requirements.txt first.\\\"\\n        ) from exc\\n\\n    return flywire, navis\\n\\n\\ndef _faces_to_adjacency(faces: np.ndarray, n_vertices: int) -> sp.csr_matrix:\\n    edges = set()\\n    for tri in faces:\\n        a, b, c = (int(tri[0]), int(tri[1]), int(tri[2]))\\n        edges.add(tuple(sorted((a, b))))\\n        edges.add(tuple(sorted((b, c))))\\n        edges.add(tuple(sorted((a, c))))\\n\\n    if not edges:\\n        raise ValueError(\\\"No edges could be built from faces.\\\")\\n\\n    rows = []\\n    cols = []\\n    for i, j in edges:\\n        rows.extend([i, j])\\n        cols.extend([j, i])\\n\\n    data = np.ones(len(rows), dtype=np.float32)\\n    adj = sp.csr_matrix((data, (rows, cols)), shape=(n_vertices, n_vertices))\\n    adj.eliminate_zeros()\\n    return adj\\n\\n\\ndef _uniform_laplacian(adj: sp.csr_matrix) -> sp.csr_matrix:\\n    deg = np.asarray(adj.sum(axis=1)).ravel()\\n    d = sp.diags(deg)\\n    return d - adj\\n\\n\\ndef _choose_patch_vertices(adj: sp.csr_matrix, patch_hops: int, cap: int) -> np.ndarray:\\n    n_vertices = adj.shape[0]\\n    seed = n_vertices // 2\\n    dist = shortest_path(adj, directed=False, indices=seed, unweighted=True)\\n    patch = np.where(np.isfinite(dist) & (dist <= patch_hops))[0]\\n    if patch.size > cap:\\n        order = np.argsort(dist[patch])\\n        patch = patch[order[:cap]]\\n    return patch.astype(np.int32)\\n\\n\\ndef fetch_mesh_and_optional_skeleton(\\n    *,\\n    root_id: int,\\n    bundle_paths: GeometryBundlePaths,\\n    flywire_dataset: str = \\\"public\\\",\\n    fetch_skeletons: bool = True,\\n) -> dict[str, str]:\\n    flywire, navis = _optional_imports()\\n\\n    ensure_dir(bundle_paths.raw_mesh_path.parent)\\n    ensure_dir(bundle_paths.raw_skeleton_path.parent)\\n\\n    flywire.set_default_dataset(flywire_dataset)\\n\\n    neuron = flywire.get_mesh_neuron(int(root_id))\\n    mesh = trimesh.Trimesh(vertices=np.asarray(neuron.vertices), faces=np.asarray(neuron.faces), process=False)\\n    mesh.export(bundle_paths.raw_mesh_path)\\n\\n    raw_skeleton_status = ASSET_STATUS_MISSING\\n    if fetch_skeletons:\\n        try:\\n            sk = flywire.get_skeletons(int(root_id))\\n            navis.write_swc(sk, bundle_paths.raw_skeleton_path)\\n            raw_skeleton_status = ASSET_STATUS_READY\\n        except Exception:\\n            raw_skeleton_status = ASSET_STATUS_MISSING\\n\\n    return {\\n        RAW_MESH_KEY: ASSET_STATUS_READY,\\n        RAW_SKELETON_KEY: raw_skeleton_status if fetch_skeletons else \\\"skipped\\\",\\n    }\\n\\n\\ndef process_mesh_into_wave_assets(\\n    *,\\n    root_id: int,\\n    bundle_paths: GeometryBundlePaths,\\n    simplify_target_faces: int = 15000,\\n    patch_hops: int = 6,\\n    patch_vertex_cap: int = 2500,\\n    registry_metadata: dict[str, Any] | None = None,\\n) -> dict[str, Any]:\\n    ensure_dir(bundle_paths.simplified_mesh_path.parent)\\n    ensure_dir(bundle_paths.surface_graph_path.parent)\\n\\n    raw_mesh = trimesh.load_mesh(bundle_paths.raw_mesh_path, process=False)\\n    if not isinstance(raw_mesh, trimesh.Trimesh):\\n        raise TypeError(f\\\"Expected a Trimesh at {bundle_paths.raw_mesh_path}, got {type(raw_mesh)!r}\\\")\\n\\n    mesh = raw_mesh.copy()\\n    original_face_count = int(len(mesh.faces))\\n    target_faces = min(int(simplify_target_faces), int(len(mesh.faces)))\\n    if target_faces >= 4:\\n        try:\\n            mesh = mesh.simplify_quadric_decimation(target_faces)\\n        except Exception:\\n            # Fallback: keep original mesh if local environment lacks simplification backend.\\n            pass\\n\\n    vertices = np.asarray(mesh.vertices, dtype=np.float32)\\n    faces = np.asarray(mesh.faces, dtype=np.int32)\\n    adj = _faces_to_adjacency(faces, vertices.shape[0])\\n    lap = _uniform_laplacian(adj)\\n    patch_vertices = _choose_patch_vertices(adj, patch_hops, patch_vertex_cap)\\n    patch_mask = np.zeros(vertices.shape[0], dtype=np.uint8)\\n    patch_mask[patch_vertices] = 1\\n    patch_adj = adj[patch_vertices][:, patch_vertices].tocsr()\\n    patch_lap = _uniform_laplacian(patch_adj)\\n\\n    mesh.export(bundle_paths.simplified_mesh_path)\\n\\n    np.savez_compressed(\\n        bundle_paths.surface_graph_path,\\n        vertices=vertices,\\n        faces=faces,\\n        adj_data=adj.data,\\n        adj_indices=adj.indices,\\n        adj_indptr=adj.indptr,\\n        adj_shape=np.asarray(adj.shape, dtype=np.int32),\\n        lap_data=lap.data,\\n        lap_indices=lap.indices,\\n        lap_indptr=lap.indptr,\\n        lap_shape=np.asarray(lap.shape, dtype=np.int32),\\n        patch_vertices=patch_vertices,\\n        patch_mask=patch_mask,\\n    )\\n\\n    np.savez_compressed(\\n        bundle_paths.patch_graph_path,\\n        patch_vertices=patch_vertices,\\n        adj_data=patch_adj.data,\\n        adj_indices=patch_adj.indices,\\n        adj_indptr=patch_adj.indptr,\\n        adj_shape=np.asarray(patch_adj.shape, dtype=np.int32),\\n        lap_data=patch_lap.data,\\n        lap_indices=patch_lap.indices,\\n        lap_indptr=patch_lap.indptr,\\n        lap_shape=np.asarray(patch_lap.shape, dtype=np.int32),\\n    )\\n\\n    descriptor_payload = {\\n        \\\"root_id\\\": int(root_id),\\n        \\\"n_vertices\\\": int(vertices.shape[0]),\\n        \\\"n_faces\\\": int(faces.shape[0]),\\n        \\\"surface_graph_edge_count\\\": int(adj.nnz // 2),\\n        \\\"patch_graph_vertex_count\\\": int(patch_vertices.size),\\n        \\\"patch_graph_edge_count\\\": int(patch_adj.nnz // 2),\\n        \\\"patch_hops\\\": int(patch_hops),\\n        \\\"patch_vertex_cap\\\": int(patch_vertex_cap),\\n        \\\"simplify_target_faces\\\": int(simplify_target_faces),\\n        \\\"raw_mesh_face_count\\\": original_face_count,\\n        \\\"surface_area\\\": float(mesh.area),\\n        \\\"volume\\\": float(mesh.volume),\\n        \\\"bounds_min\\\": vertices.min(axis=0).tolist(),\\n        \\\"bounds_max\\\": vertices.max(axis=0).tolist(),\\n        \\\"raw_mesh_path\\\": str(bundle_paths.raw_mesh_path),\\n        \\\"processed_mesh_path\\\": str(bundle_paths.simplified_mesh_path),\\n        \\\"surface_graph_path\\\": str(bundle_paths.surface_graph_path),\\n        \\\"patch_graph_path\\\": str(bundle_paths.patch_graph_path),\\n        \\\"registry_metadata\\\": registry_metadata or {},\\n    }\\n    write_json(descriptor_payload, bundle_paths.descriptor_sidecar_path)\\n\\n    qa_payload = {\\n        \\\"root_id\\\": int(root_id),\\n        \\\"raw_mesh_available\\\": bundle_paths.raw_mesh_path.exists(),\\n        \\\"raw_skeleton_available\\\": bundle_paths.raw_skeleton_path.exists(),\\n        \\\"simplified_mesh_available\\\": bundle_paths.simplified_mesh_path.exists(),\\n        \\\"surface_graph_available\\\": bundle_paths.surface_graph_path.exists(),\\n        \\\"patch_graph_available\\\": bundle_paths.patch_graph_path.exists(),\\n        \\\"descriptor_sidecar_available\\\": bundle_paths.descriptor_sidecar_path.exists(),\\n        \\\"is_watertight\\\": bool(mesh.is_watertight),\\n        \\\"vertex_count_matches_surface_graph\\\": int(vertices.shape[0]) == int(adj.shape[0]),\\n        \\\"patch_vertex_count\\\": int(patch_vertices.size),\\n        \\\"patch_is_nonempty\\\": bool(patch_vertices.size),\\n    }\\n    write_json(qa_payload, bundle_paths.qa_sidecar_path)\\n\\n    write_json(\\n        {\\n            **descriptor_payload,\\n            \\\"descriptor_sidecar_path\\\": str(bundle_paths.descriptor_sidecar_path),\\n            \\\"qa_sidecar_path\\\": str(bundle_paths.qa_sidecar_path),\\n        },\\n        bundle_paths.legacy_meta_json_path,\\n    )\\n\\n    return {\\n        \\\"asset_statuses\\\": {\\n            RAW_MESH_KEY: ASSET_STATUS_READY if bundle_paths.raw_mesh_path.exists() else ASSET_STATUS_MISSING,\\n            RAW_SKELETON_KEY: ASSET_STATUS_READY if bundle_paths.raw_skeleton_path.exists() else ASSET_STATUS_MISSING,\\n            SIMPLIFIED_MESH_KEY: ASSET_STATUS_READY,\\n            SURFACE_GRAPH_KEY: ASSET_STATUS_READY,\\n            PATCH_GRAPH_KEY: ASSET_STATUS_READY,\\n            DESCRIPTOR_SIDECAR_KEY: ASSET_STATUS_READY,\\n            QA_SIDECAR_KEY: ASSET_STATUS_READY,\\n        },\\n        \\\"bundle_metadata\\\": {\\n            \\\"n_vertices\\\": int(vertices.shape[0]),\\n            \\\"n_faces\\\": int(faces.shape[0]),\\n            \\\"surface_graph_edge_count\\\": int(adj.nnz // 2),\\n            \\\"patch_graph_vertex_count\\\": int(patch_vertices.size),\\n            \\\"patch_graph_edge_count\\\": int(patch_adj.nnz // 2),\\n            \\\"simplify_target_faces\\\": int(simplify_target_faces),\\n        },\\n    }\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n./agent_tickets/runs/20260321T170513Z/FW-M5-001_Define_a_versioned_geometry_asset_contract_for_multiresolution_morphology_bundles/stdout.jsonl:48:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_26\",\"type\":\"file_change\",\"changes\":[{\"path\":\"/home/jack/Documents/github/personal/fly_neural_simulation/flywire_wave_repo/scripts/03_build_wave_assets.py\",\"kind\":\"update\"}],\"status\":\"completed\"}}\n./agent_tickets/runs/20260321T170513Z/FW-M5-001_Define_a_versioned_geometry_asset_contract_for_multiresolution_morphology_bundles/st