LOGY,\\\\n    94\\\\t        )\\\\n    95\\\\t        bundle_paths = build_geometry_bundle_paths(\\\\n    96\\\\t            101,\\\\n    97\\\\t            meshes_raw_dir=ROOT / \\\\\\\"data\\\\\\\" / \\\\\\\"interim\\\\\\\" / \\\\\\\"meshes_raw\\\\\\\",\\\\n    98\\\\t            skeletons_raw_dir=ROOT / \\\\\\\"data\\\\\\\" / \\\\\\\"interim\\\\\\\" / \\\\\\\"skeletons_raw\\\\\\\",\\\\n    99\\\\t            processed_mesh_dir=ROOT / \\\\\\\"data\\\\\\\" / \\\\\\\"processed\\\\\\\" / \\\\\\\"meshes\\\\\\\",\\\\n   100\\\\t            processed_graph_dir=ROOT / \\\\\\\"data\\\\\\\" / \\\\\\\"processed\\\\\\\" / \\\\\\\"graphs\\\\\\\",\\\\n   101\\\\t        )\\\\n   102\\\\t\\\\n   103\\\\t        asset_statuses = default_asset_statuses(fetch_skeletons=False)\\\\n   104\\\\t        asset_statuses.update(\\\\n   105\\\\t            {\\\\n   106\\\\t                RAW_MESH_KEY: ASSET_STATUS_READY,\\\\n   107\\\\t                SIMPLIFIED_MESH_KEY: ASSET_STATUS_READY,\\\\n   108\\\\t                SURFACE_GRAPH_KEY: ASSET_STATUS_READY,\\\\n   109\\\\t                PATCH_GRAPH_KEY: ASSET_STATUS_READY,\\\\n   110\\\\t                DESCRIPTOR_SIDECAR_KEY: ASSET_STATUS_READY,\\\\n   111\\\\t                QA_SIDECAR_KEY: ASSET_STATUS_READY,\\\\n   112\\\\t                TRANSFER_OPERATORS_KEY: ASSET_STATUS_READY,\\\\n   113\\\\t                OPERATOR_METADATA_KEY: ASSET_STATUS_READY,\\\\n   114\\\\t            }\\\\n   115\\\\t        )\\\\n   116\\\\t\\\\n   117\\\\t        record = build_geometry_manifest_record(\\\\n   118\\\\t            bundle_paths=bundle_paths,\\\\n   119\\\\t            asset_statuses=asset_statuses,\\\\n   120\\\\t            dataset_name=\\\\\\\"public\\\\\\\",\\\\n   121\\\\t            materialization_version=783,\\\\n   122\\\\t            meshing_config_snapshot={\\\\\\\"fetch_skeletons\\\\\\\": False, \\\\\\\"patch_hops\\\\\\\": 2},\\\\n   123\\\\t            registry_metadata={\\\\\\\"cell_type\\\\\\\": \\\\\\\"T5a\\\\\\\"},\\\\n   124\\\\t            coupling_bundle_metadata=coupling_metadata,\\\\n   125\\\\t            processed_coupling_dir=processed_coupling_dir,\\\\n   126\\\\t        )\\\\n   127\\\\t        manifest = build_geometry_manifest(\\\\n   128\\\\t            bundle_records={101: record},\\\\n   129\\\\t            dataset_name=\\\\\\\"public\\\\\\\",\\\\n   130\\\\t            materialization_version=783,\\\\n   131\\\\t            meshing_config_snapshot={\\\\\\\"fetch_skeletons\\\\\\\": False, \\\\\\\"patch_hops\\\\\\\": 2},\\\\n   132\\\\t            processed_coupling_dir=processed_coupling_dir,\\\\n   133\\\\t        )\\\\n   134\\\\t\\\\n   135\\\\t        self.assertEqual(manifest[\\\\\\\"_coupling_contract_version\\\\\\\"], COUPLING_BUNDLE_CONTRACT_VERSION)\\\\n   136\\\\t        self.assertEqual(manifest[\\\\\\\"_coupling_contract\\\\\\\"][\\\\\\\"design_note\\\\\\\"], COUPLING_BUNDLE_DESIGN_NOTE)\\\\n   137\\\\t        self.assertEqual(\\\\n   138\\\\t            manifest[\\\\\\\"_coupling_contract\\\\\\\"][\\\\\\\"local_synapse_registry\\\\\\\"][\\\\\\\"path\\\\\\\"],\\\\n   139\\\\t            str((processed_coupling_dir / \\\\\\\"synapse_registry.csv\\\\\\\").resolve()),\\\\n   140\\\\t        )\\\\n   141\\\\t        self.assertEqual(manifest[\\\\\\\"101\\\\\\\"][\\\\\\\"coupling_bundle\\\\\\\"][\\\\\\\"status\\\\\\\"], ASSET_STATUS_READY)\\\\n   142\\\\t        self.assertEqual(\\\\n   143\\\\t            manifest[\\\\\\\"101\\\\\\\"][\\\\\\\"coupling_bundle\\\\\\\"][\\\\\\\"topology_family\\\\\\\"],\\\\n   144\\\\t            DISTRIBUTED_PATCH_CLOUD_TOPOLOGY,\\\\n   145\\\\t        )\\\\n   146\\\\t\\\\n   147\\\\t        discovered_paths = discover_coupling_bundle_paths(manifest[\\\\\\\"101\\\\\\\"])\\\\n   148\\\\t        self.assertEqual(\\\\n   149\\\\t            discovered_paths[LOCAL_SYNAPSE_REGISTRY_KEY],\\\\n   150\\\\t            (processed_coupling_dir / \\\\\\\"synapse_registry.csv\\\\\\\").resolve(),\\\\n   151\\\\t        )\\\\n   152\\\\t        self.assertEqual(\\\\n   153\\\\t            discovered_paths[INCOMING_ANCHOR_MAP_KEY],\\\\n   154\\\\t            (processed_coupling_dir / \\\\\\\"roots/101_incoming_anchor_map.npz\\\\\\\").resolve(),\\\\n   155\\\\t        )\\\\n   156\\\\t        self.assertEqual(\\\\n   157\\\\t            discovered_paths[OUTGOING_ANCHOR_MAP_KEY],\\\\n   158\\\\t            (processed_coupling_dir / \\\\\\\"roots/101_outgoing_anchor_map.npz\\\\\\\").resolve(),\\\\n   159\\\\t        )\\\\n   160\\\\t        self.assertEqual(\\\\n   161\\\\t            discovered_paths[COUPLING_INDEX_KEY],\\\\n   162\\\\t            (processed_coupling_dir / \\\\\\\"roots/101_coupling_index.json\\\\\\\").resolve(),\\\\n   163\\\\t        )\\\\n   164\\\\t\\\\n   165\\\\t        discovered_edge_bundles = discover_edge_coupling_bundle_paths(manifest[\\\\\\\"101\\\\\\\"])\\\\n   166\\\\t        self.assertEqual(\\\\n   167\\\\t            [\\\\n   168\\\\t                (item[\\\\\\\"pre_root_id\\\\\\\"], item[\\\\\\\"post_root_id\\\\\\\"], item[\\\\\\\"relation_to_root\\\\\\\"], item[\\\\\\\"path\\\\\\\"])\\\\n   169\\\\t                for item in discovered_edge_bundles\\\\n   170\\\\t            ],\\\\n   171\\\\t            [\\\\n   172\\\\t                (\\\\n   173\\\\t                    101,\\\\n   174\\\\t                    303,\\\\n   175\\\\t                    \\\\\\\"outgoing\\\\\\\",\\\\n   176\\\\t                    (processed_coupling_dir / \\\\\\\"edges/101__to__303_coupling.npz\\\\\\\").resolve(),\\\\n   177\\\\t                ),\\\\n   178\\\\t                (\\\\n   179\\\\t                    202,\\\\n   180\\\\t                    101,\\\\n   181\\\\t                    \\\\\\\"incoming\\\\\\\",\\\\n   182\\\\t                    (processed_coupling_dir / \\\\\\\"edges/202__to__101_coupling.npz\\\\\\\").resolve(),\\\\n   183\\\\t                ),\\\\n   184\\\\t            ],\\\\n   185\\\\t        )\\\\n   186\\\\t\\\\n   187\\\\t        operator_paths = disco