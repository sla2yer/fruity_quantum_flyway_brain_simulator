4997\t    diagnostic_cards: Sequence[Mapping[str, Any]],\n  4998\t) -> dict[str, Any]:\n  4999\t    if (\n  5000\t        artifact_role_id == ANALYSIS_UI_PAYLOAD_ROLE_ID\n  5001\t        and locator == \"wave_only_diagnostics.phase_map_references[0]\"\n  5002\t        and phase_refs\n  5003\t    ):\n  5004\t        first_phase = phase_refs[0]\n  5005\t        return {\n  5006\t            \"source_kind\": \"phase_map_reference\",\n  5007\t            \"bundle_id\": str(first_phase.get(\"bundle_id\", \"\")),\n  5008\t            \"arm_id\": str(first_phase.get(\"arm_id\", \"\")),\n  5009\t            \"seed\": int(first_phase.get(\"seed\", 0)),\n  5010\t            \"artifact_id\": str(first_phase.get(\"artifact_id\", \"\")),\n  5011\t            \"root_ids\": [int(item) for item in first_phase.get(\"root_ids\", [])],\n  5012\t            \"path\": str(first_phase.get(\"path\", \"\")),\n  5013\t        }\n  5014\t    if (\n  5015\t        artifact_role_id == ANALYSIS_UI_PAYLOAD_ROLE_ID\n  5016\t        and locator == \"wave_only_diagnostics.diagnostic_cards[0]\"\n  5017\t        and diagnostic_cards\n  5018\t    ):\n  5019\t        first_card = diagnostic_cards[0]\n  5020\t        return {\n  5021\t            \"source_kind\": \"diagnostic_card\",\n  5022\t            \"card_id\": str(first_card.get(\"card_id\", \"\")),\n  5023\t            \"arm_id\": str(first_card.get(\"arm_id\", \"\")),\n  5024\t            \"metric_id\": str(first_card.get(\"metric_id\", \"\")),\n  5025\t            \"mean_value\": first_card.get(\"mean_value\"),\n  5026\t            \"units\": str(first_card.get(\"units\", \"\")),\n  5027\t            \"seed_count\": int(first_card.get(\"seed_count\", 0)),\n  5028\t        }\n  5029\t    return {\n  5030\t        \"source_kind\": \"explicit_reference\",\n  5031\t        \"artifact_role_id\": str(artifact_role_id),\n  5032\t        \"locator\": None if locator is None else str(locator),\n  5033\t    }\n  5034\t\n  5035\t\n  5036\tdef _build_highlight_fallback_path(\n  5037\t    *,\n  5038\t    suite_support_references: Sequence[Mapping[str, Any]],\n  5039\t    validation_support_references: Sequence[Mapping[str, Any]],\n  5040\t    fallback_reason: str,\n  5041\t) -> dict[str, Any]:\n  5042\t    return {\n  5043\t        \"fallback_step_id\": BASELINE_WAVE_COMPARISON_STEP_ID,\n  5044\t        \"fallback_preset_id\": HIGHLIGHT_FALLBACK_PRESET_ID,\n  5045\t        \"cue_kind_id\": FALLBACK_REDIRECT_CUE_KIND_ID,\n  5046\t        \"fallback_explanation\": str(fallback_reason),\n  5047\t        \"supporting_evidence_references\": [\n  5048\t            build_showcase_evidence_reference(\n  5049\t                evidence_role_id=SHARED_COMPARISON_EVIDENCE_ROLE_ID,\n  5050\t                artifact_role_id=ANALYSIS_UI_PAYLOAD_ROLE_ID,\n  5051\t                citation_label=\"Analysis shared-comparison payload\",\n  5052\t                locator=\"shared_comparison\",\n  5053\t            ),\n  5054\t            *[copy.deepcopy(dict(item)) for item in suite_support_references],\n  5055\t            *[copy.deepcopy(dict(item)) for item in validation_support_references],\n  5056\t        ],\n  5057\t    }\n  5058\t\n  5059\t\n  5060\tdef _story_arc_preset_ids() -> dict[str, str]:\n  5061\t    return {\n  5062\t        \"scene_choice\": SCENE_CONTEXT_PRESET_ID,\n  5063\t        \"fly_view_framing\": RETINAL_INPUT_FOCUS_PRESET_ID,\n  5064\t        \"active_subset_emphasis\": SUBSET_CONTEXT_PRESET_ID,\n  5065\t        \"propagation_view\": PROPAGATION_REPLAY_PRESET_ID,\n  5066\t        \"comparison_pairing\": PAIRED_COMPARISON_PRESET_ID,\n  5067\t        \"highlight_phenomenon_reference\": APPROVED_HIGHLIGHT_PRESET_ID,\n  5068\t        \"highlight_fallback\": HIGHLIGHT_FALLBACK_PRESET_ID,\n  5069\t        \"final_analysis_landing\": ANALYSIS_SUMMARY_PRESET_ID,\n  5070\t    }\n  5071\t\n  5072\t\n  5073\tdef _build_showcase_fixture_profile(\n  5074\t    *,\n  5075\t    fixture_mode: str,\n  5076\t    dashboard_context: Mapping[str, Any],\n  5077\t    suite_context: Mapping[str, Any] | None,\n  5078\t    narrative_context: Mapping[str, Any],\n  5079\t) -> dict[str, Any]:\n  5080\t    return {\n  5081\t        \"fixture_mode\": str(fixture_mode),\n  5082\t        \"fixture_id\": \"milestone16_local_rehearsal\",\n  5083\t        \"display_name\": \"Milestone 16 Local Rehearsal\",\n  5084\t        \"workflow_kind\": \"local_showcase_rehearsal\",\n  5085\t        \"keeps_readiness_fixtures_fast\": True,\n  5086\t        \"uses_packaged_dashboard_session\": True,\n  5087\t        \"uses_packaged_suite_review\": bool(\n  5088\t            suite_context is not None and suite_context.get(\"summary_table_artifact\") is not None\n  5089\t        ),\n  5090\t        \"dashboard_origin\": str(dashboard_context[\"origin\"]),\n  5091\t        \"selected_root_count\": int(\n  5092\t            narrative_context[\"active_subset_focus_targets\"][\"root_count\"]\n  5093\t        ),\n  5094\t        \"story_arc_preset_ids\": _story_arc_preset_ids(),\n  5095\t    }\n  5096\t\n  5097\t\n  5098\tdef _select_suite_artifact(\n  5099\t    items: Sequence[Mapping[str, Any]],\n  5100\t    *,\n  5101\t    preferred_artifact_id: str | None,\n  5102\t    preferred_section_id: str | None,\n  5103\t) -> dict[str, Any] | None:\n  5104\t    normalized = _normalize_mapping_sequence(items, field_name=\"suite_artifacts\")\n  5105\t    if not normalized:\n  5106\t        return None\n  5107\t    candidates = normalized\n  5108\t    if preferred_artifact_id is not None:\n  5109\t        exact = [\n  5110\t            dict(item)\n  5111\t            for item in normalized\n  5112\t            if str(item.get(\"artifact_id\")) == preferred_artifact_id\n  5113\t        ]\n  5114\t        if exact:\n  5115\t            return exact[0]\n  5116\t    if preferred_section_id is not None:\n  5117\t        section_matches = [\n  5118\t            dict(item)\n  5119\t            for item in normalized\n  5120\t            if str(item.get(\"section_id\")) == preferred_section_id\n  5121\t        ]\n  5122\t        if section_matches:\n  5123\t            candidates = section_matches\n  5124\t    candidates.sort(\n  5125\t        key=lambda item: (\n  5126\t            \"\" if item.get(\"section_id\") is None else str(item[\"section_id\"]),\n  5127\t            str(item[\"artifact_id\"]),\n  5128\t        )\n  5129\t    )\n  5130\t    return candidates[0]\n  5131\t\n  5132\t\n  5133\tdef _load_upstream_bundle_metadata_from_dashboard(\n  5134\t    *,\n  5135\t    dashboard_metadata: Mapping[str, Any],\n  5136\t    dashboard_role_id: str,\n  5137\t    explicit_metadata_path: str | None,\n  5138\t    loader,\n  5139\t) -> dict[str, Any]:\n  5140\t    if explicit_metadata_path is not None:\n  5141\t        return loader(Path(explicit_metadata_path).resolve())\n  5142\t    refs = discover_dashboard_session_artifact_references(\n  5143\t        dashboard_metadata,\n  5144\t        artifact_role_id=dashboard_role_id,\n  5145\t    )\n  5146\t    if len(refs) != 1:\n  5147\t        raise ValueError(\n  5148\t            f\"dashboard_session metadata must include exactly one artifact reference for {dashboard_role_id!r}.\"\n  5149\t        )\n  5150\t    return loader(Path(refs[0][\"path\"]).resolve())\n  5151\t\n  5152\t\n  5153\tdef _explicit_or_default_path(\n  5154\t    raw_explicit_artifacts: Mapping[str, Mapping[str, Any]],\n  5155\t    *,\n  5156\t    role_id: str,\n  5157\t    default_path: str | Path,\n  5158\t) -> Path:\n  5159\t    raw = raw_explicit_artifacts.get(role_id)\n  5160\t    if raw is None:\n  5161\t        return Path(default_path).resolve()\n  5162\t    return Path(raw[\"path\"]).resolve()\n  5163\t\n  5164\t\n  5165\tdef _scene_surface_kind(scene_context: Mapping[str, Any]) -> str:\n  5166\t    if str(scene_context[\"source_kind\"]) == \"retinal_bundle\":\n  5167\t        return \"retinal_input\"\n  5168\t    return \"fly_view\"\n  5169\t\n  5170\t\n  5171\tdef _preferred_overlay(available_overlays: set[str], *candidates: str) -> str:\n  5172\t    for candidate in candidates:\n  5173\t        if candidate in available_overlays:\n  5174\t            return candidate\n  5175\t    raise ValueError(\n  5176\t        f\"Showcase planning could not find a supported overlay from candidates {candidates!r}.\"\n  5177\t    )\n  5178\t\n  5179\t\n  5180\tdef _deep_merge(base: Any, override: Any) -> Any:\n  5181\t    if isinstance(base, Mapping) and isinstance(override, Mapping):\n  5182\t        merged = {str(key): copy.deepcopy(value) for key, value in base.items()}\n  5183\t        for key, value in override.items():\n  5184\t            merged[str(key)] = _deep_merge(merged.get(str(key)), value)\n  5185\t        return merged\n  5186\t    return copy.deepcopy(override)\n  5187\t\n  5188\t\n  5189\tdef _normalize_mapping_sequence(\n  5190\t    payload: Sequence[Mapping[str, Any]],\n  5191\t    *,\n  5192\t    field_name: str,\n  5193\t) -> list[dict[str, Any]]:\n  5194\t    if not isinstance(payload, Sequence) or isinstance(payload, (str, bytes)):\n  5195\t        raise ValueError(f\"{field_name} must be a sequence of mappings.\")\n  5196\t    result: list[dict[str, Any]] = []\n  5197\t    for index, item in enumerate(payload):\n  5198\t        if not isinstance(item, Mapping):\n  5199\t            raise ValueError(f\"{field_name}[{index}] must be a mapping.\")\n  5200\t        result.append(copy.deepcopy(dict(item)))\n  5201\t    return result\n  5202\t\n  5203\t\n  5204\tdef _load_json_mapping(path: str | Path, *, field_name: str) -> dict[str, Any]:\n  5205\t    resolved = Path(path).resolve()\n  5206\t    if not resolved.exists():\n  5207\t        raise ValueError(f\"{field_name} is missing required local artifact {resolved}.\")\n  5208\t    with resolved.open(\"r\", encoding=\"utf-8\") as handle:\n  5209\t        payload = json.load(handle)\n  5210\t    if not isinstance(payload, Mapping):\n  5211\t        raise ValueError(f\"{field_name} must deserialize to a mapping.\")\n  5212\t    return copy.deepcopy(dict(payload))\n  5213\t\n  5214\t\n  5215\tdef _require_mapping(value: Any, *, field_name: str) -> dict[str, Any]:\n  5216\t    if not isinstance(value, Mapping):\n  5217\t        raise ValueError(f\"{field_name} must be a mapping.\")\n  5218\t    return copy.deepcopy(dict(value))\n","exit_code":0,"status":"completed"}}
