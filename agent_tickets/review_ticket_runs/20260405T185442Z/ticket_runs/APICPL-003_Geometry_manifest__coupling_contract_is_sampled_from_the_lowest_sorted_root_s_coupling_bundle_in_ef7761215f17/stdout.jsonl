 build_coupling_contract_manifest_metadata(\n   882\t        processed_coupling_dir=resolved_processed_coupling_dir,\n   883\t        local_synapse_registry_status=resolved_local_synapse_registry_status,\n   884\t    )\n   885\t\n   886\t\n   887\tdef _collect_manifest_local_synapse_registry_records(\n   888\t    bundle_records: Mapping[int | str, Mapping[str, Any]],\n   889\t) -> list[dict[str, Any]]:\n   890\t    registry_records: list[dict[str, Any]] = []\n   891\t    for root_id in sorted(bundle_records, key=lambda value: int(value)):\n   892\t        record = bundle_records[root_id]\n   893\t        if not isinstance(record, Mapping):\n   894\t            continue\n   895\t        coupling_bundle = record.get(\"coupling_bundle\")\n   896\t        if isinstance(coupling_bundle, Mapping):\n   897\t            normalized_bundle = parse_coupling_bundle_metadata(coupling_bundle)\n   898\t            local_synapse_registry = normalized_bundle[\"assets\"][LOCAL_SYNAPSE_REGISTRY_KEY]\n   899\t            registry_records.append(\n   900\t                {\n   901\t                    \"root_id\": int(root_id),\n   902\t                    \"path\": Path(str(local_synapse_registry[\"path\"])).resolve(),\n   903\t                    \"status\": str(local_synapse_registry[\"status\"]),\n   904\t                }\n   905\t            )\n   906\t    return registry_records\n   907\t\n   908\t\n   909\tdef _resolve_manifest_processed_coupling_dir(\n   910\t    bundle_records: Mapping[int | str, Mapping[str, Any]],\n   911\t    *,\n   912\t    processed_coupling_dir: str | Path | None,\n   913\t) -> Path:\n   914\t    if processed_coupling_dir is not None:\n   915\t        return Path(processed_coupling_dir).resolve()\n   916\t\n   917\t    inferred_dirs: dict[Path, list[int]] = {}\n   918\t    for root_id in sorted(bundle_records, key=lambda value: int(value)):\n   919\t        record = bundle_records[root_id]\n   920\t        if not isinstance(record, Mapping):\n   921\t            continue\n   922\t        inferred_dir = _infer_record_processed_coupling_dir(record)\n   923\t        if inferred_dir is None:\n   924\t            continue\n   925\t        inferred_dirs.setdefault(inferred_dir, []).append(int(root_id))\n   926\t\n   927\t    if not inferred_dirs:\n   928\t        raise ValueError(\n   929\t            \"processed_coupling_dir must be provided when geometry manifest records do not \"\n   930\t            \"contain enough geometry path metadata to infer the manifest coupling directory.\"\n   931\t        )\n   932\t    if len(inferred_dirs) > 1:\n   933\t        conflict_details = \"; \".join(\n   934\t            f\"{path} from roots {root_ids!r}\"\n   935\t            for path, root_ids in sorted(inferred_dirs.items(), key=lambda item: str(item[0]))\n   936\t        )\n   937\t        raise ValueError(\n   938\t            \"Geometry manifest records imply conflicting default processed_coupling_dir values. \"\n   939\t            f\"Provide processed_coupling_dir explicitly. Conflicts: {conflict_details}.\"\n   940\t        )\n   941\t    return next(iter(inferred_dirs))\n   942\t\n   943\t\n   944\tdef _infer_record_processed_coupling_dir(record: Mapping[str, Any]) -> Path | None:\n   945\t    surface_graph_path = record.get(\"surface_graph_path\", record.get(\"processed_graph_path\"))\n   946\t    if not isinstance(surface_graph_path, str) or not surface_graph_path:\n   947\t        return None\n   948\t    return (Path(surface_graph_path).resolve().parent.parent / \"coupling\").resolve()\n   949\t\n   950\t\n   951\tdef _resolve_manifest_local_synapse_registry_status(\n   952\t    registry_records: list[dict[str, Any]],\n   953\t    *,\n   954\t    local_synapse_registry_status: str | None,\n   955\t) -> str:\n   956\t    if local_synapse_registry_status is not None:\n   957\t        normalized_status = str(local_synapse_registry_status)\n   958\t        if not normalized_status:\n   959\t            raise ValueError(\"local_synapse_registry_status must be a non-empty string when provided.\")\n   960\t        return normalized_status\n   961\t\n   962\t    if not registry_records:\n   963\t        return ASSET_STATUS_MISSING\n   964\t\n   965\t    statuses = {str(record[\"status\"]) for record in registry_records}\n","exit_code":0,"status":"completed"}}
