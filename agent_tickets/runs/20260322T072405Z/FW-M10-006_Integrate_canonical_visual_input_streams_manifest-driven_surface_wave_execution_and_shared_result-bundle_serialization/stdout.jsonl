   0 0 1\n            1 0 0\n            0 1 0\n            -1 0 0\n            0 -1 0\n            0 0 -1\n            3 0 1 2\n            3 0 2 3\n            3 0 3 4\n            3 0 4 1\n            3 5 2 1\n            3 5 3 2\n            3 5 4 3\n            3 5 1 4\n            \"\"\"\n        ).strip()\n        + \"\\n\",\n        encoding=\"utf-8\",\n    )\n\n\ndef _write_stub_swc(path: Path) -> None:\n    path.parent.mkdir(parents=True, exist_ok=True)\n    path.write_text(\n        \"1 1 0 0 0 1 -1\\n2 3 0 1 0 1 1\\n\",\n        encoding=\"utf-8\",\n    )\n\n\nif __name__ == \"__main__\":\n    unittest.main()\n","exit_code":0,"status":"completed"}}
