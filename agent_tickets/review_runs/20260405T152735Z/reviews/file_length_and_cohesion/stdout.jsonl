rences = _highlight_validation_support_references(\n  1672\t        validation_context\n  1673\t    )\n  1674\t\n  1675\t    if normalized_override is not None:\n  1676\t        requested_role = str(normalized_override[\"artifact_role_id\"])\n  1677\t        locator = normalized_override.get(\"locator\")\n  1678\t        if requested_role == ANALYSIS_UI_PAYLOAD_ROLE_ID:\n  1679\t            _validate_highlight_locator(\n  1680\t                locator=locator,\n  1681\t                phase_refs=phase_refs,\n  1682\t                diagnostic_cards=diagnostic_cards,\n  1683\t            )\n  1684\t        source_reference = _resolve_highlight_source_reference(\n  1685\t            artifact_role_id=requested_role,\n  1686\t            locator=locator,\n  1687\t            phase_refs=phase_refs,\n  1688\t            diagnostic_cards=diagnostic_cards,\n  1689\t        )\n  1690\t        if not approved:\n  1691\t            raise ValueError(\n  1692\t                \"Showcase planning received a nominated highlight override, but \"\n  1693\t                \"validation review_handoff does not approve the highlight: \"\n  1694\t                f\"scientific_plausibility_decision={scientific_decision!r}, \"\n  1695\t                f\"review_status={review_status!r}.\"\n  1696\t            )\n  1697\t        return {\n  1698\t            \"phenomenon_id\": str(normalized_override[\"phenomenon_id\"]),\n  1699\t            \"artifact_role_id\": requested_role,\n  1700\t            \"locator\": locator,\n  1701\t            \"citation_label\": str(normalized_override[\"citation_label\"]),\n  1702\t            \"presentation_status\": PRESENTATION_STATUS_READY,\n  1703\t            \"scientific_plausibility_decision\": scientific_decision,\n  1704\t            \"review_status\": review_status,\n  1705\t            \"fallback_reason\": None,\n  1706\t            \"source_reference\": source_reference,\n  1707\t            \"primary_evidence_reference\": build_showcase_evidence_reference(\n  1708\t                evidence_role_id=APPROVED_WAVE_HIGHLIGHT_EVIDENCE_ROLE_ID,\n  1709\t                artifact_role_id=requested_role,\n  1710\t                citation_label=str(normalized_override[\"citation_label\"]),\n  1711\t                locator=locator,\n  1712\t            ),\n  1713\t            \"supporting_evidence_references\": suite_support_references\n  1714\t            + validation_support_references,\n  1715\t            \"fallback_path\": _build_highlight_fallback_path(\n  1716\t                suite_support_references=suite_support_references,\n  1717\t                validation_support_references=validation_support_references,\n  1718\t                fallback_reason=(\n  1719\t                    \"Redirect to the paired comparison if the nominated wave-only beat \"\n  1720\t                    \"cannot be shown honestly at rehearsal time.\"\n  1721\t                ),\n  1722\t            ),\n  1723\t        }\n  1724\t\n  1725\t    if phase_refs:\n  1726\t        first_phase = phase_refs[0]\n  1727\t        candidate = {\n  1728\t            \"phenomenon_id\": _normalize_identifier(\n  1729\t                f\"{first_phase.get('artifact_id', 'phase_map')}_{first_phase.get('arm_id', 'wave')}\",\n  1730\t                field_name=\"phenomenon_id\",\n  1731\t            ),\n  1732\t            \"artifact_role_id\": ANALYSIS_UI_PAYLOAD_ROLE_ID,\n  1733\t            \"locator\": \"wave_only_diagnostics.phase_map_references[0]\",\n  1734\t            \"citation_label\": \"Wave phase-map reference\",\n  1735\t            \"source_reference\": {\n  1736\t                \"source_kind\": \"phase_map_reference\",\n  1737\t                \"bundle_id\": str(first_phase.get(\"bundle_id\", \"\")),\n  1738\t                \"arm_id\": str(first_phase.get(\"arm_id\", \"\")),\n  1739\t                \"seed\": int(first_phase.get(\"seed\", 0)),\n  1740\t                \"artifact_id\": str(first_phase.get(\"artifact_id\", \"\")),\n  17