    )\n  1449\t        )\n  1450\t\n  1451\t    highlight_ready = (\n  1452\t        str(highlight_presentation[\"presentation_status\"]) == PRESENTATION_STATUS_READY\n  1453\t    )\n  1454\t    return {\n  1455\t        \"view_id\": \"summary_analysis_landing_view\",\n  1456\t        \"view_kind\": \"summary_analysis_landing\",\n  1457\t        \"display_name\": \"Summary Analysis Landing\",\n  1458\t        \"headline\": _SUMMARY_ANALYSIS_HEADLINE,\n  1459\t        \"subheadline\": _SUMMARY_ANALYSIS_SUBHEAD,\n  1460\t        \"analysis_overall_status\": str(\n  1461\t            analysis_summary_card.get(\"overall_status\", \"unavailable\")\n  1462\t        ),\n  1463\t        \"newcomer_summary_lines\": [\n  1464\t            (\n  1465\t                \"Start from the matched shared-comparison surface on one readout and \"\n  1466\t                \"one shared timebase.\"\n  1467\t            ),\n  1468\t            (\n  1469\t                \"Use the wave-only highlight as an explicitly labeled diagnostic.\"\n  1470\t                if highlight_ready\n  1471\t                else \"Demote the wave-only highlight to a caveated note when approval is missing.\"\n  1472\t            ),\n  1473\t            (\n  1474\t                \"Close on packaged analysis, suite, and validation artifacts rather \"\n  1475\t                \"than a disconnected summary slide.\"\n  1476\t            ),\n  1477\t        ],\n  1478\t        \"comparison_anchor\": {\n  1479\t            \"pairing_id\": str(comparison_act[\"pairing_id\"]),\n  1480\t            \"content_scope_label\": str(comparison_act[\"content_scope_label\"]),\n  1481\t            \"selected_readout_id\": str(\n  1482\t                comparison_act[\"stable_pairing_semantics\"][\"selected_readout_id\"]\n  1483\t            ),\n  1484\t        },\n  1485\t        \"highlight_outcome\": {\n  1486\t            \"presentation_status\": str(highlight_presentation[\"presentation_status\"]),\n  1487\t            \"c