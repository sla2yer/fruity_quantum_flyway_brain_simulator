ry_bundle.v1\\\"\\n    14\\tOPERATOR_BUNDLE_CONTRACT_VERSION = \\\"operator_bundle.v1\\\"\\n    15\\tOPERATOR_BUNDLE_DESIGN_NOTE = \\\"docs/operator_bundle_design.md\\\"\\n    16\\t\\n    17\\tASSET_STATUS_READY = \\\"ready\\\"\\n    18\\tASSET_STATUS_MISSING = \\\"missing\\\"\\n    19\\tASSET_STATUS_SKIPPED = \\\"skipped\\\"\\n    20\\t\\n    21\\tFETCH_STATUS_FETCHED = \\\"fetched\\\"\\n    22\\tFETCH_STATUS_CACHE_HIT = \\\"cache_hit\\\"\\n    23\\tFETCH_STATUS_SKIPPED = \\\"skipped\\\"\\n    24\\tFETCH_STATUS_FAILED = \\\"failed\\\"\\n    25\\t\\n    26\\tRAW_MESH_KEY = \\\"raw_mesh\\\"\\n    27\\tRAW_SKELETON_KEY = \\\"raw_skeleton\\\"\\n    28\\tSIMPLIFIED_MESH_KEY = \\\"simplified_mesh\\\"\\n    29\\tSURFACE_GRAPH_KEY = \\\"surface_graph\\\"\\n    30\\tPATCH_GRAPH_KEY = \\\"patch_graph\\\"\\n    31\\tDESCRIPTOR_SIDECAR_KEY = \\\"descriptor_sidecar\\\"\\n    32\\tQA_SIDECAR_KEY = \\\"qa_sidecar\\\"\\n    33\\tTRANSFER_OPERATORS_KEY = \\\"transfer_operators\\\"\\n    34\\tOPERATOR_METADATA_KEY = \\\"operator_metadata\\\"\\n    35\\t\\n    36\\tFINE_OPERATOR_KEY = \\\"fine_operator\\\"\\n    37\\tCOARSE_OPERATOR_KEY = \\\"coarse_operator\\\"\\n    38\\t\\n    39\\tGEOMETRY_PROCESSED_ASSET_KEYS = (\\n    40\\t    SIMPLIFIED_MESH_KEY,\\n    41\\t    SURFACE_GRAPH_KEY,\\n    42\\t    PATCH_GRAPH_KEY,\\n    43\\t    DESCRIPTOR_SIDECAR_KEY,\\n    44\\t    QA_SIDECAR_KEY,\\n    45\\t)\\n    46\\tPROCESSED_ASSET_KEYS = GEOMETRY_PROCESSED_ASSET_KEYS + (\\n    47\\t    TRANSFER_OPERATORS_KEY,\\n    48\\t    OPERATOR_METADATA_KEY,\\n    49\\t)\\n    50\\t\\n    51\\tDEFAULT_FINE_DISCRETIZATION_FAMILY = \\\"triangle_mesh_cotangent_fem\\\"\\n    52\\tDEFAULT_MASS_TREATMENT = \\\"lumped_mass\\\"\\n    53\\tDEFAULT_NORMALIZATION = \\\"mass_normalized\\\"\\n    54\\tDEFAULT_BOUNDARY_CONDITION_MODE = \\\"closed_surface_zero_flux\\\"\\n    55\\t\\n    56\\tFALLBACK_FINE_DISCRETIZATION_FAMILY = \\\"surface_graph_uniform_laplacian\\\"\\n    57\\tFALLBACK_MASS_TREATMENT = \\\"unifor