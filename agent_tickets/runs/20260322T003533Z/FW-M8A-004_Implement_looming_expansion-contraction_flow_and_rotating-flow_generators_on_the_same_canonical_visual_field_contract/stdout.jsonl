{"type":"item.started","item":{"id":"item_46","type":"command_execution","command":"/bin/bash -lc \"PYTHONPATH=src ./.venv/bin/python - <<'PY'\nfrom flywire_wave.stimulus_generators import synthesize_stimulus\n\nradial_common = {\n    'temporal_sampling': {'dt_ms': 50.0, 'duration_ms': 300.0},\n    'stimulus_overrides': {\n        'background_level': 0.5,\n        'contrast': 0.25,\n        'polarity': 'positive',\n        'onset_ms': 0.0,\n        'offset_ms': 300.0,\n        'radial_speed_deg_per_s': 20.0,\n        'radial_spatial_frequency_cpd': 0.25,\n        'phase_deg': 90.0,\n        'waveform': 'square',\n        'inner_radius_deg': 2.0,\n        'outer_radius_deg': 12.0,\n    },\n}\nfor name in ['expanding_flow', 'contracting_flow']:\n    stim = {'stimulus': {'stimulus_family': 'radial_flow', 'stimulus_name': name, **radial_common}}\n    result = synthesize_stimulus(stim)\n    print(name)\n    print(' t100 r6 ', result.sample_field(time_ms=100.0, azimuth_deg=6.0, elevation_deg=0.0))\n    print(' t0 r4 ', result.sample_field(time_ms=0.0, azimuth_deg=4.0, elevation_deg=0.0))\n    print(' t0 r8 ', result.sample_field(time_ms=0.0, azimuth_deg=8.0, elevation_deg=0.0))\n    print()\n\nrot_common = {\n    'temporal_sampling': {'dt_ms': 250.0, 'duration_ms': 1250.0},\n    'stimulus_overrides': {\n        'background_level': 0.5,\n        'contrast': 0.25,\n        'polarity': 'positive',\n        'onset_ms': 0.0,\n        'offset_ms': 1250.0,\n        'angular_velocity_deg_per_s': 90.0,\n        'angular_cycle_count': 2,\n        'phase_deg': 45.0,\n        'waveform': 'square',\n        'inner_radius_deg': 2.0,\n        'outer_radius_deg': 12.0,\n    },\n}\nfor name in ['clockwise_rotation', 'counterclockwise_rotation']:\n    stim = {'stimulus': {'stimulus_family': 'rotating_flow', 'stimulus_name': name, **rot_common}}\n    result = synthesize_stimulus(stim)\n    print(name)\n    print(' t1000 right ', result.sample_field(time_ms=1000.0, azimuth_deg=6.0, elevation_deg=0.0))\n    print(' t0 top ', result.sample_field(time_ms=0.0, azimuth_deg=0.0, elevation_deg=6.0))\n    print(' t0 bottom ', result.sample_field(time_ms=0.0, azimuth_deg=0.0, elevation_deg=-6.0))\n    print()\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
