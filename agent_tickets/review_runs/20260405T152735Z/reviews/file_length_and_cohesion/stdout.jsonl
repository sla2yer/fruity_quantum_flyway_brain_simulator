eld_name}.selected_edge_bundle_paths[{edge_index}]\",\n  2368\t            )\n  2369\t            pre_root_id = int(normalized_edge_bundle[\"pre_root_id\"])\n  2370\t            post_root_id = int(normalized_edge_bundle[\"post_root_id\"])\n  2371\t            if (\n  2372\t                pre_root_id not in selected_root_ids\n  2373\t                or post_root_id not in selected_root_ids\n  2374\t            ):\n  2375\t                raise ValueError(\n  2376\t                    \"Hybrid morphology routing encountered selected edge bundle \"\n  2377\t                    f\"{pre_root_id}->{post_root_id} outside the selected root roster.\"\n  2378\t                )\n  2379\t            path = Path(str(normalized_edge_bundle[\"path\"])).resolve()\n  2380\t            if not path.exists():\n  2381\t                raise ValueError(\n  2382\t                    f\"Hybrid morphology selected edge bundle is missing: {path}.\"\n  2383\t                )\n  2384\t            edge_key = (pre_root_id, post_root_id)\n  2385\t            if edge_key in edge_paths and edge_paths[edge_key] != path:\n  2386\t                raise ValueError(\n  2387\t                    \"Hybrid morphology routing encountered conflicting bundle paths for \"\n  2388\t                    f\"edge {pre_root_id}->{post_root_id}: \"\n  2389\t                    f\"{edge_paths[edge_key]} != {path}.\"\n  2390\t                )\n  2391\t            edge_paths[edge_key] = path\n  2392\t\n  2393\t    for index, asset in enumerate(\n  2394\t        _require_sequence(\n  2395\t            execution_plan.get(\"selected_root_coupling_assets\", ()),\n  2396\t            field_name=\"surface_wave_execution_plan.selected_root_coupling_assets\",\n  2397\t        )\n  2398\t    ):\n  2399\t        register_from_asset(\n  2400\t            _require_mapping(\n  2401\t                asset,\n  2402\t                field_name=f\"selected_root_coupling_assets[{index}]\",\n  2403\t            ),\n  2404\t            field_name=f\"selected_root_coupling_assets[{index}]\",\n  2405\t        )\n  2406\t    for index, asset in enumerate(\n  2407\t        _require_sequence(\n  2408\t            execution_plan.get(\"selected_root_skeleton_assets\", ()),\n  2409\t            field_name=\"surface_wave_execution_plan.selected_root_skeleton_assets\",\n  2410\t        )\n  2411\t    ):\n  2412\t        register_from_asset(\n  2413\t            _require_mapping(\n  2414\t                asset,\n  2415\t                field_name=f\"selected_root_skeleton_assets[{index}]\",\n  2416\t            ),\n  2417\t            field_name=f\"selected_root_skeleton_assets[{index}]\",\n  2418\t        )\n  2419\t    mixed_fidelity = execution_plan.get(\"mixed_fidelity\")\n  2420\t    if isinstance(mixed_fidelity, Mapping):\n  2421\t        for index, assignment in enumerate(\n  2422\t            _require_sequence(\n  2423\t                mixed_fidelity.get(\"per_root_assignments\", ()),\n  2424\t                field_name=\"surface_wave_execution_plan.mixed_fidelity.per_root_assignments\",\n  2425\t            )\n  2426\t        ):\n  2427\t            normalized_assignment = _require_mapping(\n  2428\t                assignment,\n  2429\t                field_name=f\"mixed_fidelity.per_root_assignments[{index}]\",\n  2430\t            )\n  2431\t            coupling_asset = normalized_assignment.get(\"coupling_asset\")\n  2432\t            if not isinstance(coupling_asset, Mapping):\n  2433\t                continue\n  2434\t            register_from_asset(\n  2435\t                _require_mapping(\n  2436\t                    coupling_asset,\n  2437\t                    field_name=(\n  2438\t                        f\"mixed_fidelity.per_root_assignments[{index}].coupling_asset\"\n  2439\t                    ),\n  2440\t                ),\n  2441\t                field_name=(\n  2442\t                    f\"mixed_fidelity.per_root_assignments[{index}].coupling_asset\"\n  2443\t                ),\n  2444\t            )\n  2445\t    return edge_paths\n  2446\t\n  2447\t\n  2448\tdef _surface_subset_component_families(\n  2449\t    surface_runtime: SurfaceWaveMorphologyRuntime | None,\n  2450\t) -> list[dict[str, Any]]:\n  2451\t    if surface_runtime is None:\n  2452\t        return []\n  2453\t    grouped_component_ids: dict[tuple[int, int], list[str]] = {}\n  2454\t    for component in surface_runtime._resolved.coupling_plan.components:\n  2455\t        edge_key = (int(component.pre_root_id), int(component.post_root_id))\n  2456\t        grouped_component_ids.setdefault(edge_key, []).append(component.component_id)\n  2457\t    families: list[dict[str, Any]] = []\n  2458\t    for edge_key in sorted(grouped_component_ids):\n  2459\t        pre_root_id, post_root_id = edge_key\n  2460\t        route_id = _route_id_for_classes(SURFACE_NEURON_CLASS, SURFACE_NEURON_CLASS)\n  2461\t        families.append(\n  2462\t            {\n  2463\t                \"component_family_id\": (\n  2464\t                    f\"{pre_root_id}__to__{post_root_id}__{route_id}\"\n  2465\t                ),\n  2466\t                \"pre_root_id\": int(pre_root_id),\n  2467\t                \"post_root_id\": int(post_root_id),\n  2468\t                \"source_morphology_class\": SURFACE_NEURON_CLASS,\n  2469\t                \"target_morphology_class\": SURFACE_NEURON_CLASS,\n  2470\t                \"route_id\": route_id,\n  2471\t                \"projection_route\": _projection_route_for_classes(\n  2472\t                    SURFACE_NEURON_CLASS,\n  2473\t                    SURFACE_NEURON_CLASS,\n  2474\t                ),\n  2475\t                \"source_projection_surface\": _PROJECTION_SURFACE_BY_CLASS[\n  2476\t                    SURFACE_NEURON_CLASS\n  2477\t                ],\n  2478\t                \"target_injection_surface\": _PROJECTION_SURFACE_BY_CLASS[\n  2479\t                    SURFACE_NEURON_CLASS\n  2480\t                ],\n  2481\t                \"source_anchor_mode\": SURFACE_PATCH_CLOUD_MODE,\n  2482\t                \"target_anchor_mode\": SURFACE_PATCH_CLOUD_MODE,\n  2483\t                \"source_anchor_type\": ANCHOR_TYPE_SURFACE_PATCH,\n  2484\t                \"target_anchor_type\": ANCHOR_TYPE_SURFACE_PATCH,\n  2485\t                \"source_anchor_resolution\": ANCHOR_RESOLUTION_COARSE_PATCH,\n  2486\t                \"target_anchor_resolution\": ANCHOR_RESOLUTION_COARSE_PATCH,\n  2487\t                \"topology_family\": DISTRIBUTED_PATCH_CLOUD_TOPOLOGY,\n  2488\t                \"kernel_family\": SEPARABLE_RANK_ONE_CLOUD_KERNEL,\n  2489\t                \"aggregation_rule\": \"sum_over_synapses_preserving_sign_and_delay_bins\",\n  2490\t                \"edge_bundle_path\": None,\n  2491\t                \"component_count\": len(grouped_component_ids[edge_key]),\n  2492\t                \"component_ids\": sorted(grouped_component_ids[edge_key]),\n  2493\t                \"blocked_synapse_count\": 0,\n  2494\t                \"blocked_reasons\": [],\n  2495\t                \"source_fallback_used\": False,\n  2496\t                \"target_fallback_used\": False,\n  2497\t                \"source_fallback_reasons\": [],\n  2498\t                \"target_fallback_reasons\": [],\n  2499\t                \"status\": \"ready\",\n  2500\t            }\n  2501\t        )\n  2502\t    return families\n  2503\t\n  2504\t\n  2505\tdef _component_fallback_metadata(\n  2506\t    *,\n  2507\t    bundle: Any,\n  2508\t    component_index: int,\n  2509\t    prefix: str,\n  2510\t) -> dict[str, Any]:\n  2511\t    if bundle.synapse_table.empty or bundle.component_synapse_table.empty:\n  2512\t        return {\n  2513\t            \"fallback_used\": False,\n  2514\t            \"fallback_reasons\": [],\n  2515\t        }\n  2516\t    component_rows = bundle.component_synapse_table.loc[\n  2517\t        bundle.component_synapse_table[\"component_index\"] == int(component_index)\n  2518\t    ]\n  2519\t    if component_rows.empty:\n  2520\t        return {\n  2521\t            \"fallback_used\": False,\n  2522\t            \"fallback_reasons\": [],\n  2523\t        }\n  2524\t    component_synapse_ids = {\n  2525\t        str(value)\n  2526\t        for value in component_rows[\"synapse_row_id\"].tolist()\n  2527\t    }\n  2528\t    synapse_rows = bundle.synapse_table.loc[\n  2529\t        bundle.synapse_table[\"synapse_row_id\"].isin(component_synapse_ids)\n  2530\t    ]\n  2531\t    if synapse_rows.empty:\n  2532\t        return {\n  2533\t            \"fallback_used\": False,\n  2534\t            \"fallback_reasons\": [],\n  2535\t        }\n  2536\t    fallback_used_column = f\"{prefix}fallback_used\"\n  2537\t    fallback_reason_column = f\"{prefix}fallback_reason\"\n  2538\t    fallback_used = False\n  2539\t    if fallback_used_column in synapse_rows.columns:\n  2540\t        fallback_used = any(bool(value) for value in synapse_rows[fallback_used_column].tolist())\n  2541\t    fallback_reasons = []\n  2542\t    if fallback_reason_column in synapse_rows.columns:\n  2543\t        fallback_reasons = sorted(\n  2544\t            {\n  2545\t                str(value)\n  2546\t                for value in synapse_rows[fallback_reason_column].tolist()\n  2547\t                if str(value) and str(value) != \"nan\"\n  2548\t            }\n  2549\t        )\n  2550\t    return {\n  2551\t        \"fallback_used\": bool(fallback_used),\n  2552\t        \"fallback_reasons\": fallback_reasons,\n  2553\t    }\n  2554\t\n  2555\t\n  2556\tdef _blocked_reason_catalog(bundle: Any) -> list[str]:\n  2557\t    if bundle.blocked_synapse_table.empty:\n  2558\t        return []\n  2559\t    reasons: set[str] = set()\n  2560\t    for column_name in (\"pre_blocked_reason\", \"post_blocked_reason\"):\n  2561\t        if column_name not in bundle.blocked_synapse_table.columns:\n  2562\t            continue\n  2563\t        reasons.update(\n  2564\t            str(value)\n  2565\t            for value in bundle.blocked_synapse_table[column_name].tolist()\n  2566\t            if str(value) and str(value) != \"nan\"\n  2567\t        )\n  2568\t    return sorted(reasons)\n  2569\t\n  2570\t\n  2571\tdef _resolve_hybrid_component_cloud(\n  2572\t    *,\n  2573\t    bundle_path: Path,\n  2574\t    component_index: int,\n  2575\t    component_id: str,\n  2576\t    anchor_table: Any,\n  2577\t    cloud_table: Any,\n  2578\t    expected_root_id: int,\n  2579\t    morphology_class: str,\n  2580\t    surface_patch_permutation: np.ndarray | None,\n  2581\t    skeleton_runtime: _SingleRootSkeletonGraphRuntime | None,\n  2582\t    role: str,\n  2583\t) -> HybridCouplingCloud:\n  2584\t    component_rows = cloud_table.loc[\n  2585\t        cloud_table[\"component_index\"] == int(component_index)\n  2586\t    ].sort_values(\n  2587\t        [\"anchor_table_index\"],\n  2588\t        kind=\"mergesort\",\n  2589\t    )\n  2590\t    if component_rows.empty:\n  2591\t        raise ValueError(\n  2592\t            f\"Hybrid coupling component {component_id!r} in {bundle_path} is missing \"\n  2593\t            f\"its {role} cloud definition.\"\n  2594\t        )\n  2595\t    anchor_rows = anchor_table.set_index(\"anchor_table_index\", drop=False)\n  2596\t    local_weights: dict[tuple[int, int], float] = {}\n  2597\t    anchor_mode: str | None = None\n  2598\t    anchor_type: str | None = None\n  2599\t    anchor_resolution: str | None = None\n  2600\t    projection_surface: str | None = None\n  2601\t    for row in component_rows.itertuples(index=False):\n  2602\t        anchor_table_index = int(row.anchor_table_index)\n  2603\t        if anchor_table_index not in anchor_rows.index:\n  2604\t            raise ValueError(\n  2605\t                f\"Hybrid coupling component {component_id!r} in {bundle_path} references \"\n  2606\t                f\"unknown {role} anchor_table_index {anchor_table_index}.\"\n  2607\t            )\n  2608\t        anchor = anchor_rows.loc[anchor_table_index]\n  2609\t        if int(anchor[\"root_id\"]) != int(expected_root_id):\n  2610\t            raise ValueError(\n  2611\t                f\"Hybrid coupling component {component_id!r} in {bundle_path} has a \"\n  2612\t                f\"{role} anchor on root {int(anchor['root_id'])}, expected {expected_root_id}.\"\n  2613\t            )\n  2614\t        current_anchor_mode = str(anchor[\"anchor_mode\"])\n  2615\t        current_anchor_type = str(anchor[\"anchor_type\"])\n  2616\t        current_anchor_resolution = str(anchor[\"anchor_resolution\"])\n  2617\t        local_index, resolved_projection_surface = _resolve_runtime_anchor_index(\n  2618\t            component_id=component_id,\n  2619\t            bundle_path=bundle_path,\n  2620\t            expected_root_id=expected_root_id,\n  2621\t            morphology_class=morphology_class,\n  2622\t            anchor_mode=current_anchor_mode,\n  2623\t            anchor_type=current_anchor_type,\n  2624\t            anchor_resolution=current_anchor_resolution,\n  2625\t            anchor_index=int(anchor[\"anchor_index\"]),\n  2626\t            surface_patch_permutation=surface_patch_permutation,\n  2627\t            skeleton_runtime=skeleton_runtime,\n  2628\t            role=role,\n  2629\t        )\n  2630\t        if anchor_mode is None:\n  2631\t            anchor_mode = current_anchor_mode\n  2632\t            anchor_type = current_anchor_type\n  2633\t            anchor_resolution = current_anchor_resolution\n  2634\t            projection_surface = resolved_projection_surface\n  2635\t        elif (\n  2636\t            anchor_mode != current_anchor_mode\n  2637\t            or anchor_type != current_anchor_type\n  2638\t            or anchor_resolution != current_anchor_resolution\n  2639\t            or projection_surface != resolved_projection_surface\n  2640\t        ):\n  2641\t            raise ValueError(\n  2642\t                f\"Hybrid coupling component {component_id!r} in {bundle_path} mixes \"\n  2643\t                f\"incompatible {role} anchor representations, which is ambiguous.\"\n  2644\t            )\n  2645\t        key = (local_index, int(anchor[\"anchor_index\"]))\n  2646\t        local_weights[key] = local_weights.get(key, 0.0) + float(row.cloud_weight)\n  2647\t    ordered_pairs = sorted(local_weights)\n  2648\t    return HybridCouplingCloud(\n  2649\t        local_indices=np.asarray(\n  2650\t            [local_index for local_index, _anchor_index in ordered_pairs],\n  2651\t            dtype=np.int64,\n  2652\t        ),\n  2653\t        weights=np.asarray(\n  2654\t            [local_weights[pair] for pair in ordered_pairs],\n  2655\t            dtype=np.float64,\n  2656\t        ),\n  2657\t        anchor_indices=np.asarray(\n  2658\t            [_anchor_index for _local_index, _anchor_index in ordered_pairs],\n  2659\t            dtype=np.int64,\n  2660\t        ),\n  2661\t        anchor_mode=str(anchor_mode),\n  2662\t        anchor_type=str(anchor_type),\n  2663\t        anchor_resolution=str(anchor_resolution),\n  2664\t        projection_surface=str(projection_surface),\n  2665\t    )\n  2666\t\n  2667\t\n  2668\tdef _resolve_runtime_anchor_index(\n  2669\t    *,\n  2670\t    component_id: str,\n  2671\t    bundle_path: Path,\n  2672\t    expected_root_id: int,\n  2673\t    morphology_class: str,\n  2674\t    anchor_mode: str,\n  2675\t    anchor_type: str,\n  2676\t    anchor_resolution: str,\n  2677\t    anchor_index: int,\n  2678\t    surface_patch_permutation: np.ndarray | None,\n  2679\t    skeleton_runtime: _SingleRootSkeletonGraphRuntime | None,\n  2680\t    role: str,\n  2681\t) -> tuple[int, str]:\n  2682\t    expected_anchor_mode = _ANCHOR_MODE_BY_CLASS[str(morphology_class)]\n  2683\t    expected_anchor_type = _ANCHOR_TYPE_BY_CLASS[str(morphology_class)]\n  2684\t    expected_anchor_resolution = _ANCHOR_RESOLUTION_BY_CLASS[str(morphology_class)]\n  2685\t    if anchor_mode != expected_anchor_mode:\n  2686\t        raise ValueError(\n  2687\t            f\"Hybrid coupling component {component_id!r} in {bundle_path} requires \"\n  2688\t            f\"{role} anchor_mode {expected_anchor_mode!r} for root {expected_root_id} \"\n  2689\t            f\"({morphology_class}), got {anchor_mode!r}.\"\n  2690\t        )\n  2691\t    if anchor_type != expected_anchor_type:\n  2692\t        raise ValueError(\n  2693\t            f\"Hybrid coupling component {component_id!r} in {bundle_path} requires \"\n  2694\t            f\"{role} anchor_type {expected_anchor_type!r} for root {expected_root_id} \"\n  2695\t            f\"({morphology_class}), got {anchor_type!r}.\"\n  2696\t        )\n  2697\t    if anchor_resolution != expected_anchor_resolution:\n  2698\t        raise ValueError(\n  2699\t            f\"Hybrid coupling component {component_id!r} in {bundle_path} requires \"\n  2700\t            f\"{role} anchor_resolution {expected_anchor_resolution!r} for root \"\n  2701\t            f\"{expected_root_id} ({morphology_class}), got {anchor_resolution!r}.\"\n  2702\t        )\n  2703\t    if morphology_class == SURFACE_NEURON_CLASS:\n  2704\t        local_index = int(anchor_index)\n  2705\t        if local_index < 0:\n  2706\t            raise ValueError(\n  2707\t                f\"Hybrid coupling component {component_id!r} in {bundle_path} has an \"\n  2708\t                f\"invalid {role} surface patch index {anchor_index}.\"\n  2709\t            )\n  2710\t        if surface_patch_permutation is not None:\n  2711\t            if local_index >= int(surface_patch_permutation.shape[0]):\n  2712\t                raise ValueError(\n  2713\t                    f\"Hybrid coupling component {component_id!r} in {bundle_path} has an \"\n  2714\t                    f\"out-of-range {role} surface patch index {anchor_index}.\"\n  2715\t                )\n  2716\t            local_index = int(surface_patch_permutation[local_index])\n  2717\t        return local_index, _PROJECTION_SURFACE_BY_CLASS[SURFACE_NEURON_CLASS]\n  2718\t    if morphology_class == SKELETON_NEURON_CLASS:\n  2719\t        if skeleton_runtime is None:\n  2720\t            raise ValueError(\n  2721\t                f\"Hybrid coupling component {component_id!r} in {bundle_path} requires \"\n  2722\t                f\"a skeleton runtime for root {expected_root_id}.\"\n  2723\t            )\n  2724\t        node_index_by_node_id = skeleton_runtime.node_index_by_node_id\n  2725\t        if int(anchor_index) not in node_index_by_node_id:\n  2726\t            raise ValueError(\n  2727\t                f\"Hybrid coupling component {component_id!r} in {bundle_path} references \"\n  2728\t                f\"unknown skeleton node_id {anchor_index} on root {expected_root_id}.\"\n  2729\t            )\n  2730\t        return (\n  2731\t            int(node_index_by_node_id[int(anchor_index)]),\n  2732\t            _PROJECTION_SURFACE_BY_CLASS[SKELETON_NEURON_CLASS],\n  2733\t        )\n  2734\t    if int(anchor_index) != 0:\n  2735\t        raise ValueError(\n  2736\t            f\"Hybrid coupling component {component_id!r} in {bundle_path} requires the \"\n  2737\t            f\"point-state anchor_index 0 for root {expected_root_id}, got {anchor_index}.\"\n  2738\t        )\n  2739\t    return 0, _PROJECTION_SURFACE_BY_CLASS[POINT_NEURON_CLASS]\n  2740\t\n  2741\t\n  2742\tdef _resolve_shared_delay_steps(\n  2743\t    *,\n  2744\t    delay_ms: float,\n  2745\t    dt_ms: float,\n  2746\t    component_id: str,\n  2747\t) -> int:\n  2748\t    if not np.isfinite(delay_ms) or delay_ms < 0.0:\n  2749\t        raise ValueError(\n  2750\t            f\"Hybrid coupling component {component_id!r} has unusable delay_ms {delay_ms!r}.\"\n  2751\t        )\n  2752\t    delay_steps_float = float(delay_ms) / float(dt_ms)\n  2753\t    delay_steps = int(round(delay_steps_float))\n  2754\t    if abs(delay_steps_float - delay_steps) > _DELAY_STEP_TOLERANCE:\n  2755\t        raise ValueError(\n  2756\t            f\"Hybrid coupling component {component_id!r} delay_ms={delay_ms} cannot \"\n  2757\t            f\"be represented on the mixed shared timestep {dt_ms} ms.\"\n  2758\t        )\n  2759\t    return delay_steps\n  2760\t\n  2761\t\n  2762\tdef _route_id_for_classes(source_class: str, target_class: str) -> str:\n  2763\t    return f\"{source_class}_to_{target_class}\"\n  2764\t\n  2765\t\n  2766\tdef _projection_route_for_classes(source_class: str, target_class: str) -> str:\n  2767\t    return (\n  2768\t        f\"{_PROJECTION_LABEL_BY_CLASS[str(source_class)]}_projection_to_\"\n  2769\t        f\"{_PROJECTION_LABEL_BY_CLASS[str(target_class)]}_injection\"\n  2770\t    )\n  2771\t\n  2772\t\n  2773\tdef _resolve_hybrid_coupling_drives(\n  2774\t    *,\n  2775\t    hybrid_coupling_plan: Mapping[str, Any],\n  2776\t    root_ids: Sequence[int],\n  2777\t    root_class_by_root: Mapping[int, str],\n  2778\t    surface_runtime: SurfaceWaveMorphologyRuntime | None,\n  2779\t    skeleton_runtime_by_root: Mapping[int, _SingleRootSkeletonGraphRuntime],\n  2780\t    point_runtime_by_root: Mapping[int, _SingleRootPointNeuronRuntime],\n  2781\t    shared_step_index: int,\n  2782\t    timebase: SimulationTimebase,\n  2783\t) -> tuple[dict[int, np.ndarray], list[dict[str, Any]]]:\n  2784\t    routed_drives_by_root = _empty_local_drives_by_root(\n  2785\t        root_ids=root_ids,\n  2786\t        root_class_by_root=root_class_by_root,\n  2787\t        surface_runtime=surface_runtime,\n  2788\t        skeleton_runtime_by_root=skeleton_runtime_by_root,\n  2789\t    )\n  2790\t    projection_history_by_root = _shared_projection_history_by_root(\n  2791\t        root_ids=root_ids,\n  2792\t        root_class_by_root=root_class_by_root,\n  2793\t        surface_runtime=surface_runtime,\n  2794\t        skeleton_runtime_by_root=skeleton_runtime_by_root,\n  2795\t        point_runtime_by_root=point_runtime_by_root,\n  2796\t    )\n  2797\t    coupling_events: list[dict[str, Any]] = []\n  2798\t    for component in hybrid_coupling_plan[\"components\"]:\n  2799\t        assert isinstance(component, HybridCouplingComponent)\n  2800\t        source_step_index = int(shared_step_index) - int(component.delay_steps)\n  2801\t        if source_step_index < 0:\n  2802\t            continue\n  2803\t        source_history = np.asarray(\n  2804\t            projection_history_by_root[int(component.pre_root_id)],\n  2805\t            dtype=np.float64,\n  2806\t        )\n  2807\t        if source_step_index >= int(source_history.shape[0]):\n  2808\t            raise ValueError(\n  2809\t                \"Hybrid morphology routing source history is shorter than expected \"\n  2810\t                f\"for component {component.component_id!r}.\"\n  2811\t            )\n  2812\t        source_projection = np.asarray(\n  2813\t            source_history[source_step_index],\n  2814\t            dtype=np.float64,\n  2815\t        )\n  2816\t        sampled_values = source_projection[component.source_cloud.local_indices]\n  2817\t        source_value = float(\n  2818\t            np.dot(\n  2819\t                sampled_values,\n  2820\t                component.source_cloud.weights,\n  2821\t            )\n  2822\t        )\n  2823\t        signed_source_value = float(source_value * component.signed_weight_total)\n  2824\t        target_projection_drive = (\n  2825\t            signed_source_value * component.target_cloud.weights\n  2826\t        )\n  2827\t        np.add.at(\n  2828\t            routed_drives_by_root[int(component.post_root_id)],\n  2829\t            component.target_cloud.local_indices,\n  2830\t            target_projection_drive,\n  2831\t        )\n  2832\t        coupling_events.append(\n  2833\t            {\n  2834\t                \"target_shared_step_index\": int(shared_step_index),\n  2835\t                \"resulting_shared_step_index\": int(shared_step_index + 1),\n  2836\t                \"applied_time_ms\": float(timebase.time_ms_after_steps(shared_step_index)),\n  2837\t                \"source_step_index\": int(source_step_index),\n  2838\t                \"source_time_ms\": float(timebase.time_ms_after_steps(source_step_index)),\n  2839\t                \"component_id\": component.component_id,\n  2840\t                \"component_family_id\": component.component_family_id,\n  2841\t                \"pre_root_id\": int(component.pre_root_id),\n  2842\t                \"post_root_id\": int(component.post_root_id),\n  2843\t                \"source_morphology_class\": component.source_morphology_class,\n  2844\t                \"target_morphology_class\": component.target_morphology_class,\n  2845\t                \"route_id\": component.route_id,\n  2846\t                \"projection_route\": component.projection_route,\n  2847\t                \"source_projection_surface\": component.source_projection_surface,\n  2848\t                \"target_injection_surface\": component.target_injection_surface,\n  2849\t                \"topology_family\": component.topology_family,\n  2850\t                \"kernel_family\": component.kernel_family,\n  2851\t                \"aggregation_rule\": component.aggregation_rule,\n  2852\t                \"delay_ms\": float(component.delay_ms),\n  2853\t                \"delay_steps\": int(component.delay_steps),\n  2854\t                \"sign_label\": component.sign_label,\n  2855\t                \"signed_weight_total\": float(component.signed_weight_total),\n  2856\t                \"synapse_count\": int(component.synapse_count),\n  2857\t                \"source_anchor_mode\": component.source_anchor_mode,\n  2858\t                \"target_anchor_mode\": component.target_anchor_mode,\n  2859\t                \"source_anchor_type\": component.source_anchor_type,\n  2860\t                \"target_anchor_type\": component.target_anchor_type,\n  2861\t                \"source_anchor_resolution\": component.source_anchor_resolution,\n  2862\t                \"target_anchor