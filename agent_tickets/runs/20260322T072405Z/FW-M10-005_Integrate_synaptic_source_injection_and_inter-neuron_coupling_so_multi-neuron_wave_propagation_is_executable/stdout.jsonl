ne:\n   571\t            raise ValueError(\"surface-wave circuit has already been initialized.\")\n   572\t        self._capture_patch_readouts()\n   573\t        self._initial_states_by_root = {\n   574\t            root_id: self._solver_by_root[root_id].state.as_mapping()\n   575\t            for root_id in self.root_ids\n   576\t        }\n   577\t        initial_summary = self._build_shared_readout_summary(\n   578\t            lifecycle_stage=INITIALIZED_STAGE,\n   579\t        )\n   580\t        self._shared_readout_history = [initial_summary]\n   581\t        return copy.deepcopy(initial_summary)\n   582\t\n   583\t    def _resolve_coupling_patch_drives(\n   584\t        self,\n   585\t        coupling_patch_drives: dict[int, np.ndarray],\n   586\t    ) -> list[dict[str, Any]]:\n   587\t        coupling_events: list[dict[str, Any]] = []\n   588\t        for component in self._plan.coupling_plan.components:\n   589\t            source_step_index = int(self._substep_index) - int(component.delay_steps)\n   590\t            if source_step_index < 0:\n   591\t                continue\n   592\t            source_history = self._patch_readout_history_by_root[component.pre_root_id]\n   593\t            source_patch_values = np.asarray(\n   594\t                source_history[source_step_index],\n   595\t                dtype=np.float64,\n   596\t            )\n   597\t            sampled_patch_values = source_patch_values[component.source_cloud.patch_indices]\n   598\t            source_value = float(\n   599\t                np.dot(\n   600\t                    sampled_patch_values,\n   601\t                    component.source_cloud.weights,\n   602\t                )\n   603\t            )\n   604\t            signed_source_value = float(source_value * component.signed_weight_total)\n   605\t            target_patch_drive = (\n   606\t                signed_source_value * component.target_cloud.weights\n   607\t            )\n   608\t            np.add.at(\n   609