oot_id\\n  preview_edge_limit: 20\\n  presets:\\n    motion_minimal:\\n      description: >\\n        Milestone 2 locked core motion patch centered on T4a/T5a and their direct\\n        ON/OFF feedforward partners.\\n      include:\\n        super_classes:\\n          - optic\\n          - visual_projection\\n        cell_types:\\n          - T4a\\n          - T5a\\n          - Mi1\\n          - Tm3\\n          - Mi4\\n          - Mi9\\n          - Tm1\\n          - Tm2\\n          - Tm4\\n          - Tm9\\n      exclude:\\n        cell_types:\\n          - R7\\n          - R8\\n\\n    motion_medium:\\n      extends: motion_minimal\\n      description: >\\n        Add one-hop local context and direct downstream readout candidates while\\n        keeping the active motion channel easy to inspect.\\n      relations:\\n        - name: direct_motion_inputs\\n          direction: upstream\\n          seed:\\n            cell_types:\\n              - T4a\\n              - T5a\\n          include:\\n            super_classes:\\n              - optic\\n              - visual_projection\\n            neuropils:\\n              - ME_R\\n              - LO_R\\n          min_syn_count: 5\\n          max_added: 48\\n        - name: direct_motion_outputs\\n          direction: downstream\\n          seed:\\n            cell_types:\\n              - T4a\\n              - T5a\\n          include:\\n            super_classes:\\n              - optic\\n              - visual_projection\\n            neuropils:\\n              - LOP_R\\n          min_syn_count: 5\\n          max_added: 24\\n\\n    motion_dense:\\n      extends: motion_medium\\n      description: >\\n        Add a denser local halo around the same motion patch for boundary checks,\\n        ablations, and later promotion decisions.\\n      relations:\\n        - name: local_halo_context\\n          direction: upstream\\n          seed_from: current\\n          include:\\n            super_classes:\\n              - opt