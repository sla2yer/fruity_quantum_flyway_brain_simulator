    assignment_policy = _require_mapping(\n2027:        normalized_config.get(\"assignment_policy\"),\n2028:        field_name=\"simulation.mixed_fidelity.assignment_policy\",\n2095:    per_root_assignments: list[dict[str, Any]] = []\n2175:        per_root_assignments.append(\n2193:                    assignment_policy=assignment_policy,\n2230:        \"mixed_fidelity\": {\n2233:            \"assignment_policy\": copy.deepcopy(assignment_policy),\n2253:            \"per_root_assignments\": per_root_assignments,\n2266:    assignment_policy: Mapping[str, Any],\n2270:        \"default_source\": str(assignment_policy[\"default_source\"]),\n2274:        \"promotion_mode\": str(assignment_policy[\"promotion_mode\"]),\n2275:        \"demotion_mode\": str(assignment_policy[\"demotion_mode\"]),\n","exit_code":0,"status":"completed"}}
