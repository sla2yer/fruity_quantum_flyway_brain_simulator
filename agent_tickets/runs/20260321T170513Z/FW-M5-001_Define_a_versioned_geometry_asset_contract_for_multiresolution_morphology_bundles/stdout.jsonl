   51\t\n    52\t    if not edges:\n    53\t        raise ValueError(\"No edges could be built from faces.\")\n    54\t\n    55\t    rows = []\n    56\t    cols = []\n    57\t    for i, j in edges:\n    58\t        rows.extend([i, j])\n    59\t        cols.extend([j, i])\n    60\t\n    61\t    data = np.ones(len(rows), dtype=np.float32)\n    62\t    adj = sp.csr_matrix((data, (rows, cols)), shape=(n_vertices, n_vertices))\n    63\t    adj.eliminate_zeros()\n    64\t    return adj\n    65\t\n    66\t\n    67\tdef _uniform_laplacian(adj: sp.csr_matrix) -> sp.csr_matrix:\n    68\t    deg = np.asarray(adj.sum(axis=1)).ravel()\n    69\t    d = sp.diags(deg)\n    70\t    return d - adj\n    71\t\n    72\t\n    73\tdef _choose_patch_vertices(adj: sp.csr_matrix, patch_hops: int, cap: int) -> np.ndarray:\n    74\t    n_vertices = adj.shape[0]\n    75\t    seed = n_vertices // 2\n    76\t    dist = shortest_path(adj, directed=False, indices=seed, unweighted=True)\n    77\t    patch = np.where(np.isfinite(dist) & (dist <= patch_hops))[0]\n    78\t    if patch.size > cap:\n    79\t        order = np.argsort(dist[patch])\n    80\t        patch = patch[order[:cap]]\n    81\t    return patch.astype(np.int32)\n    82\t\n    83\t\n    84\tdef fetch_mesh_and_optional_skeleton(\n    85\t    *,\n    86\t    root_id: int,\n    87\t    bundle_paths: GeometryBundlePaths,\n    88\t    flywire_dataset: str = \"public\",\n    89\t    fetch_skeletons: bool = True,\n    90\t) -> dict[str, str]:\n    91\t    flywire, navis = _optional_imports()\n    92\t\n    93\t    ensure_dir(bundle_paths.raw_mesh_path.parent)\n    94\t    ensure_dir(bundle_paths.raw_skeleton_path.parent)\n    95\t\n    96\t    flywire.set_default_dataset(flywire_dataset)\n    97\t\n    98\t    neuron = flywire.get_mesh_neuron(int(root_id))\n    99\t    mesh = trimesh.Trimesh(vertices=np.asarray(neuron.vertices), faces=np.asarray(neuron.faces), process=False)\n   100\t    mesh.export(bundle_paths.raw_mesh_path)\n   101\t\n   