ministic pathway highlight survived the packaged query budget.\",\n  2042\t                )\n  2043\t            )\n  2044\t            continue\n  2045\t        preset_payloads[preset_id] = _build_query_preset_payload(\n  2046\t            blueprint=blueprint,\n  2047\t            preset_query_state=preset_query_state,\n  2048\t            preset_reduction_profile=preset_reduction_profile,\n  2049\t            preset_execution=preset_execution,\n  2050\t        )\n  2051\t        available_presets.append(\n  2052\t            _build_query_preset_record(\n  2053\t                blueprint=blueprint,\n  2054\t                sequence_index=sequence_index,\n  2055\t                query_profile=query_profile,\n  2056\t                preset_query_state=preset_query_state,\n  2057\t                preset_execution=preset_execution,\n  2058\t                linked_sessions=linked_sessions,\n  2059\t            )\n  2060\t        )\n  2061\t    active_preset_id = _resolve_active_query_preset_id(\n  2062\t        active_query_profile_id=str(\n  2063\t            query_profile_resolution[\"active_query_profile_id\"]\n  2064\t        ),\n  2065\t        available_presets=available_presets,\n  2066\t    )\n  2067\t    return {\n  2068\t        \"preset_library_id\": DEFAULT_CONTEXT_QUERY_PRESET_LIBRARY_ID,\n  2069\t        \"fixture_profile\": copy.deepcopy(dict(fixture_profile)),\n  2070\t        \"active_preset_id\": active_preset_id,\n  2071\t        \"available_preset_ids\": [\n  2072\t            str(item[\"preset_id\"]) for item in available_presets\n  2073\t        ],\n  2074\t        \"preset_discovery_order\": list(SUPPORTED_CONTEXT_QUERY_PRESET_IDS),\n  2075\t        \"available_query_presets\": [copy.deepcopy(dict(item)) for item in available_presets],\n  2076\t        \"unavailable_query_presets\": [\n  2077\t            copy.deepcopy(dict(item)) for item in unavailable_presets\n  2078\t        ],\n  2079\t        \"handoff_preset_ids\": {\n  2080\t            \"dashboard\": (\n  2081\t                DASHBOARD_HANDOFF_PRESET_ID\n  2082\t                if any(\n  2083\t                    str(item[\"preset_id\"]) == DASHBOARD_HANDOFF_PRESET_ID\n  2084\t                    for item in available_presets\n  2085\t                )\n  2086\t                else None\n  2087\t            ),\n  2088\t            \"showcase\": (\n  2089\t                SHOWCASE_HANDOFF_PRESET_ID\n  2090\t                if any(\n  2091\t                    str(item[\"preset_id\"]) == SHOWCASE_HANDOFF_PRESET_ID\n  2092\t                    for item in available_presets\n  2093\t                )\n  2094\t                else None\n  2095\t            ),\n  2096\t        },\n  2097\t        \"preset_payloads_by_id\": copy.deepcopy(preset_payloads),\n  2098\t    }\n  2099\t\n  2100\t\n  2101\tdef _query_preset_blueprints() -> list[dict[str, Any]]:\n  2102\t    return [\n  2103\t        {\n  2104\t            \"preset_id\": OVERVIEW_CONTEXT_PRESET_ID,\n  2105\t            \"display_name\": \"Whole-Brain Overview\",\n  2106\t            \"description\": \"Default richer Milestone 17 review landing for the active subset plus a broader deterministic neighborhood.\",\n  2107\t            \"preferred_query_profile_ids\": [\n  2108\t                BIDIRECTIONAL_CONNECTIVITY_CONTEXT_QUERY_PROFILE_ID,\n  2109\t                DOWNSTREAM_CONNECTIVITY_CONTEXT_QUERY_PROFILE_ID,\n  2110\t                UPSTREAM_CONNECTIVITY_CONTEXT_QUERY_PROFILE_ID,\n  2111\t                ACTIVE_SUBSET_SHELL_QUERY_PROFILE_ID,\n  2112\t            ],\n  2113\t            \"preferred_overlay_ids\": [\n  2114\t                ACTIVE_BOUNDARY_OVERLAY_ID,\n  2115\t                BIDIRECTIONAL_CONTEXT_GRAPH_OVERLAY_ID,\n  2116\t                UPSTREAM_GRAPH_OVERLAY_ID,\n  2117\t                DOWNSTREAM_GRAPH_OVERLAY_ID,\n  2118\t                PATHWAY_HIGHLIGHT_OVERLAY_ID,\n  2119\t                DOWNSTREAM_MODULE_OVERLAY_ID,\n  2120\t                METADATA_FACET_BADGES_OVERLAY_ID,\n  2121\t            ],\n  2122\t            \"default_overlay_id\": BIDIRECTIONAL_CONTEXT_GRAPH_OVERLAY_ID,\n  2123\t            \"default_reduction_profile_id\": BALANCED_NEIGHBORHOOD_REDUCTION_PROFILE_ID,\n  2124\t            \"reduction_controls_patch\": {},\n  2125\t            \"primary_graph_view_id\": \"overview_graph\",\n  2126\t            \"required_linked_session_kind\": None,\n  2127\t            \"requires_pathway_highlight\": False,\n  2128\t            \"discovery_note\": \"Use this preset to compare the compact upstream gate against the richer packaged context graph.\",\n  2129\t        },\n  2130\t        {\n  2131\t            \"preset_id\": UPSTREAM_HALO_PRESET_ID,\n  2132\t            \"display_name\": \"Upstream Halo\",\n  2133\t            \"description\": \"Directional incoming-context review surface around the active subset.\",\n  2134\t            \"preferred_query_profile_ids\": [\n  2135\t                UPSTREAM_CONNECTIVITY_CONTEXT_QUERY_PROFILE_ID,\n  2136\t            ],\n  2137\t            \"preferred_overlay_ids\": [\n  2138\t                ACTIVE_BOUNDARY_OVERLAY_ID,\n  2139\t                UPSTREAM_GRAPH_OVERLAY_ID,\n  2140\t                PATHWAY_HIGHLIGHT_OVERLAY_ID,\n  2141\t                METADATA_FACET_BADGES_OVERLAY_ID,\n  2142\t            ],\n  2143\t            \"default_overlay_id\": UPSTREAM_GRAPH_OVERLAY_ID,\n  2144\t            \"default_reduction_profile_id\": BALANCED_NEIGHBORHOOD_REDUCTION_PROFILE_ID,\n  2145\t            \"reduction_controls_patch\": {},\n  2146\t            \"primary_graph_view_id\": \"overview_graph\",\n  2147\t            \"required_linked_session_kind\": None,\n  2148\t            \"requires_pathway_highlight\": False,\n  2149\t            \"discovery_note\": \"Use this preset to review context-only nodes that feed into the active subset.\",\n  2150\t        },\n  2151\t        {\n  2152\t            \"preset_id\": DOWNSTREAM_HALO_PRESET_ID,\n  2153\t            \"display_name\": \"Downstream Halo\",\n  2154\t            \"description\": \"Directional outgoing-context review surface around the active subset.\",\n  2155\t            \"preferred_query_profile_ids\": [\n  2156\t                DOWNSTREAM_CONNECTIVITY_CONTEXT_QUERY_PROFILE_ID,\n  2157\t            ],\n  2158\t            \"preferred_overlay_ids\": [\n  2159\t                ACTIVE_BOUNDARY_OVERLAY_ID,\n  2160\t                DOWNSTREAM_GRAPH_OVERLAY_ID,\n  2161\t                DOWNSTREAM_MODULE_OVERLAY_ID,\n  2162\t                PATHWAY_HIGHLIGHT_OVERLAY_ID,\n  2163\t                METADATA_FACET_BADGES_OVERLAY_ID,\n  2164\t            ],\n  2165\t            \"default_overlay_id\": DOWNSTREAM_GRAPH_OVERLAY_ID,\n  2166\t            \"default_reduction_profile_id\": DOWNSTREAM_MODULE_COLLAPSED_REDUCTION_PROFILE_ID,\n  2167\t            \"reduction_controls_patch\": {},\n  2168\t            \"primary_graph_view_id\": \"overview_graph\",\n  2169\t            \"required_linked_session_kind\": None,\n  2170\t            \"requires_pathway_highlight\": False,\n  2171\t            \"discovery_note\": \"Use this preset to review outgoing context breadth without relabeling it as active simulator state.\",\n  2172\t        },\n  2173\t        {\n  2174\t            \"preset_id\": PATHWAY_FOCUS_PRESET_ID,\n  2175\t            \"display_name\": \"Pathway Focus\",\n  2176\t            \"description\": \"Focused pathway review surface for one deterministic highlighted context path.\",\n  2177\t            \"preferred_query_profile_ids\": [\n  2178\t                PATHWAY_HIGHLIGHT_REVIEW_QUERY_PROFILE_ID,\n  2179\t            ],\n  2180\t            \"preferred_overlay_ids\": [\n  2181\t                ACTIVE_BOUNDARY_OVERLAY_ID,\n  2182\t                PATHWAY_HIGHLIGHT_OVERLAY_ID,\n  2183\t                METADATA_FACET_BADGES_OVERLAY_ID,\n  2184\t            ],\n  2185\t            \"default_overlay_id\": PATHWAY_HIGHLIGHT_OVERLAY_ID,\n  2186\t            \"default_reduction_profile_id\": PATHWAY_FOCUS_REDUCTION_PROFILE_ID,\n  2187\t            \"reduction_controls_patch\": {},\n  2188\t            \"primary_graph_view_id\": \"focused_subgraph\",\n  2189\t            \"required_linked_session_kind\": None,\n  2190\t            \"requires_pathway_highlight\": True,\n  2191\t            \"discovery_note\": \"Use this preset for the first local pathway-focused Milestone 17 review case.\",\n  2192\t        },\n  2193\t        {\n  2194\t            \"preset_id\": DASHBOARD_HANDOFF_PRESET_ID,\n  2195\t            \"display_name\": \"Dashboard Handoff\",\n  2196\t            \"description\": \"Bridge the compact dashboard gate into the richer whole-brain review package.\",\n  2197\t            \"preferred_query_profile_ids\": [\n  2198\t                BIDIRECTIONAL_CONNECTIVITY_CONTEXT_QUERY_PROFILE_ID,\n  2199\t                DOWNSTREAM_CONNECTIVITY_CONTEXT_QUERY_PROFILE_ID,\n  2200\t                UPSTREAM_CONNECTIVITY_CONTEXT_QUERY_PROFILE_ID,\n  2201\t                ACTIVE_SUBSET_SHELL_QUERY_PROFILE_ID,\n  2202\t            ],\n  2203\t            \"preferred_overlay_ids\": [\n  2204\t                ACTIVE_BOUNDARY_OVERLAY_ID,\n  2205\t                BIDIRECTIONAL_CONTEXT_GRAPH_OVERLAY_ID,\n  2206\t                UPSTREAM_GRAPH_OVERLAY_ID,\n  2207\t                DOWNSTREAM_GRAPH_OVERLAY_ID,\n  2208\t                METADATA_FACET_BADGES_OVERLAY_ID,\n  2209\t            ],\n  2210\t            \"default_overlay_id\": BIDIRECTIONAL_CONTEXT_GRAPH_OVERLAY_ID,\n  2211\t            \"default_reduction_profile_id\": BALANCED_NEIGHBORHOOD_REDUCTION_PROFILE_ID,\n  2212\t            \"reduction_controls_patch\": {},\n  2213\t            \"primary_graph_view_id\": \"overview_graph\",\n  2214\t            \"required_linked_session_kind\": \"dashboard\",\n  2215\t            \"requires_pathway_highlight\": False,\n  2216\t            \"discovery_note\": \"Use this preset when reviewing the packaged dashboard session as the fast readiness gate before opening broader context.\",\n  2217\t        },\n  2218\t        {\n  2219\t            \"preset_id\": SHOWCASE_HANDOFF_PRESET_ID,\n  2220\t            \"display_name\": \"Showcase Handoff\",\n  2221\t            \"description\": \"Bridge the compact showcase rehearsal surface into a richer whole-brain review state.\",\n  2222\t            \"preferred_query_profile_ids\": [\n  2223\t                PATHWAY_HIGHLIGHT_REVIEW_QUERY_PROFILE_ID,\n  2224\t                DOWNSTREAM_MODULE_REVIEW_QUERY_PROFILE_ID,\n  2225\t                BIDIRECTIONAL_CONNECTIVITY_CONTEXT_QUERY_PROFILE_ID,\n  2226\t                DOWNSTREAM_CONNECTIVITY_CONTEXT_QUERY_PROFILE_ID,\n  2227\t            ],\n  2228\t            \"preferred_overlay_ids\": [\n  2229\t                ACTIVE_BOUNDARY_OVERLAY_ID,\n  2230\t                PATHWAY_HIGHLIGHT_OVERLAY_ID,\n  2231\t                DOWNSTREAM_GRAPH_OVERLAY_ID,\n  2232\t                DOWNSTREAM_MODULE_OVERLAY_ID,\n  2233\t                METADATA_FACET_BADGES_OVERLAY_ID,\n  2234\t            ],\n  2235\t            \"default_overlay_id\": PATHWAY_HIGHLIGHT_OVERLAY_ID,\n  2236\t            \"default_reduction_profile_id\": PATHWAY_FOCUS_REDUCTION_PROFILE_ID,\n  2237\t            \"reduction_controls_patch\": {},\n  2238\t            \"primary_graph_view_id\": \"focused_subgraph\",\n  2239\t            \"required_linked_session_kind\": \"showcase\",\n  2240\t            \"requires_pathway_highlight\": False,\n  2241\t            \"discovery_note\": \"Use this preset for review handoff from the compact showcase surface into broader context and pathway emphasis.\",\n  2242\t        },\n  2243\t    ]\n  2244\t\n  2245\t\n  2246\tdef _build_query_preset_payload(\n  2247\t    *,\n  2248\t    blueprint: Mapping[str, Any],\n  2249\t    preset_query_state: Mapping[str, Any],\n  2250\t    preset_reduction_profile: Mapping[str, Any],\n  2251\t    preset_execution: Mapping[str, Any],\n  2252\t) -> dict[str, Any]:\n  2253\t    return {\n  2254\t        \"preset_id\": str(blueprint[\"preset_id\"]),\n  2255\t        \"display_name\": str(blueprint[\"display_name\"]),\n  2256\t        \"query_profile_id\": str(preset_execution[\"query_profile_id\"]),\n  2257\t        \"query_family\": str(preset_execution[\"query_family\"]),\n  2258\t        \"query_state\": copy.deepcopy(dict(preset_query_state)),\n  2259\t        \"reduction_profile\": copy.deepcopy(dict(preset_reduction_profile)),\n  2260\t        \"reduction_controls\": copy.deepcopy(dict(preset_execution[\"reduction_controls\"])),\n  2261\t        \"execution_summary\": copy.deepcopy(dict(preset_execution[\"execution_summary\"])),\n  2262\t        \"overview_graph\": copy.deepcopy(dict(preset_execution[\"overview_graph\"])),\n  2263\t        \"focused_subgraph\": copy.deepcopy(dict(preset_execution[\"focused_subgraph\"])),\n  2264\t        \"pathway_highlights\": [\n  2265\t            copy.deepcopy(dict(item)) for item in preset_execution[\"pathway_highlights\"]\n  2266\t        ],\n  2267\t    }\n  2268\t\n  2269\t\n  2270\tdef _build_query_preset_record(\n  2271\t    *,\n  2272\t    blueprint: Mapping[str, Any],\n  2273\t    sequence_index: int,\n  2274\t    query_profile: Mapping[str, Any],\n  2275\t    preset_query_state: Mapping[str, Any],\n  2276\t    preset_execution: Mapping[str, Any],\n  2277\t    linked_sessions: Mapping[str, Any],\n  2278\t) -> dict[str, Any]:\n  2279\t    preset_id = str(blueprint[\"preset_id\"])\n  2280\t    primary_graph_view_id = _query_preset_primary_graph_view_id(\n  2281\t        blueprint=blueprint,\n  2282\t        preset_execution=preset_execution,\n  2283\t    )\n  2284\t    pathway_reference = {\n  2285\t        \"artifact_role_id\": CONTEXT_VIEW_PAYLOAD_ROLE_ID,\n  2286\t        \"payload_path\": f\"query_preset_payloads.{preset_id}.pathway_highlights\",\n  2287\t        \"highlight_count\": len(preset_execution[\"pathway_highlights\"]),\n  2288\t    }\n  2289\t    if preset_execution[\"pathway_highlights\"]:\n  2290\t        pathway_reference[\"primary_pathway_id\"] = str(\n  2291\t            preset_execution[\"pathway_highlights\"][0][\"pathway_id\"]\n  2292\t        )\n  2293\t    return {\n  2294\t        \"preset_id\": preset_id,\n  2295\t        \"display_name\": str(blueprint[\"display_name\"]),\n  2296\t        \"description\": str(blueprint[\"description\"]),\n  2297\t        \"sequence_index\": sequence_index,\n  2298\t        \"availability\": \"available\",\n  2299\t        \"query_profile_id\": str(query_profile[\"query_profile_id\"]),\n  2300\t        \"query_family\": str(query_profile[\"query_family\"]),\n  2301\t        \"default_overlay_id\": str(preset_query_state[\"default_overlay_id\"]),\n  2302\t        \"enabled_overlay_ids\": list(preset_query_state[\"enabled_overlay_ids\"]),\n  2303\t        \"default_reduction_profile_id\": str(\n  2304\t            preset_query_state[\"default_reduction_profile_id\"]\n  2305\t        ),\n  2306\t        \"execution_summary\": copy.deepcopy(\n  2307\t            dict(preset_execution[\"execution_summary\"])\n  2308\t        ),\n  2309\t        \"primary_graph_view_id\": primary_graph_view_id,\n  2310\t        \"graph_payload_references\": {\n  2311\t            \"primary_graph\": _build_graph_payload_reference(\n  2312\t                preset_id=preset_id,\n  2313\t                graph_view_id=primary_graph_view_id,\n  2314\t            ),\n  2315\t            \"overview_graph\": _build_graph_payload_reference(\n  2316\t                preset_id=preset_id,\n  2317\t                graph_view_id=\"overview_graph\",\n  2318\t            ),\n  2319\t            \"focused_subgraph\": _build_graph_payload_reference(\n  2320\t                preset_id=preset_id,\n  2321\t                graph_view_id=\"focused_subgraph\",\n  2322\t            ),\n  2323\t            \"pathway_highlights\": pathway_reference,\n  2324\t        },\n  2325\t        \"linked_session_target\": _build_linked_session_target(\n  2326\t            blueprint=blueprint,\n  2327\t            linked_sessions=linked_sessions,\n  2328\t        ),\n  2329\t        \"scientific_curation_required\": bool(\n  2330\t            query_profile[\"scientific_curation_required\"]\n  2331\t        ),\n  2332\t        \"discovery_note\": str(blueprint[\"discovery_note\"]),\n  2333\t    }\n  2334\t\n  2335\t\n  2336\tdef _build_unavailable_query_preset_record(\n  2337\t    *,\n  2338\t    blueprint: Mapping[str, Any],\n  2339\t    sequence_index: int,\n  2340\t    reason: str,\n  2341\t) -> dict[str, Any]:\n  2342\t    return {\n  2343\t        \"preset_id\": str(blueprint[\"preset_id\"]),\n  2344\t        \"display_name\": str(blueprint[\"display_name\"]),\n  2345\t        \"description\": str(blueprint[\"description\"]),\n  2346\t        \"sequence_index\": sequence_index,\n  2347\t        \"availability\": \"unavailable\",\n  2348\t        \"preferred_query_profile_ids\": list(blueprint[\"preferred_query_profile_ids\"]),\n  2349\t        \"required_linked_session_kind\": blueprint.get(\"required_linked_session_kind\"),\n  2350\t        \"unavailable_reason\": str(reason),\n  2351\t    }\n  2352\t\n  2353\t\n  2354\tdef _resolve_active_query_preset_id(\n  2355\t    *,\n  2356\t    active_query_profile_id: str,\n  2357\t    available_presets: Sequence[Mapping[str, Any]],\n  2358\t) -> str | None:\n  2359\t    available_by_id = {\n  2360\t        str(item[\"preset_id\"]): copy.deepcopy(dict(item)) for item in available_presets\n  2361\t    }\n  2362\t    preferred_by_profile = {\n  2363\t        ACTIVE_SUBSET_SHELL_QUERY_PROFILE_ID: [OVERVIEW_CONTEXT_PRESET_ID],\n  2364\t        UPSTREAM_CONNECTIVITY_CONTEXT_QUERY_PROFILE_ID: [UPSTREAM_HALO_PRESET_ID],\n  2365\t        DOWNSTREAM_CONNECTIVITY_CONTEXT_QUERY_PROFILE_ID: [DOWNSTREAM_HALO_PRESET_ID],\n  2366\t        BIDIRECTIONAL_CONNECTIVITY_CONTEXT_QUERY_PROFILE_ID: [\n  2367\t            OVERVIEW_CONTEXT_PRESET_ID,\n  2368\t            DASHBOARD_HANDOFF_PRESET_ID,\n  2369\t        ],\n  2370\t        PATHWAY_HIGHLIGHT_REVIEW_QUERY_PROFILE_ID: [\n  2371\t            PATHWAY_FOCUS_PRESET_ID,\n  2372\t            SHOWCASE_HANDOFF_PRESET_ID,\n  2373\t        ],\n  2374\t        DOWNSTREAM_MODULE_REVIEW_QUERY_PROFILE_ID: [\n  2375\t            SHOWCASE_HANDOFF_PRESET_ID,\n  2376\t            DOWNSTREAM_HALO_PRESET_ID,\n  2377\t        ],\n  2378\t    }\n  2379\t    for preset_id in preferred_by_profile.get(active_query_profile_id, []):\n  2380\t        if (\n  2381\t            preset_id in available_by_id\n  2382\t            and str(available_by_id[preset_id][\"query_profile_id\"])\n  2383\t            == active_query_profile_id\n  2384\t        ):\n  2385\t            return preset_id\n  2386\t    for item in available_presets:\n  2387\t        if str(item[\"query_profile_id\"]) == active_query_profile_id:\n  2388\t            return str(item[\"preset_id\"])\n  2389\t    if available_presets:\n  2390\t        return str(available_presets[0][\"preset_id\"])\n  2391\t    return None\n  2392\t\n  2393\t\n  2394\tdef _build_graph_payload_reference(*, preset_id: str, graph_view_id: str) -> dict[str, Any]:\n  2395\t    return {\n  2396\t        \"artifact_role_id\": CONTEXT_VIEW_PAYLOAD_ROLE_ID,\n  2397\t        \"payload_path\": f\"query_preset_payloads.{preset_id}.{graph_view_id}\",\n  2398\t        \"view_id\": graph_view_id,\n  2399\t    }\n  2400\t\n  2401\t\n  2402\tdef _query_preset_primary_graph_view_id(\n  2403\t    *,\n  2404\t    blueprint: Mapping[str, Any],\n  2405\t    preset_execution: Mapping[str, Any],\n  2406\t) -> str:\n  2407\t    preferred_graph_view_id = str(blueprint[\"primary_graph_view_id\"])\n  2408\t    if (\n  2409\t        preferred_graph_view_id == \"focused_subgraph\"\n  2410\t        and not preset_execution[\"pathway_highlights\"]\n  2411\t    ):\n  2412\t        return \"overview_graph\"\n  2413\t    return preferred_graph_view_id\n  2414\t\n  2415\t\n  2416\tdef _build_linked_session_target(\n  2417\t    *,\n  2418\t    blueprint: Mapping[str, Any],\n  2419\t    linked_sessions: Mapping[str, Any],\n  2420\t) -> dict[str, Any] | None:\n  2421\t    required_linked_session_kind = blueprint.get(\"required_linked_session_kind\")\n  2422\t    if required_linked_session_kind is None:\n  2423\t        return None\n  2424\t    linked_session = linked_sessions.get(str(required_linked_session_kind))\n  2425\t    if not isinstance(linked_session, Mapping):\n  2426\t        return None\n  2427\t    artifact_role_id = (\n  2428\t        SHOWCASE_SESSION_METADATA_ROLE_ID\n  2429\t        if str(required_linked_session_kind) == \"showcase\"\n  2430\t        else DASHBOARD_SESSION_METADATA_ROLE_ID\n  2431\t    )\n  2432\t    return {\n  2433\t        \"session_kind\": str(required_linked_session_kind),\n  2434\t        \"artifact_role_id\": artifact_role_id,\n  2435\t        \"bundle_id\": str(linked_session[\"bundle_id\"]),\n  2436\t        \"metadata_path\": str(linked_session[\"metadata_path\"]),\n  2437\t        \"source_preset_ids\": sorted(\n  2438\t            {\n  2439\t                str(item[\"source_preset_id\"])\n  2440\t                for item in linked_session.get(\"handoff_links\", [])\n  2441\t                if isinstance(item, Mapping)\n  2442\t                and str(item.get(\"target_context_preset_id\"))\n  2443\t                == str(blueprint.get(\"preset_id\"))\n  2444\t                and item.get(\"source_preset_id\") is not None\n  2445\t            }\n  2446\t        ),\n  2447\t    }\n  2448\t\n  2449\t\n  2450\tdef _discover_showcase_handoff_links(\n  2451\t    narrative_preset_catalog: Mapping[str, Any] | None,\n  2452\t) -> list[dict[str, Any]]:\n  2453\t    if not isinstance(narrative_preset_catalog, Mapping):\n  2454\t        return []\n  2455\t    result: list[dict[str, Any]] = []\n  2456\t    saved_presets = narrative_preset_catalog.get(\"saved_presets\", [])\n  2457\t    if not isinstance(saved_presets, Sequence) or isinstance(saved_presets, (str, bytes)):\n  2458\t        return result\n  2459\t    for preset in saved_presets:\n  2460\t        if not isinstance(preset, Mapping):\n  2461\t            continue\n  2462\t        preset_id = _normalize_optional_identifier(\n  2463\t            preset.get(\"preset_id\"),\n  2464\t            field_name=\"showcase_handoff.preset_id\",\n  2465\t        )\n  2466\t        patch = preset.get(\"presentation_state_patch\", {})\n  2467\t        if not isinstance(patch, Mapping):\n  2468\t            continue\n  2469\t        rehearsal_metadata = patch.get(\"rehearsal_metadata\", {})\n  2470\t        if not isinstance(rehearsal_metadata, Mapping):\n  2471\t            continue\n  2472\t        presentation_links = rehearsal_metadata.get(\"presentation_links\", [])\n  2473\t        if not isinstance(presentation_links, Sequence) or isinstance(\n  2474\t            presentation_links,\n  2475\t            (str, bytes),\n  2476\t        ):\n  2477\t            continue\n  2478\t        for item in presentation_links:\n  2479\t            if not isinstance(item, Mapping):\n  2480\t                continue\n  2481\t            if str(item.get(\"link_kind\")) != WHOLE_BRAIN_CONTEXT_HANDOFF_LINK_KIND:\n  2482\t                continue\n  2483\t            shared_context = item.get(\"shared_context\", {})\n  2484\t            if not isinstance(shared_context, Mapping):\n  2485\t                continue\n  2486\t            target_contract_version = _normalize_optional_string(\n  2487\t                shared_context.get(\"target_contract_version\"),\n  2488\t                field_name=\"showcase_handoff.target_contract_version\",\n  2489\t            )\n  2490\t            if (\n  2491\t                target_contract_version is not None\n  2492\t                and target_contract_version\n  2493\t                != WHOLE_BRAIN_CONTEXT_SESSION_CONTRACT_VERSION\n  2494\t            ):\n  2495\t                raise ValueError(\n  2496\t                    \"Showcase whole-brain handoff links must target \"\n  2497\t                    f\"{WHOLE_BRAIN_CONTEXT_SESSION_CONTRACT_VERSION!r}.\"\n  2498\t                )\n  2499\t            target_context_preset_id = _normalize_optional_identifier(\n  2500\t                shared_context.get(\"target_context_preset_id\"),\n  2501\t                field_name=\"showcase_handoff.target_context_preset_id\",\n  2502\t            )\n  2503\t            if preset_id is None or target_context_preset_id is None:\n  2504\t                continue\n  2505\t            result.append(\n  2506\t                {\n  2507\t                    \"source_preset_id\": preset_id,\n  2508\t                    \"source_link_id\": _normalize_optional_identifier(\n  2509\t                        item.get(\"link_id\"),\n  2510\t                        field_name=\"showcase_handoff.link_id\",\n  2511\t                    ),\n  2512\t                    \"target_context_preset_id\": target_context_preset_id,\n  2513\t                    \"discovery_note\": _normalize_optional_string(\n  2514\t                        shared_context.get(\"discovery_note\"),\n  2515\t                        field_name=\"showcase_handoff.discovery_note\",\n  2516\t                    ),\n  2517\t                }\n  2518\t            )\n  2519\t    return sorted(\n  2520\t        result,\n  2521\t        key=lambda item: (\n  2522\t            item[\"source_preset_id\"],\n  2523\t            \"\" if item[\"source_link_id\"] is None else item[\"source_link_id\"],\n  2524\t            item[\"target_context_preset_id\"],\n  2525\t        ),\n  2526\t    )\n  2527\t\n  2528\t\n  2529\tdef _apply_downstream_module_handoffs_to_query_preset_library(\n  2530\t    *,\n  2531\t    query_preset_library: Mapping[str, Any],\n  2532\t    linked_sessions: Mapping[str, Any],\n  2533\t) -> dict[str, Any]:\n  2534\t    result = copy.deepcopy(dict(query_preset_library))\n  2535\t    handoff_targets = _build_downstream_module_handoff_targets(\n  2536\t        query_preset_library=result,\n  2537\t        linked_sessions=linked_sessions,\n  2538\t    )\n  2539\t    payloads = _require_mapping(\n  2540\t        result.get(\"preset_payloads_by_id\", {}),\n  2541\t        field_name=\"query_preset_library.preset_payloads_by_id\",\n  2542\t    )\n  2543\t    result[\"preset_payloads_by_id\"] = {\n  2544\t        str(preset_id): _apply_downstream_module_handoffs_to_preset_payload(\n  2545\t            payload=payload,\n  2546\t            handoff_targets=handoff_targets,\n  2547\t        )\n  2548\t        for preset_id, payload in payloads.items()\n  2549\t        if isinstance(payload, Mapping)\n  2550\t    }\n  2551\t    return result\n  2552\t\n  2553\t\n  2554\tdef _apply_downstream_module_handoffs_to_query_execution(\n  2555\t    *,\n  2556\t    query_execution: Mapping[str, Any],\n  2557\t    query_preset_library: Mapping[str, Any],\n  2558\t    linked_sessions: Mapping[str, Any],\n  2559\t) -> dict[str, Any]:\n  2560\t    result = copy.deepcopy(dict(query_execution))\n  2561\t    handoff_targets = _build_downstream_module_handoff_targets(\n  2562\t        query_preset_library=query_preset_library,\n  2563\t        linked_sessions=linked_sessions,\n  2564\t    )\n  2565\t    result[\"representative_context\"] = _apply_downstream_module_handoffs_to_context_record(\n  2566\t        result.get(\"representative_context\", {}),\n  2567\t        handoff_targets=handoff_targets,\n  2568\t    )\n  2569\t    for graph_key in (\"overview_graph\", \"focused_subgraph\"):\n  2570\t        if isinstance(result.get(graph_key), Mapping):\n  2571\t            result[graph_key] = _apply_downstream_module_handoffs_to_graph_view(\n  2572\t                result[graph_key],\n  2573\t                handoff_targets=handoff_targets,\n  2574\t            )\n  2575\t    return result\n  2576\t\n  2577\t\n  2578\tdef _build_downstream_module_handoff_targets(\n  2579\t    *,\n  2580\t    query_preset_library: Mapping[str, Any],\n  2581\t    linked_sessions: Mapping[str, Any],\n  2582\t) -> list[dict[str, Any]]:\n  2583\t    available_presets = {\n  2584\t        str(item[\"preset_id\"]): dict(item)\n  2585\t        for item in query_preset_library.get(\"available_query_presets\", [])\n  2586\t        if isinstance(item, Mapping)\n  2587\t    }\n  2588\t    handoff_targets: list[dict[str, Any]] = []\n  2589\t    handoff_preset_ids = _require_mapping(\n  2590\t        query_preset_library.get(\"handoff_preset_ids\", {}),\n  2591\t        field_name=\"query_preset_library.handoff_preset_ids\",\n  2592\t    )\n  2593\t\n  2594\t    dashboard_preset_id = _normalize_optional_identifier(\n  2595\t        handoff_preset_ids.get(\"dashboard\"),\n  2596\t        field_name=\"handoff_preset_ids.dashboard\",\n  2597\t    )\n  2598\t    dashboard_session = linked_sessions.get(\"dashboard\")\n  2599\t    if dashboard_preset_id is not None and isinstance(dashboard_session, Mapping):\n  2600\t        preset_record = available_presets.get(dashboard_preset_id)\n  2601\t        if preset_record is not None:\n  2602\t            handoff_targets.append(\n  2603\t                _build_downstream_module_handoff_target_record(\n  2604\t                    linked_session=dashboard_session,\n  2605\t                    linked_session_kind=\"dashboard\",\n  2606\t                    preset_record=preset_record,\n  2607\t                    source_preset_id=None,\n  2608\t                    source_link_id=None,\n  2609\t                    discovery_note=\"Compact dashboard gate can hand off into the broader Milestone 17 context preset.\",\n  2610\t                )\n  2611\t            )\n  2612\t\n  2613\t    showcase_preset_id = _normalize_optional_identifier(\n  2614\t        handoff_preset_ids.get(\"showcase\"),\n  2615\t        field_name=\"handoff_preset_ids.showcase\",\n  2616\t    )\n  2617\t    showcase_session = linked_sessions.get(\"showcase\")\n  2618\t    if showcase_preset_id is not None and isinstance(showcase_session, Mapping):\n  2619\t        preset_record = available_presets.get(showcase_preset_id)\n  2620\t        if preset_record is not None:\n  2621\t            matching_links = [\n  2622\t                dict(item)\n  2623\t                for item in showcase_session.get(\"handoff_links\", [])\n  2624\t                if isinstance(item, Mapping)\n  2625\t                and str(item.get(\"target_context_preset_id\")) == showcase_preset_id\n  2626\t            ]\n  2627\t            if not matching_links:\n  2628\t                matching_links = [\n  2629\t                    {\n  2630\t                        \"source_preset_id\": None,\n  2631\t                        \"source_link_id\": None,\n  2632\t                        \"discovery_note\": (\n  2633\t                            \"Linked showcase surface may hand off into the packaged \"\n  2634\t                            \"Milestone 17 showcase_handoff preset.\"\n  2635\t                        ),\n  2636\t                    }\n  2637\t                ]\n  2638\t            for link in matching_links:\n  2639\t                handoff_targets.append(\n  2640\t                    _build_downstream_module_handoff_target_record(\n  2641\t                        linked_session=showcase_session,\n  2642\t                        linked_session_kind=\"showcase\",\n  2643\t                        preset_record=preset_record,\n  2644\t                        source_preset_id=link.get(\"source_preset_id\"),\n  2645\t                        source_link_id=link.get(\"source_link_id\"),\n  2646\t                        discovery_note=link.get(\"discovery_note\"),\n  2647\t                    )\n  2648\t                )\n  2649\t    return handoff_targets\n  2650\t\n  2651\t\n  2652\tdef _build_downstream_module_handoff_target_record(\n  2653\t    *,\n  2654\t    linked_session: Mapping[str, Any],\n  2655\t    linked_session_kind: str,\n  2656\t    preset_record: Mapping[str, Any],\n  2657\t    source_preset_id: str | None,\n  2658\t    source_link_id: str | None,\n  2659\t    discovery_note: str | None,\n  2660\t) -> dict[str, Any]:\n  2661\t    graph_payload_references = _require_mapping(\n  2662\t        preset_record.get(\"graph_payload_references\", {}),\n  2663\t        field_name=\"query_preset.graph_payload_references\",\n  2664\t    )\n  2665\t    primary_graph = _require_mapping(\n  2666\t        graph_payload_references.get(\"primary_graph\", {}),\n  2667\t        field_name=\"query_preset.graph_payload_references.primary_graph\",\n  2668\t    )\n  2669\t    return {\n  2670\t        \"target_kind\": \"context_query_preset\",\n  2671\t        \"linked_session_kind\": str(linked_session_kind),\n  2672\t        \"source_bundle_id\": str(linked_session[\"bundle_id\"]),\n  2673\t        \"source_metadata_path\": str(linked_session[\"metadata_path\"]),\n  2674\t        \"source_preset_id\": None if source_preset_id is None else str(source_preset_id),\n  2675\t        \"source_link_id\": None if source_link_id is None else str(source_link_id),\n  2676\t        \"artifact_role_id\": CONTEXT_VIEW_PAYLOAD_ROLE_ID,\n  2677\t        \"target_preset_id\": str(preset_record[\"preset_id\"]),\n  2678\t        \"target_graph_view_id\": str(preset_record[\"primary_graph_view_id\"]),\n  2679\t        \"target_payload_path\": str(primary_graph[\"payload_path\"]),\n  2680\t        \"target_query_profile_id\": str(preset_record[\"query_profile_id\"]),\n  2681\t        \"discovery_note\": None if discovery_note is None else str(discovery_note),\n  2682\t    }\n  2683\t\n  2684\t\n  2685\tdef _apply_downstream_module_handoffs_to_preset_payload(\n  2686\t    *,\n  2687\t    payload: Mapping[str, Any],\n  2688\t    handoff_targets: Sequence[Mapping[str, Any]],\n  2689\t) -> dict[str, Any]:\n  2690\t    result = copy.deepcopy(dict(payload))\n  2691\t    for graph_key in (\"overview_graph\", \"focused_subgraph\"):\n  2692\t        if isinstance(result.get(graph_key), Mapping):\n  2693\t            re