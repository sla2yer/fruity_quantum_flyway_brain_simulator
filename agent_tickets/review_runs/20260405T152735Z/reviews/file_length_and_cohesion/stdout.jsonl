d_overlays:\n  1484\t            overlay_ids.append(METADATA_FACET_BADGES_OVERLAY_ID)\n  1485\t        metadata = metadata_by_root.get(int(root_id), {})\n  1486\t        nearest_hop_count = _nearest_hop_count(root_id=root_id, path_registry=path_registry)\n  1487\t        node_record = {\n  1488\t            \"root_id\": str(int(root_id)),\n  1489\t            \"node_role_id\": node_role_id,\n  1490\t            \"context_layer_id\": context_layer_id,\n  1491\t            \"overlay_ids\": overlay_ids,\n  1492\t            \"metadata_facet_values\": _node_metadata_facet_values(\n  1493\t                root_id=root_id,\n  1494\t                node_role_id=node_role_id,\n  1495\t                metadata=metadata,\n  1496\t                enabled_facets=enabled_facets,\n  1497\t                highlighted=root_id in highlight_root_ids,\n  1498\t                boundary_status=boundary_status,\n  1499\t            ),\n  1500\t            \"display_label\": _display_label(root_id=root_id, metadata=metadata),\n  1501\t            \"node_id\": _node_id(root_id=root_id, context_layer_id=context_layer_id),\n  1502\t            \"boundary_status\": boundary_status,\n  1503\t            \"directional_context\": direction_membership,\n  1504\t            \"nearest_active_hop_count\": nearest_hop_count,\n  1505\t            \"is_active_selected\": root_id in active_root_set,\n  1506\t            \"is_context_only\": root_id not in active_root_set,\n  1507\t            \"secondary_context_layer_ids\": _secondary_context_layers(\n  1508\t                root_id=root_id,\n  1509\t                directional_membership=directional_membership,\n  1510\t                primary_context_layer_id=context_layer_id,\n  1511\t            ),\n  1512\t            \"anchor_record\": (\n  1513\t                None\n  1514\t                if root_id not in active_anchor_records\n  1515\t                else copy.deepcopy(dict(active_anchor_records[root_id]))\n  1516\t            ),\n  1517\t        }\n  1518\t        records.append(node_record)\n  1519\t    return records\n  1520\t\n  1521\t\n  1522\tdef _build_highlight_node_records(\n  1523\t    *,\n  1524\t    highlight_root_ids: set[int],\n  1525\t    active_root_set: set[int],\n  1526\t    metadata_by_root: Mapping[int, Mapping[str, Any]],\n  1527\t    enabled_overlays: set[str],\n  1528\t    enabled_facets: set[str],\n  1529\t) -> list[dict[str, Any]]:\n  1530\t    if not highlight_root_ids or PATHWAY_HIGHLIGHT_OVERLAY_ID not in enabled_overlays:\n  1531\t        return []\n  1532\t    overlay_ids = [ACTIVE_BOUNDARY_OVERLAY_ID, PATHWAY_HIGHLIGHT_OVERLAY_ID]\n  1533\t    if METADATA_FACET_BADGES_OVERLAY_ID in enabled_overlays:\n  1534\t        overlay_ids.append(METADATA_FACET_BADGES_OVERLAY_ID)\n  1535\t    records: list[dict[str, Any]] = []\n  1536\t    for root_id in sorted(highlight_root_ids):\n  1537\t        is_active = int(root_id) in active_root_set\n  1538\t        node_role_id = (\n  1539\t            ACTIVE_PATHWAY_HIGHLIGHT_NODE_ROLE_ID\n  1540\t            if is_active\n  1541\t            else CONTEXT_PATHWAY_HIGHLIGHT_NODE_ROLE_ID\n  1542\t        )\n  1543\t        metadata = metadata_by_root.get(int(root_id), {})\n  1544\t        records.append(\n  1545\t            {\n  1546\t                \"root_id\": str(int(root_id)),\n  1547\t                \"node_role_id\": node_role_id,\n  1548\t                \"context_layer_id\": PATHWAY_HIGHLIGHT_CONTEXT_LAYER_ID,\n  1549\t                \"overlay_ids\": overlay_ids,\n  1550\t                \"metadata_facet_values\": _node_metadata_facet_values(\n  1551\t                    root_id=root_id,\n  1552\t                    node_role_id=node_role_id,\n  1553\t                    metadata=metadata,\n  1554\t                    enabled_facets=enabled_facets,\n  1555\t                    highlighted=True,\n  1556\t                    boundary_status=\"active\" if is_active else \"context\",\n  1557\t                ),\n  1558\t                \"display_label\": _display_label(root_id=root_id, metadata=metadata),\n  1559\t                \"node_id\": _node_id(\n  1560\t                    root_id=root_id,\n  1561\t                    context_layer_id=PATHWAY_HIGHLIGHT_CONTEXT_LAYER_ID,\n  1562\t                ),\n  1563\t                \"boundary_status\": \"active\" if is_active else \"context\",\n  1564\t                \"directional_context\": [],\n  1565\t                \"nearest_active_hop_count\": 0 if is_active else None,\n  1566\t                \"is_active_selected\": is_active,\n  1567\t                \"is_context_only\": not is_active,\n  1568\t            }\n  1569\t        )\n  1570\t    return records\n  1571\t\n  1572\t\n  1573\tdef _build_base_edge_records(\n  1574\t    *,\n  1575\t    selected_biological_edges: Sequence[Mapping[str, Any]],\n  1576\t    active_root_set: set[int],\n  1577\t    query_family: str,\n  1578\t    enabled_overlays: set[str],\n  1579\t    directional_membership: Mapping[int, set[str]],\n  1580\t    highlight_edge_keys: set[tuple[int, int]],\n  1581\t) -> list[dict[str, Any]]:\n  1582\t    records: list[dict[str, Any]] = []\n  1583\t    for edge in selected_biological_edges:\n  1584\t        source_root_id = int(edge[\"source_root_id\"])\n  1585\t        target_root_id = int(edge[\"target_root_id\"])\n  1586\t        edge_role_id = _biological_edge_role(\n  1587\t            source_root_id=source_root_id,\n  1588\t            target_root_id=target_root_id,\n  1589\t            active_root_set=active_root_set,\n  1590\t        )\n  1591\t        overlay_ids = [ACTIVE_BOUNDARY_OVERLAY_ID]\n  1592\t        direction_membership = sorted(\n  1593\t            directional_membership.get(source_root_id, set())\n  1594\t            | directional_membership.get(target_root_id, set())\n  1595\t        )\n  1596\t        if UPSTREAM_GRAPH_OVERLAY_ID in enabled_overlays and (\n  1597\t            edge_role_id == CONTEXT_TO_ACTIVE_EDGE_ROLE_ID or \"upstream\" in direction_membership\n  1598\t        ):\n  1599\t            overlay_ids.append(UPSTREAM_GRAPH_OVERLAY_ID)\n  1600\t        if DOWNSTREAM_GRAPH_OVERLAY_ID in enabled_overlays and (\n  1601\t            edge_role_id == ACTIVE_TO_CONTEXT_EDGE_ROLE_ID or \"downstream\" in direction_membership\n  1602\t        ):\n  1603\t            overlay_ids.append(DOWNSTREAM_GRAPH_OVERLAY_ID)\n  1604\t        if (\n  1605\t            query_family in {\n  1606\t                BIDIRECTIONAL_CONTEXT_QUERY_FAMILY,\n  1607\t                DOWNSTREAM_MODULE_REVIEW_QUERY_FAMILY,\n  1608\t            }\n  1609\t            and BIDIRECTIONAL_CONTEXT_GRAPH_OVERLAY_ID in enabled_overlays\n  1610\t            and (\n  1611\t                source_root_id in active_root_set\n  1612\t                or target_root_id in active_root_set\n  1613\t                or bool(direction_membership)\n  1614\t            )\n  1615\t        ):\n  1616\t            overlay_ids.append(BIDIRECTIONAL_CONTEXT_GRAPH_OVERLAY_ID)\n  1617\t        records.append(\n  1618\t            {\n  1619\t                \"source_root_id\": str(source_root_id),\n  1620\t                \"target_root_id\": str(target_root_id),\n  1621\t                \"edge_role_id\": edge_role_id,\n  1622\t                \"overlay_ids\": overlay_ids,\n  1623\t                \"weight\": float(edge[\"total_weight\"]),\n  1624\t                \"edge_id\": _edge_id(\n  1625\t                    source_root_id=source_root_id,\n  1626\t                    target_root_id=target_root_id,\n  1627\t                    edge_role_id=edge_role_id,\n  1628\t                ),\n  1629\t                \"directional_context\": direction_membership,\n  1630\t                \"synapse_count\": int(edge[\"synapse_count\"]),\n  1631\t                \"mean_confidence\": _coerce_optional_float(edge.get(\"mean_confidence\")),\n  1632\t                \"neuropils\": list(edge[\"neuropils\"]),\n  1633\t                \"dominant_neuropil\": edge.get(\"dominant_neuropil\"),\n  1634\t                \"nt_types\": list(edge[\"nt_types\"]),\n  1635\t                \"dominant_nt_type\": edge.get(\"dominant_nt_type\"),\n  1636\t                \"highlighted\": tuple(edge[\"edge_key\"]) in highlight_edge_keys,\n  1637\t            }\n  1638\t        )\n  1639\t    return records\n  1640\t\n  1641\t\n  1642\tdef _build_highlight_edge_records(\n  1643\t    *,\n  1644\t    selected_biological_edges: Sequence[Mapping[str, Any]],\n  1645\t    highlight_edge_keys: set[tuple[int, int]],\n  1646\t) -> list[dict[str, Any]]:\n  1647\t    edge_lookup = {\n  1648\t        tuple(edge[\"edge_key\"]): copy.deepcopy(dict(edge))\n  1649\t        for edge in selected_biological_edges\n  1650\t    }\n  1651\t    records: list[dict[str, Any]] = []\n  1652\t    for edge_key in sorted(highlight_edge_keys):\n  1653\t        edge = edge_lookup.get(tuple(edge_key))\n  1654\t        if edge is None:\n  1655\t            continue\n  1656\t        records.append(\n  1657\t            {\n  1658\t                \"source_root_id\": str(int(edge[\"source_root_id\"])),\n  1659\t                \"target_root_id\": str(int(edge[\"target_root_id\"])),\n  1660\t                \"edge_role_id\": PATHWAY_HIGHLIGHT_EDGE_ROLE_ID,\n  1661\t                \"overlay_ids\": [PATHWAY_HIGHLIGHT_OVERLAY_ID],\n  1662\t                \"weight\": float(edge[\"total_weight\"]),\n  1663\t                \"edge_id\": _edge_id(\n  1664\t                    source_root_id=int(edge[\"source_root_id\"]),\n  1665\t                    target_root_id=int(edge[\"target_root_id\"]),\n  1666\t                    edge_role_id=PATHWAY_HIGHLIGHT_EDGE_ROLE_ID,\n  1667\t                ),\n  1668\t                \"directional_context\": [],\n  1669\t                \"synapse_count\": int(edge[\"synapse_count\"]),\n  1670\t                \"mean_confidence\": _coerce_optional_float(edge.get(\"mean_confidence\")),\n  1671\t                \"neuropils\": list(edge[\"neuropils\"]),\n  1672\t                \"dominant_neuropil\": edge.get(\"dominant_neuropil\"),\n  1673\t                \"nt_types\": list(edge[\"nt_types\"]),\n  1674\t                \"dominant_nt_type\": edge.get(\"dominant_nt_type\"),\n  1675\t                \"highlighted\": True,\n  1676\t            }\n  1677\t        )\n  1678\t    return records\n  1679\t\n  1680\t\n  1681\tdef _build_downstream_module_records(\n  1682\t    *,\n  1683\t    plan: Mapping[str, Any],\n  1684\t    metadata_by_root: Mapping[int, Mapping[str, Any]],\n  1685\t    selected_context_root_ids: set[int],\n  1686\t    directional_membership: Mapping[int, set[str]],\n  1687\t    path_registry: Mapping[tuple[str, int], Mapping[str, Any]],\n  1688\t    reduction_controls: Mapping[str, Any],\n  1689\t    query_profile_id: str,\n  1690\t    query_family: str,\n  1691\t    enabled_overlays: set[str],\n  1692\t    enabled_facets: set[str],\n  1693\t    highlight_path_records: Sequence[Mapping[str, Any]],\n  1694\t) -> list[dict[str, Any]]:\n  1695\t    requests = plan.get(\"downstream_module_requests\")\n  1696\t    if not isinstance(requests, Sequence) or isinstance(requests, (str, bytes)):\n  1697\t        return []\n  1698\t    if DOWNSTREAM_MODULE_OVERLAY_ID not in enabled_overlays:\n  1699\t        return []\n  1700\t    downstream_context_roots = [\n  1701\t        int(root_id)\n  1702\t        for root_id in sorted(selected_context_root_ids)\n  1703\t        if \"downstream\" in directional_membership.get(int(root_id), set())\n  1704\t    ]\n  1705\t    if not downstream_context_roots:\n  1706\t        return []\n  1707\t    max_module_count = int(reduction_controls[\"max_downstream_module_count\"])\n  1708\t    if max_module_count <= 0:\n  1709\t        return []\n  1710\t    records: list[dict[str, Any]] = []\n  1711\t    for request in requests:\n  1712\t        if len(records) >= max_module_count:\n  1713\t            break\n  1714\t        if not isinstance(request, Mapping):\n  1715\t            continue\n  1716\t        role_id = _require_nonempty_identifier(\n  1717\t            request.get(\"downstream_module_role_id\"),\n  1718\t            field_name=\"downstream_module_request.downstream_module_role_id\",\n  1719\t        )\n  1720\t        represented_root_ids = downstream_context_roots[: min(12, len(downstream_context_roots))]\n  1721\t        active_anchor_root_ids = sorted(\n  1722\t            {\n  1723\t                int(path[\"active_anchor_root_id\"])\n  1724\t                for root_id in represented_root_ids\n  1725\t                for direction in directional_membership.get(int(root_id), set())\n  1726\t                for path in [path_registry.get((str(direction), int(root_id)))]\n  1727\t                if isinstance(path, Mapping)\n  1728\t            }\n  1729\t        )\n  1730\t        supporting_pathway_ids = sorted(\n  1731\t            {\n  1732\t                str(record[\"pathway_id\"])\n  1733\t                for record in highlight_path_records\n  1734\t                if isinstance(record, Mapping)\n  1735\t                and {\n  1736\t                    int(root_id)\n  1737\t                    for root_id in record.get(\"node_root_ids\", [])\n  1738\t                }\n  1739\t                & set(represented_root_ids)\n  1740\t            }\n  1741\t        )\n  1742\t        dominant_cell_class = _dominant_counter_value(\n  1743\t            Counter(\n  1744\t                _string_or_none(metadata_by_root.get(root_id, {}).get(\"super_class\"))\n  1745\t                or _string_or_none(metadata_by_root.get(root_id, {}).get(\"class\"))\n  1746\t                or _string_or_none(metadata_by_root.get(root_id, {}).get(\"project_role\"))\n  1747\t                for root_id in represented_root_ids\n  1748\t            )\n  1749\t        )\n  1750\t        dominant_neuropil = _dominant_counter_value(\n  1751\t            Counter(\n  1752\t                _string_or_none(metadata_by_root.get(root_id, {}).get(\"neuropils\"))\n  1753\t                for root_id in represented_root_ids\n  1754\t            )\n  1755\t        )\n  1756\t        metadata_values = {}\n  1757\t        if \"cell_class\" in enabled_facets and dominant_cell_class is not None:\n  1758\t            metadata_values[\"cell_class\"] = dominant_cell_class\n  1759\t        if \"neuropil\" in enabled_facets and dominant_neuropil is not None:\n  1760\t            metadata_values[\"neuropil\"] = dominant_neuropil\n  1761\t        if \"pathway_relevance_status\" in enabled_facets:\n  1762\t            metadata_values[\"pathway_relevance_status\"] = \"collapsed_downstream_module\"\n  1763\t        records.append(\n  1764\t            {\n  1765\t                \"module_id\": f\"module:{role_id}:{represented_root_ids[0]}\",\n  1766\t                \"downstream_module_role_id\": role_id,\n  1767\t                \"display_name\": str(request.get(\"display_name\") or role_id.replace(\"_\", \" \").title()),\n  1768\t                \"description\": (\n  1769\t                    \"Optional simplified downstream context summary representing \"\n  1770\t                    f\"{len(represented_root_ids)} context roots.\"\n  1771\t                ),\n  1772\t                \"represented_root_ids\": [str(root_id) for root_id in represented_root_ids],\n  1773\t                \"overlay_ids\": (\n  1774\t                    [\n  1775\t                        DOWNSTREAM_MODULE_OVERLAY_ID,\n  1776\t                        BIDIRECTIONAL_CONTEXT_GRAPH_OVERLAY_ID,\n  1777\t                    ]\n  1778\t                    if (\n  1779\t                        query_family in {\n  1780\t                            BIDIRECTIONAL_CONTEXT_QUERY_FAMILY,\n  1781\t                            DOWNSTREAM_MODULE_REVIEW_QUERY_FAMILY,\n  1782\t                        }\n  1783\t                        and BIDIRECTIONAL_CONTEXT_GRAPH_OVERLAY_ID in enabled_overlays\n  1784\t                    )\n  1785\t                    else [DOWNSTREAM_MODULE_OVERLAY_ID]\n  1786\t                ),\n  1787\t                \"metadata_facet_values\": metadata_values,\n  1788\t                \"summary_labels\": {\n  1789\t                    \"is_optional\": True,\n  1790\t                    \"is_simplified\": True,\n  1791\t                    \"is_context_oriented\": True,\n  1792\t                    \"scientific_curation_required\": bool(\n  1793\t                        request.get(\"requires_scientific_curation\", True)\n  1794\t                    ),\n  1795\t                    \"claim_scope\": CONTEXT_SUMMARY_ONLY_CLAIM_SCOPE,\n  1796\t                    \"truthfulness_note\": (\n  1797\t                        \"Optional simplified downstream summary for context review; \"\n  1798\t                        \"not a new simulated biological claim.\"\n  1799\t                    ),\n  1800\t                },\n  1801\t                \"lineage\": {\n  1802\t                    \"active_anchor_root_ids\": [\n  1803\t                        str(root_id) for root_id in active_anchor_root_ids\n  1804\t                    ],\n  1805\t                    \"source_query_profile_id\": str(query_profile_id),\n  1806\t                    \"source_query_family\": str(query_family),\n  1807\t                    \"supporting_pathway_ids\": list(supporting_pathway_ids),\n  1808\t                    \"primary_supporting_pathway_id\": (\n  1809\t                        None if not supporting_pathway_ids else supporting_pathway_ids[0]\n  1810\t                    ),\n  1811\t                },\n  1812\t                \"handoff_targets\": [],\n  1813\t                \"context_layer_id\": DOWNSTREAM_MODULE_CONTEXT_LAYER_ID,\n  1814\t                \"module_kind\": \"collapsed_context_summary\",\n  1815\t            }\n  1816\t        )\n  1817\t    return records\n  1818\t\n  1819\t\n  1820\tdef _augment_graph_view_with_explanation_layer(\n  1821\t    *,\n  1822\t    graph_view: Mapping[str, Any],\n  1823\t    query_profile_id: str,\n  1824\t    query_family: str,\n  1825\t    active_root_ids: Sequence[int],\n  1826\t    enabled_overlays: set[str],\n  1827\t    enabled_facets: set[str],\n  1828\t    metadata_by_root: Mapping[int, Mapping[str, Any]],\n  1829\t    highlight_path_records: Sequence[Mapping[str, Any]],\n  1830\t) -> dict[str, Any]:\n  1831\t    result = copy.deepcopy(dict(graph_view))\n  1832\t    node_index = _graph_node_index(result.get(\"node_records\", []))\n  1833\t    edge_index = _graph_edge_index(result.get(\"edge_records\", []))\n  1834\t    module_records = [\n  1835\t        copy.deepcopy(dict(item))\n  1836\t        for item in result.get(\"downstream_module_records\", [])\n  1837\t        if isinstance(item, Mapping)\n  1838\t    ]\n  1839\t    overlay_workflow_catalog = _build_overlay_workflow_catalog(\n  1840\t        node_index=node_index,\n  1841\t        edge_index=edge_index,\n  1842\t        module_records=module_records,\n  1843\t        query_family=query_family,\n  1844\t        active_root_ids=active_root_ids,\n  1845\t        enabled_overlays=enabled_overlays,\n  1846\t    )\n  1847\t    (\n  1848\t        metadata_facet_group_catalog,\n  1849\t        metadata_facet_filter_catalog,\n  1850\t    ) = _build_metadata_facet_group_and_filter_catalogs(\n  1851\t        node_index=node_index,\n  1852\t        edge_index=edge_index,\n  1853\t        module_records=module_records,\n  1854\t        active_root_ids=active_root_ids,\n  1855\t        enabled_facets=enabled_facets,\n  1856\t    )\n  1857\t    pathway_explanation_catalog = _build_pathway_explanation_catalog(\n  1858\t        graph_root_ids=set(node_index),\n  1859\t        highlight_path_records=highlight_path_records,\n  1860\t        metadata_by_root=metadata_by_root,\n  1861\t        active_root_ids=active_root_ids,\n  1862\t    )\n  1863\t    interaction_flow_catalog = _build_interaction_flow_catalog(\n  1864\t        graph_view_id=str(result.get(\"view_id\") or \"\"),\n  1865\t        query_profile_id=query_profile_id,\n  1866\t        overlay_workflow_catalog=overlay_workflow_catalog,\n  1867\t        metadata_facet_group_catalog=metadata_facet_group_catalog,\n  1868\t        pathway_explanation_catalog=pathway_explanation_catalog,\n  1869\t    )\n  1870\t    reviewer_summary_cards = _build_reviewer_summary_cards(\n  1871\t        node_index=node_index,\n  1872\t        overlay_workflow_catalog=overlay_workflow_catalog,\n  1873\t        metadata_facet_group_catalog=metadata_facet_group_catalog,\n  1874\t        pathway_explanation_catalog=pathway_explanation_catalog,\n  1875\t    )\n  1876\t    summary = copy.deepcopy(\n  1877\t        dict(_require_mapping(result.get(\"summary\", {}), field_name=\"graph_view.summary\"))\n  1878\t    )\n  1879\t    summary[\"overlay_workflow_count\"] = len(overlay_workflow_catalog)\n  1880\t    summary[\"metadata_facet_group_count\"] = len(metadata_facet_group_catalog)\n  1881\t    summary[\"metadata_facet_filter_count\"] = len(metadata_facet_filter_catalog)\n  1882\t    summary[\"pathway_explanation_mode_count\"] = len(pathway_explanation_catalog)\n  1883\t    summary[\"interaction_flow_count\"] = len(interaction_flow_catalog)\n  1884\t    result[\"summary\"] = summary\n  1885\t    result[\"reviewer_caption\"] = (\n  1886\t        reviewer_summary_cards[0][\"caption\"] if reviewer_summary_cards else str(result[\"description\"])\n  1887\t    )\n  1888\t    result[\"overlay_workflow_catalog\"] = overlay_workflow_catalog\n  1889\t    result[\"metadata_facet_group_catalog\"] = metadata_facet_group_catalog\n  1890\t    result[\"metadata_facet_filter_catalog\"] = metadata_facet_filter_catalog\n  1891\t    result[\"pathway_explanation_catalog\"] = pathway_explanation_catalog\n  1892\t    result[\"interaction_flow_catalog\"] = interaction_flow_catalog\n  1893\t    result[\"reviewer_summary_cards\"] = reviewer_summary_cards\n  1894\t    return result\n  1895\t\n  1896\t\n  1897\tdef _graph_node_index(payload: Any) -> dict[int, dict[str, Any]]:\n  1898\t    index: dict[int, dict[str, Any]] = {}\n  1899\t    if not isinstance(payload, Sequence):\n  1900\t        return index\n  1901\t    for item in payload:\n  1902\t        if not isinstance(item, Mapping):\n  1903\t            continue\n  1904\t        root_id = int(item[\"root_id\"])\n  1905\t        entry = index.setdefault(\n  1906\t            root_id,\n  1907\t            {\n  1908\t                \"root_id\": root_id,\n  1909\t                \"display_label\": \"\",\n  1910\t                \"overlay_ids\": set(),\n  1911\t                \"directional_context\": set(),\n  1912\t                \"metadata_facet_values\": {},\n  1913\t                \"boundary_status\": None,\n  1914\t                \"is_active_selected\": False,\n  1915\t                \"is_context_only\": False,\n  1916\t                \"nearest_active_hop_count\": None,\n  1917\t                \"source_node_role_ids\": set(),\n  1918\t                \"pathway_highlight\": False,\n  1919\t            },\n  1920\t        )\n  1921\t        if not entry[\"display_label\"] and _string_or_none(item.get(\"display_label\")) is not None:\n  1922\t            entry[\"display_label\"] = str(item[\"display_label\"])\n  1923\t        entry[\"overlay_ids\"].update(\n  1924\t            str(value) for value in item.get(\"overlay_ids\", []) if _string_or_none(value) is not None\n  1925\t        )\n  1926\t        entry[\"directional_context\"].update(\n  1927\t            str(value)\n  1928\t            for value in item.get(\"directional_context\", [])\n  1929\t            if _string_or_none(value) is not None\n  1930\t        )\n  1931\t        if isinstance(item.get(\"metadata_facet_values\", {}), Mapping):\n  1932\t            entry[\"metadata_facet_values\"].update(dict(item[\"metadata_facet_values\"]))\n  1933\t        boundary_status = _string_or_none(item.get(\"boundary_status\"))\n  1934\t        if boundary_status is not None:\n  1935\t            entry[\"boundary_status\"] = boundary_status\n  1936\t        entry[\"is_active_selected\"] = bool(entry[\"is_active_selected\"]) or bool(\n  1937\t            item.get(\"is_active_selected\")\n  1938\t        )\n  1939\t        entry[\"is_context_only\"] = bool(entry[\"is_context_only\"]) or bool(\n  1940\t            item.get(\"is_context_only\")\n  1941\t        )\n  1942\t        nearest_hop = _coerce_nullable_int(item.get(\"nearest_active_hop_count\"))\n  1943\t        if nearest_hop is not None and (\n  1944\t            entry[\"nearest_active_hop_count\"] is None\n  1945\t            or nearest_hop < int(entry[\"nearest_active_hop_count\"])\n  1946\t        ):\n  1947\t            entry[\"nearest_active_hop_count\"] = nearest_hop\n  1948\t        node_role_id = _string_or_none(item.get(\"node_role_id\"))\n  1949\t        if node_role_id is not None:\n  1950\t            entry[\"source_node_role_ids\"].add(node_role_id)\n  1951\t            if node_role_id in {\n  1952\t                ACTIVE_PATHWAY_HIGHLIGHT_NODE_ROLE_ID,\n  1953\t                CONTEXT_PATHWAY_HIGHLIGHT_NODE_ROLE_ID,\n  1954\t            }:\n  1955\t                entry[\"pathway_highlight\"] = True\n  1956\t    return index\n  1957\t\n  1958\t\n  1959\tdef _graph_edge_index(payload: Any) -> dict[tuple[int, int], dict[str, Any]]:\n  1960\t    index: dict[tuple[int, int], dict[str, Any]] = {}\n  1961\t    if not isinstance(payload, Sequence):\n  1962\t        return index\n  1963\t    for item in payload:\n  1964\t        if not isinstance(item, Mapping):\n  1965\t            continue\n  1966\t        edge_key = (int(item[\"source_root_id\"]), int(item[\"target_root_id\"]))\n  1967\t        entry = index.setdefault(\n  1968\t            edge_key,\n  1969\t            {\n  1970\t                \"source_root_id\": edge_key[0],\n  1971\t                \"target_root_id\": edge_key[1],\n  1972\t                \"overlay_ids\": set(),\n  1973\t                \"edge_role_ids\": set(),\n  1974\t                \"synapse_count\": 0,\n  1975\t                \"weight\": 0.0,\n  1976\t                \"dominant_neuropil\": None,\n  1977\t                \"dominant_nt_type\": None,\n  1978\t                \"highlighted\": False,\n  1979\t            },\n  1980\t        )\n  1981\t        entry[\"overlay_ids\"].update(\n  1982\t            str(value) for value in item.get(\"overlay_ids\", []) if _string_or_none(value) is not None\n  1983\t        )\n  1984\t        edge_role_id = _string_or_none(item.get(\"edge_role_id\"))\n  1985\t        if edge_role_id is not None:\n  1986\t            entry[\"edge_role_ids\"].add(edge_role_id)\n  1987\t        entry[\"synapse_count\"] = max(\n  1988\t            int(entry[\"synapse_count\"]),\n  1989\t            int(item.get(\"synapse_count\", 0) or 0),\n  1990\t        )\n  1991\t        entry[\"weight\"] = max(\n  1992\t            float(entry[\"weight\"]),\n  1993\t            float(item.get(\"weight\", 0.0) or 0.0),\n  1994\t        )\n  1995\t        if entry[\"dominant_neuropil\"] is None and _string_or_none(item.get(\"dominant_neuropil\")) is not None:\n  1996\t            entry[\"dominant_neuropil\"] = str(item[\"dominant_neuropil\"])\n  1997\t        if entry[\"dominant_nt_type\"] is None and _string_or_none(item.get(\"dominant_nt_type\")) is not None:\n  1998\t            entry[\"dominant_nt_type\"] = str(item[\"dominant_nt_type\"])\n  1999\t        entry[\"highlighted\"] = bool(entry[\"highlighted\"]) or bool(item.get(\"highlighted\"))\n  2000\t    return index\n  2001\t\n  2002\t\n  2003\tdef _build_overlay_workflow_catalog(\n  2004\t    *,\n  2005\t    node_index: Mapping[int, Mapping[str, Any]],\n  2006\t    edge_index: Mapping[tuple[int, int], Mapping[str, Any]],\n  2007\t    module_records: Sequence[Mapping[str, Any]],\n  2008\t    query_family: str,\n  2009\t    active_root_ids: Sequence[int],\n  2010\t    enabled_overlays: set[str],\n  2011\t) -> list[dict[str, Any]]:\n  2012\t    overlay_order = [\n  2013\t        ACTIVE_BOUNDARY_OVERLAY_ID,\n  2014\t        UPSTREAM_GRAPH_OVERLAY_ID,\n  2015\t        DOWNSTREAM_GRAPH_OVERLAY_ID,\n  2016\t        BIDIRECTIONAL_CONTEXT_GRAPH_OVERLAY_ID,\n  2017\t        PATHWAY_HIGHLIGHT_OVERLAY_ID,\n  2018\t        DOWNSTREAM_MODULE_OVERLAY_ID,\n  2019\t        METADATA_FACET_BADGES_OVERLAY_ID,\n  2020\t    ]\n  2021\t    active_root_id_set = {int(root_id) for root_id in active_root_ids}\n  2022\t    result: list[dict[str, Any]] = []\n  2023\t    for overlay_id in overlay_order:\n  2024\t        if overlay_id not in enabled_overlays:\n  2025\t            continue\n  2026\t        if overlay_id == ACTIVE_BOUNDARY_OVERLAY_ID:\n  2027\t            matching_root_ids = sorted(node_index)\n  2028\t            matching_edge_pairs = [list(pair) for pair in sorted(edge_index)]\n  2029\t            matching_module_ids = []\n  2030\t        else:\n  2031\t            matching_root_ids = [\n  2032\t                root_id\n  2033\t                for root_id, node in sorted(node_index.items())\n  2034\t                if overlay_id in set(node[\"overlay_ids\"])\n  2035\t            ]\n  2036\t            matching_edge_pairs = [\n  2037\t                list(pair)\n  2038\t                for pair, edge in sorted(edge_index.items())\n  2039\t                if overlay_id in set(edge[\"overlay_ids\"])\n  2040\t            ]\n  2041\t            matching_module_ids = [\n  2042\t                str(item[\"module_id\"])\n  2043\t                for item in module_records\n  2044\t                if overlay_id\n  2045\t                in {\n  2046\t                    str(value)\n  2047\t                    for value in item.get(\"overlay_ids\", [])\n  2048\t                    if _string_or_none(value) is not None\n  2049\t                }\n  2050\t            ]\n  2051\t        visible_root_ids = sorted(\n  2052\t            set(matching_root_ids)\n  2053\t            | (\n  2054\t                active_root_id_set\n  2055\t                if overlay_id != ACTIVE_BOUNDARY_OVERLAY_ID\n  2056\t                else set(matching_root_ids)\n  2057\t            )\n  2058\t        )\n  2059\t        available = bool(matching_root_ids or matching_edge_pairs or matching_module_ids)\n  2060\t        result.append(\n  2061\t            {\n  2062\t                \"overlay_workflow_id\": f\"overlay_workflow:{overlay_id}\",\n  2063\t                \"overlay_id\": overlay_id,\n  2064\t                \"display_name\": _OVERLAY_DISPLAY_NAMES.get(overlay_id, overlay_id),\n  2065\t                \"availability\": \"available\" if available else \"unavailable\",\n  2066\t                \"query_family\": query_family,\n  2067\t                \"matching_root_ids\": [int(root_id) for root_id in matching_root_ids],\n  2068\t                \"visible_root_ids\": [int(root_id) for root_id in visible_root_ids],\n  2069\t                \"matching_edge_pairs\": matching_edge_pairs,\n  2070\t                \"matching_module_ids\": matching_module_ids,\n  2071\t                \"matching_active_root_count\": sum(\n  2072\t                    1 for root_id in matching_root_ids if int(root_id) in active_root_id_set\n  2073\t                ),\n  2074\t                \"matching_context_root_count\": sum(\n  2075\t                    1 for root_id in matching_root_ids if int(root_id) not in active_root_id_set\n  2076\t                ),\n  2077\t                \"caption\": _overlay_workflow_caption(\n  2078\t                    overlay_id=overlay_id,\n  2079\t                    node_index=node_index,\n  2080\t                    matching_root_ids=matching_root_ids,\n  2081\t                    matching_module_ids=matching_module_ids,\n  2082\t                    active_root_id_set=active_root_id_set,\n  2083\t                ),\n  2084\t                \"boundary_note\": (\n  2085\t                    \"Active roots remain the simulator-facing subset even when this overlay is emphasized.\"\n  2086\t                ),\n  2087\t            }\n  2088\t        )\n  2089\t    return result\n  2090\t\n  2091\t\n  2092\tdef _overlay_workflow_caption(\n  2093\t    *,\n  2094\t    overlay_id: str,\n  2095\t    node_index: Mapping[int, Mapping[str, Any]],\n  2096\t    matching_root_ids: Sequence[int],\n  2097\t    matching_module_ids: Sequence[str],\n  2098\t    active_root_id_set: set[int],\n  2099\t) -> str:\n  2100\t    matching_root_id_set = {int(root_id) for root_id in matching_root_ids}\n  2101\t    context_root_ids = sorted(matching_root_id_set - active_root_id_set)\n  2102\t    if overlay_id == ACTIVE_BOUNDARY_OVERLAY_ID:\n  2103\t        return (\n  2104\t            f\"Active boundary keeps {len(active_root_id_set)} simulated roots distinct from \"\n  2105\t            f\"{sum(1 for root_id in node_index if root_id not in active_root_id_set)} context-only roots.\"\n  2106\t        )\n  2107\t    if overlay_id == UPSTREAM_GRAPH_OVERLAY_ID:\n  2108\t        return (\n  2109\t            f\"Upstream emphasis surfaces {len(context_root_ids)} context roots that feed into \"\n  2110\t            f\"{len(active_root_id_set)} active anchors.\"\n  2111\t        )\n  2112\t    if overlay_id == DOWNSTREAM_GRAPH_OVERLAY_ID:\n  2113\t        return (\n  2114\t            f\"Downstream emphasis shows {len(context_root_ids)} context roots reached from \"\n  2115\t            f\"{len(active_root_id_set)} active anchors.\"\n  2116\t        )\n  2117\t    if overlay_id == BIDIRECTIONAL_CONTEXT_GRAPH_OVERLAY_ID:\n  2118\t        upstream_count = 0\n  2119\t        downstream_count = 0\n  2120\t        mixed_count = 0\n  2121\t        for root_id in context_root_ids:\n  2122\t            directions = set(node_index[root_id][\"directional_context\"])\n  2123\t            if directions == {\"upstream\"}:\n  2124\t                upstream_count += 1\n  2125\t            elif directions == {\"downstream\"}:\n  2126\t                downstream_count += 1\n  2127\t            elif directions == {\"upstream\", \"downstream\"}:\n  2128\t                mixed_count += 1\n  2129\t        return (\n  2130\t            \"Bidirectional context combines \"\n  2131\t            f\"{upstream_count} upstream, {downstream_count} downstream, and {mixed_count} \"\n  2132\t            f\"mixed-direction context roots around {len(active_root_id_set)} active anchors.\"\n  2133\t        )\n  2134\t    if overlay_id == PATHWAY_HIGHLIGHT_OVERLAY_ID:\n  2135\t        return (\n  2136\t            f\"Pathway emphasis marks {len(context_root_ids)} contextual bridge roots without \"\n  2137\t            \"changing their active-versus-context identity.\"\n  2138\t        )\n  2139\t    if overlay_id == DOWNSTREAM_MODULE_OVERLAY_ID:\n  2140\t        return (\n  2141\t            f\"Downstream module overlay adds {len(matching_module_ids)} collapsed summary objects \"\n  2142\t            \"for broader readout context.\"\n  2143\t        )\n  2144\t    if overlay_id == METADATA_FACET_BADGES_OVERLAY_ID:\n  2145\t        return (\n  2146\t            f\"Metadata facet badges annotate {len(matching_root_id_set)} roots with reviewer-readable \"\n  2147\t            \"group labels such as cell class and neuropil.\"\n  2148\t        )\n  2149\t    return f\"{_OVERLAY_DISPLAY_NAMES.get(overlay_id, overlay_id)} is available for this graph view.\"\n  2150\t\n  2151\t\n  2152\tdef _build_metadata_facet_group_and_filter_catalogs(\n  2153\t    *,\n  2154\t    node_index: Mapping[int, Mapping[str, Any]],\n  2155\t    edge_index: Mapping[tuple[int, int], Mapping[str, Any]],\n  2156\t    module_records: Sequence[Mapping[str, Any]],\n  2157\t    active_root_ids: Sequence[int],\n  2158\t    enabled_facets: set[str],\n  2159\t) -> tuple[list[dict[str, Any]], list[dict[str, Any]]]:\n  2160\t    active_root_id_set = {int(root_id) for root_id in active_root_ids}\n  2161\t    filter_catalog = [\n  2162\t        {\n  2163\t            \"filter_id\": \"facet_filter:all_context\",\n  2164\t            \"display_name\": \"All Context\",\n  2165\t            \"metadata_facet_id\": None,\n  2166\t            \"facet_value\": None,\n  2167\t            \"availability\": \"available\",\n  2168\t            \"matching_root_ids\": [int(root_id) for root_id in sorted(node_index)],\n  2169\t            \"visible_root_ids\": [int(root_id) for root_id in sorted(node_index)],\n  2170\t            \"visible_edge_pairs\": [list(pair) for pair in sorted(edge_index)],\n  2171\t            \"visible_module_ids\": [\n  2172\t                str(item[\"module_id\"]) for item in module_records if _string_or_none(item.get(\"module_id\")) is not None\n  2173\t            ],\n  2174\t            \"matching_active_root_count\": len(active_root_id_set),\n  2175\t            \"matching_context_root_count\": sum(\n  2176\t                1 for root_id in node_index if int(root_id) not in active_root_id_set\n  2177\t            ),\n  2178\t            \"caption\": \"No metadata facet filter is applied; the full packaged context remains visible.\",\n  2179\t            \"boundary_note\": \"Active anchors remain visible even when later filters narrow context groups.\",\n  2180\t        }\n  2181\t    ]\n  2182\t    group_catalog: list[dict[str, Any]] = []\n  2183\t    facet_order = [\n  2184\t        CELL_CLASS_METADATA_FACET_ID,\n  2185\t        NEUROPIL_METADATA_FACET_ID,\n  2186\t        \"cell_type\",\n  2187\t        \"side\",\n  2188\t        \"nt_type\",\n  2189\t        \"selection_boundary_status\",\n  2190\t        \"pathway_relevance_status\",\n  2191\t    ]\n  2192\t    for facet_id in facet_order:\n  2193\t        if facet_id not in enabled_facets:\n  2194\t            continue\n  2195\t        value_to_root_ids: dict[str, set[int]] = {}\n  2196\t        value_to_module_ids: dict[str, set[str]] = {}\n  2197\t        for root_id, node in node_index.items():\n  2198\t            value = _string_or_none(node[\"metadata_facet_values\"].get(facet_id))\n  2199\t            if value is None:\n  2200\t                continue\n  2201\t            value_to_root_ids.setdefault(value, set()).add(int(root_id))\n  2202\t        for item in module_records:\n  2203\t            metadata_values = item.get(\"metadata_facet_values\", {})\n  2204\t            if not isinstance(metadata_values, Mapping):\n  2205\t                continue\n  2206\t            value = _string_or_none(metadata_values.get(facet_id))\n  2207\t            if value is None:\n  2208\t                continue\n  2209\t            module_id = _string_or_none(item.get(\"module_id\"))\n  2210\t            if module_id is None:\n  2211\t                continue\n  2212\t            value_to_module_ids.setdefault(value, set()).add(module_id)\n  2213\t        facet_values = sorted(\n  2214\t            set(value_to_root_ids) | set(value_to_module_ids),\n  2215\t            key=lambda item: (_normalize_identifier_token(item), item),\n  2216\t        )\n  2217\t        if not facet_values:\n  2218\t            continue\n  2219\t        available_filter_ids: list[str] = []\n  2220\t        for facet_value in facet_values:\n  2221\t            matching_root_ids = sorted(value_to_root_ids.get(facet_value, set()))\n  2222\t            matching_module_ids = sorted(value_to_module_ids.get(facet_value, set()))\n  2223\t            visible_root_id_set = set(matching_root_ids) | active_root_id_set\n  2224\t            visible_edge_pairs = [\n  2225\t                list(pair)\n  2226\t                for pair in sorted(edge_index)\n  2227\t                if pair[0] in visible_root_id_set and pair[1] in visible_root_id_set\n  2228\t            ]\n  2229\t            visible_module_ids = sorted(\n  2230\t                set(matching_module_ids)\n  2231\t                | {\n  2232\t                    str(item[\"module_id\"])\n  2233\t                    for item in module_records\n  2234\t                    if visible_root_id_set\n  2235\t                    & {\n  2236\t                        int(root_id)\n  2237\t                        for root_id in item.get(\"represented_root_ids\", [])\n  2238\t                    }\n  2239\t                }\n  2240\t            )\n  2241\t            filter_id = (\n  2242\t                f\"facet_filter:{facet_id}:{_normalize_identifier_token(facet_value)}\"\n  2243\t            )\n  2244\t            available_filter_ids.append(filter_id)\n  2245\t            matching_root_id_set = set(matching_root_ids)\n  2246\t            filter_catalog.append(\n  2247\t                {\n  2248\t                    \"filter_id\": filter_id,\n  2249\t                    \"display_name\": (\n  2250\t                        f\"{_METADATA_FACET_DISPLAY_NAMES.get(facet_id, facet_id)} = {facet_value}\"\n  2251\t                    ),\n  2252\t                    \"metadata_facet_id\": facet_id,\n  2253\t                    \"facet_value\": facet_value,\n  2254\t                    \"availability\": \"available\",\n  2255\t                    \"matching_root_ids\": [int(root_id) for root_id in matching_root_ids],\n  2256\t                    \"visible_root_ids\": [int(root_id) for root_id in sorted(visible_root_id_set)],\n  2257\t                    \"visible_edge_pairs\": visible_edge_pairs,\n  2258\t                    \"visible_module_ids\": visible_module_ids,\n  2259\t                    \"matching_active_root_count\": sum(\n  2260\t                        1 for root_id in matching_root_id_set if root_id in active_root_id_set\n  2261\t                    ),\n  2262\t                    \"matching_context_root_count\": sum(\n  2263\t                        1 for root_id in matching_root_id_set if root_id not in active_root_id_set\n  2264\t                    ),\n  2265\t                    \"caption\": (\n  2266\t                        f\"{_METADATA_FACET_DISPLAY_NAMES.get(facet_id, facet_id)} = {facet_value} \"\n  2267\t                        f\"matches {sum(1 for root_id in matching_root_id_set if root_id not in active_root_id_set)} \"\n  2268\t                        \"context roots while preserving active anchors for boundary reference.\"\n  2269\t                    ),\n  2270\t                    \"boundary_note\": (\n  2271\t                        \"Facet filtering narrows contextual groups but does not relabel context-only roots as simulated.\"\n  2272\t                    ),\n  2273\t                }\n  2274\t            )\n  2275\t        group_catalog.append(\n  2276\t            {\n  2277\t                \"metadata_facet_id\": facet_id,\n  2278\t                \"display_name\": _METADATA_FACET_DISPLAY_NAMES.get(facet_id, facet_id),\n  2279\t                \"availability\": \"available\",\n  2280\t                \"default_filter_id\": available_filter_ids[0],\n  2281\t                \"available_filter_ids\": available_filter_ids,\n  2282\t                \"facet_value_count\": len(available_filter_ids),\n  2283\t                \"caption\": (\n  2284\t                    f\"{_METADATA_FACET_DISPLAY_NAMES.get(facet_id, facet_id)} ships \"\n  2285\t                    f\"{len(available_filter_ids)} deterministic filter values for this graph view.\"\n  2286\t                ),\n  2287\t            }\n  2288\t        )\n  2289\t    return group_catalog, filter_catalog\n  2290\t\n  2291\t\n  2292\tdef _build_pathway_explanation_catalog(\n  2293\t    *,\n  2294\t    graph_root_ids: set[int],\n  2295\t    highlight_path_records: Sequence[Mapping[str, Any]],\n  2296\t    metadata_by_root: Mapping[int, Mapping[str, Any]],\n  2297\t    active_root_ids: Sequence[int],\n  2298\t) -> list[dict[str, Any]]:\n  2299\t    active_root_id_set = {int(root_id) for root_id in active_root_ids}\n  2300\t    cards: list[dict[str, Any]] = []\n  2301\t    for record in sorted(\n  2302\t        (copy.deepcopy(dict(item)) for item in highlight_path_records),\n  2303\t        key=lambda item: (\n  2304\t            str(item.get(\"direction\") or \"\"),\n  2305\t            int(item.get(\"anchor_root_id\", 0) or 0),\n  2306\t            int(item.get(\"target_root_id\", 0) or 0),\n  2307\t        ),\n  2308\t    ):\n  2309\t        node_root_ids = [int(root_id) for root_id in record.get(\"node_root_ids\", [])]\n  2310\t        if not set(node_root_ids).issubset(graph_root_ids):\n  2311\t            continue\n  2312\t        anchor_root_id = int(record[\"anchor_root_id\"])\n  2313\t        target_root_id = int(record[\"target_root_id\"])\n  2314\t        direction = str(record[\"direction\"])\n  2315\t        review_root_ids = (\n  2316\t            list(reversed(node_root_ids))\n  2317\t            if direction == \"upstream\"\n  2318\t            else list(node_root_ids)\n  2319\t        )\n  2320\t        anchor_metadata = metadata_by_root.get(anchor_root_id, {})\n  2321\t        target_metadata = metadata_by_root.get(target_root_id, {})\n  2322\t        anchor_label = _display_label(root_id=anchor_root_id, metadata=anchor_metadata)\n  2323\t        target_label = _display_label(root_id=target_root_id, metadata=target_metadata)\n  2324\t        facet_groupings = []\n  2325\t        for facet_id in (CELL_CLASS_METADATA_FACET_ID, NEUROPIL_METADATA_FACET_ID):\n  2326\t            facet_value = _pathway_grouping_value(\n  2327\t                metadata=target_metadata,\n  2328\t                metadata_facet_id=facet_id,\n  2329\t            )\n  2330\t            if facet_value is None:\n  2331\t                continue\n  2332\t            facet_groupings.append(\n  2333\t                {\n  2334\t                    \"metadata_facet_id\": facet_id,\n  2335\t                    \"display_name\": _METADATA_FACET_DISPLAY_NAMES.get(facet_id, facet_id),\n  2336\t                    \"facet_value\": facet_value,\n  2337\t                }\n  2338\t            )\n  2339\t        facet_caption = (\n  2340\t            \"No facet grouping is available for the context target.\"\n  2341\t            if not facet_groupings\n  2342\t            else \", \".join(\n  2343\t                f\"{item['display_name']} = {item['facet_value']}\" for item in facet_groupings\n  2344\t            )\n  2345\t        )\n  2346\t        cards.append(\n  2347\t            {\n  2348\t                \"explanation_id\": f\"pathway_explanation:{record['pathway_id']}\",\n  2349\t                \"pathway_id\": str(record[\"pathway_id\"]),\n  2350\t                \"display_name\": f\"{anchor_label} to {target_label}\",\n  2351\t                \"biological_direction\": direction,\n  2352\t                \"review_direction\": \"active_to_context\",\n  2353\t                \"anchor_root_id\": anchor_root_id,\n  2354\t                \"target_root_id\": target_root_id,\n  2355\t                \"review_node_root_ids\": review_root_ids,\n  2356\t                \"node_root_ids\": node_root_ids,\n  2357\t                \"edge_key_pairs\": [\n  2358\t                    [int(pair[0]), int(pair[1])] for pair in record.get(\"edge_key_pairs\", [])\n  2359\t                ],\n  2360\t                \"hop_count\": int(record.get(\"hop_count\", 0) or 0),\n  2361\t                \"path_synapse_count\": int(record.get(\"path_synapse_count\", 0) or 0),\n  2362\t                \"path_weight\": float(record.get(\"path_weight\", 0.0) or 0.0),\n  2363\t                \"active_root_ids\": [\n  2364\t                    int(root_id) for root_id in node_root_ids if int(root_id) in active_root_id_set\n  2365\t                ],\n  2366\t                \"context_root_ids\": [\n  2367\t                    int(root_id) for root_id in node_root_ids if int(root_id) not in active_root_id_set\n  2368\t                ],\n  2369\t                \"facet_groupings\": facet_groupings,\n  2370\t                \"facet_caption\": facet_caption,\n  2371\t                \"caption\": (\n  2372\t                    f\"{anchor_label} is the active anchor and {target_label} remains context-only. \"\n  2373\t                    f\"The highlighted {direction} bridge spans {int(record.get('hop_count', 0) or 0)} hop(s) \"\n  2374\t                    f\"and {int(record.get('path_synapse_count', 0) or 0)} local synapses.\"\n  2375\t                ),\n  2376\t                \"why_included\": (\n  2377\t                    f\"Deterministic {direction} path from the active subset toward a broader-context target \"\n  2378\t                    f\"under the packaged Milestone 17 reduction budget.\"\n  2379\t                ),\n  2380\t                \"boundary_note\": (\n  2381\t                    \"Pathway explanation clarifies why the context target is shown, but it does not move that target into the simulated subset.\"\n  2382\t                ),\n  2383\t            }\n  2384\t        )\n  2385\t    mode = {\n  2386\t        \"explanation_mode_id\": _PATHWAY_EXPLANATION_MODE_ID,\n  2387\t        \"display_name\": \"Active-To-Context Pathway\",\n  2388\t        \"description\": (\n  2389\t            \"Follow one highlighted bridge from an active anchor toward a contextual target while keeping biological direction explicit.\"\n  2390\t        ),\n  2391\t        \"availability\": \"available\" if cards else \"unavailable\",\n  2392\t        \"default_explanation_id\": None if not cards else str(cards[0][\"explanation_id\"]),\n  2393\t        \"card_count\": len(cards),\n  2394\t        \"caption\": (\n  2395\t            \"This explanation mode starts from the active subset, names the contextual target, and keeps active-versus-context labels explicit on every step.\"\n  2396\t        ),\n  2397\t        \"boundary_note\": (\n  2398\t            \"Context targets remain explanatory scaffolding even when the path itself is highlighted.\"\n  2399\t        ),\n  2400\t        \"cards\": cards,\n  2401\t    }\n  2402\t    return [mode]\n  2403\t\n  2404\t\n  2405\tdef _pathway_grouping_value(\n  2406\t    *,\n  2407\t    metadata: Mapping[str, Any],\n  2408\t    metadata_facet_id: str,\n  2409\t) -> str | None:\n  2410\t    if metadata_facet_id == CELL_CLASS_METADATA_FACET_ID:\n  2411\t        return (\n  2412\t            _string_or_none(metadata.get(\"super_class\"))\n  2413\t            or _string_or_none(metadata.get(\"class\"))\n  2414\t            or _string_or_none(metadata.get(\"project_role\"))\n  2415\t        )\n  2416\t    if metadata_facet_id == NEUROPIL_METADATA_FACET_ID:\n  2417\t        return _string_or_none(metadata.get(\"neuropils\"))\n  2418\t    return _string_or_none(metadata.get(metadata_facet_id))\n  2419\t\n  2420\t\n  2421\tdef _build_interaction_flow_catalog(\n  2422\t    *,\n  2423\t    graph_view_id: str,\n  2424\t    query_profile_id: str,\n  2425\t    overlay_workflow_catalog: Sequence[Mapping[str, Any]],\n  2426\t    metadata_facet_group_catalog: Sequence[Mapping[str, Any]],\n  2427\t    pathway_explanation_catalog: Sequence[Mapping[str, Any]],\n  2428\t) -> list[dict[str, Any]]:\n  2429\t    overlay_by_id = {\n  2430\t        str(item[\"overlay_id\"]): copy.deepcopy(dict(item))\n  2431\t        for item in overlay_workflow_catalog\n  2432\t        if isinstance(item, Mapping) and item.get(\"overlay_id\") is not None\n  2433\t    }\n  2434\t    facet_group_by_id = {\n  2435\t        str(item[\"metadata_facet_id\"]): copy.deepcopy(dict(item))\n  2436\t        for item in metadata_facet_group_catalog\n  2437\t        if isinstance(item, Mapping) and item.get(\"metadata_facet_id\") is not None\n  2438\t    }\n  2439\t    pathway_mode = (\n  2440\t        copy.deepcopy(dict(pathway_explanation_catalog[0]))\n  2441\t        if pathway_explanation_catalog\n  2442\t        else {\n  2443\t            \"explanation_mode_id\": _PATHWAY_EXPLANATION_MODE_ID,\n  2444\t            \"availability\": \"unavailable\",\n  2445\t            \"default_explanation_id\": None,\n  2446\t        }\n  2447\t    )\n  2448\t    result = []\n  2449\t    for workflow_id, display_name, overlay_id, caption in (\n  2450\t        (\n  2451\t            \"interaction_flow:overlay:upstream_emphasis\",\n  2452\t            \"Upstream Emphasis\",\n  2453\t            UPSTREAM_GRAPH_OVERLAY_ID,\n  2454\t            \"Switch to incoming context while keeping active anchors visibly separate from context-only roots.\",\n  2455\t        ),\n  2456\t        (\n  2457\t            \"interaction_flow:overlay:downstream_emphasis\",\n  2458\t            \"Downstream Emphasis\",\n  2459\t            DOWNSTREAM_GRAPH_OVERLAY_ID,\n  2460\t            \"Switch to outgoing context while keeping context-only branches labeled as non-simulated structure.\",\n  2461\t        ),\n  2462\t        (\n  2463\t            \"interaction_flow:overlay:bidirectional_context\",\n  2464\t            \"Bidirectional Context\",\n  2465\t            BIDIRECTIONAL_CONTEXT_GRAPH_OVERLAY_ID,\n  2466\t            \"Show the mixed whole-brain neighborhood when reviewers need upstream and downstream context together.\",\n  2467\t        ),\n  2468\t    ):\n  2469\t        overlay_record = overlay_by_id.get(overlay_id)\n  2470\t        result.append(\n  2471\t            {\n  2472\t                \"interaction_flow_id\": workflow_id,\n  2473\t                \"display_name\": display_name,\n  2474\t                \"flow_kind\": \"overlay_switch\",\n  2475\t                \"graph_view_id\": graph_view_id,\n  2476\t                \"query_profile_id\": query_profile_id,\n  2477\t                \"overlay_id\": overlay_id,\n  2478\t                \"availability\": (\n  2479\t                    \"unavailable\"\n  2480\t                    if overlay_record is None\n  2481\t                    else str(overlay_record[\"availability\"])\n  2482\t                ),\n  2483\t                \"default_target_id\": (\n  2484\t                    None\n  2485\t                    if overlay_record is None\n  2486\t                    else str(overlay_record[\"overlay_workflow_id\"])\n  2487\t                ),\n  2488\t                \"caption\": caption,\n  2489\t            }\n  2490\t        )\n  2491\t    for facet_id in (CELL_CLASS_METADATA_FACET_ID, NEUROPIL_METADATA_FACET_ID):\n  2492\t        facet_group = facet_group_by_id.get(facet_id)\n  2493\t        result.append(\n  2494\t            {\n  2495\t                \"interaction_flow_id\": f\"interaction_flow:facet:{facet_id}\",\n  2496\t                \"display_name\": (\n  2497\t                    f\"{_METADATA_FACET_DISPLAY_NAMES.get(facet_id, facet_id)} Filter\"\n  2498\t                ),\n  2499\t                \"flow_kind\": \"metadata_facet_filter\",\n  2500\t                \"graph_view_id\": graph_view_id,\n  2501\t                \"query_profile_id\": query_profile_id,\n  2502\t                \"overlay_id\": METADATA_FACET_BADGES_OVERLAY_ID,\n  2503\t                \"metadata_facet_id\": facet_id,\n  2504\t                \"availability\": (\n  2505\t                    \"unavailable\"\n  2506\t                    if facet_group is None\n  2507\t                    else str(facet_group[\"availability\"])\n  2508\t                ),\n  2509\t                \"default_target_id\": (\n  2510\t                    None if facet_group is None else str(facet_group[\"default_filter_id\"])\n  2511\t                ),\n  2512\t                \"caption\": (\n  2513\t                    f\"Filter the packaged context by {_METADATA_FACET_DISPLAY_NAMES.get(facet_id, facet_id).lower()} \"\n  2514\t                    \"while preserving active anchors for orientation.\"\n  2515\t                ),\n  2516\t            }\n  2517\t        )\n  2518\t    result.append(\n  2519\t        {\n  2520\t            \"interaction_flow_id\": \"interaction_flow:pathway:active_to_context\",\n  2521\t            \"display_name\": \"Active-To-Context Pathway\",\n  2522\t            \"flow_kind\": \"pathway_explanation\",\n  2523\t            \"graph_view_id\": graph_view_id,\n  2524\t            \"query_profile_id\": query_profile_id,\n  2525\t            \"overlay_id\": PATHWAY_HIGHLIGHT_OVERLAY_ID,\n  2526\t            \"pathway_explanation_mode_id\": str(pathway_mode[\"explanation_mode_id\"]),\n  2527\t            \"availability\": str(pathway_mode[\"availability\"]),\n  2528\t            \"default_target_id\": pathway_mode.get(\"default_explanation_id\"),\n  2529\t            \"caption\": (\n  2530\t                \"Explain one highlighted bridge from the active subset toward a broader-context target without blurring the active/context boundary.\"\n  2531\t            ),\n  2532\t        }\n  2533\t    )\n  2534\t    return result\n  2535\t\n  2536\t\n  2537\tdef _build_reviewer_summary_cards(\n  2538\t    *,\n  2539\t    node_index: Mapping[int, Mapping[str, Any]],\n  2540\t    overlay_workflow_catalog: Sequence[Mapping[str, Any]],\n  2541\t    metadata_facet_group_catalog: Sequence[Mapping[str, Any]],\n  2542\t    pathway_explanation_catalog: Sequence[Mapping[str, Any]],\n  2543\t) -> list[dict[str, Any]]:\n  2544\t    active_root_count = sum(\n  2545\t        1 for item in node_index.values() if bool(item[\"is_active_selected\"])\n  2546\t    )\n  2547\t    context_root_count = sum(\n  2548\t        1 for item in node_index.values() if not bool(item[\"is_active_selected\"])\n  2549\t    )\n  2550\t    pathway_mode = (\n  2551\t        pathway_explanation_catalog[0] if pathway_explanation_catalog else {\"card_count\": 0}\n  2552\t    )\n  2553\t    available_overlay_ids = [\n  2554\t        str(item[\"overlay_id\"])\n  2555\t        for item in overlay_workflow_catalog\n  2556\t        if str(item.get(\"availability\", \"unavailable\")) == \"available\"\n  2557\t    ]\n  2558\t    return [\n  2559\t        {\n  2560\t            \"card_id\": \"reviewer_card:boundary_summary\",\n  2561\t            \"display_name\": \"Active Vs Context Boundary\",\n  2562\t            \"caption\": (\n  2563\t                f\"{active_root_count} roots remain in the active simulator-facing subset while \"\n  2564\t                f\"{context_root_count} roots stay explicitly contextual.\"\n  2565\t            ),\n  2566\t            \"facts\": {\n  2567\t        