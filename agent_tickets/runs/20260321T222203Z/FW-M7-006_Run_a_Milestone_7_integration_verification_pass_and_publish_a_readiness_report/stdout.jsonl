\\\\n   343\\\\t        if tangent_norm <= _GEOMETRY_EPSILON:\\\\n   344\\\\t            raise FineSurfaceOperatorAssemblyError(\\\\n   345\\\\t                f\\\\\\\"Could not construct a tangent frame at vertex index {vertex_index}.\\\\\\\"\\\\n   346\\\\t            )\\\\n   347\\\\t        tangent_u[vertex_index] = tangent / tangent_norm\\\\n   348\\\\t        tangent_v[vertex_index] = np.cross(normal, tangent_u[vertex_index])\\\\n   349\\\\t\\\\n   350\\\\t    tangent_v = _normalize_vectors(tangent_v, label=\\\\\\\"secondary tangent vectors\\\\\\\")\\\\n   351\\\\t    return tangent_u, tangent_v\\\\n   352\\\\t\\\\n   353\\\\t\\\\n   354\\\\tdef _normalize_vectors(vectors: np.ndarray, *, label: str) -> np.ndarray:\\\\n   355\\\\t    norms = np.linalg.norm(vectors, axis=1)\\\\n   356\\\\t    if np.any(norms <= _GEOMETRY_EPSILON):\\\\n   357\\\\t        raise FineSurfaceOperatorAssemblyError(f\\\\\\\"Could not normalize {label}; at least one vector had near-zero norm.\\\\\\\")\\\\n   358\\\\t    return vectors / norms[:, None]\\\\n   359\\\\t\\\\n   360\\\\t\\\\n   361\\\\tdef _build_symmetric_edge_matrix(\\\\n   362\\\\t    *,\\\\n   363\\\\t    vertex_count: int,\\\\n   364\\\\t    edge_vertex_indices: np.ndarray,\\\\n   365\\\\t    edge_values: np.ndarray,\\\\n   366\\\\t) -> sp.csr_matrix:\\\\n   367\\\\t    rows = np.concatenate((edge_vertex_indices[:, 0], edge_vertex_indices[:, 1]))\\\\n   368\\\\t    cols = np.concatenate((edge_vertex_indices[:, 1], edge_vertex_indices[:, 0]))\\\\n   369\\\\t    data = np.concatenate((edge_values, edge_values)).astype(np.float64, copy=False)\\\\n   370\\\\t    matrix = sp.csr_matrix((data, (rows, cols)), shape=(vertex_count, vertex_count), dtype=np.float64)\\\\n   371\\\\t    matrix.eliminate_zeros()\\\\n   372\\\\t    matrix.sort_indices()\\\\n   373\\\\t    return matrix\\\\n   374\\\\t\\\\n   375\\\\t\\\\n   376\\\\tdef _assemble_stiffness_matrix(\\\\n   377\\\\t    *,\\\\n   378\\\\t    vertex_count: int,\\\\n   379\