rd_session_contract.py:727:    return parse_dashboard_session_metadata(\nsrc/flywire_wave/dashboard_session_contract.py:1114:def parse_dashboard_session_artifact_reference(payload: Mapping[str, Any]) -> dict[str, Any]:\nsrc/flywire_wave/dashboard_session_contract.py:1170:def parse_dashboard_session_contract_metadata(payload: Mapping[str, Any]) -> dict[str, Any]:\nsrc/flywire_wave/dashboard_session_contract.py:1442:def parse_dashboard_session_metadata(payload: Mapping[str, Any]) -> dict[str, Any]:\nsrc/flywire_wave/dashboard_session_contract.py:1470:    contract_metadata = build_dashboard_session_contract_metadata()\nsrc/flywire_wave/dashboard_session_contract.py:1571:    expected_hash = build_dashboard_session_spec_hash(\nsrc/flywire_wave/dashboard_session_contract.py:1584:    bundle_paths = build_dashboard_session_bundle_paths(\nsrc/flywire_wave/dashboard_session_contract.py:1596:    normalized[\"artifacts\"] = _normalize_dashboard_session_artifacts(\nsrc/flywire_wave/dashboard_session_contract.py:1676:def write_dashboard_session_contract_metadata(\nsrc/flywire_wave/dashboard_session_contract.py:1680:    normalized = parse_dashboard_session_contract_metadata(contract_metadata)\nsrc/flywire_wave/dashboard_session_contract.py:1684:def load_dashboard_session_contract_metadata(metadata_path: str | Path) -> dict[str, Any]:\nsrc/flywire_wave/dashboard_session_contract.py:1688:    return parse_dashboard_session_contract_metadata(payload)\nsrc/flywire_wave/dashboard_session_contract.py:1691:def write_dashboard_session_metadata(\nsrc/flywire_wave/dashboard_session_contract.py:1695:    normalized = parse_dashboard_session_metadata(bundle_metadata)\nsrc/flywire_wave/dashboard_session_contract.py:1704:def load_dashboard_session_metadata(metadata_path: str | Path) -> dict[str, Any]:\nsrc/flywire_wave/dashboard_session_contract.py:1708:    return parse_dashboard_session_metadata(payload)\nsrc/flywire_wave/dashboard_session_contract.py:1716:    metadata = parse_dashboard_session_