"\n    48\t            / \"stimuli\"\n    49\t            / \"bundles\"\n    50\t            / \"moving_edge\"\n    51\t            / \"simple_moving_edge\"\n    52\t            / parameter_hash\n    53\t        ).resolve()\n    54\t        self.assertEqual(bundle_paths.bundle_directory, expected_bundle_dir)\n    55\t        self.assertEqual(bundle_paths.metadata_json_path, expected_bundle_dir / \"stimulus_bundle.json\")\n    56\t        self.assertEqual(bundle_paths.frame_cache_path, expected_bundle_dir / \"stimulus_frames.npz\")\n    57\t        self.assertEqual(bundle_paths.preview_gif_path, expected_bundle_dir / \"stimulus_preview.gif\")\n    58\t        self.assertEqual(\n    59\t            bundle_paths.bundle_id,\n    60\t            f\"{STIMULUS_BUNDLE_CONTRACT_VERSION}:moving_edge:simple_moving_edge:{parameter_hash}\",\n    61\t        )\n    62\t\n    63\t    def test_fixture_bundle_metadata_serializes_deterministically_and_resolves_aliases(self) -> None:\n    64\t        with tempfile.TemporaryDirectory(dir=ROOT) as tmp_dir_str:\n    65\t            stimulus_dir = Path(tmp_dir_str) / \"stimuli\"\n    66\t            temporal_sampling = {\n    67\t                \"dt_ms\": 10.0,\n    68\t                \"duration_ms\": 400.0,\n    69\t                \"frame_count\": 40,\n    70\t            }\n    71\t            spatial_frame = {\n    72\t                \"width_px\": 96,\n    73\t                \"height_px\": 48,\n    74\t                \"width_deg\": 120.0,\n    75\t                \"height_deg\": 60.0,\n    76\t            }\n    77\t            parameter_snapshot_a = {\n    78\t                \"contrast\": 0.6,\n    79\t                \"edge_width_deg\": 8.0,\n    80\t                \"velocity_deg_per_s\": 45.0,\n    81\t                \"phase_offsets_deg\": [0.0, 90.0],\n    82\t                \"aperture\": {\n    83\t                    \"soften_deg\": 2.0,\n    84\t                    \"shape\": \"ellipse\",\n    85\t                },\n    86\t            }\n    87\t            parameter_snapshot_b = {\n    88\t                \"aperture\": {\n    89\t                    \"shape\": \"ellipse\",\n    90\t                    \"soften_deg\": 2.0,\n    91\t                },\n    92\t                \"phase_offsets_deg\": [0.0, 90.0],\n    93\t                \"velocity_deg_per_s\": 45.0,\n    94\t                \"edge_width_deg\": 8.0,\n    95\t                \"contrast\": 0.6,\n    96\t            }\n    97\t\n    98\t            metadata_a = build_stimulus_bundle_metadata(\n    99\t                stimulus_family=\"moving_edge\",\n   100\t                stimulus_name=\"simple_moving_edge\",\n   101\t                parameter_snapshot=parameter_snapshot_a,\n   102\t                seed=11,\n   103\t                temporal_sampling=temporal_sampling,\n   104\t                spatial_frame=spatial_frame,\n   105\t                processed_stimulus_dir=stimulus_dir,\n   106\t                frame_cache_status=ASSET_STATUS_READY,\n   107\t                preview_gif_status=ASSET_STATUS_MISSING,\n   108\t                compatibility_aliases=[\n   109\t                    {\n   110\t                        \"stimulus_family\": \"legacy_edge\",\n   111\t                        \"stimulus_name\": \"simple_edge_v0\",\n   112\t                    }\n   113\t                ],\n   114\t            )\n   115\t            metadata_b = build_stimulus_bundle_metadata(\n   116\t                stimulus_family=\"moving_edge\",\n   117\t                stimulus_name=\"simple_moving_edge\",\n   118\t                parameter_snapshot=parameter_snapshot_b,\n   119\t                seed=11,\n   120\t                temporal_sampling=temporal_sampling,\n   121\t                spatial_frame=spatial_frame,\n   122\t                processed_stimulus_dir=stimulus_dir,\n   123\t                frame_cache_status=ASSET_STATUS_READY,\n   124\t                preview_gif_status=ASSET_STATUS_MISSING,\n   125\t                compatibility_aliases=[\n   126\t                    {\n   127\t                        \"stimulus_family\": \"legacy_edge\",\n   128\t                        \"stimulus_name\": \"simple_edge_v0\",\n   129\t                    }\n   130\t                ],\n   131\t            )\n   132\t            manifest_metadata = build_stimulus_contract_manifest_metadata(\n   133\t                processed_stimulus_dir=stimulus_dir\n   134\t            )\n   135\t\n   136\t            self.assertEqual(metadata_a, metadata_b)\n   137\t            self.assertEqual(metadata_a[\"contract_version\"], STIMULUS_BUNDLE_CONTRACT_VERSION)\n   138\t            self.assertEqual(metadata_a[\"design_note\"], STIMULUS_BUNDLE_DESIGN_NOTE)\n   139\t            self.assertEqual(metadata_a[\"representation_family\"], DEFAULT_REPRESENTATION_FAMILY)\n   140\t            self.assertEqual(metadata_a[\"determinism\"][\"seed\"], 11)\n   141\t            self.assertEqual(metadata_a[\"temporal_sampling\"][\"frame_count\"], 40)\n   142\t            self.assertEqual(metadata_a[\"spatial_frame\"][\"frame_name\"], \"visual_field_degrees_centered\")\n   143\t            self.assertEqual(\n   144\t                metadata_a[\"luminance_convention\"][\"contrast_semantics\"],\n   145\t                \"signed_delta_from_neutral_gray\",\n   146\t            )\n   147\t            self.assertEqual(manifest_metadata[\"version\"], STIMULUS_BUNDLE_CONTRACT_VERSION)\n   148\t            self.assertEqual(manifest_metadata[\"design_note\"], STIMULUS_BUNDLE_DESIGN_NOTE)\n   149\t            self.assertEqual(manifest_metadata[\"default_representation_family\"], DEFAULT_REPRESENTATION_FAMILY)\n   150\t\n   151\t            metadata_path = write_stimulus_bundle_metadata(metadata_a)\n   152\t            loaded_metadata = load_stimulus_bundle_metadata(metadata_path)\n   153\t            discovered_paths = discover_stimulus_bundle_paths(metadata_a)\n   154\t            alias_paths = discover_stimulus_alias_paths(metadata_a)\n   155\t\n   156\t            self.assertEqual(loaded_metadata, metadata_a)\n   157\t            self.assertEqual(discovered_paths[METADATA_JSON_KEY], metadata_path.resolve())\n   158\t            self.assertEqual(\n   159\t                discovered_paths[FRAME_CACHE_KEY],\n   160\t                Path(metadata_a[\"assets\"][FRAME_CACHE_KEY][\"path\"]).resolve(),\n   161\t            )\n   162\t            self.assertEqual(\n   163\t                discovered_paths[PREVIEW_GIF_KEY],\n   164\t                Path(metadata_a[\"assets\"][PREVIEW_GIF_KEY][\"path\"]).resolve(),\n   165\t            )\n   166\t            self.assertEqual(len(alias_paths), 1)\n   167\t            alias_record = load_stimulus_alias_record(alias_paths[0])\n   168\t            self.assertEqual(alias_record[\"bundle_metadata_path\"], str(metadata_path.resolve()))\n   169\t            self.assertEqual(alias_record[\"parameter_hash\"], metadata_a[\"parameter_hash\"])\n   170\t\n   171\t            resolved_metadata_path = resolve_stimulus_bundle_metadata_path(\n   172\t                stimulus_family=\"legacy_edge\",\n   173\t                stimulus_name=\"simple_edge_v0\",\n   174\t                processed_stimulus_dir=stimulus_dir,\n   175\t                parameter_snapshot=parameter_snapshot_b,\n   176\t                seed=11,\n   177\t                temporal_sampling=temporal_sampling,\n   178\t                spatial_frame=spatial_frame,\n   179\t            )\n   180\t            self.assertEqual(resolved_metadata_path, metadata_path.resolve())\n   181\t\n   182\t            serialized = json.dumps(metadata_a, indent=2, sort_keys=True)\n   183\t            self.assertEqual(metadata_path.read_text(encoding=\"utf-8\"), serialized)\n   184\t\n   185\t\n   186\tif __name__ == \"__main__\":\n   187\t    unittest.main()\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_65","type":"command_execution","command":"/bin/bash -lc \"nl -ba docs/stimulus_bundle_design.md | sed -n '1,260p'\"","aggregated_output":"     1\t# Milestone 8A Canonical Stimulus Bundle Contract And Generator Choice\n     2\t\n     3\tThis note freezes the Milestone 8A stimulus handoff so later retinal-sampling,\n     4\tscene, simulator, and orchestration work can target one explicit bundle\n     5\tcontract, one explicit replay model, and one explicit interpretation of \"the\n     6\tsame stimulus.\"\n     7\t\n     8\t## Contract summary\n     9\t\n    10\tThe canonical Milestone 8A bundle contract is `stimulus_bundle.v1`.\n    11\t\n    12\tThe bundle owns:\n    13\t\n    14\t- one canonical bundle ID built from canonical stimulus family, canonical\n    15\t  stimulus name, and the reproducibility hash\n    16\t- one authoritative metadata file that records the stimulus-contract version,\n    17\t  design-note version, replay semantics, and all deterministic reproduction\n    18\t  fields\n    19\t- one optional cached frame archive for acceleration\n    20\t- one optional preview animation for human review\n    21\t- zero or more compatibility-alias records that point old names at the same\n    22\t  canonical bundle\n    23\t\n    24\tThe canonical layout is:\n    25\t\n    26\t- `data/processed/stimuli/bundles/<stimulus_family>/<stimulus_name>/<parameter_hash>/stimulus_bundle.json`\n    27\t- `data/processed/stimuli/bundles/<stimulus_family>/<stimulus_name>/<parameter_hash>/stimulus_frames.npz`\n    28\t- `data/processed/stimuli/bundles/<stimulus_family>/<stimulus_name>/<parameter_hash>/stimulus_preview.gif`\n    29\t- `data/processed/stimuli/aliases/<alias_family>/<alias_name>/<parameter_hash>.json`\n    30\t\n    31\tLater tickets may add more sidecars, but those paths are the stable discovery\n    32\tsurface.\n    33\t\n    34\t## Candidate representation families\n    35\t\n    36\t### Pure procedural regeneration\n    37\t\n    38\tDefinition:\n    39\t\n    40\t- store only generator descriptors, temporal sampling, conventions, and seed\n    41\t- rebuild every frame on demand\n    42\t\n    43\tAdvantages:\n    44\t\n    45\t- smallest on-disk footprint\n    46\t- easiest way to preserve one authoritative semantic description\n    47\t- naturally avoids cache invalidation bugs because there is no cache\n    48\t\n    49\tCosts:\n    50\t\n    51\t- later tooling pays generation cost every time\n    52\t- offline review becomes slower because previews and retinal sampling need to\n    53\t  regenerate first\n    54\t- debugging cache-versus-regeneration drift is replaced with repeated compute\n    55\t\n    56\t### Fully cached frame bundle\n    57\t\n    58\tDefinition:\n    59\t\n    60\t- treat the serialized frame archive as the primary artifact\n    61\t- the bundle is mostly an index into pre-rendered frames\n    62\t\n    63\tAdvantages:\n    64\t\n    65\t- fastest playback for downstream tools\n    66\t- easy to hand off to image-oriented samplers and UIs\n    67\t- cheap to inspect without re-running the generator\n    68\t\n    69\tCosts:\n    70\t\n    71\t- large storage footprint\n    72\t- cache invalidation becomes the core contract problem\n    73\t- easy for downstream code to bind itself to one frame layout instead of the\n    74\t  semantic generator description\n    75\t- renaming files or changing frame dtype can accidentally change bundle\n    76\t  identity\n    77\t\n    78\t### Hybrid descriptor plus cache\n    79\t\n    80\tDefinition:\n    81\t\n    82\t- the descriptor metadata is authoritative\n    83\t- frame caches are optional accelerators derived from that descriptor\n    84\t- later tooling may regenerate when the cache is absent, but not reinterpret\n    85\t  the descriptor\n    86\t\n    87\tAdvantages:\n    88\t\n    89\t- keeps one semantic source of truth\n    90\t- supports cheap replay when the cache exists\n    91\t- makes deterministic regeneration and offline review compatible\n    92\t- keeps later milestones from binding bundle identity to one incidental frame\n    93\t  serialization\n    94\t\n    95\tCosts:\n    96\t\n    97\t- requires explicit rules for cache authority and drift checks\n    98\t- slightly more metadata than either extreme\n    99\t\n   100\t## Decision\n   101\t\n   102\tThe default Milestone 8A representation family is\n   103\t`hybrid_descriptor_plus_cache`.\n   104\t\n   105\tPure procedural descriptors and fully cached frame bundles remain recognized\n   106\tcomparison modes for debugging, ablations, or extreme storage/performance\n   107\tconstraints, but the authoritative Milestone 8A contract assumes:\n   108\t\n   109\t- the metadata descriptor is the source of truth\n   110\t- the cache is optional\n   111\t- the same descriptor, seed, and contract version mean the same stimulus even\n   112\t  if one run has a frame cache and another does not\n   113\t\n   114\tWhy this is the default:\n   115\t\n   116\t- Milestones 8B and 8C need semantic coordinates, timing, and luminance rules,\n   117\t  not just opaque frame filenames\n   118\t- Milestones 9 and 15 need a compact way to refer to a reusable stimulus in\n   119\t  manifests and batch runs\n   120\t- deterministic regeneration matters because later sweeps will not want to\n   121\t  commit every frame archive for every variant\n   122\t- optional caching still matters because retinal projection and UI inspection\n   123\t  will repeatedly revisit the same stimuli\n   124\t\n   125\t## Coordinate, timing, and luminance conventions\n   126\t\n   127\t### Spatial frame\n   128\t\n   129\tMilestone 8A uses one canonical 2D image-plane frame:\n   130\t\n   131\t- frame name: `visual_field_degrees_centered`\n   132\t- origin: `aperture_center`\n   133\t- horizontal axis: `azimuth_deg_positive_right`\n   134\t- vertical axis: `elevation_deg_positive_up`\n   135\t- raster samples are defined at `pixel_centers`\n   136\t- the bundle records both raster size (`width_px`, `height_px`) and angular\n   137\t  extent (`width_deg`, `height_deg`)\n   138\t\n   139\tInterpretation:\n   140\t\n   141\t- frame coordinates are centered on the stimulus aperture rather than anchored\n   142\t  to a later camera or retinal lattice implementation\n   143\t- later retinal or scene code may transform into other coordinate systems, but\n   144\t  it must preserve the meaning of this canonical frame when claiming to replay\n   145\t  the same stimulus\n   146\t\n   147\t### Temporal sampling\n   148\t\n   149\tMilestone 8A uses one canonical time unit and one canonical default playback\n   150\trule:\n   151\t\n   152\t- time unit: milliseconds\n   153\t- bundle time origin: `time_origin_ms`, default `0.0`\n   154\t- frame step: `dt_ms`\n   155\t- total duration: `duration_ms`\n   156\t- frame count: `frame_count`\n   157\t- sampling mode: `sample_hold`\n   158\t\n   159\tMeaning:\n   160\t\n   161\t- each generated frame is authoritative for the half-open interval\n   162\t  `[t, t + dt_ms)`\n   163\t- later simulators may integrate internally at finer timesteps, but they must\n   164\t  preserve the same piecewise-constant stimulus values at the bundle frame\n   165\t  boundaries unless a later contract explicitly versions a different temporal\n   166\t  interpolation rule\n   167\t\n   168\t### Luminance and contrast\n   169\t\n   170\tMilestone 8A fixes one conservative luminance convention:\n   171\t\n   172\t- encoding: `linear_luminance_unit_interval`\n   173\t- minimum value: `0.0`\n   174\t- neutral gray: `0.5`\n   175\t- maximum value: `1.0`\n   176\t- contrast semantics: `signed_delta_from_neutral_gray`\n   177\t- positive polarity means `brighter_than_neutral`\n   178\t\n   179\tMeaning:\n   180\t\n   181\t- generator parameters express signed luminance deltas relative to neutral gray\n   182\t- emitted frame values live in linear luminance space, not gamma-compressed\n   183\t  display space\n   184\t- out-of-range results are clipped into `[0.0, 1.0]`, and that clipping is part\n   185\t  of the canonical replay semantics\n   186\t\n   187\t## Determinism, hashing, and aliases\n   188\t\n   189\t### Deterministic seeding\n   190\t\n   191\tEvery bundle records:\n   192\t\n   193\t- one non-negative integer seed\n   194\t- one RNG family, fixed today to `numpy_pcg64`\n   195\t- a seed scope stating that all stochastic generator branches derive from that\n   196\t  recorded seed\n   197\t\n   198\tRules:\n   199\t\n   200\t- stochastic subcomponents may derive child streams internally, but only as a\n   201\t  deterministic function of the recorded seed\n   202\t- downstream tools may not inject extra randomness while still claiming they are\n   203\t  replaying the same bundle\n   204\t\n   205\t### Parameter hash\n   206\t\n   207\tMilestone 8A uses one reproducibility hash:\n   208\t\n   209\t- algorithm: `sha256`\n   210\t- input: canonical JSON of the parameter snapshot, deterministic seed and RNG\n   211\t  family, temporal sampling block, spatial frame block, and luminance\n   212\t  convention block\n   213\t- excluded inputs: cache status, preview status, artifact filenames, and\n   214\t  compatibility aliases\n   215\t\n   216\tMeaning:\n   217\t\n   218\t- the hash names the reproducible stimulus specification, not the incidental\n   219\t  cache state\n   220\t- a bundle cache may be added or deleted without changing the parameter hash\n   221\t- renaming a stimulus through compatibility aliases must not change the\n   222\t  parameter hash\n   223\t\n   224\t### Compatibility aliases\n   225\t\n   226\tAliases exist only to preserve discoverability when names change.\n   227\t\n   228\tRules:\n   229\t\n   230\t- aliases point to the canonical bundle metadata path for the same parameter\n   231\t  hash\n   232\t- aliases may rename family and/or name, but they may not silently change seed,\n   233\t  timing, spatial frame, luminance semantics, or generator parameters\n   234\t- canonical metadata remains authoritative; alias records are lookup shims, not\n   235\t  alternate metadata authorities\n   236\t\n   237\t## Invariants for later milestones\n   238\t\n   239\tLater retinal-sampling, scene, simulator, and orchestration code must preserve\n   240\tthese invariants when they claim to reuse or replay `stimulus_bundle.v1`:\n   241\t\n   242\t- bundle identity is the tuple `(contract_version, stimulus_family,\n   243\t  stimulus_name, parameter_hash)`\n   244\t- reproducibility identity is the tuple `(contract_version, parameter_hash,\n   245\t  seed, temporal_sampling, spatial_frame, luminance_convention)`\n   246\t- descriptor metadata is authoritative; caches may accelerate replay but may not\n   247\t  redefine pixel values, timestamps, or conventions\n   248\t- alias lookup must resolve to the same canonical metadata rather than\n   249\t  duplicating or mutating the canonical bundle\n   250\t- retinal sampling may resample into another lattice, but it must preserve the\n   251\t  same canonical time axis and the same underlying linear-luminance semantics\n   252\t- simulator orchestration may store only the compact bundle reference, but it\n   253\t  must resolve through the library contract rather than hardcoded filenames\n   254\t\n   255\tThe practical consequence is simple: later code may transform, cache, project,\n   256\tor subsample the stimulus, but it does not get to redefine what bundle it came\n   257\tfrom.\n","exit_code":0,"status":"completed"}}
