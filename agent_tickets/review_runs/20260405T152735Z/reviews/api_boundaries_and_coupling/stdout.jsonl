   101\tbootstrap:\n   102\t\ttest -x .venv/bin/python || python3 -m venv .venv\n   103\t\t./.venv/bin/python -m pip install --upgrade pip\n   104\t\t./.venv/bin/python -m pip install -e .\n   105\t\n   106\tverify:\n   107\t\t$(PYTHON) scripts/00_verify_access.py --config $(CONFIG)\n   108\t\n   109\tregistry:\n   110\t\t$(PYTHON) scripts/build_registry.py --config $(CONFIG)\n   111\t\n   112\tselect:\n   113\t\t$(PYTHON) scripts/01_select_subset.py --config $(CONFIG)\n   114\t\n   115\tmeshes:\n   116\t\t$(PYTHON) scripts/02_fetch_meshes.py --config $(CONFIG)\n   117\t\n   118\tassets:\n   119\t\t$(PYTHON) scripts/03_build_wave_assets.py --config $(CONFIG)\n   120\t\n   121\tpreview:\n   122\t\t$(PYTHON) scripts/05_preview_geometry.py --config $(CONFIG)\n   123\t\n   124\tcoupling-inspect:\n   125\t\t$(PYTHON) scripts/08_coupling_inspection.py --config $(CONFIG) $(COUPLING_INSPECT_ARGS)\n   126\t\n   127\toperator-qa:\n   128\t\t$(PYTHON) scripts/06_operator_qa.py --config $(CONFIG)\n   129\t\n   130\tsimulate:\n   131\t\t$(PYTHON) scripts/run_simulation.py --config $(CONFIG) --manifest $(MANIFEST) --schema $(SCHEMA) --design-lock $(DESIGN_LOCK) $(SIMULATE_ARGS)\n   132\t\n   133\treview-tickets:\n   134\t\t$(PYTHON) scripts/run_review_prompt_tickets.py $(REVIEW_TICKETS_ARGS)\n   135\t\n   136\tsuite-run:\n   137\t\t$(PYTHON) scripts/31_run_experiment_suite.py --config $(CONFIG) --schema $(SCHEMA) --design-lock $(DESIGN_LOCK) $(SUITE_RUN_ARGS)\n   138\t\n   139\tsuite-aggregate:\n   140\t\t$(PYTHON) scripts/32_suite_aggregation.py $(SUITE_AGGREGATE_ARGS)\n   141\t\n   142\tsuite-report:\n   143\t\t$(PYTHON) scripts/33_suite_report.py $(SUITE_REPORT_ARGS)\n   144\t\n   145\tcompare-analysis:\n   146\t\t$(PYTHON) scripts/20_experiment_comparison_analysis.py --config $(CONFIG) --manifest $(MANIFEST) --schema $(SCHEMA) --design-lock $(DESIGN_LOCK) $(COMPARE_ANALYSIS_ARGS)\n   147\t\n   148\tdashboard:\n   149\t\t$(PYTHON) scripts/29_dashboard_shell.py build --config $(CONFIG) --manifest $(MANIFEST) --schema $(SCHEMA) --design-lock $(DESIGN_LOCK) $(DASHBOARD_ARGS)\n   150\t\n   151\tdashboard-open:\n   152\t\t$(PYTHON) scripts/29_dashboard_shell.py build --config $(CONFIG) --manifest $(MANIFEST) --schema $(SCHEMA) --design-lock $(DESIGN_LOCK) --open $(DASHBOARD_ARGS)\n   153\t\n   154\tdashboard-export:\n   155\t\ttest -n \"$(DASHBOARD_SESSION_METADATA)\"\n   156\t\t$(PYTHON) scripts/29_dashboard_shell.py export --dashboard-session-metadata $(DASHBOARD_SESSION_METADATA) $(DASHBOARD_EXPORT_ARGS)\n   157\t\n   158\tshowcase-session:\n   159\t\t$(PYTHON) scripts/35_showcase_session.py build --config $(CONFIG) $(SHOWCASE_ARGS)\n   160\t\n   161\tshowcase-player:\n   162\t\ttest -n \"$(SHOWCASE_SESSION_METADATA)\"\n   163\t\t$(PYTHON) scripts/35_showcase_session.py $(SHOWCASE_PLAYER_COMMAND) --showcase-session-metadata $(SHOWCASE_SESSION_METADATA) $(SHOWCASE_PLAYER_ARGS)\n   164\t\n   165\twhole-brain-context:\n   166\t\t$(PYTHON) scripts/36_whole_brain_context_session.py build --config $(CONFIG) $(WHOLE_BRAIN_CONTEXT_ARGS)\n   167\t\n   168\twave-inspect:\n   169\t\t$(PYTHON) scripts/15_surface_wave_inspection.py --config $(CONFIG) --manifest $(MANIFEST) --schema $(SCHEMA) --design-lock $(DESIGN_LOCK) $(WAVE_INSPECT_ARGS)\n   170\t\n   171\tmixed-fidelity-inspect:\n   172\t\t$(PYTHON) scripts/18_mixed_fidelity_inspection.py --config $(CONFIG) --manifest $(MANIFEST) --schema $(SCHEMA) --design-lock $(DESIGN_LOCK) $(MIXED_FIDELITY_INSPECT_ARGS)\n   173\t\n   174\tnumerical-validate:\n   175\t\t$(PYTHON) scripts/23_numerical_validation.py --config $(CONFIG) --manifest $(MANIFEST) --schema $(SCHEMA) --design-lock $(DESIGN_LOCK) $(NUMERICAL_VALIDATE_ARGS)\n   176\t\n   177\tmorphology-validate:\n   178\t\t$(PYTHON) scripts/24_morphology_validation.py --config $(CONFIG) --manifest $(MANIFEST) --schema $(SCHEMA) --design-lock $(DESIGN_LOCK) $(MORPHOLOGY_VALIDATE_ARGS)\n   179\t\n   180\tcircuit-validate:\n   181\t\t$(PYTHON) scripts/25_circuit_validation.py --config $(CONFIG) --manifest $(MANIFEST) --schema $(SCHEMA) --design-lock $(DESIGN_LOCK) $(CIRCUIT_VALIDATE_ARGS)\n   182\t\n   183\ttask-validate:\n   184\t\t$(PYTHON) scripts/26_task_validation.py --config $(CONFIG) --manifest $(MANIFEST) --schema $(SCHEMA) --design-lock $(DESIGN_LOCK) $(TASK_VALIDATE_ARGS)\n   185\t\n   186\tvalidation-ladder-package:\n   187\t\t$(PYTHON) scripts/27_validation_ladder.py package $(VALIDATION_LADDER_ARGS)\n   188\t\n   189\tvalidation-ladder-smoke:\n   190\t\t$(PYTHON) scripts/27_validation_ladder.py smoke --baseline tests/fixtures/validation_ladder_smoke_baseline.json --enforce-baseline $(VALIDATION_LADDER_SMOKE_ARGS)\n   191\t\n   192\tmilestone6-readiness:\n   193\t\t$(PYTHON) scripts/07_milestone6_readiness.py --config $(M6_CONFIG)\n   194\t\n   195\tmilestone7-readiness:\n   196\t\t$(PYTHON) scripts/09_milestone7_readiness.py --config $(M7_CONFIG) --edges-file $(M7_EDGE_FILE)\n   197\t\n   198\tmilestone8a-readiness:\n   199\t\t$(PYTHON) scripts/11_milestone8a_readiness.py --config $(M8A_CONFIG)\n   200\t\n   201\tmilestone8b-readiness:\n   202\t\t$(PYTHON) scripts/13_milestone8b_readiness.py --config $(M8B_CONFIG)\n   203\t\n   204\tmilestone9-readiness:\n   205\t\t$(PYTHON) scripts/14_milestone9_readiness.py --config $(M9_CONFIG)\n   206\t\n   207\tmilestone10-readiness:\n   208\t\t$(PYTHON) scripts/16_milestone10_readiness.py --config $(M10_CONFIG)\n   209\t\n   210\tmilestone11-readiness:\n   211\t\t$(PYTHON) scripts/19_milestone11_readiness.py --config $(M11_CONFIG) $(M11_READINESS_ARGS)\n   212\t\n   213\tmilestone12-readiness:\n   214\t\t$(PYTHON) scripts/22_milestone12_readiness.py --config $(M12_CONFIG) $(M12_READINESS_ARGS)\n   215\t\n   216\tmilestone13-readiness:\n   217\t\t$(PYTHON) scripts/28_milestone13_readiness.py --config $(M13_CONFIG) $(M13_READINESS_ARGS)\n   218\t\n   219\tmilestone14-readiness:\n   220\t\t$(PYTHON) scripts/30_milestone14_readiness.py --config $(M14_CONFIG) $(M14_READINESS_ARGS)\n   221\t\n   222\tmilestone15-readiness:\n   223\t\t$(PYTHON) scripts/34_milestone15_readiness.py --config $(M15_CONFIG) $(M15_READINESS_ARGS)\n   224\t\n   225\tmilestone17-readiness:\n   226\t\t$(PYTHON) scripts/37_milestone17_readiness.py --config $(M17_CONFIG) $(M17_READINESS_ARGS)\n   227\t\n   228\tvalidate-manifest:\n   229\t\t$(PYTHON) scripts/04_validate_manifest.py --manifest $(MANIFEST) --schema $(SCHEMA) --design-lock $(DESIGN_LOCK)\n   230\t\n   231\ttest:\n   232\t\t$(PYTHON) -m unittest discover -s tests -v\n   233\t\n   234\tsmoke: test validate-manifest\n   235\t\n   236\tall: verify registry select meshes assets\n","exit_code":0,"status":"completed"}}
