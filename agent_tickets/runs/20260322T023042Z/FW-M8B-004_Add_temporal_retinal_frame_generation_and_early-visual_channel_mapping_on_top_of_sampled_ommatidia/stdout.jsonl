n provenance\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\ndef _cache_snapshot(path: Path, validator: Callable[[Path], tuple[bool, str]]) -> dict[str, str]:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    valid, reason = validator(path)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    if valid:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        state = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"valid\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    elif path.exists():\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        state = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"invalid\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    else:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        state = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"missing\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    return {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"state\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": state,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"reason\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": reason,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    }\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\ndef _validate_cached_mesh(path: Path) -> tuple[bool, str]:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    if not path.exists():\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        return False, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"missing_file\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    if path.stat().st_size <= 0:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        return False, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"empty_file\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    try:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        mesh = trimesh.load_mesh(path, process=False)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    except Exception as exc:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        return False, f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"load_failed:{type(exc).__name__}\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    if not isinstance(mesh, trimesh.Trimesh):\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        return False, f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"unexpected_type:{type(mesh).__name__}\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    vertices = np.asarray(mesh.vertices)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    faces = np.asarray(mesh.faces)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    if vertices.ndim != 2 or vertices.shape[0] == 0 or vertices.shape[1] != 3:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        return False, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"invalid_vertices\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    if faces.ndim != 2 or faces.shape[0] == 0 or faces.shape[1] < 3:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        return False, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"invalid_faces\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    return True, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"validated_trimesh\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\ndef _validate_cached_skeleton(path: Path) -> tuple[bool, str]:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    if not path.exists():\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        return False, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"missing_file\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    if path.stat().st_size <= 0:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        return False, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"empty_file\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    data_lines = 0\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    with path.open(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"r\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", encoding=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"utf-8\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\") as handle:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        for raw_line in handle:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            line = raw_line.strip()\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            if not line or line.startswith(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"#\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"):\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                continue\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            parts = line.split()\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            if len(parts) != 7:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                return False, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"invalid_swc_columns\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            try:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                int(parts[0])\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                int(parts[1])\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                float(parts[2])\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                float(parts[3])\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                float(parts[4])\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                float(parts[5])\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                int(parts[6])\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            except ValueError:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                return False, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"invalid_swc_values\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            data_lines += 1\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    if data_lines == 0:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        return False, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"missing_swc_nodes\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    return True, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"validated_swc\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\ndef _write_mesh_atomically(mesh: trimesh.Trimesh, path: Path) -> None:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    tmp_path = path.with_suffix(f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\".tmp{path.suffix}\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    try:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        mesh.export(tmp_path)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        tmp_path.replace(path)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    finally:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        if tmp_path.exists():\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            tmp_path.unlink(missing_ok=True)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\ndef _write_skeleton_atomically(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    skeleton: Any,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    path: Path,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    skeleton_writer: Callable[[Any, str | Path], None],\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n) -> None:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    tmp_path = path.with_suffix(f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\".tmp{path.suffix}\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    try:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        skeleton_writer(skeleton, tmp_path)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        tmp_path.replace(path)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    finally:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        if tmp_path.exists():\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            tmp_path.unlink(missing_ok=True)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\ndef _file_metadata(path: Path) -> tuple[int | None, str | None]:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    if not path.exists():\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        return None, None\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    stat = path.stat()\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    mtime = datetime.fromtimestamp(stat.st_mtime, tz=timezone.utc).replace(microsecond=0).isoformat()\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    return int(stat.st_size), mtime\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\ndef _utc_now() -> str:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    return datetime.now(timezone.utc).replace(microsecond=0).isoformat()\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\ndef process_mesh_into_wave_assets(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    *,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    root_id: int,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    bundle_paths: GeometryBundlePaths,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    simplify_target_faces: int = 15000,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    patch_hops: int = 6,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    patch_vertex_cap: int = 2500,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    registry_metadata: dict[str, Any] | None = None,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    qa_thresholds: dict[str, Any] | None = None,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n) -> dict[str, Any]:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    ensure_dir(bundle_paths.simplified_mesh_path.parent)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    ensure_dir(bundle_paths.surface_graph_path.parent)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    raw_mesh = trimesh.load_mesh(bundle_paths.raw_mesh_path, process=False)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    if not isinstance(raw_mesh, trimesh.Trimesh):\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        raise TypeError(f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Expected a Trimesh at {bundle_paths.raw_mesh_path}, got {type(raw_mesh)!r}\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    raw_vertices = np.asarray(raw_mesh.vertices, dtype=np.float32)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    raw_faces = np.asarray(raw_mesh.faces, dtype=np.int32)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    raw_adj = _faces_to_adjacency(raw_faces, raw_vertices.shape[0])\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    raw_mesh_summary = describe_mesh(raw_mesh, adj=raw_adj)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    mesh = raw_mesh.copy()\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    original_face_count = int(len(mesh.faces))\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    target_faces = min(int(simplify_target_faces), int(len(mesh.faces)))\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    if 4 <= target_faces < original_face_count:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        try:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            mesh = mesh.simplify_quadric_decimation(target_faces)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        except Exception:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            # Fallback: keep original mesh if local environment lacks simplification backend.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            pass\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    vertices = np.asarray(mesh.vertices, dtype=np.float32)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    faces = np.asarray(mesh.faces, dtype=np.int32)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    adj = _faces_to_